-- ============================================================
-- CheckoutServer — Script · ServerScriptService
--
-- STAFFED REGISTER (IsCheckoutStaff=true):
--   E → instant trigger → 3s wait → pays ALL unpaid items at once
--   Only triggers if player has enough money for everything
--   Simple conveyor-belt feel: hand it all over, cashier handles it
--
-- SELF-CHECKOUT (IsCheckoutSelf=true):
--   E → opens self-checkout UI (ShowSelfCheckoutUI fires to client)
--   Client shows unpaid item list; player clicks individual items to scan
--   Each click fires SelfCheckoutScanItem(slotIndex)
--   Server charges cost, marks that item paid, fires SelfCheckoutItemPaid
--   Player can close the UI at any time (SelfCheckoutClose fires to server)
--
-- Remotes (auto-created):
--   CheckoutStart       Server → Client  (staffed progress bar start)
--   CheckoutComplete    Server → Client  (staffed result)
--   ShowSelfCheckoutUI  Server → Client  (open self-checkout panel)
--   HideSelfCheckoutUI  Server → Client  (close self-checkout panel)
--   SelfCheckoutScanItem Client → Server  (player clicks an item)
--   SelfCheckoutItemPaid Server → Client  (item now paid, update UI)
--   SelfCheckoutClose   Client → Server  (player closes the kiosk)
-- ============================================================

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local PlayerState  = require(ServerScriptService:WaitForChild("PlayerState"))
local ChompersData = require(ReplicatedStorage:WaitForChild("ChompersData"))

local Remotes = ReplicatedStorage:WaitForChild("ChompersRemotes")
local C       = ChompersData.Constants

local function getOrCreate(name)
	local r = Remotes:FindFirstChild(name)
	if not r then
		r = Instance.new("RemoteEvent"); r.Name=name; r.Parent=Remotes
	end
	return r
end

local CheckoutStart          = Remotes:WaitForChild("CheckoutStart")
local CheckoutComplete       = Remotes:WaitForChild("CheckoutComplete")
local ShowSelfCheckoutUI     = getOrCreate("ShowSelfCheckoutUI")
local HideSelfCheckoutUI     = getOrCreate("HideSelfCheckoutUI")
local SelfCheckoutScanItem   = getOrCreate("SelfCheckoutScanItem")
local SelfCheckoutItemPaid   = getOrCreate("SelfCheckoutItemPaid")
local SelfCheckoutClose      = getOrCreate("SelfCheckoutClose")
local AnnounceRemote         = getOrCreate("Announce")

-- ── Timing ───────────────────────────────────────────────────
local STAFF_HOLD_TIME    = 3.0  -- seconds for staffed lane
local SELF_SCAN_COOLDOWN = 0.5  -- min seconds between scans (prevents spam)

-- ── Session state ─────────────────────────────────────────────
local activeStaffed    = {}  -- [player] = true (in staffed hold)
local activeSelfKiosk  = {}  -- [player] = true (self-checkout UI open)
local lastScanTime     = {}  -- [player] = tick() of last scan

-- ── Shared helpers ────────────────────────────────────────────
local function getUnpaidItems(player)
	local s = PlayerState.Get(player)
	if not s then return {} end
	local result = {}
	for i, item in ipairs(s.inventory) do
		if not item.paid then
			table.insert(result, { slotIndex=i, item=item })
		end
	end
	return result
end

local function getTotalUnpaidCost(player)
	local items = getUnpaidItems(player)
	local cost  = 0
	for _, e in ipairs(items) do cost = cost + (e.item.cost or 0) end
	return cost
end

local function playerMoney(player)
	local s = PlayerState.Get(player)
	return s and s.money or 0
end

-- ============================================================
-- STAFFED REGISTER
-- ============================================================
local function setupStaffedRegister(part)
	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText            = "Pay Here"
	prompt.ObjectText            = "🧑  Cashier"
	prompt.KeyboardKeyCode       = Enum.KeyCode.E
	prompt.HoldDuration          = 0
	prompt.MaxActivationDistance = 8
	prompt.RequiresLineOfSight   = false
	prompt.Parent                = part

	prompt.Triggered:Connect(function(player)
		if activeStaffed[player] then return end
		local s = PlayerState.Get(player)
		if not s or s.isEliminated then return end

		local unpaid = getUnpaidItems(player)
		if #unpaid == 0 then
			AnnounceRemote:FireClient(player,
				"🧾 Nothing unpaid to check out.", C and C.stroke or Color3.fromRGB(105,100,138), 2)
			return
		end

		local totalCost = getTotalUnpaidCost(player)
		if playerMoney(player) < totalCost then
			CheckoutComplete:FireClient(player, false, #unpaid, totalCost, "broke")
			return
		end

		activeStaffed[player] = true
		CheckoutStart:FireClient(player, STAFF_HOLD_TIME, totalCost)

		task.delay(STAFF_HOLD_TIME, function()
			activeStaffed[player] = nil

			local s2 = PlayerState.Get(player)
			if not s2 or s2.isEliminated then
				CheckoutComplete:FireClient(player, false, #unpaid, totalCost, "eliminated")
				return
			end

			-- Re-check (inventory may have changed during wait)
			local finalUnpaid = getUnpaidItems(player)
			local finalCost   = 0
			for _, e in ipairs(finalUnpaid) do finalCost = finalCost + (e.item.cost or 0) end

			if finalCost == 0 then
				CheckoutComplete:FireClient(player, false, 0, 0, "nothing")
				return
			end

			if not PlayerState.DeductMoney(player, finalCost) then
				CheckoutComplete:FireClient(player, false, #finalUnpaid, finalCost, "broke")
				return
			end

			PlayerState.MarkAllUnpaidAsPaid(player)
			PlayerState.AddPoints(player, #finalUnpaid * (C.Points.IngredientPaidCheckout or 3))

			if #finalUnpaid >= 4 or finalCost >= 20 then
				AnnounceRemote:FireClient(player,
					"🧾 Checked out "..#finalUnpaid.." items for $"..finalCost.."!",
					Color3.fromRGB(75,205,60), 3)
			end

			CheckoutComplete:FireClient(player, true, #finalUnpaid, finalCost)
		end)
	end)
end

-- ============================================================
-- SELF-CHECKOUT KIOSK
-- ============================================================
local function setupSelfCheckout(part)
	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText            = "Self-Checkout"
	prompt.ObjectText            = "🖥  Register"
	prompt.KeyboardKeyCode       = Enum.KeyCode.E
	prompt.HoldDuration          = 0.2   -- short visual hold to prevent accidental open
	prompt.MaxActivationDistance = 12
	prompt.RequiresLineOfSight   = false
	prompt.Parent                = part

	prompt.Triggered:Connect(function(player)
		if activeSelfKiosk[player] then return end
		local s = PlayerState.Get(player)
		if not s or s.isEliminated then return end

		local unpaid = getUnpaidItems(player)
		if #unpaid == 0 then
			AnnounceRemote:FireClient(player,
				"🖥 Nothing unpaid — you're all set!", Color3.fromRGB(75,205,60), 2)
			return
		end

		-- Build item list for client UI
		local itemList = {}
		for _, e in ipairs(unpaid) do
			table.insert(itemList, {
				slotIndex = e.slotIndex,
				name      = e.item.name,
				emoji     = e.item.emoji or "🍽",
				cost      = e.item.cost or 0,
				rarity    = e.item.rarity or "Common",
			})
		end

		activeSelfKiosk[player] = true
		ShowSelfCheckoutUI:FireClient(player, itemList, playerMoney(player))
	end)
end

-- ── Self-checkout: player scans one item at a time ────────────
SelfCheckoutScanItem.OnServerEvent:Connect(function(player, slotIndex)
	if not activeSelfKiosk[player] then return end
	local s = PlayerState.Get(player)
	if not s or s.isEliminated then
		HideSelfCheckoutUI:FireClient(player)
		activeSelfKiosk[player] = nil
		return
	end

	-- Rate limit: no faster than SELF_SCAN_COOLDOWN
	local now = tick()
	if lastScanTime[player] and (now - lastScanTime[player]) < SELF_SCAN_COOLDOWN then
		return
	end
	lastScanTime[player] = now

	-- Validate slot
	slotIndex = tonumber(slotIndex)
	if not slotIndex or slotIndex < 1 or slotIndex > 10 then return end

	local item = s.inventory[slotIndex]
	if not item then return end
	if item.paid then
		-- Already paid (UI may be stale) — just refresh
		SelfCheckoutItemPaid:FireClient(player, slotIndex, 0, playerMoney(player), "already_paid")
		return
	end

	local cost = item.cost or 0
	if playerMoney(player) < cost then
		SelfCheckoutItemPaid:FireClient(player, slotIndex, cost, playerMoney(player), "broke")
		return
	end

	-- Charge and mark paid
	PlayerState.DeductMoney(player, cost)
	PlayerState.MarkItemPaid(player, slotIndex)
	PlayerState.AddPoints(player, C.Points.IngredientPaidCheckout or 3)

	SelfCheckoutItemPaid:FireClient(player, slotIndex, cost, playerMoney(player), "ok")
end)

-- ── Player closes self-checkout UI ───────────────────────────
SelfCheckoutClose.OnServerEvent:Connect(function(player)
	activeSelfKiosk[player] = nil
	HideSelfCheckoutUI:FireClient(player)
end)

-- ── Cleanup on disconnect ─────────────────────────────────────
Players.PlayerRemoving:Connect(function(player)
	activeStaffed[player]   = nil
	activeSelfKiosk[player] = nil
	lastScanTime[player]    = nil
end)

-- ── Scan workspace for tagged checkout parts ──────────────────
local function setupAll()
	local nSelf, nStaff = 0, 0
	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("BasePart") then
			if desc:GetAttribute("IsCheckoutSelf") == true then
				setupSelfCheckout(desc); nSelf = nSelf + 1
			elseif desc:GetAttribute("IsCheckoutStaff") == true then
				setupStaffedRegister(desc); nStaff = nStaff + 1
			end
		end
	end
	print(string.format("[CheckoutServer] Registered %d self-checkout, %d staffed terminal(s)",
		nSelf, nStaff))
end

setupAll()
print("[CheckoutServer] Ready")
