local function createPrompt(parent, emoji, name, holdTime)
	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText = "Pick up"
	prompt.ObjectText = emoji.."  "..name
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.HoldDuration = holdTime or 0.25
	prompt.MaxActivationDistance = 8
	prompt.RequiresLineOfSight = false
	prompt.Parent = parent
	return prompt
end

local function spawnIngredientAt(worldX, worldZ, surfaceTop, ingData, surfacePart)
	local part = Instance.new("Part")
	part.Name     = ingData.n
	part.Size     = Vector3.new(2,2,2)
	-- Place centre of ingredient 1 stud above surface top
	part.Position = Vector3.new(worldX, surfaceTop + 1, worldZ)
	part.Anchored    = true
	part.CanCollide  = true
	part.CastShadow  = false
	part.Color       = RARITY_COLORS[ingData.r] or Color3.fromRGB(200,200,200)
	part.Material    = Enum.Material.SmoothPlastic

	part:SetAttribute("IngredientName", ingData.n)
	part:SetAttribute("Rarity",         ingData.r)
	part:SetAttribute("Weight",         ingData.wt)
	part:SetAttribute("Cost",           ingData.cost)
	part:SetAttribute("Emoji",          ingData.emoji)
	part:SetAttribute("Allergy",        ingData.allergy)
	part:SetAttribute("Zone",           ingData.zone)
	part:SetAttribute("IsIngredient",   true)
	part:SetAttribute("IsPaid",         false)
	part:SetAttribute("IsTrash",        false)

	createBillboard(part, ingData.emoji, ingData.n,
		RARITY_COLORS[ingData.r] or Color3.fromRGB(200,200,200))
	createPrompt(part, ingData.emoji, ingData.n, 0.25)

	part.Parent = LiveFolder

	-- Schedule respawn
	local rt = RESPAWN_TIMES[ingData.r] or 30
	if rt ~= math.huge and surfacePart then
		table.insert(respawnQueue, {
			ingData     = ingData,
			worldX      = worldX,
			worldZ      = worldZ,
			surfaceTop  = surfaceTop,
			surfacePart = surfacePart,
			respawnAt   = os.clock() + rt,
		})
	end

	return part
end

