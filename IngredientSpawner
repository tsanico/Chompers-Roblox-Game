-- ============================================================
-- INGREDIENT POOLS
-- ============================================================

local function buildPools()
	local pools = {}
	for _, zoneName in ipairs({"Produce","Bakery","Freezer"}) do
		pools[zoneName] = ChompersData.GetIngredientsByZone(zoneName)
	end
	pools.Aisles = ChompersData.GetIngredientsByZone("Dry Goods")

	pools.Deli = {}
	for _, ing in ipairs(ChompersData.Ingredients) do
		if (ing.zone == "Bakery" or ing.zone == "Freezer")
			and ing.rarity ~= "Common"
			and (ing.phase or 1) == 1 then
			table.insert(pools.Deli, ing)
		end
	end

	pools.Stockroom = {}
	for _, ing in ipairs(ChompersData.Ingredients) do
		if ing.rarity ~= "Legendary" and (ing.phase or 1) == 1 then
			table.insert(pools.Stockroom, ing)
		end
	end

	for zoneName, pool in pairs(pools) do
		if #pool == 0 then
			warn(string.format("[IngredientSpawner] Empty pool for zone '%s'", zoneName))
		end
	end
	return pools
end

