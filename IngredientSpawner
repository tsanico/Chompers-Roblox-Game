-- ============================================================

local function pickLoot(allowBracelet)
	local pool = {
		{ name="Loose Cash",        emoji="💵", rarity="Common",    type="cash",     value=math.random(1,3),   color=Color3.fromRGB(75,205,60)   },
		{ name="Cash Stack",        emoji="💵", rarity="Uncommon",  type="cash",     value=math.random(10,15), color=Color3.fromRGB(55,165,45)   },
		{ name="Big Stack",         emoji="💵", rarity="Rare",      type="cash",     value=math.random(18,25), color=Color3.fromRGB(239,159,39)  },
		{ name="Napkin",            emoji="🧻", rarity="Napkin",    type="napkin",   value=1,                  color=Color3.fromRGB(100,180,255) },
		{ name="Alliance Bracelet", emoji="💜", rarity="UltraRare", type="bracelet", value=1,                  color=Color3.fromRGB(180,90,255)  },
	}
	local filtered = {}
	for _, lt in ipairs(pool) do
		if lt.type ~= "bracelet" or allowBracelet then table.insert(filtered, lt) end
	end
	local total, weighted = 0, {}
	for _, lt in ipairs(filtered) do
		local w = LOOT_WEIGHTS[lt.rarity] or 1
		total = total + w
		table.insert(weighted, { lt=lt, cumulative=total })
	end
	local roll = math.random() * total
	for _, entry in ipairs(weighted) do
		if roll <= entry.cumulative then return entry.lt end
	end
	return filtered[1]
end

local function spawnLootAt(worldX, worldZ, y, allowBracelet)
	if not LiveFolder then return end
	local loot = pickLoot(allowBracelet ~= false)
	local part = Instance.new("Part")
	part.Name     = loot.name
	part.Size     = Vector3.new(1.5, 0.3, 1.5)
	part.Position = Vector3.new(worldX, y, worldZ)
	part.Anchored = true; part.CanCollide = true; part.CastShadow = false
	part.Color    = loot.color; part.Material = Enum.Material.SmoothPlastic
	part:SetAttribute("IsLoot",    true)
	part:SetAttribute("LootType",  loot.type)
	part:SetAttribute("LootName",  loot.name)
	part:SetAttribute("LootValue", loot.value)
	part:SetAttribute("LootEmoji", loot.emoji)
	part:SetAttribute("Rarity",    loot.rarity)
	local bb = Instance.new("BillboardGui")
	bb.Size = UDim2.new(0,60,0,50); bb.StudsOffset = Vector3.new(0,2,0)
	bb.AlwaysOnTop = false; bb.Parent = part
	local emojiL = Instance.new("TextLabel")
	emojiL.Size = UDim2.new(1,0,0.5,0); emojiL.BackgroundTransparency = 1
	emojiL.Text = loot.emoji; emojiL.TextScaled = true
	emojiL.Font = Enum.Font.GothamBold; emojiL.Parent = bb
	local valL = Instance.new("TextLabel")
	valL.Size = UDim2.new(1,0,0.5,0); valL.Position = UDim2.new(0,0,0.5,0)
	valL.BackgroundTransparency = 1
	valL.Text = loot.type == "cash" and "$"..loot.value or loot.name
	valL.TextScaled = true; valL.Font = Enum.Font.GothamBold
	valL.TextColor3 = loot.color; valL.TextStrokeTransparency = 0.4
	valL.TextStrokeColor3 = Color3.fromRGB(0,0,0); valL.Parent = bb
	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText            = "Pick up"
	prompt.ObjectText            = loot.emoji.." "..loot.name
		..(loot.type == "cash" and " ($"..loot.value..")" or "")
	prompt.KeyboardKeyCode       = Enum.KeyCode.E
	prompt.HoldDuration          = 0.2
	prompt.MaxActivationDistance = 8
	prompt.RequiresLineOfSight   = false
	prompt.Parent                = part
	part.Parent                  = LiveFolder
	local rt = loot.type == "cash"
		and (loot.rarity == "Common" and C.Respawn.Cash_Small or C.Respawn.Cash_Stack)
		or 0
	if rt > 0 then
		table.insert(respawnQueue, {
			isLoot=true, worldX=worldX, worldZ=worldZ, y=y,
			allowBracelet=false, respawnAt=os.clock()+rt,
		})
	end
end

-- ============================================================
-- MAIN SPAWN — ingredients
-- ============================================================

local function spawnAllIngredients(pools)
	local totalSpawned    = 0
	local totalSurfaces   = 0
	local missingSurfaces = 0

	for zoneName, surfaces in pairs(ZONE_SURFACES) do
		local pool = pools[zoneName]
		if not pool or #pool == 0 then
			warn("[IngredientSpawner] No pool for zone: "..zoneName)
			continue
		end
		for _, surface in ipairs(surfaces) do
			totalSurfaces = totalSurfaces + 1
			local folder = getFolder(surface.folder)
			if not folder then
				warn(string.format("[IngredientSpawner] Folder not found: %s", surface.folder))
				missingSurfaces = missingSurfaces + 1; continue
			end
			local part = folder:FindFirstChild(surface.name, true)
			if not part then
				warn(string.format("[IngredientSpawner] Surface not found: %s in %s",
					surface.name, surface.folder))
				missingSurfaces = missingSurfaces + 1; continue
			end

			local spawnTop = surface.surfaceTop + (surface.yOffset or 1) - 1
			local points   = getSurfacePoints(part, surface.maxItems, surface)

			for _, pt in ipairs(points) do
				local injected = tryInjectCaviar(pt.X, pt.Z, spawnTop, part)
				if not injected then
					local ing = weightedPick(pool)
					spawnIngredientAt(pt.X, pt.Z, spawnTop, ing, part)
				end
				totalSpawned = totalSpawned + 1
			end
		end
	end

	if totalSpawned == 0 then
		warn("[IngredientSpawner] ZERO ingredients spawned — check Map > Props structure")
	end
	print(string.format(
		"[IngredientSpawner] v9  surfaces: %d/%d found  ingredients: %d",
		totalSurfaces - missingSurfaces, totalSurfaces, totalSpawned))
	return totalSpawned
end

-- ============================================================
-- MAIN SPAWN — loot
-- ============================================================

local function spawnAllLoot()
	local totalSpawned = 0
	for _, zone in ipairs(LOOT_ZONES) do
		for _ = 1, zone.count do
			local rx = zone.minX + math.random() * (zone.maxX - zone.minX)
			local rz = zone.minZ + math.random() * (zone.maxZ - zone.minZ)
			spawnLootAt(rx, rz, zone.y, false)
			totalSpawned = totalSpawned + 1
		end
	end
	if STOCKROOM_LOOT_COUNT > 0 then
		local stkr = ZONE_SURFACES.Stockroom
		if stkr and #stkr > 0 then
			for _ = 1, STOCKROOM_LOOT_COUNT do
				local surface = stkr[math.random(#stkr)]
				local folder  = getFolder(surface.folder)
				local part    = folder and folder:FindFirstChild(surface.name, true)
				if part then
					local jX = (math.random()-0.5) * (part.Size.X * 0.6)
					local jZ = (math.random()-0.5) * (part.Size.Z * 0.6)
					spawnLootAt(part.Position.X+jX, part.Position.Z+jZ,
						surface.surfaceTop+1, true)
					totalSpawned = totalSpawned + 1
				end
			end
		end
	end
	return totalSpawned
end

-- ============================================================
-- RESPAWN LOOP
-- ============================================================

task.spawn(function()
	while true do
		task.wait(1)
		if not LiveFolder then continue end
		local now, remaining = os.clock(), {}
		for _, entry in ipairs(respawnQueue) do
			if now >= entry.respawnAt then
				if entry.isLoot then
					spawnLootAt(entry.worldX, entry.worldZ, entry.y, entry.allowBracelet or false)
				elseif entry.surfacePart and entry.surfacePart.Parent then
					local jX = (math.random()-0.5)*2.8
					local jZ = (math.random()-0.5)*2.8
					spawnIngredientAt(
						entry.worldX+jX, entry.worldZ+jZ,
						entry.surfaceTop, entry.ing, entry.surfacePart)
				end
			else
				table.insert(remaining, entry)
			end
		end
		respawnQueue = remaining
	end
end)

