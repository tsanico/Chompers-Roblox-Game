-- INGREDIENT POOLS (built from ChompersData — no hardcoding)
-- ============================================================

-- Build per-zone pool from ChompersData.Ingredients
-- Deli pool = Dairy + Freezer + mid-tier Produce (Uncommon+)
local function buildPools()
	local pools = {}

	-- Standard zones
	for _, zoneName in ipairs({"Produce","Bakery","Dairy","Freezer","Aisles"}) do
		pools[zoneName] = ChompersData.GetIngredientsByZone(zoneName)
	end

	-- Stockroom = all 65 ingredients
	pools.Stockroom = ChompersData.Ingredients

	-- Deli = mid-tier mix: Dairy + Freezer Uncommon+, Produce Uncommon+
	-- (lower CL common ingredients excluded — deli is a "mid-tier loot node")
	pools.Deli = {}
	for _, ing in ipairs(ChompersData.Ingredients) do
		local zone = ing.zone
		local rarity = ing.rarity
		if (zone == "Dairy" or zone == "Freezer") and rarity ~= "UltraRare" and rarity ~= "Legendary" then
			table.insert(pools.Deli, ing)
		elseif zone == "Produce" and (rarity == "Uncommon" or rarity == "Rare") then
			table.insert(pools.Deli, ing)
		end
	end

	return pools
end

