-- SPAWN ONE LOOT ITEM (cash or napkin)
-- ============================================================
local function spawnLootAt(worldX, worldZ, y)
	-- Pick a random loot type (weighted by rarity)
	local lootPool = LOOT_TYPES
	local total = 0
	local weighted = {}
	for _, lt in ipairs(lootPool) do
		local w = LOOT_RARITY_WEIGHTS[lt.rarity] or 1
		total = total + w
		table.insert(weighted, {item=lt, cumulative=total})
	end
	local roll = math.random() * total
	local loot = lootPool[1]
	for _, entry in ipairs(weighted) do
		if roll <= entry.cumulative then
			loot = entry.item
			break
		end
	end

	local part = Instance.new("Part")
	part.Name     = loot.n
	part.Size     = Vector3.new(1.5,0.3,1.5)
	part.Position = Vector3.new(worldX, y, worldZ)
	part.Anchored    = true
	part.CanCollide  = true
	part.CastShadow  = false
	part.Color       = loot.color
	part.Material    = Enum.Material.SmoothPlastic

	part:SetAttribute("IsLoot",     true)
	part:SetAttribute("LootType",   loot.type)
	part:SetAttribute("LootName",   loot.n)
	part:SetAttribute("LootValue",  loot.value)
	part:SetAttribute("LootEmoji",  loot.emoji)
	part:SetAttribute("Rarity",     loot.rarity)

	-- Flat billboard showing value
	local bb = Instance.new("BillboardGui")
	bb.Size        = UDim2.new(0,60,0,50)
	bb.StudsOffset = Vector3.new(0,2,0)
	bb.AlwaysOnTop = false
	bb.Parent = part

	local emojiL = Instance.new("TextLabel")
	emojiL.Size = UDim2.new(1,0,0.5,0)
	emojiL.BackgroundTransparency = 1
	emojiL.Text = loot.emoji
	emojiL.TextScaled = true
	emojiL.Font = Enum.Font.GothamBold
	emojiL.Parent = bb

	local valL = Instance.new("TextLabel")
	valL.Size = UDim2.new(1,0,0.5,0)
	valL.Position = UDim2.new(0,0,0.5,0)
	valL.BackgroundTransparency = 1
	valL.Text = loot.type=="cash"
		and "$"..tostring(loot.value)
		or  "Napkin"
	valL.TextScaled = true
	valL.Font = Enum.Font.GothamBold
	valL.TextColor3 = loot.color
	valL.TextStrokeTransparency = 0.4
	valL.TextStrokeColor3 = Color3.fromRGB(0,0,0)
	valL.Parent = bb

	createPrompt(part, loot.emoji, loot.n..(loot.type=="cash" and " ($"..loot.value..")" or ""), 0.2)

	part.Parent = LiveFolder

	-- Loot respawns on a 45 second timer
	local respawnDelay = loot.rarity=="Common" and 45
		or loot.rarity=="Uncommon" and 60
		or loot.rarity=="Rare" and 90
		or math.huge
	if respawnDelay ~= math.huge then
		table.insert(respawnQueue, {
			isLoot    = true,
			worldX    = worldX,
			worldZ    = worldZ,
			y         = y,
			respawnAt = os.clock() + respawnDelay,
		})
	end
end

-- ============================================================
-- INITIAL SPAWN — ingredients on surfaces
-- ============================================================
local function spawnIngredients()
	for zoneName, surfaces in pairs(ZONE_SURFACES) do
		local pool = ZONE_POOLS[zoneName]
		if not pool or #pool == 0 then continue end

		for _, surface in ipairs(surfaces) do
			local folder = getFolder(surface.folder)
			if not folder then
				warn("IngredientSpawner: folder not found: "..surface.folder)
				continue
			end
			local part = folder:FindFirstChild(surface.name)
			if not part then
				warn("IngredientSpawner: part not found: "
					..surface.name.." in "..surface.folder)
				continue
			end

			local points = getSurfacePoints(part, surface.maxItems)
			for _, pt in ipairs(points) do
				local ingData = weightedRandom(pool, RARITY_WEIGHTS)
				spawnIngredientAt(pt.X, pt.Z,
					surface.surfaceTop, ingData, part)
			end
		end
	end
end

-- ============================================================
-- INITIAL SPAWN — loot outside
-- ============================================================
local function spawnOutsideLoot()
	for _, zone in ipairs(LOOT_SPAWN_ZONES) do
		for i = 1, zone.count do
			local rx = zone.minX + math.random()*(zone.maxX - zone.minX)
			local rz = zone.minZ + math.random()*(zone.maxZ - zone.minZ)
			spawnLootAt(rx, rz, zone.y)
		end
	end
end

-- ============================================================
-- RESPAWN LOOP
-- ============================================================
task.spawn(function()
	while true do
		task.wait(1)
		local now = os.clock()
		local remaining = {}
		for _, entry in ipairs(respawnQueue) do
			if now >= entry.respawnAt then
				if entry.isLoot then
					spawnLootAt(entry.worldX, entry.worldZ, entry.y)
				elseif entry.surfacePart and entry.surfacePart.Parent then
					spawnIngredientAt(
						entry.worldX, entry.worldZ,
						entry.surfaceTop, entry.ingData,
						entry.surfacePart)
				end
			else
				table.insert(remaining, entry)
			end
		end
		respawnQueue = remaining
	end
end)

-- ============================================================
-- PUBLIC API
-- ============================================================
local IngredientSpawner = {}

function IngredientSpawner.StartGatheringPhase()
	LiveFolder = workspace:FindFirstChild(LIVE_FOLDER_NAME)
	if not LiveFolder then
		LiveFolder = Instance.new("Folder")
		LiveFolder.Name = LIVE_FOLDER_NAME
		LiveFolder.Parent = workspace
	else
		LiveFolder:ClearAllChildren()
	end
	respawnQueue = {}
	math.randomseed(os.clock())

	spawnIngredients()
	spawnOutsideLoot()

	print("IngredientSpawner: "
		..#LiveFolder:GetChildren()
		.." items spawned (ingredients + loot)!")
end

function IngredientSpawner.ClearAll()
	if LiveFolder then LiveFolder:ClearAllChildren() end
	respawnQueue = {}
end

return IngredientSpawner
