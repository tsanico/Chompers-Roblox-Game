-- Loot pool built inline — these aren't ingredients, just economy items
local function pickLoot()
	local lootTypes = {
		{ name="Loose Cash",  emoji="💵", rarity="Common",    type="cash",   value=math.random(1,3),   color=Color3.fromRGB(75,205,60)  },
		{ name="Cash Stack",  emoji="💵", rarity="Uncommon",  type="cash",   value=math.random(10,15), color=Color3.fromRGB(55,165,45)  },
		{ name="Big Stack",   emoji="💵", rarity="Rare",      type="cash",   value=math.random(18,25), color=Color3.fromRGB(239,159,39) },
		{ name="Napkin",      emoji="🧻", rarity="UltraRare", type="napkin", value=1,                  color=Color3.fromRGB(100,180,255) },
	}
	local total = 0
	local weighted = {}
	for _, lt in ipairs(lootTypes) do
		local w = LOOT_WEIGHTS[lt.rarity] or 1
		total = total + w
		table.insert(weighted, { lt = lt, cumulative = total })
	end
	local roll = math.random() * total
	for _, entry in ipairs(weighted) do
		if roll <= entry.cumulative then return entry.lt end
	end
	return lootTypes[1]
end

