-- ============================================================
-- SPAWN ONE INGREDIENT PART
-- ============================================================

local LiveFolder   = nil
local respawnQueue = {}

local function spawnIngredientAt(worldX, worldZ, surfaceTop, ing, surfacePart)
	if not LiveFolder then return end

	local color = RARITY_COLORS[ing.rarity] or Color3.fromRGB(200, 200, 200)

	local part = Instance.new("Part")
	part.Name     = ing.name
	part.Size     = Vector3.new(2, 2, 2)
	part.Position = Vector3.new(worldX, surfaceTop + 1, worldZ)
	part.Anchored = true
	part.CanCollide     = true
	part.CastShadow     = false
	part.Color          = color
	part.Material       = Enum.Material.SmoothPlastic

	-- Attributes used by IngredientPickupServer
	part:SetAttribute("IsIngredient",   true)
	part:SetAttribute("IngredientName", ing.name)
	part:SetAttribute("Rarity",         ing.rarity)
	part:SetAttribute("Weight",         ing.wt)
	part:SetAttribute("Cost",           ing.cost)
	part:SetAttribute("Emoji",          ing.emoji or "🍽")
	part:SetAttribute("Allergy",        ing.allergy)
	part:SetAttribute("Zone",           ing.zone)
	part:SetAttribute("IsPaid",         false)
	part:SetAttribute("IsTrash",        false)
	part:SetAttribute("CLValue",        ing.cl)   -- raw CL for combat system

	createBillboard(part, ing)
	createPrompt(part, ing, 0.25)
	part.Parent = LiveFolder

	-- Queue respawn (Legendary = 0, never respawns)
	local rt = RESPAWN_TIMES[ing.rarity] or 0
	if rt > 0 and surfacePart then
		table.insert(respawnQueue, {
			ing        = ing,
			worldX     = worldX,
			worldZ     = worldZ,
			surfaceTop = surfaceTop,
			surfacePart = surfacePart,
			respawnAt  = os.clock() + rt,
		})
	end

	return part
end

