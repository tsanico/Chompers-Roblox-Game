local function getCaviarData()
	for _, ing in ipairs(ChompersData.Ingredients) do
		if ing.name == "Caviar" then return ing end
	end
	return nil
end

local function applyLegendaryVisual(part)
	local orbit = Instance.new("Part")
	orbit.Name         = "_LegendaryOrbit"
	orbit.Size         = Vector3.new(0.2, 0.2, 0.2)
	orbit.Shape        = Enum.PartType.Ball
	orbit.Material     = Enum.Material.SmoothPlastic
	orbit.Color        = Color3.fromRGB(218, 182, 58)
	orbit.Transparency = 0.20
	orbit.Anchored     = true
	orbit.CanCollide   = false
	orbit.Parent       = part.Parent
	local radius    = part.Size.X + 0.5
	local startTime = tick()
	local rs        = game:GetService("RunService")
	local conn
	conn = rs.Heartbeat:Connect(function()
		if not part or not part.Parent then orbit:Destroy(); conn:Disconnect(); return end
		local t = (tick() - startTime) / 4 * 2 * math.pi
		orbit.CFrame = CFrame.new(
			part.Position.X + radius * math.cos(t),
			part.Position.Y,
			part.Position.Z + radius * math.sin(t))
	end)
end

local function tryInjectCaviar(worldX, worldZ, spawnTop, surfacePart)
	if legendaryState.caviarSpawned then return false end
	if math.random() > LEGENDARY_CHANCE then return false end
	local caviar = getCaviarData()
	if not caviar then return false end
	local LiveFolder = workspace:FindFirstChild("Ingredients_Live")
	if not LiveFolder then return false end
	local part = Instance.new("Part")
	part.Name     = caviar.name
	part.Size     = Vector3.new(2, 2, 2)
	part.Position = Vector3.new(worldX, spawnTop + 1, worldZ)
	part.Anchored = true; part.CanCollide = true; part.CastShadow = false
	part.Color    = RARITY_COLORS.Legendary; part.Material = Enum.Material.SmoothPlastic
	part:SetAttribute("IsIngredient",   true)
	part:SetAttribute("IngredientName", caviar.name)
	part:SetAttribute("Rarity",         "Legendary")
	part:SetAttribute("Weight",         caviar.wt)
	part:SetAttribute("Cost",           caviar.cost)
	part:SetAttribute("Emoji",          caviar.emoji or "🫧")
	part:SetAttribute("Allergy",        caviar.allergy)
	part:SetAttribute("Zone",           "Any")
	part:SetAttribute("IsPaid",         false)
	part:SetAttribute("IsTrash",        false)
	part:SetAttribute("CLValue",        caviar.cl)
	applyLegendaryVisual(part)
	part.Parent = LiveFolder
	legendaryState.caviarSpawned = true
	legendaryState.caviarPart    = part
	print(string.format("[IngredientSpawner] 🌟 Caviar spawned at (%.1f, %.1f)", worldX, worldZ))
	return true
end

