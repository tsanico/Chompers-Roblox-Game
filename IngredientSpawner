-- HELPERS
-- ============================================================

local Map = workspace:WaitForChild("Map", 10)
if not Map then warn("[IngredientSpawner] Map folder not found") end

-- Navigate a slash-delimited path inside Map
local function getFolder(path)
	local current = Map
	if not current then return nil end
	for segment in path:gmatch("[^/]+") do
		current = current:FindFirstChild(segment)
		if not current then return nil end
	end
	return current
end

-- Weighted random pick from pool using rarity weights
local function weightedPick(pool)
	local total = 0
	local weighted = {}
	for _, ing in ipairs(pool) do
		local w = RARITY_WEIGHTS[ing.rarity] or 1
		total = total + w
		table.insert(weighted, { ing = ing, cumulative = total })
	end
	if total == 0 then return pool[1] end
	local roll = math.random() * total
	for _, entry in ipairs(weighted) do
		if roll <= entry.cumulative then return entry.ing end
	end
	return pool[1]
end

-- Distribute N spawn points evenly across a part's top surface
local function getSurfacePoints(part, count)
	local pos   = part.Position
	local sizeX = part.Size.X
	local sizeZ = part.Size.Z
	local cols  = math.ceil(math.sqrt(count))
	local rows  = math.ceil(count / cols)
	local stepX = sizeX / (cols + 1)
	local stepZ = sizeZ / (rows + 1)
	local points = {}
	local i = 0
	for row = 1, rows do
		for col = 1, cols do
			i = i + 1
			if i > count then break end
			local jX = (math.random() - 0.5) * stepX * 0.35
			local jZ = (math.random() - 0.5) * stepZ * 0.35
			table.insert(points, Vector3.new(
				pos.X - sizeX/2 + stepX * col + jX,
				0,
				pos.Z - sizeZ/2 + stepZ * row + jZ))
		end
	end
	return points
end

