local Map = workspace:WaitForChild("Map", 10)
if not Map then warn("[IngredientSpawner] Map folder not found") end

local function getFolder(path)
	local current = Map
	if not current then return nil end
	for segment in path:gmatch("[^/]+") do
		current = current:FindFirstChild(segment)
		if not current then return nil end
	end
	return current
end

local function weightedPick(pool)
	local total, weighted = 0, {}
	for _, ing in ipairs(pool) do
		local w = RARITY_WEIGHTS[ing.rarity] or 0
		if w > 0 then
			total = total + w
			table.insert(weighted, { ing=ing, cumulative=total })
		end
	end
	if total == 0 or #weighted == 0 then return pool[1] end
	local roll = math.random() * total
	for _, entry in ipairs(weighted) do
		if roll <= entry.cumulative then return entry.ing end
	end
	return weighted[#weighted].ing
end

-- ============================================================
-- GRID PLACEMENT — v9
--
-- spawnXmin/spawnXmax/spawnZmin/spawnZmax all supported.
-- Inset is proportional (5% per side, min 0.3) so narrow
-- X ranges (5 studs) work without collapsing to zero.
-- ============================================================

local function getSurfacePoints(part, count, surface)
	local pos   = part.Position
	local sizeX = part.Size.X
	local sizeZ = part.Size.Z

	local xMin = pos.X - sizeX * 0.5
	local xMax = pos.X + sizeX * 0.5
	local zMin = pos.Z - sizeZ * 0.5
	local zMax = pos.Z + sizeZ * 0.5

	if surface then
		if surface.spawnXmin then xMin = surface.spawnXmin end
		if surface.spawnXmax then xMax = surface.spawnXmax end
		if surface.spawnZmin then zMin = surface.spawnZmin end
		if surface.spawnZmax then zMax = surface.spawnZmax end
	end

	-- Proportional inset: 5% per side, min 0.3 studs
	-- Prevents narrow overrides from collapsing to zero usable space
	local insetX = math.max(0.3, (xMax - xMin) * 0.05)
	local insetZ = math.max(0.3, (zMax - zMin) * 0.05)
	xMin = xMin + insetX; xMax = xMax - insetX
	zMin = zMin + insetZ; zMax = zMax - insetZ

	local usableX = math.max(xMax - xMin, 0.1)
	local usableZ = math.max(zMax - zMin, 0.1)
	local aspect  = usableX / usableZ

	local nX = math.max(1, math.floor(math.sqrt(count * aspect) + 0.5))
	local nZ = math.max(1, math.ceil(count / nX))
	local cellW = usableX / nX
	local cellH = usableZ / nZ

	local cells = {}
	for xi = 0, nX-1 do
		for zi = 0, nZ-1 do
			table.insert(cells, {
				x = xMin + cellW*(xi+0.5),
				z = zMin + cellH*(zi+0.5),
			})
		end
	end
	-- Shuffle for variety between matches
	for i = #cells, 2, -1 do
		local j = math.random(i)
		cells[i], cells[j] = cells[j], cells[i]
	end

	local JITTER = 0.20
	local points = {}
	for i = 1, math.min(count, #cells) do
		table.insert(points, Vector3.new(
			cells[i].x + (math.random()-0.5)*JITTER*2,
			0,
			cells[i].z + (math.random()-0.5)*JITTER*2
			))
	end
	return points
end

