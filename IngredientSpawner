-- Build zone-filtered pools from master list
local function buildPool(zoneName)
	local pool = {}
	for _, ing in ipairs(ALL_INGREDIENTS) do
		if ing.zone == zoneName then
			table.insert(pool, ing)
		end
	end
	return pool
end

-- Stockroom gets EVERYTHING
local function buildStockroomPool()
	return ALL_INGREDIENTS
end

