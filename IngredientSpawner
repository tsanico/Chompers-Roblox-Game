	part.Parent = LiveFolder

	-- Loot respawn (napkins/bracelets: never)
	local rt = loot.type == "cash"
		and (loot.rarity == "Common" and C.Respawn.Cash_Small or C.Respawn.Cash_Stack)
		or 0  -- napkins never respawn
	if rt > 0 then
		table.insert(respawnQueue, {
			isLoot = true,
			worldX = worldX, worldZ = worldZ, y = y,
			respawnAt = os.clock() + rt,
		})
	end
end

-- ============================================================
-- MAIN SPAWN — ingredients across all zones
-- ============================================================

local function spawnAllIngredients(pools)
	local totalSpawned = 0

	for zoneName, surfaces in pairs(ZONE_SURFACES) do
		local pool = pools[zoneName]
		if not pool or #pool == 0 then
			warn("[IngredientSpawner] No ingredient pool for zone: " .. zoneName)
			continue
		end

		for _, surface in ipairs(surfaces) do
			local folder = getFolder(surface.folder)
			if not folder then
				warn(string.format("[IngredientSpawner] Folder not found: %s", surface.folder))
				continue
			end

			local part = folder:FindFirstChild(surface.name)
			if not part then
				warn(string.format("[IngredientSpawner] Part not found: %s in %s",
					surface.name, surface.folder))
				continue
			end

			local points = getSurfacePoints(part, surface.maxItems)
			for _, pt in ipairs(points) do
				local ing = weightedPick(pool)
				spawnIngredientAt(pt.X, pt.Z, surface.surfaceTop, ing, part)
				totalSpawned = totalSpawned + 1
			end
		end
	end

	return totalSpawned
end

-- ============================================================
-- MAIN SPAWN — outdoor loot
-- ============================================================

local function spawnAllLoot()
	local totalSpawned = 0
	for _, zone in ipairs(LOOT_ZONES) do
		for _ = 1, zone.count do
			local rx = zone.minX + math.random() * (zone.maxX - zone.minX)
			local rz = zone.minZ + math.random() * (zone.maxZ - zone.minZ)
			spawnLootAt(rx, rz, zone.y)
			totalSpawned = totalSpawned + 1
		end
	end
	return totalSpawned
end

-- ============================================================
-- RESPAWN LOOP
-- ============================================================

task.spawn(function()
	while true do
		task.wait(1)
		if not LiveFolder then continue end

		local now = os.clock()
		local remaining = {}

		for _, entry in ipairs(respawnQueue) do
			if now >= entry.respawnAt then
				if entry.isLoot then
					spawnLootAt(entry.worldX, entry.worldZ, entry.y)
				elseif entry.surfacePart and entry.surfacePart.Parent then
					spawnIngredientAt(
						entry.worldX, entry.worldZ,
						entry.surfaceTop, entry.ing,
						entry.surfacePart)
				end
			else
				table.insert(remaining, entry)
			end
		end

		respawnQueue = remaining
	end
end)

-- ============================================================
-- PUBLIC API
-- ============================================================

local IngredientSpawner = {}

function IngredientSpawner.StartGatheringPhase()
	-- Set up or clear the live folder
	LiveFolder = workspace:FindFirstChild(LIVE_FOLDER_NAME)
	if not LiveFolder then
		LiveFolder = Instance.new("Folder")
		LiveFolder.Name   = LIVE_FOLDER_NAME
		LiveFolder.Parent = workspace
	else
		LiveFolder:ClearAllChildren()
	end

	respawnQueue = {}
	math.randomseed(os.clock())

	-- Build ingredient pools fresh each match from ChompersData
	local pools = buildPools()

	local ingCount  = spawnAllIngredients(pools)
	local lootCount = spawnAllLoot()

	print(string.format(
		"[IngredientSpawner] Gathering started — %d ingredients, %d loot items (%d total)",
		ingCount, lootCount, ingCount + lootCount))
end

function IngredientSpawner.ClearAll()
	if LiveFolder then LiveFolder:ClearAllChildren() end
	respawnQueue = {}
end

-- ============================================================
-- PHASE LISTENER — auto-trigger on Gathering start
-- ============================================================

if PhaseChangedEvent then
	PhaseChangedEvent.Event:Connect(function(newPhase)
		if newPhase == "Gathering" then
			IngredientSpawner.StartGatheringPhase()
		elseif newPhase == "Prelobby" then
			-- Clean up between matches
			IngredientSpawner.ClearAll()
		end
	end)
else
	warn("[IngredientSpawner] PhaseChangedEvent not found — call StartGatheringPhase() manually")
end

return IngredientSpawner
