cFrame.Position = UDim2.new(0.5, 0, 1, -100)
cFrame.BackgroundColor3 = Color3.fromRGB(20, 18, 32); cFrame.BorderSizePixel = 0
mkCorner(cFrame, 12)
local cStroke = Instance.new("UIStroke", cFrame)
cStroke.Thickness = 2; cStroke.Color = C.money

local cTitle = mkLabel(cFrame, "💵  Checking out...",
	Enum.Font.GothamBold, 18, C.money, Enum.TextXAlignment.Center,
	UDim2.new(0, 0, 0, 6), UDim2.new(1, 0, 0, 28))

local cTrack = Instance.new("Frame", cFrame)
cTrack.Size = UDim2.new(1, -24, 0, 10); cTrack.Position = UDim2.new(0, 12, 1, -18)
cTrack.BackgroundColor3 = Color3.fromRGB(30, 28, 44); cTrack.BorderSizePixel = 0
mkCorner(cTrack, 5)
local cFill = Instance.new("Frame", cTrack)
cFill.Size = UDim2.new(0, 0, 1, 0)
cFill.BackgroundColor3 = C.money; cFill.BorderSizePixel = 0
mkCorner(cFill, 5)

local checkoutTween = nil

if CheckoutStartRemote then
	CheckoutStartRemote.OnClientEvent:Connect(function(holdTime, cost)
		checkoutGui.Enabled = true
		cFill.Size = UDim2.new(0, 0, 1, 0)
		if checkoutTween then checkoutTween:Cancel() end
		checkoutTween = TweenService:Create(cFill,
			TweenInfo.new(holdTime, Enum.EasingStyle.Linear),
			{Size = UDim2.new(1, 0, 1, 0)})
		checkoutTween:Play()
	end)
end

if CheckoutCompleteRemote then
	CheckoutCompleteRemote.OnClientEvent:Connect(function(success, newMoney, cost)
		if checkoutTween then checkoutTween:Cancel(); checkoutTween = nil end
		checkoutGui.Enabled = true
		if success then
			cFrame.BackgroundColor3 = Color3.fromRGB(18, 45, 20)
			cTitle.Text = "✓  Paid $" .. tostring(cost) .. "!"
			cTitle.TextColor3 = C.green
		else
			cFrame.BackgroundColor3 = Color3.fromRGB(45, 15, 15)
			cTitle.Text = "✗  Not enough money!"
			cTitle.TextColor3 = C.red
		end
		task.wait(success and 1.2 or 1.5)
		checkoutGui.Enabled = false
		cFrame.BackgroundColor3 = Color3.fromRGB(20, 18, 32)
		cTitle.Text = "💵  Checking out..."
		cTitle.TextColor3 = C.money
	end)
end

