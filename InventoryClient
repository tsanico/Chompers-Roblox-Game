local selectedListBtn = nil

local function buildLeftList()
	for _, c in ipairs(LeftScroll:GetChildren()) do
		if c:IsA("TextButton") or c:IsA("Frame") or c:IsA("TextLabel") then
			c:Destroy()
		end
	end

	if #localInventory == 0 then
		local icon = containerType == "Cart" and "🛒" or "🧺"
		local el = Instance.new("TextLabel", LeftScroll)
		el.Size=UDim2.new(1,0,0,80); el.LayoutOrder=0
		el.BackgroundTransparency=1
		el.Text=icon.." Your "..containerType:lower().." is empty!"
		el.Font=Enum.Font.Gotham; el.TextSize=13; el.TextColor3=C.dim
		el.TextXAlignment=Enum.TextXAlignment.Center
		el.TextYAlignment=Enum.TextYAlignment.Center
		el.TextWrapped=true; el.ZIndex=13
		showPlaceholder(icon.."  Empty!\n\nPick up ingredients to get started.")
		selectedListBtn=nil; selectedItem=nil
		return
	end

	selectedListBtn = nil
	if not selectedItem then showPlaceholder("← Select an item to see details.") end

	-- Separate paid vs unpaid, each sorted by rarity desc then name asc
	local function sortItems(list)
		table.sort(list, function(a, b)
			local ra = RARITY_ORDER[normalRarity(a.item.rarity)] or 5
			local rb = RARITY_ORDER[normalRarity(b.item.rarity)] or 5
			if ra ~= rb then return ra < rb end
			return (a.item.name or "") < (b.item.name or "")
		end)
	end

	local unpaid, paid = {}, {}
	for i, item in ipairs(localInventory) do
		local entry = { item=item, origIndex=i }
		if item.paid then table.insert(paid, entry)
		else               table.insert(unpaid, entry)
		end
	end
	sortItems(unpaid); sortItems(paid)

	local layoutOrder = 0

	local function makeSectionHeader(text, color)
		layoutOrder = layoutOrder + 1
		local hdr = Instance.new("TextLabel", LeftScroll)
		hdr.Size = UDim2.new(1,0,0,22); hdr.LayoutOrder = layoutOrder
		hdr.BackgroundColor3 = Color3.fromRGB(22,20,36); hdr.BorderSizePixel=0
		hdr.Text = text; hdr.Font = Enum.Font.GothamBlack; hdr.TextSize = 11
		hdr.TextColor3 = color; hdr.TextXAlignment = Enum.TextXAlignment.Left
		hdr.ZIndex = 13
		local pad = Instance.new("UIPadding", hdr)
		pad.PaddingLeft = UDim.new(0,8)
	end

	local function makeRow(entry)
		local item  = entry.item
		local origI = entry.origIndex
		local rarity    = normalRarity(item.rarity or "Common")
		local strokeCol = RARITY_STROKE[rarity] or C.stroke
		local isPaid    = item.paid == true

		layoutOrder = layoutOrder + 1
		local row = Instance.new("TextButton", LeftScroll)
		row.Name             = "Row_" .. origI
		row.Size             = UDim2.new(1,0,0,48)
		row.BackgroundColor3 = origI == selectedSlot
			and Color3.fromRGB(35,33,54)
			or (isPaid and Color3.fromRGB(14,26,16) or Color3.fromRGB(30,14,14))
		row.BorderSizePixel  = 0; row.AutoButtonColor = false
		row.LayoutOrder      = layoutOrder; row.ZIndex = 13
		corner(row, 8)
		local rowStroke = mkStroke(row,
			origI == selectedSlot and 2 or 1.5,
			origI == selectedSlot and C.red or strokeCol)

		-- Paid/unpaid indicator bar on left edge
		local bar = Instance.new("Frame", row)
		bar.Size = UDim2.new(0,3,1,-8); bar.Position = UDim2.new(0,2,0,4)
		bar.BackgroundColor3 = isPaid and C.green or C.red
		bar.BorderSizePixel = 0; bar.ZIndex = 14; corner(bar, 2)

		-- Slot badge
		local slotKey = origI == 10 and "0" or tostring(origI)
		local badge = Instance.new("Frame", row)
		badge.Size=UDim2.new(0,20,0,16); badge.Position=UDim2.new(0,8,0.5,-8)
		badge.BackgroundColor3=Color3.fromRGB(40,38,60); badge.BorderSizePixel=0
		badge.ZIndex=14; corner(badge,4)
		mkLabel(badge, slotKey, Enum.Font.GothamBlack, 9, C.dim).ZIndex=15

		mkLabel(row, item.emoji or "🍽",
			Enum.Font.GothamBold, 22, C.white, Enum.TextXAlignment.Center,
			UDim2.new(0,30,0,0), UDim2.new(0,34,1,0)).ZIndex=14

		local nameL = mkLabel(row, item.name or "?",
			Enum.Font.GothamBold, 13, C.white, Enum.TextXAlignment.Left,
			UDim2.new(0,68,0,4), UDim2.new(1,-76,0,20))
		nameL.ZIndex=14; nameL.TextTruncate=Enum.TextTruncate.AtEnd

		-- Status sub-label
		local subText, subCol
		if item.cookStatus == "Cooked" then
			subText = "✓ Cooked"; subCol = C.green
		elseif item.cookStatus == "Burned" then
			subText = "🔥 Burned"; subCol = C.red
		elseif item.cookStatus == "Uncooked" then
			subText = "⚠ Uncooked"; subCol = C.gold
		elseif isPaid then
			subText = "✓ Paid · ⚖"..tostring(item.wt or 0)
			subCol = Color3.fromRGB(70,195,85)
		else
			subText = "Unpaid $"..(item.cost or 0).." · ⚖"..tostring(item.wt or 0)
			subCol = C.red
		end
		mkLabel(row, subText, Enum.Font.Gotham, 10, subCol,
			Enum.TextXAlignment.Left,
			UDim2.new(0,68,0,28), UDim2.new(1,-76,0,14)).ZIndex=14

		local capOrigI = origI; local capItem = item
		row.MouseButton1Click:Connect(function()
			if selectedListBtn then
				local oi = tonumber(selectedListBtn.Name:match("%d+"))
				local prevPaid = oi and localInventory[oi] and localInventory[oi].paid
				selectedListBtn.BackgroundColor3 = prevPaid
					and Color3.fromRGB(14,26,16) or Color3.fromRGB(30,14,14)
				local s = selectedListBtn:FindFirstChildWhichIsA("UIStroke")
				if s then
					local or_ = oi and localInventory[oi]
						and normalRarity(localInventory[oi].rarity) or "Common"
					s.Thickness=1.5; s.Color=RARITY_STROKE[or_] or C.stroke
				end
			end
			row.BackgroundColor3 = Color3.fromRGB(35,33,54)
			rowStroke.Thickness=2; rowStroke.Color=C.red
			selectedListBtn=row; selectedItem=capItem
			showDetail(capItem, capOrigI)
		end)

		if selectedItem and selectedItem.name==item.name
		and selectedItem.emoji==item.emoji then
			selectedListBtn=row
			row.BackgroundColor3=Color3.fromRGB(35,33,54)
			rowStroke.Thickness=2; rowStroke.Color=C.red
			showDetail(capItem, capOrigI)
		end
	end

	if #unpaid > 0 then
		makeSectionHeader("❌  UNPAID  ("..#unpaid..")", C.red)
		for _, entry in ipairs(unpaid) do makeRow(entry) end
	end
	if #paid > 0 then
		makeSectionHeader("✅  PAID  ("..#paid..")", C.green)
		for _, entry in ipairs(paid) do makeRow(entry) end
	end
end

