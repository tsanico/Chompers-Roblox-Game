-- ============================================================
-- SELF-CHECKOUT — uses the existing inventory panel + PAY buttons
-- When player presses E at a self-checkout kiosk the server fires
-- ShowSelfCheckoutUI, which opens the normal inventory and sets
-- checkoutMode=true. Each unpaid row gets a PAY button.
-- Closing inventory fires SelfCheckoutClose to the server.
-- ============================================================

local SelfCheckoutR = Remotes:WaitForChild("ShowSelfCheckoutUI", 10)
local HideSelfCoR   = Remotes:WaitForChild("HideSelfCheckoutUI", 10)
local ScanItemR     = Remotes:WaitForChild("SelfCheckoutScanItem", 10)
local ItemPaidR     = Remotes:WaitForChild("SelfCheckoutItemPaid", 10)
local CloseKioskR   = Remotes:WaitForChild("SelfCheckoutClose", 10)

local checkoutMode  = false  -- true while at a self-checkout kiosk

-- Notify server when player closes the inventory panel during checkout
local origClosePanel
CloseBtn.MouseButton1Click:Connect(function()
	if checkoutMode then
		checkoutMode = false
		if CloseKioskR then CloseKioskR:FireServer() end
		rebuildPanel()   -- remove PAY buttons
	end
end)

if SelfCheckoutR then
	SelfCheckoutR.OnClientEvent:Connect(function(_, money)
		checkoutMode = true
		openPanel()   -- opens existing inventory panel
		-- Money label update happens via normal UpdateMoney remote
	end)
end

if HideSelfCoR then
	HideSelfCoR.OnClientEvent:Connect(function()
		checkoutMode = false
		closePanel()
		rebuildPanel()
	end)
end

-- When server confirms an item is paid, refresh the panel
if ItemPaidR then
	ItemPaidR.OnClientEvent:Connect(function(slotIndex, cost, newMoney, reason)
		if reason == "ok" then
			-- Mark item as paid locally for instant feedback
			if localInventory[slotIndex] then
				localInventory[slotIndex].paid = true
			end
			syncHotbar()
			rebuildPanel()
			if _G.Chompers and _G.Chompers.Announce then
				local name = localInventory[slotIndex] and localInventory[slotIndex].name or "Item"
				_G.Chompers.Announce("✅ Paid for "..name.." ($"..cost..")",
					Color3.fromRGB(70,195,85), 1.8)
			end
		elseif reason == "broke" then
			if _G.Chompers and _G.Chompers.Announce then
				_G.Chompers.Announce("❌ Not enough money!", Color3.fromRGB(218,65,65), 2)
			end
		end
	end)
end

-- buildLeftList already calls makeRow; we extend makeRow with PAY button in checkout mode
-- The PAY button is injected into makeRow via checkoutMode flag (closure captures it)
-- We store a reference to the original makeRow builder and re-run buildLeftList
-- when checkoutMode changes (rebuildPanel handles this).

-- Patch: inject PAY button into rows when in checkoutMode.
-- This is done by overriding the row click area with a dedicated button.
-- We hook into UpdateInventory to rebuild when inventory changes.
local _origRebuild = rebuildPanel
function rebuildPanel()
	_origRebuild()
	if not checkoutMode then return end
	-- After normal build, add PAY buttons to unpaid rows in LeftScroll
	for _, child in ipairs(LeftScroll:GetChildren()) do
		if child:IsA("TextButton") and child.Name:match("^Row_") then
			local slotIdx = tonumber(child.Name:match("%d+"))
			if slotIdx and localInventory[slotIdx] and not localInventory[slotIdx].paid then
				-- Only add if not already there
				if not child:FindFirstChild("PayBtn") then
					local payBtn = Instance.new("TextButton", child)
					payBtn.Name = "PayBtn"
					payBtn.Size = UDim2.new(0,56,0,28)
					payBtn.AnchorPoint = Vector2.new(1,0.5)
					payBtn.Position = UDim2.new(1,-6,0.5,0)
					payBtn.BackgroundColor3 = Color3.fromRGB(30,100,40)
					payBtn.BorderSizePixel = 0
					payBtn.Font = Enum.Font.GothamBlack
					payBtn.TextSize = 12
					payBtn.TextColor3 = Color3.fromRGB(150,255,160)
					payBtn.Text = "PAY"
					payBtn.AutoButtonColor = false
					payBtn.ZIndex = 20
					local uic = Instance.new("UICorner", payBtn)
					uic.CornerRadius = UDim.new(0,6)
					local capIdx = slotIdx
					payBtn.MouseButton1Click:Connect(function()
						if ScanItemR then ScanItemR:FireServer(capIdx) end
					end)
				end
			end
		end
	end
end

