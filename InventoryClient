}

-- Rarity sort order (highest priority = lowest number)
local RARITY_ORDER = {
	Legendary = 1, UltraRare = 2, ["Ultra-Rare"] = 2,
	Rare = 3, Uncommon = 4, Common = 5,
}

-- Sort inventory by rarity (desc) then alphabetically
local function sortedInventory()
	local sorted = {}
	for i, item in ipairs(localInventory) do
		table.insert(sorted, { item = item, origIndex = i })
	end
	table.sort(sorted, function(a, b)
		local ra = RARITY_ORDER[normaliseRarity(a.item.rarity)] or 5
		local rb = RARITY_ORDER[normaliseRarity(b.item.rarity)] or 5
		if ra ~= rb then return ra < rb end
		return (a.item.name or "") < (b.item.name or "")
	end)
	return sorted
end

