	CheckoutCompleteRemote.OnClientEvent:Connect(function(success,_,cost)
		if cTween then cTween:Cancel(); cTween=nil end
		checkoutGui.Enabled=true
		if success then
			cFrame.BackgroundColor3=Color3.fromRGB(18,45,20)
			cTitle.Text="✓  Paid $"..tostring(cost).."!"
			cTitle.TextColor3=C.green
		else
			cFrame.BackgroundColor3=Color3.fromRGB(45,15,15)
			cTitle.Text="✗  Not enough money!"
			cTitle.TextColor3=C.red
		end
		task.wait(success and 1.2 or 1.5)
		checkoutGui.Enabled=false
		cFrame.BackgroundColor3=Color3.fromRGB(20,18,32)
		cTitle.Text="💵  Checking out..."
		cTitle.TextColor3=C.money
	end)
end

