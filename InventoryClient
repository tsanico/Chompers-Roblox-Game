local function showDetail(item, origIndex)
	clearRight()
	if not item then showPlaceholder("Select an item to see details."); return end

	local rarity    = normalRarity(item.rarity or "Common")
	local strokeCol = RARITY_STROKE[rarity] or C.stroke
	local bgCol     = RARITY_BG[rarity]    or C.bgCard

	-- ── HERO: emoji fills left column, name+status stacked right ──
	local topCard = Instance.new("Frame", RightScroll)
	topCard.Size = UDim2.new(1,0,0,110)
	topCard.BackgroundColor3 = bgCol
	topCard.BorderSizePixel = 0; topCard.LayoutOrder = 1; topCard.ZIndex = 12
	corner(topCard, 12); mkStroke(topCard, 2, strokeCol)

	mkLabel(topCard, item.emoji or "🍽",
		Enum.Font.GothamBold, 64, C.white, Enum.TextXAlignment.Center,
		UDim2.new(0,0,0,0), UDim2.new(0,100,1,0)).ZIndex = 13

	mkLabel(topCard, item.name or "Unknown",
		Enum.Font.GothamBlack, 24, C.white, Enum.TextXAlignment.Left,
		UDim2.new(0,104,0,12), UDim2.new(1,-112,0,30)).ZIndex = 13

	mkLabel(topCard, rarity..(item.zone and ("  ·  "..(item.zone)) or ""),
		Enum.Font.GothamBold, 15, strokeCol, Enum.TextXAlignment.Left,
		UDim2.new(0,104,0,46), UDim2.new(1,-112,0,20)).ZIndex = 13

	-- Paid status
	local stText = item.paid and "✓  PAID" or ("UNPAID  $"..tostring(item.cost or 0))
	local stCol  = item.paid and C.green or C.orange
	mkLabel(topCard, stText, Enum.Font.GothamBlack, 13, stCol,
		Enum.TextXAlignment.Left,
		UDim2.new(0,104,0,72), UDim2.new(1,-112,0,20)).ZIndex = 13

	-- ── SUBICONS (Cookbook-style 72px chips) ──────────────────────
	local chipRow = Instance.new("Frame", RightScroll)
	chipRow.LayoutOrder = 2
	chipRow.Size = UDim2.new(1,0,0,0); chipRow.AutomaticSize = Enum.AutomaticSize.Y
	chipRow.BackgroundTransparency = 1
	local chipLL = Instance.new("UIListLayout", chipRow)
	chipLL.FillDirection = Enum.FillDirection.Horizontal
	chipLL.HorizontalAlignment = Enum.HorizontalAlignment.Left
	chipLL.VerticalAlignment   = Enum.VerticalAlignment.Center
	chipLL.Padding = UDim.new(0, 6)

	local function chip(icon, label, bg, tc)
		local f = Instance.new("Frame", chipRow)
		f.Size = UDim2.new(0,0,0,72); f.AutomaticSize = Enum.AutomaticSize.X
		f.BackgroundColor3 = bg; f.BorderSizePixel = 0; corner(f, 12)
		local s = Instance.new("UIStroke", f); s.Thickness = 2; s.Color = tc
		local ll = Instance.new("UIListLayout", f)
		ll.SortOrder = Enum.SortOrder.LayoutOrder
		ll.HorizontalAlignment = Enum.HorizontalAlignment.Center
		ll.VerticalAlignment   = Enum.VerticalAlignment.Center
		local pad = Instance.new("UIPadding", f)
		pad.PaddingLeft=UDim.new(0,12); pad.PaddingRight=UDim.new(0,12)
		pad.PaddingTop=UDim.new(0,8);   pad.PaddingBottom=UDim.new(0,8)
		local iL = Instance.new("TextLabel", f); iL.LayoutOrder=1
		iL.Size=UDim2.new(0,0,0,32); iL.AutomaticSize=Enum.AutomaticSize.X
		iL.BackgroundTransparency=1; iL.Text=icon
		iL.Font=Enum.Font.GothamBold; iL.TextSize=30; iL.TextColor3=tc; iL.ZIndex=13
		local lL = Instance.new("TextLabel", f); lL.LayoutOrder=2
		lL.Size=UDim2.new(0,0,0,20); lL.AutomaticSize=Enum.AutomaticSize.X
		lL.BackgroundTransparency=1; lL.Text=label
		lL.Font=Enum.Font.GothamBlack; lL.TextSize=17; lL.TextColor3=tc; lL.ZIndex=13
	end

	-- Allergy or clean
	if item.allergy and item.allergy ~= "None" then
		chip("⚠️", item.allergy, Color3.fromRGB(50,10,10), Color3.fromRGB(230,90,90))
	else
		chip("✅", "No allergen", Color3.fromRGB(10,28,14), Color3.fromRGB(70,195,85))
	end
	-- Cost
	chip("💲", "$"..(item.cost or "?"), Color3.fromRGB(10,28,14), Color3.fromRGB(70,195,85))
	-- CL
	local clVal = (item.cl and item.cl > 0) and "+"..item.cl.." CL" or "N/A"
	local clCol = (item.cl and item.cl > 0) and Color3.fromRGB(65,185,235) or C.dim
	chip("🧼", clVal, Color3.fromRGB(14,28,50), clCol)
	-- Weight
	chip("⚖️", (item.wt or item.weight or 0).." wt",
		Color3.fromRGB(30,22,8), Color3.fromRGB(200,160,80))

	-- ── EFFECT / NOTE ─────────────────────────────────────────────
	local nextOrder = 3
	if item.effect and item.effect ~= "" then
		local eff = Instance.new("TextLabel", RightScroll); eff.LayoutOrder = nextOrder; nextOrder=nextOrder+1
		eff.Size=UDim2.new(1,0,0,0); eff.AutomaticSize=Enum.AutomaticSize.Y
		eff.BackgroundTransparency=1; eff.Text="💥  "..item.effect
		eff.Font=Enum.Font.GothamBold; eff.TextSize=18
		eff.TextColor3=Color3.fromRGB(220,215,240)
		eff.TextXAlignment=Enum.TextXAlignment.Left; eff.TextWrapped=true; eff.ZIndex=12
	end
	if item.notes and item.notes ~= "" then
		local nt = Instance.new("TextLabel", RightScroll); nt.LayoutOrder = nextOrder; nextOrder=nextOrder+1
		nt.Size=UDim2.new(1,0,0,0); nt.AutomaticSize=Enum.AutomaticSize.Y
		nt.BackgroundTransparency=1; nt.Text="💡  "..item.notes
		nt.Font=Enum.Font.GothamBold; nt.TextSize=18; nt.TextColor3=C.gold
		nt.TextXAlignment=Enum.TextXAlignment.Left; nt.TextWrapped=true; nt.ZIndex=12
	end
	if item.ingredients then
		local nt = Instance.new("TextLabel", RightScroll); nt.LayoutOrder = nextOrder; nextOrder=nextOrder+1
		nt.Size=UDim2.new(1,0,0,0); nt.AutomaticSize=Enum.AutomaticSize.Y
		nt.BackgroundTransparency=1
		nt.Text="📋  "..table.concat(item.ingredients, "  ·  ")
		nt.Font=Enum.Font.GothamBold; nt.TextSize=16; nt.TextColor3=C.dim
		nt.TextXAlignment=Enum.TextXAlignment.Left; nt.TextWrapped=true; nt.ZIndex=12
	end

	-- ── SLOT ASSIGNMENT ───────────────────────────────────────────
	if origIndex then
		local slotRow = Instance.new("Frame", RightScroll)
		slotRow.Size = UDim2.new(1,0,0,70)
		slotRow.BackgroundColor3 = Color3.fromRGB(22,20,36)
		slotRow.BorderSizePixel = 0
		slotRow.LayoutOrder = nextOrder; nextOrder = nextOrder+1
		slotRow.ZIndex = 12; corner(slotRow, 10)
		local ss = Instance.new("UIStroke", slotRow); ss.Thickness=1.5; ss.Color=C.stroke

		mkLabel(slotRow, "ASSIGN TO HOTBAR SLOT",
			Enum.Font.GothamBlack, 12, C.dim, Enum.TextXAlignment.Center,
			UDim2.new(0,0,0,6), UDim2.new(1,0,0,16)).ZIndex = 13

		local btnRow = Instance.new("Frame", slotRow)
		btnRow.Size = UDim2.new(1,-16,0,36); btnRow.Position = UDim2.new(0,8,0,26)
		btnRow.BackgroundTransparency = 1; btnRow.ZIndex = 13
		local bLL = Instance.new("UIListLayout", btnRow)
		bLL.FillDirection = Enum.FillDirection.Horizontal
		bLL.HorizontalAlignment = Enum.HorizontalAlignment.Center
		bLL.Padding = UDim.new(0,4)

		for si = 1, 10 do
			local key = si == 10 and "0" or tostring(si)
			local isActive = si == origIndex
			local hasItem = localInventory[si] ~= nil and si ~= origIndex
			local b = Instance.new("TextButton", btnRow)
			b.Text = key; b.Font = Enum.Font.GothamBlack; b.TextSize = 15
			b.TextColor3 = isActive and C.white or (hasItem and C.gold or C.dim)
			b.BackgroundColor3 = isActive and Color3.fromRGB(80,20,20)
				or (hasItem and Color3.fromRGB(40,30,8) or Color3.fromRGB(28,26,44))
			b.BorderSizePixel=0; b.AutoButtonColor=false
			b.Size=UDim2.new(0,0,1,0); b.AutomaticSize=Enum.AutomaticSize.X
			b.ZIndex=14; b.Parent=btnRow; corner(b,6)
			local pad=Instance.new("UIPadding",b)
			pad.PaddingLeft=UDim.new(0,10); pad.PaddingRight=UDim.new(0,10)
			mkStroke(b, 1.5, isActive and C.red or (hasItem and C.gold or C.stroke))

			local capSi=si; local capOrig=origIndex
			b.MouseButton1Click:Connect(function()
				if capSi == capOrig then return end
				-- Fire to server — server does the authoritative move, no holes
				if ReorderRemote then ReorderRemote:FireServer(capOrig, capSi) end
				-- Optimistic local update so UI feels instant (server will re-sync)
				local moved = table.remove(localInventory, capOrig)
				if moved then
					local target = math.clamp(capSi, 1, #localInventory+1)
					table.insert(localInventory, target, moved)
				end
				syncHotbar()
				selectedItem = localInventory[math.clamp(capSi,1,#localInventory)]
				rebuildPanel()
			end)
		end
	end
end

