-- ============================================================
-- HELPERS
-- ============================================================

local function mkFrame(parent, size, pos, bg, corner, nostroke)
	local f = Instance.new("Frame")
	f.Size = size or UDim2.new(1,0,1,0)
	f.Position = pos or UDim2.new(0,0,0,0)
	f.BackgroundColor3 = bg or C.bg
	f.BorderSizePixel = 0
	f.Parent = parent
	Instance.new("UICorner", f).CornerRadius = UDim.new(0, corner or 12)
	if not nostroke then
		local s = Instance.new("UIStroke", f)
		s.Thickness = 1.5; s.Color = C.stroke
	end
	return f
end

local function mkLabel(parent, text, font, size, color, xAlign, pos, sz)
	local l = Instance.new("TextLabel")
	l.Text = text or ""
	l.Font = font or Enum.Font.GothamBold
	l.TextSize = size or 14
	l.TextColor3 = color or C.white
	l.TextXAlignment = xAlign or Enum.TextXAlignment.Center
	l.TextYAlignment = Enum.TextYAlignment.Center
	l.BackgroundTransparency = 1
	l.Position = pos or UDim2.new(0,0,0,0)
	l.Size = sz or UDim2.new(1,0,1,0)
	l.Parent = parent
	return l
end

local function normaliseRarity(r)
	if r == "UltraRare" then return "Ultra-Rare" end
	return r or "Common"
end

-- ============================================================
-- HOTBAR SYNC
-- ============================================================

local function syncHotbar()
	local chompers = _G.Chompers
	if not (chompers and chompers.SetSlotItem) then return end
	local NUM = chompers.GetSlotCount and chompers.GetSlotCount() or 10
	for i = 1, NUM do chompers.SetSlotItem(i, nil) end
	for i, item in ipairs(localInventory) do
		if i > NUM then break end
		chompers.SetSlotItem(i, {
			emoji  = item.emoji or "🍽",
			name   = item.name or "?",
			rarity = normaliseRarity(item.rarity),
			paid   = item.paid,
			weight = item.wt or item.weight or 0,
			cost   = item.cost or 0,
		})
	end
	if chompers.SetItemCount then
		chompers.SetItemCount(#localInventory)
	end
end

