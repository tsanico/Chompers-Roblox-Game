	[Enum.KeyCode.Seven]=7, [Enum.KeyCode.Eight]=8,
	[Enum.KeyCode.Nine]=9,  [Enum.KeyCode.Zero]=10,
}

local function selectSlot(slot)
	selectedSlot = slot
	local ch = _G.Chompers
	if ch and ch.SetSelectedSlot then
		ch.SetSelectedSlot(selectedSlot)
	end
end

