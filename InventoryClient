local function showDetail(item, origIndex)
	clearRight()
	if not item then
		showEmptyRight("Select an item to see details.")
		return
	end

	local rarity = normaliseRarity(item.rarity or "Common")
	local strokeCol = RARITY_STROKE[rarity] or C.stroke
	local bgCol     = RARITY_BG[rarity] or C.bgCard

	-- Big emoji + name card
	local topCard = Instance.new("Frame", RightScroll)
	topCard.Size = UDim2.new(1, 0, 0, 120)
	topCard.BackgroundColor3 = bgCol
	topCard.BorderSizePixel = 0; topCard.LayoutOrder = 1; topCard.ZIndex = 12
	mkCorner(topCard, 12)
	local topStroke = mkStroke(topCard, 2, strokeCol)

	-- Giant emoji
	mkLabel(topCard, item.emoji or "🍽",
		Enum.Font.GothamBold, 72, C.white,
		Enum.TextXAlignment.Center,
		UDim2.new(0, 0, 0, 0), UDim2.new(0, 110, 1, 0)).ZIndex = 13

	-- Name + rarity
	mkLabel(topCard, item.name or "Unknown",
		Enum.Font.GothamBlack, 26, C.white,
		Enum.TextXAlignment.Left,
		UDim2.new(0, 116, 0, 10), UDim2.new(1, -124, 0, 32)).ZIndex = 13

	local rarityL = mkLabel(topCard, rarity,
		Enum.Font.GothamBold, 16, strokeCol,
		Enum.TextXAlignment.Left,
		UDim2.new(0, 116, 0, 44), UDim2.new(1, -124, 0, 20))
	rarityL.ZIndex = 13

	-- Weight + zone
	local meta = {}
	if item.zone then table.insert(meta, "📍 " .. item.zone) end
	if item.wt or item.weight then
		table.insert(meta, "⚖ " .. tostring(item.wt or item.weight) .. " wt")
	end
	mkLabel(topCard, table.concat(meta, "   "),
		Enum.Font.Gotham, 14, C.dim,
		Enum.TextXAlignment.Left,
		UDim2.new(0, 116, 0, 66), UDim2.new(1, -124, 0, 18)).ZIndex = 13

	-- Status tag
	local stText, stColor
	if item.cookStatus then
		if item.cookStatus == "Cooked" then stText = "COOKED ✓"; stColor = C.green
		elseif item.cookStatus == "Burned" then stText = "BURNED"; stColor = C.red
		else stText = "UNCOOKED"; stColor = C.gold end
	elseif item.paid then
		stText = "✓ PAID"; stColor = C.green
	else
		stText = "UNPAID  $" .. tostring(item.cost or 0); stColor = C.orange
	end
	mkLabel(topCard, stText,
		Enum.Font.GothamBlack, 15, stColor,
		Enum.TextXAlignment.Left,
		UDim2.new(0, 116, 0, 86), UDim2.new(1, -124, 0, 20)).ZIndex = 13

	-- Detail section helper
	local function addSection(title, value, color)
		if not value or value == "" then return end
		local row = Instance.new("Frame", RightScroll)
		row.Size = UDim2.new(1, 0, 0, 0)
		row.AutomaticSize = Enum.AutomaticSize.Y
		row.BackgroundColor3 = C.bgLight
		row.BorderSizePixel = 0
		row.ZIndex = 12
		mkCorner(row, 8)

		local pad = Instance.new("UIPadding", row)
		pad.PaddingLeft = UDim.new(0, 12)
		pad.PaddingRight = UDim.new(0, 12)
		pad.PaddingTop = UDim.new(0, 8)
		pad.PaddingBottom = UDim.new(0, 8)

		local ll = Instance.new("UIListLayout", row)
		ll.SortOrder = Enum.SortOrder.LayoutOrder
		ll.Padding = UDim.new(0, 2)

		local titleL = Instance.new("TextLabel", row)
		titleL.Size = UDim2.new(1, 0, 0, 16)
		titleL.BackgroundTransparency = 1
		titleL.Text = title
		titleL.Font = Enum.Font.GothamBlack; titleL.TextSize = 11
		titleL.TextColor3 = color or C.dim
		titleL.TextXAlignment = Enum.TextXAlignment.Left
		titleL.ZIndex = 13; titleL.LayoutOrder = 1

		local valL = Instance.new("TextLabel", row)
		valL.Size = UDim2.new(1, 0, 0, 0)
		valL.AutomaticSize = Enum.AutomaticSize.Y
		valL.BackgroundTransparency = 1
		valL.Text = tostring(value)
		valL.Font = Enum.Font.Gotham; valL.TextSize = 17
		valL.TextColor3 = C.white
		valL.TextXAlignment = Enum.TextXAlignment.Left
		valL.TextWrapped = true; valL.LineHeight = 1.3
		valL.ZIndex = 13; valL.LayoutOrder = 2

		row.LayoutOrder = RightScroll:FindFirstChildOfClass("Frame") and
			(#RightScroll:GetChildren()) or 2
		return row
	end

	local nextOrder = 2
	local function section(title, value, color)
		local row = addSection(title, value, color)
		if row then row.LayoutOrder = nextOrder; nextOrder = nextOrder + 1 end
	end

	-- Allergy
	if item.allergy and item.allergy ~= "None" then
		section("⚠ ALLERGY", item.allergy, C.red)
	else
		section("⚠ ALLERGY", "None", C.dim)
	end

	if item.effect and item.effect ~= "" then
		section("✨ EFFECT", item.effect, C.gold)
	end

	if item.cl and item.cl > 0 then
		section("🧼 CLEANLINESS DAMAGE", "+" .. item.cl .. " CL per hit", C.weight)
	end

	if item.ingredients then
		section("📋 INGREDIENTS", table.concat(item.ingredients, "  ·  "), C.green)
	end
	if item.station and item.station ~= "" then
		section("🍳 STATION", item.station, C.dim)
	end

	if item.notes and item.notes ~= "" then
		section("📝 NOTE", item.notes, C.dim)
	end

	-- ── Slot assignment row ───────────────────────────────────
	if origIndex then
		local slotRow = Instance.new("Frame", RightScroll)
		slotRow.Size = UDim2.new(1, 0, 0, 56)
		slotRow.BackgroundColor3 = C.bgLight
		slotRow.BorderSizePixel = 0
		slotRow.LayoutOrder = nextOrder
		slotRow.ZIndex = 12
		mkCorner(slotRow, 8)

		mkLabel(slotRow, "ASSIGN TO HOTBAR SLOT",
			Enum.Font.GothamBlack, 10, C.dim, Enum.TextXAlignment.Left,
			UDim2.new(0, 12, 0, 6), UDim2.new(1, -24, 0, 14)).ZIndex = 13

		-- 1-10 buttons
		local btnRow = Instance.new("Frame", slotRow)
		btnRow.Size = UDim2.new(1, -16, 0, 28)
		btnRow.Position = UDim2.new(0, 8, 0, 22)
		btnRow.BackgroundTransparency = 1; btnRow.ZIndex = 13
		local btnLL = Instance.new("UIListLayout", btnRow)
		btnLL.FillDirection = Enum.FillDirection.Horizontal
		btnLL.Padding = UDim.new(0, 3)

		for si = 1, 10 do
			local key = si == 10 and "0" or tostring(si)
			local isActive = si == origIndex
			local sBtn = Instance.new("TextButton", btnRow)
			sBtn.Text = key
			sBtn.Font = Enum.Font.GothamBlack; sBtn.TextSize = 12
			sBtn.TextColor3 = isActive and C.white or C.dim
			sBtn.BackgroundColor3 = isActive
				and Color3.fromRGB(80, 30, 30)
				or Color3.fromRGB(35, 33, 52)
			sBtn.BorderSizePixel = 0; sBtn.AutoButtonColor = false
			sBtn.Size = UDim2.new(0, 0, 1, 0)
			sBtn.AutomaticSize = Enum.AutomaticSize.X
			sBtn.ZIndex = 14
			mkCorner(sBtn, 5)

			-- Minimum width via UIPadding
			local sp = Instance.new("UIPadding", sBtn)
			sp.PaddingLeft = UDim.new(0, 8); sp.PaddingRight = UDim.new(0, 8)

			local capturedSi = si
			local capturedOrigI = origIndex
			sBtn.MouseButton1Click:Connect(function()
				-- Swap slots capturedOrigI ↔ capturedSi
				local a = localInventory[capturedOrigI]
				local b = localInventory[capturedSi]
				localInventory[capturedOrigI] = b
				localInventory[capturedSi]    = a
				-- If selected slot was one of the swapped, update it
				if selectedSlot == capturedOrigI then
					selectedSlot = capturedSi
				elseif selectedSlot == capturedSi then
					selectedSlot = capturedOrigI
				end
				if _G.Chompers and _G.Chompers.SetSelectedSlot then
					_G.Chompers.SetSelectedSlot(selectedSlot)
				end
				syncHotbar()
				rebuildPanel()
			end)
		end
	end
end

