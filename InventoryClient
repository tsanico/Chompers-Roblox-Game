-- ── Helpers ───────────────────────────────────────────────────
local function normalRarity(r)
	if r == "UltraRare" then return "Ultra-Rare" end
	return r or "Common"
end
local function corner(p, r)
	Instance.new("UICorner", p).CornerRadius = UDim.new(0, r or 8)
end
local function mkStroke(p, t, c)
	local s = Instance.new("UIStroke", p)
	s.Thickness = t or 1.5; s.Color = c or C.stroke; return s
end
local function mkLabel(p, text, font, size, color, xAlign, pos, sz)
	local l = Instance.new("TextLabel")
	l.Text = text or ""; l.Font = font or Enum.Font.GothamBold
	l.TextSize = size or 14; l.TextColor3 = color or C.white
	l.TextXAlignment = xAlign or Enum.TextXAlignment.Center
	l.TextYAlignment = Enum.TextYAlignment.Center
	l.BackgroundTransparency = 1
	l.Position = pos or UDim2.new(0,0,0,0)
	l.Size = sz or UDim2.new(1,0,1,0)
	l.Parent = p; return l
end

-- Sort inventory by rarity desc then alphabetical
local function sortedInventory()
	local out = {}
	for i, item in ipairs(localInventory) do
		table.insert(out, {item = item, origIndex = i})
	end
	table.sort(out, function(a, b)
		local ra = RARITY_ORDER[normalRarity(a.item.rarity)] or 5
		local rb = RARITY_ORDER[normalRarity(b.item.rarity)] or 5
		if ra ~= rb then return ra < rb end
		return (a.item.name or "") < (b.item.name or "")
	end)
	return out
end

-- ============================================================
-- HOTBAR SYNC
-- ============================================================

local function syncHotbar()
	local ch = _G.Chompers
	if not (ch and ch.SetSlotItem) then return end
	local NUM = ch.GetSlotCount and ch.GetSlotCount() or 10
	for i = 1, NUM do ch.SetSlotItem(i, nil) end
	for i, item in ipairs(localInventory) do
		if i > NUM then break end
		ch.SetSlotItem(i, {
			emoji      = item.emoji      or "🍽",
			name       = item.name       or "?",
			rarity     = normalRarity(item.rarity),
			paid       = item.paid,
			cookStatus = item.cookStatus,
			ingredients= item.ingredients,
			cost       = item.cost       or 0,
			cl         = item.cl         or 0,
			allergy    = item.allergy    or "None",
			effect     = item.effect     or "",
			buildsInto = item.buildsInto or {},
			weight     = item.wt         or item.weight or 0,
		})
	end
	if ch.SetItemCount then ch.SetItemCount(#localInventory) end
end

