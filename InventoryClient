-- ============================================================
-- PANEL OPEN / CLOSE (defined before buildCard uses them)
-- ============================================================

local function updateHeaderTitle()
	local icon = containerType == "Cart" and "🛒" or "🧺"
	HeaderTitle.Text = icon .. "  " .. containerType
end

local function closePanel()
	panelOpen = false
	SlotPicker.Visible = false
	inventoryGui.Enabled = false
end

CloseBtn.MouseButton1Click:Connect(closePanel)

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.Escape and panelOpen then
		closePanel(); return
	end
	if input.KeyCode == Enum.KeyCode.Q then
		if localInventory[selectedSlot] then
			DropItemRemote:FireServer(selectedSlot)
		end
		return
	end
	local numKeys = {
		[Enum.KeyCode.One]=1,   [Enum.KeyCode.Two]=2,
		[Enum.KeyCode.Three]=3, [Enum.KeyCode.Four]=4,
		[Enum.KeyCode.Five]=5,  [Enum.KeyCode.Six]=6,
		[Enum.KeyCode.Seven]=7, [Enum.KeyCode.Eight]=8,
		[Enum.KeyCode.Nine]=9,  [Enum.KeyCode.Zero]=10,
	}
	local slot = numKeys[input.KeyCode]
	if slot then
		selectedSlot = slot
		if _G.Chompers and _G.Chompers.SetSelectedSlot then
			_G.Chompers.SetSelectedSlot(selectedSlot)
		end
	end
end)

-- ============================================================
-- REBUILD PANEL (no forward declaration needed — defined here)
-- ============================================================

local function rebuildPanel()
	-- Clear old cards
	for _, child in ipairs(Scroll:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end

	updateHeaderTitle()
	WeightHeader.Text = tostring(currentWeight) .. " / " .. tostring(maxWeight) .. " wt"

	if #localInventory == 0 then
		-- Empty state message
		local icon = containerType == "Cart" and "🛒" or "🧺"
		local emptyF = Instance.new("Frame", Scroll)
		emptyF.Size = UDim2.new(1,0,0,120)
		emptyF.BackgroundTransparency = 1
		emptyF.LayoutOrder = 0
		local emptyL = mkLabel(emptyF,
			icon .. " Your " .. containerType:lower() .. " is empty!\nPick up ingredients to get started.",
			Enum.Font.Gotham, 15, C.dim,
			Enum.TextXAlignment.Center,
			UDim2.new(0,0,0.2,0), UDim2.new(1,0,0.6,0))
		emptyL.TextWrapped = true
		return
	end

	for i, item in ipairs(localInventory) do
		local rarity    = normaliseRarity(item.rarity or "Common")
		local strokeCol = RARITY_STROKE[rarity] or C.stroke
		local bgCol     = RARITY_BG[rarity] or C.bgCard

		local card = Instance.new("Frame", Scroll)
		card.Size = UDim2.new(1,0,0,88)
		card.BackgroundColor3 = bgCol
		card.BorderSizePixel = 0
		card.LayoutOrder = i
		card.ZIndex = 12
		Instance.new("UICorner", card).CornerRadius = UDim.new(0,10)
		local stroke = Instance.new("UIStroke", card)
		stroke.Thickness = i == selectedSlot and 2.5 or 1.5
		stroke.Color     = i == selectedSlot and C.red or strokeCol

		-- Slot badge
		local slotKey = i == 10 and 0 or i
		local badge = mkFrame(card,
			UDim2.new(0,26,0,20), UDim2.new(0,7,0,7),
			Color3.fromRGB(40,38,60), 5, true)
		badge.ZIndex = 13
		mkLabel(badge, tostring(slotKey),
			Enum.Font.GothamBlack, 10, C.dim).ZIndex = 14

		-- Emoji
		mkLabel(card, item.emoji or "🍽",
			Enum.Font.GothamBold, 32, C.white,
			Enum.TextXAlignment.Center,
			UDim2.new(0,0,0,0), UDim2.new(0,70,1,0)).ZIndex = 13

		-- Name
		mkLabel(card, item.name or "Unknown",
			Enum.Font.GothamBlack, 14, C.white,
			Enum.TextXAlignment.Left,
			UDim2.new(0,74,0,7), UDim2.new(1,-168,0,18)).ZIndex = 13

		-- Zone · allergy · weight
		local d1 = {}
		if item.zone then table.insert(d1, item.zone) end
		if item.allergy and item.allergy ~= "None" then
			table.insert(d1, item.allergy .. " allergy")
		end
		table.insert(d1, "⚖" .. tostring(item.wt or item.weight or 0))
		mkLabel(card, table.concat(d1, " · "),
			Enum.Font.Gotham, 11, C.dim,
			Enum.TextXAlignment.Left,
			UDim2.new(0,74,0,27), UDim2.new(1,-168,0,14)).ZIndex = 13

		-- Effect / CL
		local d2 = item.effect or item.notes or ""
		if item.cl and item.cl > 0 then
			d2 = "CL " .. item.cl .. (d2 ~= "" and " · " .. d2 or "")
		end
		local d2L = mkLabel(card, d2,
			Enum.Font.Gotham, 11, Color3.fromRGB(155,150,185),
			Enum.TextXAlignment.Left,
			UDim2.new(0,74,0,43), UDim2.new(1,-168,0,14))
		d2L.ZIndex = 13; d2L.TextWrapped = true

		-- Status tag
		local statusText, statusColor
		if item.cookStatus then
			if item.cookStatus == "Cooked" then
				statusText = "COOKED ✓"; statusColor = C.green
			elseif item.cookStatus == "Burned" then
				statusText = "BURNED"; statusColor = C.red
			else
				statusText = "UNCOOKED"; statusColor = C.gold
			end
		elseif item.paid then
			statusText = "PAID"; statusColor = C.green
		else
			statusText = "UNPAID $" .. tostring(item.cost or 0)
			statusColor = C.orange
		end
		local tagBg = mkFrame(card,
			UDim2.new(0,82,0,18), UDim2.new(0,74,0,62),
			Color3.fromRGB(20,18,32), 5, true)
		tagBg.ZIndex = 13
		mkLabel(tagBg, statusText,
			Enum.Font.GothamBlack, 9, statusColor).ZIndex = 14

		-- Move to slot button
		local capturedI = i
		local moveBtn = Instance.new("TextButton")
		moveBtn.Text = "Move ▾"
		moveBtn.Font = Enum.Font.GothamBold; moveBtn.TextSize = 10
		moveBtn.TextColor3 = C.dim
		moveBtn.BackgroundColor3 = Color3.fromRGB(35,33,52)
		moveBtn.BorderSizePixel = 0; moveBtn.AutoButtonColor = false
		moveBtn.Size = UDim2.new(0,72,0,24)
		moveBtn.AnchorPoint = Vector2.new(1,0.5)
		moveBtn.Position = UDim2.new(1,-8,0.5,0)
		moveBtn.ZIndex = 13; moveBtn.Parent = card
		Instance.new("UICorner", moveBtn).CornerRadius = UDim.new(0,6)
		moveBtn.MouseButton1Click:Connect(function()
			SlotPicker.Visible = true
			slotPickerCB = function(targetSlot)
				local a = localInventory[capturedI]
				local b = localInventory[targetSlot]
				localInventory[capturedI]   = b
				localInventory[targetSlot]  = a
				syncHotbar()
				rebuildPanel()
			end
		end)

		-- Drag grip hint
		mkLabel(card, "⠿",
			Enum.Font.GothamBold, 18, Color3.fromRGB(55,52,78),
			Enum.TextXAlignment.Center,
			UDim2.new(1,-18,0,0), UDim2.new(0,14,1,0)).ZIndex = 13
	end
end

local function openPanel()
	panelOpen = true
	rebuildPanel()
	inventoryGui.Enabled = true
end

-- ============================================================
-- TOGGLE EVENT (from ChompersBottomBar InventoryToggle)
-- ============================================================

task.spawn(function()
	local evt = playerGui:WaitForChild("InventoryToggle", 10)
	if not evt then
		warn("[InventoryClient] InventoryToggle event not found")
		return
	end
	evt.Event:Connect(function(isOpen)
		if isOpen then openPanel() else closePanel() end
	end)
	print("[InventoryClient] InventoryToggle connected")
end)

-- ============================================================
-- REMOTES
-- ============================================================

UpdateInventoryRemote.OnClientEvent:Connect(function(inventory)
	localInventory = inventory or {}
	syncHotbar()
	if panelOpen then rebuildPanel() end
end)

UpdateWeightRemote.OnClientEvent:Connect(function(current, maxW)
	currentWeight = current or 0
	maxWeight     = maxW or 35
	if _G.Chompers and _G.Chompers.SetWeight then
		_G.Chompers.SetWeight(currentWeight, maxWeight)
	end
	if panelOpen then
		WeightHeader.Text = tostring(currentWeight) .. " / " .. tostring(maxWeight) .. " wt"
	end
end)

UpdateMoneyRemote.OnClientEvent:Connect(function(amount)
	if _G.Chompers and _G.Chompers.SetMoney then
		_G.Chompers.SetMoney(amount)
	end
end)

