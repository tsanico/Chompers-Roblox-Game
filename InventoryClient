local function buildLeftList()
	for _, c in ipairs(LeftScroll:GetChildren()) do
		if c:IsA("TextButton") or c:IsA("Frame") or c:IsA("TextLabel") then
			c:Destroy()
		end
	end

	if #localInventory == 0 then
		local icon = containerType == "Cart" and "🛒" or "🧺"
		local emptyL = Instance.new("TextLabel", LeftScroll)
		emptyL.Size = UDim2.new(1, 0, 0, 80)
		emptyL.BackgroundTransparency = 1
		emptyL.Text = icon .. "  Empty!"
		emptyL.Font = Enum.Font.Gotham; emptyL.TextSize = 13
		emptyL.TextColor3 = C.dim
		emptyL.TextXAlignment = Enum.TextXAlignment.Center
		emptyL.TextYAlignment = Enum.TextYAlignment.Center
		emptyL.LayoutOrder = 0; emptyL.ZIndex = 13
		showEmptyRight(icon .. "  Your " .. containerType:lower() .. " is empty!\n\nPick up ingredients to get started.")
		selectedListBtn = nil; selectedItem = nil
		return
	end

	selectedListBtn = nil
	if not selectedItem then
		showEmptyRight("← Select an item to see details.")
	end

	-- Sort: rarity desc, then alphabetical
	local sorted = sortedInventory()

	for listPos, entry in ipairs(sorted) do
		local item = entry.item
		local origI = entry.origIndex
		local rarity = normaliseRarity(item.rarity or "Common")
		local strokeCol = RARITY_STROKE[rarity] or C.stroke

		local row = Instance.new("TextButton", LeftScroll)
		row.Name = "Row_" .. origI
		row.Size = UDim2.new(1, 0, 0, 48)
		row.BackgroundColor3 = origI == selectedSlot
			and Color3.fromRGB(35, 33, 54) or C.bgLight
		row.BorderSizePixel = 0; row.AutoButtonColor = false
		row.LayoutOrder = listPos; row.ZIndex = 13
		mkCorner(row, 8)
		local rowStroke = mkStroke(row, origI == selectedSlot and 2 or 1.5,
			origI == selectedSlot and C.red or strokeCol)

		-- Slot badge
		local slotKey = origI == 10 and "0" or tostring(origI)
		local badge = Instance.new("Frame", row)
		badge.Size = UDim2.new(0, 20, 0, 16)
		badge.Position = UDim2.new(0, 4, 0.5, -8)
		badge.BackgroundColor3 = Color3.fromRGB(40, 38, 60)
		badge.BorderSizePixel = 0; badge.ZIndex = 14
		mkCorner(badge, 4)
		mkLabel(badge, slotKey, Enum.Font.GothamBlack, 9, C.dim).ZIndex = 15

		-- Emoji
		mkLabel(row, item.emoji or "🍽",
			Enum.Font.GothamBold, 22, C.white,
			Enum.TextXAlignment.Center,
			UDim2.new(0, 26, 0, 0), UDim2.new(0, 34, 1, 0)).ZIndex = 14

		-- Name
		local nameL = mkLabel(row, item.name or "?",
			Enum.Font.GothamBold, 13, C.white,
			Enum.TextXAlignment.Left,
			UDim2.new(0, 64, 0, 4), UDim2.new(1, -72, 0, 20))
		nameL.ZIndex = 14; nameL.TextTruncate = Enum.TextTruncate.AtEnd

		-- Weight
		mkLabel(row, "⚖" .. tostring(item.wt or item.weight or 0),
			Enum.Font.Gotham, 10, C.dim,
			Enum.TextXAlignment.Left,
			UDim2.new(0, 64, 0, 26), UDim2.new(1, -72, 0, 14)).ZIndex = 14

		-- Click: show detail
		local capturedOrigI = origI
		local capturedItem  = item
		row.MouseButton1Click:Connect(function()
			if selectedListBtn then
				selectedListBtn.BackgroundColor3 = C.bgLight
				local s = selectedListBtn:FindFirstChildWhichIsA("UIStroke")
				if s then
					local old = tonumber(selectedListBtn.Name:match("%d+"))
					local oldR = old and localInventory[old]
						and normaliseRarity(localInventory[old].rarity) or "Common"
					s.Thickness = 1.5
					s.Color = RARITY_STROKE[oldR] or C.stroke
				end
			end
			row.BackgroundColor3 = Color3.fromRGB(35, 33, 54)
			rowStroke.Thickness = 2; rowStroke.Color = C.red
			selectedListBtn = row
			selectedItem    = capturedItem
			showDetail(capturedItem, capturedOrigI)
		end)

		-- Re-highlight if previously selected
		if selectedItem and selectedItem.name == item.name
		and selectedItem.emoji == item.emoji then
			selectedListBtn = row
			row.BackgroundColor3 = Color3.fromRGB(35, 33, 54)
			rowStroke.Thickness = 2; rowStroke.Color = C.red
			showDetail(item, origI)
		end
	end
end

