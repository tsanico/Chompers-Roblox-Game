local function clearRight()
	for _, c in ipairs(RightScroll:GetChildren()) do
		if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end
	end
end

local function showPlaceholder(msg)
	clearRight()
	local l = Instance.new("TextLabel", RightScroll)
	l.Size = UDim2.new(1,0,0,120); l.LayoutOrder = 0
	l.BackgroundTransparency = 1
	l.Text = msg or "Select an item to see details."
	l.Font = Enum.Font.Gotham; l.TextSize = 15; l.TextColor3 = C.dim
	l.TextXAlignment = Enum.TextXAlignment.Center
	l.TextYAlignment = Enum.TextYAlignment.Center
	l.TextWrapped = true; l.ZIndex = 12
end

local function showDetail(item, origIndex)
	clearRight()
	if not item then showPlaceholder("Select an item to see details."); return end

	local rarity    = normalRarity(item.rarity or "Common")
	local strokeCol = RARITY_STROKE[rarity] or C.stroke
	local bgCol     = RARITY_BG[rarity]    or C.bgCard

	-- Top card: emoji + name + status
	local topCard = Instance.new("Frame", RightScroll)
	topCard.Size             = UDim2.new(1,0,0,120)
	topCard.BackgroundColor3 = bgCol
	topCard.BorderSizePixel  = 0; topCard.LayoutOrder = 1; topCard.ZIndex = 12
	corner(topCard, 12); mkStroke(topCard, 2, strokeCol)

	mkLabel(topCard, item.emoji or "🍽",
		Enum.Font.GothamBold, 72, C.white, Enum.TextXAlignment.Center,
		UDim2.new(0,0,0,0), UDim2.new(0,110,1,0)).ZIndex = 13

	mkLabel(topCard, item.name or "Unknown",
		Enum.Font.GothamBlack, 26, C.white, Enum.TextXAlignment.Left,
		UDim2.new(0,116,0,10), UDim2.new(1,-124,0,30)).ZIndex = 13

	mkLabel(topCard, rarity,
		Enum.Font.GothamBold, 15, strokeCol, Enum.TextXAlignment.Left,
		UDim2.new(0,116,0,42), UDim2.new(1,-124,0,18)).ZIndex = 13

	-- Zone + weight meta
	local meta = {}
	if item.zone then table.insert(meta, "📍 " .. item.zone) end
	table.insert(meta, "⚖ " .. tostring(item.wt or item.weight or 0) .. " wt")
	mkLabel(topCard, table.concat(meta, "   "),
		Enum.Font.Gotham, 13, C.dim, Enum.TextXAlignment.Left,
		UDim2.new(0,116,0,62), UDim2.new(1,-124,0,16)).ZIndex = 13

	-- Status (paid/unpaid or cook state)
	local stText, stColor
	if item.cookStatus then
		if item.cookStatus == "Cooked" then stText="COOKED ✓"; stColor=C.green
		elseif item.cookStatus == "Burned" then stText="BURNED"; stColor=C.red
		else stText="UNCOOKED"; stColor=C.gold end
	elseif item.paid then stText="✓ PAID"; stColor=C.green
	else stText="UNPAID  $"..tostring(item.cost or 0); stColor=C.orange end
	mkLabel(topCard, stText,
		Enum.Font.GothamBlack, 14, stColor, Enum.TextXAlignment.Left,
		UDim2.new(0,116,0,82), UDim2.new(1,-124,0,22)).ZIndex = 13

	-- Section helper
	local nextOrder = 2
	local function section(title, value, color)
		if not value or value == "" then return end
		local row = Instance.new("Frame", RightScroll)
		row.Size = UDim2.new(1,0,0,0); row.AutomaticSize = Enum.AutomaticSize.Y
		row.BackgroundColor3 = C.bgLight; row.BorderSizePixel=0
		row.LayoutOrder = nextOrder; nextOrder = nextOrder + 1; row.ZIndex = 12
		corner(row, 8)
		local pad = Instance.new("UIPadding", row)
		pad.PaddingLeft=UDim.new(0,12); pad.PaddingRight=UDim.new(0,12)
		pad.PaddingTop=UDim.new(0,8);  pad.PaddingBottom=UDim.new(0,8)
		local ll = Instance.new("UIListLayout", row)
		ll.SortOrder=Enum.SortOrder.LayoutOrder; ll.Padding=UDim.new(0,2)

		local tl = Instance.new("TextLabel", row)
		tl.Size=UDim2.new(1,0,0,16); tl.BackgroundTransparency=1
		tl.Text=title; tl.Font=Enum.Font.GothamBlack; tl.TextSize=11
		tl.TextColor3=color or C.dim; tl.TextXAlignment=Enum.TextXAlignment.Left
		tl.ZIndex=13; tl.LayoutOrder=1

		local vl = Instance.new("TextLabel", row)
		vl.Size=UDim2.new(1,0,0,0); vl.AutomaticSize=Enum.AutomaticSize.Y
		vl.BackgroundTransparency=1; vl.Text=tostring(value)
		vl.Font=Enum.Font.Gotham; vl.TextSize=17; vl.TextColor3=C.white
		vl.TextXAlignment=Enum.TextXAlignment.Left
		vl.TextWrapped=true; vl.LineHeight=1.3; vl.ZIndex=13; vl.LayoutOrder=2
	end

	if item.allergy and item.allergy ~= "None" then
		section("⚠ ALLERGY", item.allergy, C.red)
	end
	if item.effect and item.effect ~= "" then
		section("✨ EFFECT", item.effect, C.gold)
	end
	if item.cl and item.cl > 0 then
		section("🧼 CL DAMAGE", "+" .. item.cl .. " per hit", C.weight)
	end
	if item.ingredients then
		section("📋 INGREDIENTS", table.concat(item.ingredients, " · "), C.green)
	end
	if item.station and item.station ~= "" then
		section("🍳 STATION", item.station, C.dim)
	end
	if item.notes and item.notes ~= "" then
		section("📝 NOTE", item.notes, C.dim)
	end

	-- ── Slot assignment row ───────────────────────────────────
	if origIndex then
		local slotRow = Instance.new("Frame", RightScroll)
		slotRow.Size             = UDim2.new(1,0,0,60)
		slotRow.BackgroundColor3 = C.bgLight
		slotRow.BorderSizePixel  = 0
		slotRow.LayoutOrder      = nextOrder; nextOrder = nextOrder + 1
		slotRow.ZIndex           = 12
		corner(slotRow, 8)

		mkLabel(slotRow, "ASSIGN TO HOTBAR SLOT",
			Enum.Font.GothamBlack, 10, C.dim, Enum.TextXAlignment.Left,
			UDim2.new(0,12,0,6), UDim2.new(1,-24,0,14)).ZIndex = 13

		local btnRow = Instance.new("Frame", slotRow)
		btnRow.Size = UDim2.new(1,-16,0,30)
		btnRow.Position = UDim2.new(0,8,0,22)
		btnRow.BackgroundTransparency = 1; btnRow.ZIndex = 13
		local bLL = Instance.new("UIListLayout", btnRow)
		bLL.FillDirection = Enum.FillDirection.Horizontal
		bLL.Padding = UDim.new(0,3)

		for si = 1, 10 do
			local key      = si == 10 and "0" or tostring(si)
			local isActive = si == origIndex
			local b = Instance.new("TextButton", btnRow)
			b.Text = key; b.Font = Enum.Font.GothamBlack; b.TextSize = 12
			b.TextColor3 = isActive and C.white or C.dim
			b.BackgroundColor3 = isActive
				and Color3.fromRGB(80,30,30)
				or Color3.fromRGB(35,33,52)
			b.BorderSizePixel = 0; b.AutoButtonColor = false
			b.Size = UDim2.new(0,0,1,0); b.AutomaticSize = Enum.AutomaticSize.X
			b.ZIndex = 14; b.Parent = btnRow; corner(b, 5)
			local pad = Instance.new("UIPadding", b)
			pad.PaddingLeft=UDim.new(0,8); pad.PaddingRight=UDim.new(0,8)

			local capSi = si; local capOrig = origIndex
			b.MouseButton1Click:Connect(function()
				-- Swap slots
				local a = localInventory[capOrig]
				local bItem = localInventory[capSi]
				localInventory[capOrig] = bItem
				localInventory[capSi]   = a
				if selectedSlot == capOrig then selectedSlot = capSi
				elseif selectedSlot == capSi then selectedSlot = capOrig end
				if _G.Chompers.SetSelectedSlot then
					_G.Chompers.SetSelectedSlot(selectedSlot)
				end
				syncHotbar()
				selectedItem = localInventory[capSi]  -- track moved item
				rebuildPanel()
			end)
		end
	end
end

