local function closePanel()
	panelOpen = false
	SlotPicker.Visible = false
	inventoryGui.Enabled = false
end

local function rebuildPanel()
	-- Clear old cards
	for _, child in ipairs(Scroll:GetChildren()) do
		if child:IsA("Frame") or child:IsA("TextLabel") then child:Destroy() end
	end

	-- Update header
	local icon = containerType == "Cart" and "🛒" or "🧺"
	HeaderTitle.Text = icon .. "  " .. containerType
	WeightHeader.Text = tostring(currentWeight) .. " / " .. tostring(maxWeight) .. " wt"

	-- Empty state
	if #localInventory == 0 then
		local emptyL = Instance.new("TextLabel", Scroll)
		emptyL.Size = UDim2.new(1, 0, 0, 120)
		emptyL.BackgroundTransparency = 1
		emptyL.Text = icon .. "  Your " .. containerType:lower() .. " is empty!\n\nPick up ingredients to get started."
		emptyL.Font = Enum.Font.Gotham; emptyL.TextSize = 14
		emptyL.TextColor3 = C.dim
		emptyL.TextXAlignment = Enum.TextXAlignment.Center
		emptyL.TextYAlignment = Enum.TextYAlignment.Center
		emptyL.TextWrapped = true; emptyL.LayoutOrder = 0; emptyL.ZIndex = 12
		return
	end

	-- Item cards
	for i, item in ipairs(localInventory) do
		local rarity    = normaliseRarity(item.rarity or "Common")
		local strokeCol = RARITY_STROKE[rarity] or C.stroke
		local bgCol     = RARITY_BG[rarity] or C.bgCard

		local card = Instance.new("Frame", Scroll)
		card.Size = UDim2.new(1, 0, 0, 86)
		card.BackgroundColor3 = bgCol
		card.BorderSizePixel = 0
		card.LayoutOrder = i; card.ZIndex = 12
		mkCorner(card, 10)
		local cardStroke = Instance.new("UIStroke", card)
		cardStroke.Thickness = i == selectedSlot and 2.5 or 1.5
		cardStroke.Color     = i == selectedSlot and C.red or strokeCol

		-- Slot badge
		local slotKey = i == 10 and "0" or tostring(i)
		local badge = Instance.new("Frame", card)
		badge.Size = UDim2.new(0,26,0,20); badge.Position = UDim2.new(0,7,0,7)
		badge.BackgroundColor3 = Color3.fromRGB(40,38,60)
		badge.BorderSizePixel = 0; badge.ZIndex = 13
		mkCorner(badge, 5)
		mkLabel(badge, slotKey, Enum.Font.GothamBlack, 10, C.dim).ZIndex = 14

		-- Emoji
		mkLabel(card, item.emoji or "🍽",
			Enum.Font.GothamBold, 30, C.white, Enum.TextXAlignment.Center,
			UDim2.new(0,0,0,0), UDim2.new(0,68,1,0)).ZIndex = 13

		-- Name
		mkLabel(card, item.name or "Unknown",
			Enum.Font.GothamBlack, 13, C.white, Enum.TextXAlignment.Left,
			UDim2.new(0,72,0,6), UDim2.new(1,-160,0,17)).ZIndex = 13

		-- Zone · allergy · weight
		local d1 = {}
		if item.zone then table.insert(d1, item.zone) end
		if item.allergy and item.allergy ~= "None" then table.insert(d1, item.allergy) end
		table.insert(d1, "⚖" .. tostring(item.wt or item.weight or 0))
		mkLabel(card, table.concat(d1, " · "),
			Enum.Font.Gotham, 10, C.dim, Enum.TextXAlignment.Left,
			UDim2.new(0,72,0,25), UDim2.new(1,-160,0,13)).ZIndex = 13

		-- Effect
		local d2 = ""
		if item.cl and item.cl > 0 then d2 = "CL " .. item.cl end
		if item.effect and item.effect ~= "" then
			d2 = d2 ~= "" and d2 .. " · " .. item.effect or item.effect
		end
		local d2L = mkLabel(card, d2,
			Enum.Font.Gotham, 10, Color3.fromRGB(155,150,185), Enum.TextXAlignment.Left,
			UDim2.new(0,72,0,40), UDim2.new(1,-160,0,13))
		d2L.ZIndex = 13; d2L.TextWrapped = true

		-- Status tag
		local stText, stColor
		if item.cookStatus then
			if item.cookStatus == "Cooked" then stText="COOKED ✓"; stColor=C.green
			elseif item.cookStatus == "Burned" then stText="BURNED"; stColor=C.red
			else stText="UNCOOKED"; stColor=C.gold end
		elseif item.paid then stText="PAID"; stColor=C.green
		else stText="UNPAID $"..tostring(item.cost or 0); stColor=C.orange end

		local tag = Instance.new("Frame", card)
		tag.Size = UDim2.new(0,84,0,17); tag.Position = UDim2.new(0,72,0,60)
		tag.BackgroundColor3 = Color3.fromRGB(20,18,32); tag.BorderSizePixel=0; tag.ZIndex=13
		mkCorner(tag, 5)
		mkLabel(tag, stText, Enum.Font.GothamBlack, 9, stColor).ZIndex = 14

		-- Move to slot button
		local capturedI = i
		local moveBtn = Instance.new("TextButton", card)
		moveBtn.Text = "Move ▾"; moveBtn.Font = Enum.Font.GothamBold; moveBtn.TextSize = 10
		moveBtn.TextColor3 = C.dim
		moveBtn.BackgroundColor3 = Color3.fromRGB(35,33,52)
		moveBtn.BorderSizePixel = 0; moveBtn.AutoButtonColor = false
		moveBtn.Size = UDim2.new(0,70,0,22)
		moveBtn.AnchorPoint = Vector2.new(1,0.5); moveBtn.Position = UDim2.new(1,-8,0.5,0)
		moveBtn.ZIndex = 13
		mkCorner(moveBtn, 6)
		moveBtn.MouseButton1Click:Connect(function()
			SlotPicker.Visible = true
			slotPickerCB = function(targetSlot)
				local a = localInventory[capturedI]
				local b = localInventory[targetSlot]
				localInventory[capturedI]  = b
				localInventory[targetSlot] = a
				syncHotbar()
				rebuildPanel()
			end
		end)
	end
end

local function openPanel()
	panelOpen = true
	rebuildPanel()
	inventoryGui.Enabled = true
end

CloseBtn.MouseButton1Click:Connect(closePanel)

