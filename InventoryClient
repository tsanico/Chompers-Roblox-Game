-- REMOTES
-- ============================================================

if UpdateInventoryRemote then
	UpdateInventoryRemote.OnClientEvent:Connect(function(inventory)
		localInventory = inventory or {}
		syncHotbar()
		if panelOpen then rebuildPanel() end
	end)
end

if UpdateWeightRemote then
	UpdateWeightRemote.OnClientEvent:Connect(function(current, maxW)
		currentWeight = current or 0
		maxWeight = maxW or 35
		if _G.Chompers and _G.Chompers.SetWeight then
			_G.Chompers.SetWeight(currentWeight, maxWeight)
		end
		if panelOpen then
			WeightHeader.Text = tostring(currentWeight) .. " / " .. tostring(maxWeight) .. " wt"
		end
	end)
end

if UpdateMoneyRemote then
	UpdateMoneyRemote.OnClientEvent:Connect(function(amount)
		if _G.Chompers and _G.Chompers.SetMoney then
			_G.Chompers.SetMoney(amount)
		end
	end)
end

