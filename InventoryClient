checkoutGui.IgnoreGuiInset = true; checkoutGui.Enabled = false
checkoutGui.Parent = playerGui

local cFrame = Instance.new("Frame", checkoutGui)
cFrame.Size = UDim2.new(0, 400, 0, 80)
