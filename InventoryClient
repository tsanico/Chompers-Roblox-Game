-- REBUILD PANEL
-- ============================================================

local function rebuildPanel()
	local icon = containerType == "Cart" and "🛒" or "🧺"
	HeaderTitle.Text = icon .. "  " .. containerType .. " Inventory"
	WeightHeader.Text = tostring(currentWeight) .. " / " .. tostring(maxWeight) .. " wt"
	buildLeftList()
end

-- ============================================================
-- OPEN / CLOSE
-- ============================================================

local function closePanel()
	panelOpen = false
	inventoryGui.Enabled = false
end

local function openPanel()
	-- Mutual minimize: close Store Guide if open
	if _G.Chompers and _G.Chompers.CloseStoreGuide then
		_G.Chompers.CloseStoreGuide()
	end
	panelOpen = true
	rebuildPanel()
	inventoryGui.Enabled = true
end

CloseBtn.MouseButton1Click:Connect(closePanel)
Dimmer.MouseButton1Click:Connect(closePanel)   -- click backdrop to close

-- Listen for InventoryToggle from ChompersBottomBar
task.spawn(function()
	local evt = playerGui:WaitForChild("InventoryToggle", 15)
	if not evt then
		warn("[InventoryClient] InventoryToggle not found")
		return
	end
	print("[InventoryClient] InventoryToggle connected")
	evt.Event:Connect(function(isOpen)
		if isOpen then openPanel() else closePanel() end
	end)
end)

-- ============================================================
-- INPUT
-- ============================================================

local NUM_KEYS = {
	[Enum.KeyCode.One]=1,   [Enum.KeyCode.Two]=2,
	[Enum.KeyCode.Three]=3, [Enum.KeyCode.Four]=4,
	[Enum.KeyCode.Five]=5,  [Enum.KeyCode.Six]=6,
	[Enum.KeyCode.Seven]=7, [Enum.KeyCode.Eight]=8,
	[Enum.KeyCode.Nine]=9,  [Enum.KeyCode.Zero]=10,
}

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end

	if input.KeyCode == Enum.KeyCode.Escape and panelOpen then
		closePanel(); return
	end

	if input.KeyCode == Enum.KeyCode.Q then
		if DropItemRemote and localInventory[selectedSlot] then
			DropItemRemote:FireServer(selectedSlot)
		end
		return
	end

	local slot = NUM_KEYS[input.KeyCode]
	if slot then
		selectedSlot = slot
		if _G.Chompers and _G.Chompers.SetSelectedSlot then
			_G.Chompers.SetSelectedSlot(selectedSlot)
		end
		if panelOpen then buildLeftList() end
	end
end)

