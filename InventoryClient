local selectedListBtn = nil

local function buildLeftList()
	for _, c in ipairs(LeftScroll:GetChildren()) do
		if c:IsA("TextButton") or c:IsA("Frame") or c:IsA("TextLabel") then
			c:Destroy()
		end
	end

	if #localInventory == 0 then
		local icon = containerType == "Cart" and "🛒" or "🧺"
		local el = Instance.new("TextLabel", LeftScroll)
		el.Size=UDim2.new(1,0,0,80); el.LayoutOrder=0
		el.BackgroundTransparency=1
		el.Text=icon.." Your "..containerType:lower().." is empty!"
		el.Font=Enum.Font.Gotham; el.TextSize=13; el.TextColor3=C.dim
		el.TextXAlignment=Enum.TextXAlignment.Center
		el.TextYAlignment=Enum.TextYAlignment.Center
		el.TextWrapped=true; el.ZIndex=13
		showPlaceholder(icon.."  Empty!\n\nPick up ingredients to get started.")
		selectedListBtn=nil; selectedItem=nil
		return
	end

	selectedListBtn = nil
	if not selectedItem then showPlaceholder("← Select an item to see details.") end

	local sorted = sortedInventory()
	for listPos, entry in ipairs(sorted) do
		local item  = entry.item
		local origI = entry.origIndex
		local rarity    = normalRarity(item.rarity or "Common")
		local strokeCol = RARITY_STROKE[rarity] or C.stroke

		local row = Instance.new("TextButton", LeftScroll)
		row.Name             = "Row_" .. origI
		row.Size             = UDim2.new(1,0,0,48)
		row.BackgroundColor3 = origI == selectedSlot
			and Color3.fromRGB(35,33,54) or C.bgLight
		row.BorderSizePixel  = 0; row.AutoButtonColor = false
		row.LayoutOrder      = listPos; row.ZIndex = 13
		corner(row, 8)
		local rowStroke = mkStroke(row,
			origI == selectedSlot and 2 or 1.5,
			origI == selectedSlot and C.red or strokeCol)

		-- Slot badge
		local slotKey = origI == 10 and "0" or tostring(origI)
		local badge = Instance.new("Frame", row)
		badge.Size=UDim2.new(0,20,0,16); badge.Position=UDim2.new(0,4,0.5,-8)
		badge.BackgroundColor3=Color3.fromRGB(40,38,60); badge.BorderSizePixel=0
		badge.ZIndex=14; corner(badge,4)
		mkLabel(badge, slotKey, Enum.Font.GothamBlack, 9, C.dim).ZIndex=15

		mkLabel(row, item.emoji or "🍽",
			Enum.Font.GothamBold, 22, C.white, Enum.TextXAlignment.Center,
			UDim2.new(0,26,0,0), UDim2.new(0,34,1,0)).ZIndex=14

		local nameL = mkLabel(row, item.name or "?",
			Enum.Font.GothamBold, 13, C.white, Enum.TextXAlignment.Left,
			UDim2.new(0,64,0,4), UDim2.new(1,-72,0,20))
		nameL.ZIndex=14; nameL.TextTruncate=Enum.TextTruncate.AtEnd

		mkLabel(row, "⚖"..tostring(item.wt or item.weight or 0),
			Enum.Font.Gotham, 10, C.dim, Enum.TextXAlignment.Left,
			UDim2.new(0,64,0,26), UDim2.new(1,-72,0,14)).ZIndex=14

		local capOrigI = origI; local capItem = item
		row.MouseButton1Click:Connect(function()
			if selectedListBtn then
				selectedListBtn.BackgroundColor3 = C.bgLight
				local s = selectedListBtn:FindFirstChildWhichIsA("UIStroke")
				if s then
					local oi = tonumber(selectedListBtn.Name:match("%d+"))
					local or_ = oi and localInventory[oi]
						and normalRarity(localInventory[oi].rarity) or "Common"
					s.Thickness=1.5; s.Color=RARITY_STROKE[or_] or C.stroke
				end
			end
			row.BackgroundColor3 = Color3.fromRGB(35,33,54)
			rowStroke.Thickness=2; rowStroke.Color=C.red
			selectedListBtn=row; selectedItem=capItem
			showDetail(capItem, capOrigI)
		end)

		-- Re-highlight previously selected
		if selectedItem and selectedItem.name==item.name
		and selectedItem.emoji==item.emoji then
			selectedListBtn=row
			row.BackgroundColor3=Color3.fromRGB(35,33,54)
			rowStroke.Thickness=2; rowStroke.Color=C.red
			showDetail(item, origI)
		end
	end
end

