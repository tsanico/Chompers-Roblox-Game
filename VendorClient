-- ============================================================
-- VendorClient — LocalScript · StarterPlayerScripts
--
-- Renders the vendor shop UI when the server fires OpenVendor.
-- Matches StoreGuide visual language: dark panels, GothamBlack
-- titles, gold accents, centred layout.
--
-- Tabs: All · Titles · Cosmetics
-- Each item row: name + desc + cost + Buy / Equip / Owned button
-- ============================================================

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")

local player    = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local Remotes   = ReplicatedStorage:WaitForChild("ChompersRemotes", 10)
local DataR     = ReplicatedStorage:WaitForChild("ChompersRemotes", 10)
    -- ChompersData is not available client-side as a module, but the
    -- server sends vendor data via the OpenVendor remote payload.

local function R(n) return Remotes:WaitForChild(n, 10) end
local OpenVendorR     = R("OpenVendor")
local PurchaseItemR   = R("PurchaseItem")
local PurchaseResultR = R("PurchaseResult")
local EquipItemR      = R("EquipItem")
local UpdateMedalsR   = R("UpdatePlayerMedals")
local UpdateOwnedR    = R("UpdatePlayerOwned")

-- ── Local state ───────────────────────────────────────────────
local myMedals   = 0
local ownedItems = {}   -- set-style: ownedItems[id] = true
local equipped   = {}   -- equipped[category] = itemId
local activeTab  = "All"
local currentVendorData = nil   -- cached vendor table sent from server

-- ── Palette ───────────────────────────────────────────────────
local C = {
    bg      = Color3.fromRGB(14, 12, 26),
    panel   = Color3.fromRGB(20, 18, 34),
    dark    = Color3.fromRGB(10,  8, 20),
    stroke  = Color3.fromRGB(48, 44, 70),
    white   = Color3.fromRGB(245,242,255),
    dim     = Color3.fromRGB(105,100,138),
    gold    = Color3.fromRGB(239,159, 39),
    green   = Color3.fromRGB( 70,195, 85),
    red     = Color3.fromRGB(218, 65, 65),
    blue    = Color3.fromRGB( 65,135,235),
}

local TIER_COLOR = {
    cheap   = Color3.fromRGB( 80, 78,100),
    mid     = Color3.fromRGB( 50,140, 60),
    premium = Color3.fromRGB( 50,100,200),
    prestige= Color3.fromRGB(150, 80,220),
    ultra   = Color3.fromRGB(200,140, 30),
}

-- ── Helpers ───────────────────────────────────────────────────
local function corner(p,r) Instance.new("UICorner",p).CornerRadius=UDim.new(0,r or 12) end
local function mkStroke(p,t,c)
    local s=Instance.new("UIStroke",p); s.Thickness=t or 1.5; s.Color=c or C.stroke; return s
end
local function lbl(p,text,font,size,col,xA,pos,sz)
    local l=Instance.new("TextLabel",p); l.BackgroundTransparency=1
    l.Text=text or ""; l.Font=font or Enum.Font.GothamBold
    l.TextSize=size or 14; l.TextColor3=col or C.white
    l.TextXAlignment=xA or Enum.TextXAlignment.Center
    l.TextYAlignment=Enum.TextYAlignment.Center
    l.TextWrapped=true
    l.Position=pos or UDim2.new(0,0,0,0)
    l.Size=sz or UDim2.new(1,0,1,0)
    return l
end

-- ── ScreenGui ─────────────────────────────────────────────────
local Gui = Instance.new("ScreenGui")
Gui.Name="VendorUI"; Gui.ResetOnSpawn=false; Gui.IgnoreGuiInset=true
Gui.DisplayOrder=18; Gui.Enabled=false; Gui.Parent=playerGui

-- Dim backdrop
local Dim = Instance.new("TextButton", Gui)
Dim.Size=UDim2.new(1,0,1,0); Dim.BackgroundColor3=Color3.fromRGB(4,2,14)
Dim.BackgroundTransparency=0.45; Dim.BorderSizePixel=0; Dim.ZIndex=10; Dim.Text=""

-- ── Main panel ────────────────────────────────────────────────
local Panel = Instance.new("Frame", Gui)
Panel.Size=UDim2.new(0,580,0,520); Panel.AnchorPoint=Vector2.new(0.5,0.5)
Panel.Position=UDim2.new(0.5,0,0.5,0)
Panel.BackgroundColor3=C.bg; Panel.BorderSizePixel=0; Panel.ZIndex=11
corner(Panel,18)
local PanelStroke = mkStroke(Panel,2.5,C.gold)

-- ── Header ────────────────────────────────────────────────────
local Header = Instance.new("Frame",Panel)
Header.Size=UDim2.new(1,0,0,72); Header.BackgroundColor3=C.dark
Header.BorderSizePixel=0; Header.ZIndex=12; corner(Header,18)
-- Square off bottom
local HdrBot=Instance.new("Frame",Header)
HdrBot.Size=UDim2.new(1,0,0.5,0); HdrBot.Position=UDim2.new(0,0,0.5,0)
HdrBot.BackgroundColor3=C.dark; HdrBot.BorderSizePixel=0; HdrBot.ZIndex=12

local VendorEmoji = lbl(Header,"🍳",Enum.Font.GothamBlack,36,C.white,
    Enum.TextXAlignment.Center,UDim2.new(0,0,0,0),UDim2.new(0,62,1,0))
VendorEmoji.ZIndex=13

local VendorName  = lbl(Header,"Vendor",Enum.Font.GothamBlack,24,C.gold,
    Enum.TextXAlignment.Left,UDim2.new(0,66,0,8),UDim2.new(0.6,0,0,28))
VendorName.ZIndex=13

local VendorTagline = lbl(Header,"",Enum.Font.GothamBold,14,C.dim,
    Enum.TextXAlignment.Left,UDim2.new(0,66,0,36),UDim2.new(0.6,0,0,20))
VendorTagline.ZIndex=13

-- Medal count top-right
local MedalBadge=Instance.new("Frame",Header)
MedalBadge.Size=UDim2.new(0,130,0,36); MedalBadge.AnchorPoint=Vector2.new(1,0.5)
MedalBadge.Position=UDim2.new(1,-12,0.5,0)
MedalBadge.BackgroundColor3=Color3.fromRGB(22,18,36); MedalBadge.BorderSizePixel=0
MedalBadge.ZIndex=13; corner(MedalBadge,10); mkStroke(MedalBadge,1.5,C.gold)
local MedalLbl=lbl(MedalBadge,"🏅 0",Enum.Font.GothamBlack,18,C.gold)
MedalLbl.ZIndex=14

-- Close button
local CloseBtn=Instance.new("TextButton",Panel)
CloseBtn.Size=UDim2.new(0,36,0,36); CloseBtn.AnchorPoint=Vector2.new(1,0)
CloseBtn.Position=UDim2.new(1,-8,0,8)
CloseBtn.BackgroundColor3=Color3.fromRGB(36,20,20); CloseBtn.BorderSizePixel=0
CloseBtn.Font=Enum.Font.GothamBlack; CloseBtn.TextSize=20
CloseBtn.TextColor3=C.red; CloseBtn.Text="✕"; CloseBtn.ZIndex=20; corner(CloseBtn,8)

-- ── Tab bar ───────────────────────────────────────────────────
local TabBar=Instance.new("Frame",Panel)
TabBar.Size=UDim2.new(1,-24,0,36); TabBar.Position=UDim2.new(0,12,0,78)
TabBar.BackgroundTransparency=1; TabBar.ZIndex=12

local TabLayout=Instance.new("UIListLayout",TabBar)
TabLayout.FillDirection=Enum.FillDirection.Horizontal
TabLayout.HorizontalAlignment=Enum.HorizontalAlignment.Left
TabLayout.Padding=UDim.new(0,6)

local TABS={"All","Titles","Cosmetics"}
local tabBtns={}

-- ── Item scroll ───────────────────────────────────────────────
local Scroll=Instance.new("ScrollingFrame",Panel)
Scroll.Size=UDim2.new(1,-24,1,-132); Scroll.Position=UDim2.new(0,12,0,120)
Scroll.BackgroundTransparency=1; Scroll.BorderSizePixel=0
Scroll.ScrollBarThickness=6; Scroll.ScrollBarImageColor3=C.gold
Scroll.CanvasSize=UDim2.new(1,0,0,0); Scroll.AutomaticCanvasSize=Enum.AutomaticSize.Y
Scroll.ZIndex=12
local ScrollLayout=Instance.new("UIListLayout",Scroll)
ScrollLayout.SortOrder=Enum.SortOrder.LayoutOrder; ScrollLayout.Padding=UDim.new(0,6)
local ScrollPad=Instance.new("UIPadding",Scroll)
