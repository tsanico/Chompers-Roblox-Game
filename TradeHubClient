local dumpItemFrames = {}

local function rebuildDumpHud(items)
	for _, f in ipairs(dumpItemFrames) do f:Destroy() end
	dumpItemFrames = {}
	if not items or #items == 0 then
		local empty = mkLabel(DumpPanel, "Empty", Enum.Font.GothamBold, 15, C.dim,
			Enum.TextXAlignment.Left, UDim2.new(0,0,0,0), UDim2.new(1,0,0,20))
		empty.LayoutOrder = 10
		table.insert(dumpItemFrames, empty)
		return
	end
	for i, item in ipairs(items) do
		local row = Instance.new("Frame", DumpPanel)
		row.Size = UDim2.new(1,0,0,32); row.BackgroundColor3=C.card
		row.BorderSizePixel=0; row.ZIndex=22; row.LayoutOrder=9+i
		corner(row, 6)
		mkLabel(row, (item.emoji or "🍽").."  "..item.name,
			Enum.Font.GothamBold, 16, C.white, Enum.TextXAlignment.Left,
			UDim2.new(0,8,0,0), UDim2.new(0.7,0,1,0))
		mkLabel(row, item.rarity or "", Enum.Font.Gotham, 12, C.dim,
			Enum.TextXAlignment.Right,
			UDim2.new(0.7,0,0,0), UDim2.new(0.3,-8,1,0))
		table.insert(dumpItemFrames, row)
	end
end

-- Proximity polling for dumpsters
local dumpsterParts = {}
local currentNearDumpster = nil
local GetDumpsterContents = Remotes:FindFirstChild("GetDumpsterContents")
	or R("GetDumpsterContents")

task.delay(2, function()
	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("BasePart") then
			if desc:GetAttribute("IsTrashCan") == true
				or desc:GetAttribute("IsDumpster") == true then
				table.insert(dumpsterParts, desc)
			end
		end
	end
end)

-- DumpsterUpdated: refresh HUD if we're looking at that dumpster
local DumpsterUpdated = Remotes:FindFirstChild("DumpsterUpdated") or R("DumpsterUpdated")
DumpsterUpdated.OnClientEvent:Connect(function(dumpsterPart, newList)
	if currentNearDumpster == dumpsterPart then
		rebuildDumpHud(newList)
	end
end)

task.spawn(function()
	while true do
		task.wait(0.35)
		local char = player.Character
		local hrp  = char and char:FindFirstChild("HumanoidRootPart")
		if not hrp then currentNearDumpster=nil; DumpPanel.Visible=false; continue end

		local nearest, nearestDist = nil, 9
		for _, part in ipairs(dumpsterParts) do
			if part and part.Parent then
				local d = (hrp.Position - part.Position).Magnitude
				if d < nearestDist then nearestDist=d; nearest=part end
			end
		end

		if nearest and nearest ~= currentNearDumpster then
			currentNearDumpster = nearest
			local ok, contents = pcall(function()
				return GetDumpsterContents:InvokeServer(nearest)
			end)
			rebuildDumpHud(ok and contents or {})
			DumpPanel.Visible = true
		elseif not nearest then
			currentNearDumpster = nil
			DumpPanel.Visible   = false
		end
	end
end)

