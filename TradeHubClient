local selectedSlots = {}

local function buildInventoryList(scroll, inventory, isMyItems)
	for _, c in ipairs(scroll:GetChildren()) do
		if not c:IsA("UIListLayout") then c:Destroy() end
	end
	selectedSlots = {}
	if not inventory or #inventory == 0 then
		mkLabel(scroll,"(empty)",Enum.Font.GothamBold,15,C.dim,
			Enum.TextXAlignment.Center,UDim2.new(0,0,0,0),UDim2.new(1,0,0,36)).ZIndex=47
		return
	end
	for i, item in ipairs(inventory) do
		if not item then continue end
		local row = Instance.new("Frame", scroll)
		row.Size=UDim2.new(1,0,0,44); row.BackgroundColor3=C.card
		row.BorderSizePixel=0; row.ZIndex=47; corner(row,8)
		stroke(row, C.stroke)
		mkLabel(row,(item.emoji or "🍽").."  "..(item.name or "?"),
			Enum.Font.GothamBold,16,C.white,Enum.TextXAlignment.Left,
			UDim2.new(0,8,0,0),UDim2.new(0.72,0,1,0)).ZIndex=48
		mkLabel(row,item.rarity or "",Enum.Font.Gotham,13,C.dim,
			Enum.TextXAlignment.Right,UDim2.new(0.72,0,0,0),UDim2.new(0.28,-8,1,0)).ZIndex=48

		if isMyItems then
			local capI = i
			row.InputBegan:Connect(function(input)
				if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
				local si = table.find(selectedSlots, capI)
				if si then
					table.remove(selectedSlots, si)
					row.BackgroundColor3 = C.card
					local s=row:FindFirstChildWhichIsA("UIStroke"); if s then s.Color=C.stroke end
				else
					table.insert(selectedSlots, capI)
					row.BackgroundColor3 = Color3.fromRGB(20,50,30)
					local s=row:FindFirstChildWhichIsA("UIStroke"); if s then s.Color=C.green end
				end
				local SubmitR = Remotes:FindFirstChild("SubmitTradeItems")
				if SubmitR then SubmitR:FireServer(selectedSlots) end
			end)
		end
	end
end

