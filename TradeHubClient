-- ============================================================
-- TradeHubClient — LocalScript · StarterPlayerScripts
--
-- Handles all Trade Hub and Dumpster client-side UI:
--
-- TRADE HUB MENU (opens when kiosk E pressed):
--   [💜 Buy Bracelet]  — greyed out if < $12
--   [🔄 Trade Items]   — opens player select subscreen
--
-- TRADE SUBSCREEN:
--   Player list → click to request trade
--   Incoming invite popup → Accept / Decline
--   Trade screen: your inventory + partner inventory (selectable)
--   Both confirm → trade executes
--
-- DUMPSTER HUD:
--   Small proximity panel (8 studs) shows contents of nearest
--   dumpster. Lists items with emoji + name. Closes on walk-away.
--   Refreshes when contents change (DumpsterUpdated remote).
-- ============================================================

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService  = game:GetService("UserInputService")
local TweenService      = game:GetService("TweenService")

local player    = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local Remotes   = ReplicatedStorage:WaitForChild("ChompersRemotes", 10)

-- Wait for TradeHubSystem to finish creating all remotes server-side
-- before connecting any listeners. Without this, WaitForChild may time
-- out on remotes that TradeHubSystem hasn't created yet.
task.wait(2)

local function R(n)
	local r = Remotes:FindFirstChild(n)
	if not r then r = Remotes:WaitForChild(n, 8) end
	return r
end

