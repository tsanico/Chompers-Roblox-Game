	TradeScreen.Visible   = false
	InvitePanel.Visible   = false
	if _G.Chompers and _G.Chompers.Announce and reason then
		_G.Chompers.Announce(reason, Color3.fromRGB(220,80,60), 3)
	end
end)

R("TradeComplete").OnClientEvent:Connect(function(receivedItems)
	TradeScreen.Visible = false
	if receivedItems and #receivedItems > 0 then
		local names = {}
		for _, item in ipairs(receivedItems) do
			if item and item.name then table.insert(names, item.name) end
		end
		if _G.Chompers and _G.Chompers.Announce then
			_G.Chompers.Announce(
				"✅  Received: " .. table.concat(names, ", "),
				Color3.fromRGB(100,220,100), 4)
		end
	end
end)

-- Keep money display in sync for the Buy Bracelet button
local updateMoneyR = Remotes:FindFirstChild("UpdateMoney")
if updateMoneyR then
	updateMoneyR.OnClientEvent:Connect(function(v)
		currentMoney = v or 0
		refreshMenuButtons()
	end)
end

-- ESC closes all trade UI
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.Escape then
		MenuPanel.Visible         = false
		PlayerSelectPanel.Visible = false
		TradeScreen.Visible       = false
		InvitePanel.Visible       = false
	end
end)
