-- ============================================================
-- AllianceServer — ServerScript · ServerScriptService
--
-- Handles two alliance events (Bible Part 12):
--
--   1. FOOD FIGHT RECONFIRMATION (on FoodFight phase start)
--      Allied pairs get a 15s window to reconfirm.
--      Both must click Confirm or the alliance breaks publicly.
--
--   2. FIGHT OR LEAVE (on EndGame phase start)
--      Surviving allied pairs get 30s.
--      Leave Together → both get the TogetherWin medal bonus.
--      Fight → alliance breaks, both compete individually.
-- ============================================================

local Players             = game:GetService("Players")
local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local PlayerState = require(ServerScriptService:WaitForChild("PlayerState"))
local DataService = require(ServerScriptService:WaitForChild("DataService"))

local Remotes = ReplicatedStorage:WaitForChild("ChompersRemotes")
local Announce = Remotes:FindFirstChild("Announce")

local MEDALS_TOGETHER = 18   -- matches EndMatchServer MEDALS.TogetherWin

-- ── Remotes ───────────────────────────────────────────────────
local function getOrCreate(name)
	local r = Remotes:FindFirstChild(name)
	if not r then r=Instance.new("RemoteEvent"); r.Name=name; r.Parent=Remotes end
	return r
end

local AllianceReconfirmR      = getOrCreate("AllianceReconfirm")      -- Server→Client
local AllianceReconfirmRespR  = getOrCreate("AllianceReconfirmResp")  -- Client→Server
local AllianceFightOrLeaveR   = getOrCreate("AllianceFightOrLeave")   -- Server→Client
local AllianceFightOrLeaveRespR = getOrCreate("AllianceFightOrLeaveResp") -- Client→Server

-- ── Helpers ───────────────────────────────────────────────────
local function getAlliedPairs()
	local pairs_out = {}
	local seen = {}
	for _, p in ipairs(Players:GetPlayers()) do
		local s = PlayerState.Get(p)
		if not s or not s.allyUserId then continue end
		local ally = Players:GetPlayerByUserId(s.allyUserId)
		if not ally then continue end
		local s2 = PlayerState.Get(ally)
		if not s2 then continue end
		local key = math.min(p.UserId, ally.UserId)
			.."-"..math.max(p.UserId, ally.UserId)
		if not seen[key] then
			seen[key] = true
			table.insert(pairs_out, {p1=p, p2=ally, key=key})
		end
	end
	return pairs_out
end

local function breakAlliance(p1, p2, reason)
	PlayerState.SetAlly(p1, nil)
	PlayerState.SetAlly(p2, nil)
	local n1 = p1.DisplayName or p1.Name
	local n2 = p2.DisplayName or p2.Name
	if Announce then
		Announce:FireAllClients(
			"💔  "..n1.." and "..n2.." — alliance "..reason,
			Color3.fromRGB(200,80,80), 4)
	end
end

local function announceReconfirmed(p1, p2)
	local n1 = p1.DisplayName or p1.Name
	local n2 = p2.DisplayName or p2.Name
	if Announce then
		Announce:FireAllClients(
			"🤝  "..n1.." + "..n2.." — alliance reconfirmed for the Food Fight.",
			Color3.fromRGB(70,195,85), 4)
	end
end

-- ── Phase listener ────────────────────────────────────────────
local PhaseChangedEvent = ServerScriptService:FindFirstChild("PhaseChangedEvent")
	or ServerScriptService:WaitForChild("PhaseChangedEvent", 15)

-- ============================================================
-- FOOD FIGHT RECONFIRMATION
-- ============================================================

local function startReconfirmation()
	local pairs = getAlliedPairs()
	if #pairs == 0 then return end

	local TIMEOUT = 15

	-- Track per-pair responses: [key] = {p1=bool|nil, p2=bool|nil}
	local responses = {}
	local connections = {}

	for _, pair in ipairs(pairs) do
		responses[pair.key] = {p1=nil, p2=nil, resolved=false}

		local n1 = pair.p1.DisplayName or pair.p1.Name
		local n2 = pair.p2.DisplayName or pair.p2.Name
		AllianceReconfirmR:FireClient(pair.p1, n2, TIMEOUT)
		AllianceReconfirmR:FireClient(pair.p2, n1, TIMEOUT)
	end

	-- Listen for responses
	local conn
	conn = AllianceReconfirmRespR.OnServerEvent:Connect(function(player, confirm)
		for _, pair in ipairs(pairs) do
			local r = responses[pair.key]
			if r and not r.resolved then
				if player == pair.p1 then r.p1 = confirm
				elseif player == pair.p2 then r.p2 = confirm end

				-- Either player broke it immediately
				if r.p1 == false or r.p2 == false then
					r.resolved = true
					breakAlliance(pair.p1, pair.p2, "broken by choice.")
					-- Both confirmed
				elseif r.p1 == true and r.p2 == true then
					r.resolved = true
					announceReconfirmed(pair.p1, pair.p2)
				end
			end
		end
	end)
	table.insert(connections, conn)

	-- Timeout: break any unresolved pairs
	task.delay(TIMEOUT + 0.5, function()
		conn:Disconnect()
		for _, pair in ipairs(pairs) do
			local r = responses[pair.key]
			if r and not r.resolved then
				r.resolved = true
				breakAlliance(pair.p1, pair.p2, "broken — no response in time.")
			end
		end
	end)
end

-- ============================================================
-- FIGHT OR LEAVE
-- ============================================================

local function startFightOrLeave()
	-- Only surviving allied pairs are eligible
	local allPairs = getAlliedPairs()
	local survivingPairs = {}
	for _, pair in ipairs(allPairs) do
		local s1 = PlayerState.Get(pair.p1)
		local s2 = PlayerState.Get(pair.p2)
		if s1 and s2 and not s1.isEliminated and not s2.isEliminated then
			table.insert(survivingPairs, pair)
		end
	end
	if #survivingPairs == 0 then return end

	local TIMEOUT = 30
	local responses = {}

	for _, pair in ipairs(survivingPairs) do
		responses[pair.key] = {p1=nil, p2=nil, resolved=false}
		local n1 = pair.p1.DisplayName or pair.p1.Name
		local n2 = pair.p2.DisplayName or pair.p2.Name
		AllianceFightOrLeaveR:FireClient(pair.p1, n2, TIMEOUT)
		AllianceFightOrLeaveR:FireClient(pair.p2, n1, TIMEOUT)
	end

	local conn
	conn = AllianceFightOrLeaveRespR.OnServerEvent:Connect(function(player, choice)
		-- choice: "leave" or "fight"
		for _, pair in ipairs(survivingPairs) do
			local r = responses[pair.key]
			if r and not r.resolved then
				if player == pair.p1 then r.p1 = choice
				elseif player == pair.p2 then r.p2 = choice end

				-- Either chose fight → break immediately
				if r.p1 == "fight" or r.p2 == "fight" then
					r.resolved = true
					breakAlliance(pair.p1, pair.p2, "broken — they chose to fight.")

					-- Both chose leave → together victory
				elseif r.p1 == "leave" and r.p2 == "leave" then
					r.resolved = true
					local n1 = pair.p1.DisplayName or pair.p1.Name
					local n2 = pair.p2.DisplayName or pair.p2.Name
					DataService.AddMedals(pair.p1, MEDALS_TOGETHER)
					DataService.AddMedals(pair.p2, MEDALS_TOGETHER)
					if Announce then
						Announce:FireAllClients(
							"🤝  "..n1.." and "..n2.." left together. +"..MEDALS_TOGETHER.." medals each.",
							Color3.fromRGB(239,159,39), 5)
					end
				end
			end
		end
	end)

	-- Timeout: treat non-responders as "leave" (generous default)
	task.delay(TIMEOUT + 0.5, function()
		conn:Disconnect()
		for _, pair in ipairs(survivingPairs) do
			local r = responses[pair.key]
			if r and not r.resolved then
				r.resolved = true
				-- Default: leave together (generous — they just didn't decide in time)
				local n1 = pair.p1.DisplayName or pair.p1.Name
				local n2 = pair.p2.DisplayName or pair.p2.Name
				DataService.AddMedals(pair.p1, MEDALS_TOGETHER)
				DataService.AddMedals(pair.p2, MEDALS_TOGETHER)
				if Announce then
					Announce:FireAllClients(
						"🤝  "..n1.." and "..n2.." left together. +"..MEDALS_TOGETHER.." medals each.",
						Color3.fromRGB(239,159,39), 5)
				end
			end
		end
	end)
end

-- ── Hook into phase changes ───────────────────────────────────
if PhaseChangedEvent then
	PhaseChangedEvent.Event:Connect(function(phase)
		if phase == "FoodFight" then
			task.delay(1, startReconfirmation)   -- brief delay so FoodFight announce fires first
		elseif phase == "EndGame" then
			task.delay(0.5, startFightOrLeave)
		end
	end)
end

print("[AllianceServer] Ready")
