-- ============================================================
-- CharacterController — LocalScript
-- Location: StarterPlayerScripts > CharacterController
--
-- Owns all client-side character movement feel:
--   • Jump power: 40 (Bible-spec — floaty but not broken)
--   • Low air control: 0.2s cooldown before direction change mid-air
--   • Speed: driven by UpdateSpeed remote from PlayerState
--   • Applies speed multiplier from server without trusting the client
--
-- The server (PlayerState) owns the authoritative speed value.
-- This script receives it and applies it to the Humanoid.
-- It never calculates speed itself — that stays server-side.
-- ============================================================

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService  = game:GetService("UserInputService")
local RunService        = game:GetService("RunService")

local player    = Players.LocalPlayer
local Remotes   = ReplicatedStorage:WaitForChild("ChompersRemotes")

-- ── Config ──────────────────────────────────────────────────
local BASE_WALK_SPEED   = 16
local JUMP_POWER        = 40
local AIR_CONTROL_DELAY = 0.2
local CAMERA_OFFSET     = Vector3.new(1.75, 0, 0)   -- shift-lock right-offset

-- ── State ───────────────────────────────────────────────────
local currentSpeedMult  = 1.0
local isAirborne        = false
local airTime           = 0
local lastGroundedTime  = tick()

-- ============================================================
-- CHARACTER SETUP
-- Runs every time the character spawns (respawn safe)
-- ============================================================

local function setupCharacter(character)
	local humanoid = character:WaitForChild("Humanoid")
	local hrp      = character:WaitForChild("HumanoidRootPart")

	-- Base stats — AutoRotate starts true (normal mode during onboarding UI)
	-- Shift-lock (AutoRotate=false, mouse lock, camera offset) activates
	-- only after _G.Chompers.ShiftLockReady = true (set by WelcomeScreen flow)
	humanoid.JumpPower    = JUMP_POWER
	humanoid.WalkSpeed    = BASE_WALK_SPEED * currentSpeedMult
	humanoid.AutoRotate   = true
	humanoid.CameraOffset = Vector3.new(0, 0, 0)

	-- ── Air control: dampen direction input while airborne ──
	local stateConn
	stateConn = humanoid.StateChanged:Connect(function(_, newState)
		if newState == Enum.HumanoidStateType.Jumping
		or newState == Enum.HumanoidStateType.Freefall then
			isAirborne = true
			airTime    = tick()

		elseif newState == Enum.HumanoidStateType.Landed
		or newState == Enum.HumanoidStateType.Running
		or newState == Enum.HumanoidStateType.RunningNoPhysics
		or newState == Enum.HumanoidStateType.StrafingNoPhysics then
			isAirborne       = false
			lastGroundedTime = tick()
		end
	end)

	-- ── RenderStepped: speed + conditional shift-lock ──────────
	local camera        = workspace.CurrentCamera
	local prevShiftLock = nil   -- track transitions to avoid redundant property sets
	local renderConn
	renderConn = RunService.RenderStepped:Connect(function()
		if not humanoid or not humanoid.Parent then
			renderConn:Disconnect()
			stateConn:Disconnect()
			return
		end

		-- Shift-lock gate: only active after onboarding is complete
		local shiftLock = (_G.Chompers and _G.Chompers.ShiftLockReady == true)

		-- On transition (false→true or true→false), update properties
		if shiftLock ~= prevShiftLock then
			prevShiftLock         = shiftLock
			humanoid.AutoRotate   = not shiftLock
			humanoid.CameraOffset = shiftLock and CAMERA_OFFSET or Vector3.new(0, 0, 0)
		end

		if shiftLock then
			-- Shift-lock active: lock mouse + rotate character to face camera
			UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter

			local camLook  = camera.CFrame.LookVector
			local flatLook = Vector3.new(camLook.X, 0, camLook.Z)
			if flatLook.Magnitude > 0.01 then
				local angle = math.atan2(-flatLook.X, -flatLook.Z)
				hrp.CFrame  = CFrame.new(hrp.Position)
					* CFrame.fromEulerAnglesYXZ(0, angle, 0)
			end
		else
			-- Onboarding UI open: free mouse so player can click buttons
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		end

		-- Speed (always)
		local targetSpeed = BASE_WALK_SPEED * currentSpeedMult
		if isAirborne then
			local elapsed = tick() - airTime
			if elapsed < AIR_CONTROL_DELAY then
				local alpha = elapsed / AIR_CONTROL_DELAY
				targetSpeed = humanoid.WalkSpeed + (targetSpeed - humanoid.WalkSpeed) * alpha
			end
		end
		humanoid.WalkSpeed = targetSpeed
	end)

	-- Clean up on character removal
	character.AncestryChanged:Connect(function()
		if not character.Parent then
			pcall(function() renderConn:Disconnect() end)
			pcall(function() stateConn:Disconnect() end)
		end
	end)
end

-- ============================================================
-- SPEED REMOTE — server tells client what multiplier to use
-- ============================================================

Remotes:WaitForChild("UpdateSpeed").OnClientEvent:Connect(function(mult)
	currentSpeedMult = math.max(mult, 0.35)   -- enforce 35% floor client-side too

	-- Apply immediately to existing character if present
	local character = player.Character
	local humanoid  = character and character:FindFirstChild("Humanoid")
	if humanoid then
		humanoid.WalkSpeed = BASE_WALK_SPEED * currentSpeedMult
	end
end)

-- ============================================================
-- CL / FL WARN VISUAL FEEDBACK (Part 3)
-- Subtle screen effects when bars approach 100%
-- ============================================================

local function flashScreenEdge(color)
	-- Simple: tween a full-screen frame briefly
	local screenGui = player.PlayerGui:FindFirstChild("ChompersHUD")
	if not screenGui then return end
	local edgeFrame = screenGui:FindFirstChild("BarWarningFlash")
	if not edgeFrame then return end

	-- Make visible, fade out over 0.75s
	edgeFrame.BackgroundColor3 = color
	edgeFrame.BackgroundTransparency = 0.3
	task.delay(0.75, function()
		-- Fade back
		for i = 1, 10 do
			task.wait(0.05)
			edgeFrame.BackgroundTransparency = 0.3 + (0.7 * (i / 10))
		end
		edgeFrame.BackgroundTransparency = 1
	end)
end

-- ── HitPlayer remote carries multiple signal types ──────────
Remotes:WaitForChild("HitPlayer").OnClientEvent:Connect(function(signal, ...)
	if signal == "cl_warn" then
		-- ~95% CL — red warning slow + screen edge
		flashScreenEdge(Color3.fromRGB(200, 50, 50))
		-- 0.75s slow on character
		local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
		if humanoid then
			local orig = humanoid.WalkSpeed
			humanoid.WalkSpeed = orig * 0.40
			task.delay(0.75, function()
				humanoid.WalkSpeed = orig
			end)
		end

	elseif signal == "fl_warn" then
		-- ~95% FL — orange warning
		flashScreenEdge(Color3.fromRGB(220, 120, 30))
		local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
		if humanoid then
			local orig = humanoid.WalkSpeed
			humanoid.WalkSpeed = orig * 0.40
			task.delay(0.75, function()
				humanoid.WalkSpeed = orig
			end)
		end

	elseif signal == "state100" then
		-- 0.5s dramatic slow — both bars if applicable
		local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
		if humanoid then
			humanoid.WalkSpeed = 0
			task.delay(0.5, function()
				-- Speed is re-applied next RenderStepped tick from currentSpeedMult
				-- which PlayerState already updated via UpdateSpeed
			end)
		end
	end
end)

-- ============================================================
-- PHASE-BASED RESTRICTIONS
-- During Prelobby, keep players in the car park
-- (the map boundaries do this physically but we can also
--  disable jumping in prelobby if needed — for now just note it)
-- ============================================================

Remotes:WaitForChild("PhaseChanged").OnClientEvent:Connect(function(newPhase)
	local character = player.Character
	local humanoid  = character and character:FindFirstChild("Humanoid")
	if not humanoid then return end

	if newPhase == "Prelobby" then
		-- Normal movement in prelobby
		humanoid.JumpPower = JUMP_POWER

	elseif newPhase == "Gathering"
	or newPhase == "Cooking"
	or newPhase == "CookingGrace"
	or newPhase == "FoodFight" then
		-- Full movement in all active phases
		humanoid.JumpPower = JUMP_POWER

	elseif newPhase == "EndGame"
	or newPhase == "Accolades" then
		-- Freeze movement at end of match (cosmetic — players watch accolades)
		humanoid.WalkSpeed = 0
		humanoid.JumpPower = 0
	end
end)

-- ============================================================
-- CONNECT TO PLAYER CHARACTER
-- ============================================================

-- Character might already exist if script runs late
if player.Character then
	setupCharacter(player.Character)
end

player.CharacterAdded:Connect(setupCharacter)
