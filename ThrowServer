-- ============================================================
-- ThrowServer — Script · ServerScriptService
-- v9.7.1 (Bug-Fix Pass)
--
-- CHANGES IN THIS PASS:
--   [BFP-23]  Mark application: pass itemName string directly
--             (was passing {name=itemName} table — PlayerState now
--             accepts both, but string is the canonical form).
--   [BFP-24]  Spherecast disconnect: only fire on confirmed hit,
--             not on any raycast result. Old code killed the
--             fallback whenever the spherecast hit *anything*
--             (terrain, walls, self) even if tryHit rejected.
--   [BFP-25]  FL bloat now affects hitbox W+D and AoE radius —
--             reads PlayerState.GetHitboxScale / GetAoERadiusScale.
-- ============================================================

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService        = game:GetService("RunService")
local TweenService      = game:GetService("TweenService")

local ServerScriptService = game:GetService("ServerScriptService")
local PlayerState  = require(ServerScriptService:WaitForChild("PlayerState"))
local ChompersData = require(ReplicatedStorage:WaitForChild("ChompersData"))

local Remotes = ReplicatedStorage:WaitForChild("ChompersRemotes")
local function R(n) return Remotes:WaitForChild(n) end
local C = ChompersData.Constants

-- ── Servings by rarity ─────────────────────────────────────────
local SERVINGS = { Common=3, Uncommon=2, Rare=1, UltraRare=1, Legendary=1 }

-- ── Physics clone config ───────────────────────────────────────
local CLONE_SCALE    = 1.0
local UPWARD_BOOST   = 12
local THROW_SPEED    = 160
local LIFETIME       = 4
local FADE_TIME      = 0.5
local HIT_RADIUS     = 2.5

local PhysicsObjects = workspace:FindFirstChild("PhysicsObjects")
if not PhysicsObjects then
	PhysicsObjects = Instance.new("Folder")
	PhysicsObjects.Name   = "PhysicsObjects"
	PhysicsObjects.Parent = workspace
end

local lastThrowTime = {}

local KillFeedEvent = Remotes:FindFirstChild("KillFeedEvent")
if not KillFeedEvent then
	KillFeedEvent = Instance.new("RemoteEvent")
	KillFeedEvent.Name   = "KillFeedEvent"
	KillFeedEvent.Parent = Remotes
end
local function killFeed(evType, data)
	KillFeedEvent:FireAllClients(evType, data)
end

local ingByName, recByName = {}, {}
for _, ing in ipairs(ChompersData.Ingredients) do ingByName[ing.name] = ing end
for _, rec in ipairs(ChompersData.Recipes)     do recByName[rec.name] = rec end

local RARITY_COLOURS = {
	Common    = Color3.fromRGB(200,200,200),
	Uncommon  = Color3.fromRGB(50,200,80),
	Rare      = Color3.fromRGB(50,100,220),
	UltraRare = Color3.fromRGB(150,50,220),
	Legendary = Color3.fromRGB(220,160,30),
}

-- ── Helpers ────────────────────────────────────────────────────
local function playerFromHit(part)
	return part.Parent and Players:GetPlayerFromCharacter(part.Parent)
end

local function isOilIngredient(n) return n == "Oil" end

local function isFireRecipe(n)
	for _, v in ipairs(C.Elemental.FireRecipes) do
		if v == n then return true end
	end
	return false
end

local function getItemAllergy(itemName, itemData)
	if itemData and itemData.allergy then return itemData.allergy end
	local ing = ingByName[itemName]
	if ing then return ing.allergy or "None" end
	local rec = recByName[itemName]
	if rec and rec.ingredients and #rec.ingredients > 0 then
		local fi = ingByName[rec.ingredients[1]]
		return fi and fi.allergy or "None"
	end
	return "None"
end

local function consumeServing(player, slotIndex)
	local s = PlayerState.Get(player)
	if not s then return nil end
	local itemData = s.inventory[slotIndex]
	if not itemData then return nil end

	local rarity = itemData.rarity or "Common"
	if not itemData.servingsLeft then
		itemData.servingsLeft = SERVINGS[rarity] or 1
	end

	local itemCopy = {}
	for k, v in pairs(itemData) do itemCopy[k] = v end

	itemData.servingsLeft = itemData.servingsLeft - 1
	if itemData.servingsLeft <= 0 then
		PlayerState.RemoveItem(player, slotIndex)
	end

	return itemCopy
end

-- ── Build clone ───────────────────────────────────────────────
-- [BFP-25] Bloat hitbox scaling applied to clone size (X/Z, not Y).
local function buildClone(itemName, rarity, hitboxScale)
	hitboxScale = hitboxScale or 1.0

	local function applyBloat(part)
		-- Scale W and D only, height unchanged.
		part.Size = Vector3.new(
			part.Size.X * hitboxScale,
			part.Size.Y,
			part.Size.Z * hitboxScale
		)
	end

	local ingFolder = workspace:FindFirstChild("CHOMPERS_Ingredients")
	local source    = ingFolder and ingFolder:FindFirstChild(itemName, true)

	if source and source:IsA("BasePart") then
		local clone = source:Clone()
		clone.Anchored  = false
		clone.CanCollide = true
		clone.Size      = clone.Size * CLONE_SCALE
		applyBloat(clone)
		clone.Parent    = PhysicsObjects
		return clone, math.max(clone.Size.X, clone.Size.Z) / 2

	elseif source and source:IsA("Model") then
		local base = source.PrimaryPart
			or source:FindFirstChildWhichIsA("BasePart")
		if base then
			local clone     = base:Clone()
			clone.Anchored  = false
			clone.CanCollide = true
			clone.Size      = clone.Size * CLONE_SCALE
			applyBloat(clone)
			clone.Parent    = PhysicsObjects
			return clone, math.max(clone.Size.X, clone.Size.Z) / 2
		end
	end

	-- Fallback sphere
	local sphere        = Instance.new("Part")
	sphere.Shape        = Enum.PartType.Ball
	sphere.Size         = Vector3.new(3, 3, 3) * CLONE_SCALE
	applyBloat(sphere)
	sphere.Color        = RARITY_COLOURS[rarity] or RARITY_COLOURS.Common
	sphere.Material     = Enum.Material.SmoothPlastic
	sphere.CanCollide   = true
	sphere.Anchored     = false
	sphere.CastShadow   = false
	sphere.Parent       = PhysicsObjects

	local bb   = Instance.new("BillboardGui", sphere)
	bb.Size    = UDim2.new(0, 60, 0, 60)
	bb.StudsOffset = Vector3.new(0, 1.5, 0)
	local lbl  = Instance.new("TextLabel", bb)
	lbl.Size   = UDim2.new(1,0,1,0); lbl.BackgroundTransparency = 1
	lbl.TextScaled = true
	lbl.Text   = ChompersData.GetEmoji(itemName) or "🍽"

	return sphere, HIT_RADIUS * hitboxScale
end

-- ── Damage pipeline ────────────────────────────────────────────
local function applyDamage(attacker, target, itemData, itemName)
	local tState = PlayerState.Get(target)
	local aState = PlayerState.Get(attacker)
	if not tState or not aState then return end
	if tState.isEliminated or tState.inBathroom then return end

	local baseCL      = itemData.cl or 0
	local itemAllergy = getItemAllergy(itemName, itemData)

	-- 1. Allergy
	local allergyMult = 1.0
	if tState.allergy and tState.allergy ~= "None" then
		allergyMult = (itemAllergy == tState.allergy)
			and C.Allergy.MatchMultiplier or C.Allergy.NoMatchMultiplier
	end
	local clAfterAllergy = baseCL * allergyMult

	-- 2. Elemental (Oil → Fire chain)
	local elementalMult = 1.0
	if isFireRecipe(itemName) and PlayerState.IsOilPrimed(target) then
		elementalMult = C.Elemental.OilFireMultiplier
		PlayerState.ClearOilPrimer(target)
	end
	local clAfterElemental = clAfterAllergy * elementalMult

	-- 3. Mark (read existing mark BEFORE applying new mark)
	local mark     = PlayerState.GetActiveMark(target)
	local markBonus = 0
	if mark and tick() < mark.expiresAt then
		markBonus = clAfterElemental * mark.bonus
	end
	local clAfterMark = clAfterElemental + markBonus

	-- [BFP-23] Pass the itemName string directly (was {name=itemName}).
	local markIngredients = { Tomato=true, ["Soy Sauce"]=true }
	if markIngredients[itemName] then
		PlayerState.ApplyMarkToTarget(target, itemName)
	end

	-- 4. Favourite bonus
	local favBonus = 0
	if aState.favourite and aState.favourite == itemName then
		favBonus = math.min(baseCL * C.Favourite.ThrowBonusMultiplier,
			C.Favourite.ThrowBonusCap)
	end
	local finalCL = math.max(0, clAfterMark + favBonus)

	-- 5. Apply CL
	if finalCL > 0 then
		PlayerState.ModifyCL(target, finalCL)
		PlayerState.RecordCLDealt(attacker, finalCL)
		PlayerState.AddPoints(attacker, finalCL * C.Points.DirectHitPerCL)
	end

	-- 6. FL
	local isCooked = itemData.cooked == true
	local flDelta  = isCooked and C.FLPerHit.Cooked or C.FLPerHit.RawCold
	if tState.favourite and tState.favourite == itemName then
		flDelta = flDelta * C.Favourite.EnemyFLSpike
	end
	PlayerState.ModifyFL(target, flDelta)
	if flDelta > 0 then PlayerState.RecordFLDealt(attacker, flDelta) end

	-- 7. Oil primer
	if isOilIngredient(itemName) then PlayerState.ApplyOilPrimer(target) end

	-- 8. Hit-reveal
	if _G.InspectCheckHitReveal then
		_G.InspectCheckHitReveal(attacker, target, itemName, itemAllergy)
	end

	-- 9. Elimination check
	local tState2       = PlayerState.Get(target)
	local triggered100  = tState2 and tState2.cl >= 100
	if triggered100 then
		killFeed("meltdown", {
			attacker = attacker.Name, victim = target.Name,
			item = itemName, cl = math.floor(finalCL),
		})
		PlayerState.EliminatePlayer(target, attacker)
		PlayerState.AddPoints(attacker, C.Points.DownEnemy)
		local tState3 = PlayerState.Get(target)
		if tState3 and tState3.pottyBreaks <= 0 then
			killFeed("elimination", { victim = target.Name })
		end
	elseif finalCL >= 25 and itemData.rarity == "Legendary" then
		killFeed("legendary_thrown", {
			attacker = attacker.Name, victim = target.Name,
			item = itemName, cl = math.floor(finalCL),
		})
	end
end

-- ── Spawn and throw ────────────────────────────────────────────
local function spawnAndThrow(player, itemCopy, aimPoint)
	local char = player.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	local itemName = itemCopy.name
	local rarity   = itemCopy.rarity or "Common"

	-- [BFP-25] Read attacker's bloat scalars for hitbox/AoE.
	local hitboxScale = PlayerState.GetHitboxScale(player)
	local aoeScale    = PlayerState.GetAoERadiusScale(player)

	local clone, hitRadius = buildClone(itemName, rarity, hitboxScale)
	-- Apply AoE scaling on top of the hitbox base radius.
	hitRadius = hitRadius * aoeScale

	clone.CFrame = CFrame.new(hrp.Position + Vector3.new(0, 4, 0))
	clone:SetAttribute("OwnerUserId", player.UserId)

	local rx = math.random(-20, 20)
	local rz = math.random(-20, 20)
	clone.CFrame = clone.CFrame * CFrame.Angles(math.rad(rx), 0, math.rad(rz))

	local lookFlat = Vector3.new(hrp.CFrame.LookVector.X, 0, hrp.CFrame.LookVector.Z)
	if lookFlat.Magnitude < 0.01 then lookFlat = Vector3.new(0, 0, -1) end

	local toAim  = (aimPoint - hrp.Position)
	local aimFlat = Vector3.new(toAim.X, 0, toAim.Z)
	if aimFlat.Magnitude > 1 then
		lookFlat = (lookFlat + aimFlat.Unit * 0.6).Unit
	end

	clone.AssemblyLinearVelocity = lookFlat * THROW_SPEED
		+ Vector3.new(0, UPWARD_BOOST, 0)

	local hitProcessed = {false}

	local function tryHit(part)
		if hitProcessed[1] then return end
		local target = playerFromHit(part)
		if not target or target == player then return end
		local ts = PlayerState.Get(target)
		if not ts or ts.isEliminated or ts.inBathroom then return end
		hitProcessed[1] = true
		applyDamage(player, target, itemCopy, itemName)
		clone:Destroy()
	end

	clone.Touched:Connect(function(part)
		tryHit(part)
	end)

	-- [BFP-24] Spherecast fallback: only disconnect when an actual hit
	-- was processed. Old code disconnected on ANY raycast result, so
	-- one bounce off terrain killed the fallback for the rest of the throw.
	local prevPos = clone.Position
	local conn
	conn = RunService.Heartbeat:Connect(function()
		if hitProcessed[1] or not clone or not clone.Parent then
			conn:Disconnect(); return
		end
		local newPos = clone.Position
		local dir    = newPos - prevPos
		local dist   = dir.Magnitude
		if dist > 0.01 then
			local p = RaycastParams.new()
			if char then
				p.FilterDescendantsInstances = {char, clone}
				p.FilterType = Enum.RaycastFilterType.Exclude
			end
			local r = workspace:Spherecast(prevPos, hitRadius, dir.Unit * dist, p)
			if r and r.Instance then
				tryHit(r.Instance)
				-- [BFP-24] Only disconnect if tryHit actually accepted.
				if hitProcessed[1] then
					conn:Disconnect()
				end
			end
		end
		prevPos = newPos
	end)

	-- Lifetime fade
	task.delay(LIFETIME, function()
		if not clone or not clone.Parent then return end
		if conn then conn:Disconnect() end
		TweenService:Create(clone,
			TweenInfo.new(FADE_TIME, Enum.EasingStyle.Linear),
			{Transparency = 1}):Play()
		task.delay(FADE_TIME + 0.05, function()
			if clone and clone.Parent then clone:Destroy() end
		end)
	end)
end

-- ── Remote handler ─────────────────────────────────────────────
R("ThrowFood").OnServerEvent:Connect(function(player, slotIndex, throwSpeed, aimPoint)
	local s = PlayerState.Get(player)
	if not s then return end
	if s.isEliminated or s.inBathroom then return end

	local now = tick()
	if lastThrowTime[player] and (now - lastThrowTime[player]) < C.Throw.Cooldown then
		return
	end

	slotIndex = math.floor(slotIndex or 1)
	if slotIndex < 1 or slotIndex > 10 then return end

	local itemData = s.inventory[slotIndex]
	if not itemData then return end
	if not itemData.paid then return end
	if itemData.name == "Alliance Bracelet" then return end

	if typeof(aimPoint) ~= "Vector3" then return end

	throwSpeed = math.clamp(tonumber(throwSpeed) or THROW_SPEED,
		C.Throw.MinSpeed or 40, 200)

	lastThrowTime[player] = now

	local itemCopy = consumeServing(player, slotIndex)
	if not itemCopy then return end

	spawnAndThrow(player, itemCopy, aimPoint)
end)

Players.PlayerRemoving:Connect(function(p) lastThrowTime[p] = nil end)

print("[ThrowServer] Ready")
