-- ============================================================
-- ThrowServer — Script
-- Location: ServerScriptService
--
-- Handles all food throwing:
--   • Validates throw (cooldown, paid, not eliminated, not in bathroom)
--   • Removes item from thrower's inventory
--   • Spawns a physics projectile in workspace
--   • Detects hits via .Touched + proximity heartbeat fallback
--   • Applies CL/FL with allergy, favourite, cook-depth, and elemental multipliers
--   • Calls InspectServer.CheckHitReveal on correct hit
--   • Records stats on both attacker and defender
-- ============================================================

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService        = game:GetService("RunService")
local Debris            = game:GetService("Debris")

local ServerScriptService = game:GetService("ServerScriptService")
local PlayerState  = require(ServerScriptService:WaitForChild("PlayerState"))
-- InspectServer is a Script (not ModuleScript) — access CheckHitReveal via _G
-- InspectServer exposes: _G.InspectCheckHitReveal(attacker, target, foodName, foodAllergy)
local ChompersData = require(ReplicatedStorage:WaitForChild("ChompersData"))

local Remotes = ReplicatedStorage:WaitForChild("ChompersRemotes")
local function R(name) return Remotes:WaitForChild(name) end

local C = ChompersData.Constants

-- ── Per-player throw cooldown ─────────────────────────────────
local lastThrowTime = {}   -- [player] = tick()

-- ── Ingredient lookup by name ─────────────────────────────────
local ingByName = {}
for _, ing in ipairs(ChompersData.Ingredients) do
	ingByName[ing.name] = ing
end
local recByName = {}
for _, rec in ipairs(ChompersData.Recipes) do
	recByName[rec.name] = rec
end

-- ── Rarity colour for projectile visual ───────────────────────
local RARITY_COLOURS = {
	Common    = Color3.fromRGB(200,200,200),
	Uncommon  = Color3.fromRGB(50,200,80),
	Rare      = Color3.fromRGB(50,100,220),
	UltraRare = Color3.fromRGB(150,50,220),
	Legendary = Color3.fromRGB(220,160,30),
}

-- ── Get player from a character hit ───────────────────────────
local function playerFromHit(part)
	local char = part.Parent
	if not char then return nil end
	return Players:GetPlayerFromCharacter(char)
end

-- ── Cook depth bonus (how many ingredients in the recipe) ─────
local function getCookDepthBonus(itemName)
	local rec = recByName[itemName]
	if not rec or not rec.ingredients then return 0 end
	local n = #rec.ingredients
	if n >= 4 then return C.Damage.CookDepth4Bonus
	elseif n == 3 then return C.Damage.CookDepth3Bonus
	elseif n == 2 then return C.Damage.CookDepth2Bonus
	end
	return 0
end

-- ── Is this item an Oil ingredient? ───────────────────────────
local function isOilIngredient(itemName)
	return itemName == "Oil"
end

-- ── Is this item one of the fire recipes? ─────────────────────
local function isFireRecipe(itemName)
	for _, name in ipairs(C.Elemental.FireRecipes) do
		if name == itemName then return true end
	end
	return false
end

-- ── Lookup item allergy ───────────────────────────────────────
local function getItemAllergy(itemName, itemData)
	if itemData and itemData.allergy then return itemData.allergy end
	local ing = ingByName[itemName]
	if ing then return ing.allergy or "None" end
	local rec = recByName[itemName]
	-- Recipes inherit allergy from primary/first ingredient
	if rec and rec.ingredients and #rec.ingredients > 0 then
		local firstIng = ingByName[rec.ingredients[1]]
		return firstIng and firstIng.allergy or "None"
	end
	return "None"
end

-- ============================================================
-- ============================================================
-- SPAWN PROJECTILE
-- horizSpeed validated server-side; BodyForce counteracts 10.8% of gravity
-- → effective G ≈ 175 studs/s² (matches bible 8-stud arc at 50-stud full throw).
-- Projectile size scales with item weight for dodgeability.
-- ============================================================

local function getHitRadius(wt)
	local hr = C.Throw.HitRadius
	if wt <= 2 then return hr and hr.Light  or 1.2
	elseif wt <= 4 then return hr and hr.Normal or 1.5
	else                 return hr and hr.Heavy  or 1.8
	end
end

local function spawnProjectile(itemData, origin, targetPos, horizSpeed, rarity)
	local G_COUNTER_PCT = C.Throw.GravityCounterPct or 0.108
	local G_EFF         = workspace.Gravity * (1 - G_COUNTER_PCT)  -- ≈175 studs/s²

	local disp  = targetPos - origin
	local hDist = Vector3.new(disp.X, 0, disp.Z).Magnitude
	if hDist < 0.5 then hDist = 0.5 end
	local T   = hDist / math.max(horizSpeed, 4)
	local vel = disp / T + Vector3.new(0, 0.5 * G_EFF * T, 0)
	if vel.Magnitude > 300 then vel = vel.Unit * 300 end

	local wt     = itemData.wt or itemData.weight or 1
	local radius = getHitRadius(wt)
	local diam   = radius * 2

	local proj = Instance.new("Part")
	proj.Name        = "FoodProjectile"
	proj.Shape       = Enum.PartType.Ball
	proj.Size        = Vector3.new(diam, diam, diam)
	proj.Color       = RARITY_COLOURS[rarity] or RARITY_COLOURS.Common
	proj.Material    = Enum.Material.SmoothPlastic
	proj.CanCollide  = false; proj.CastShadow = false; proj.Anchored = false
	proj.CFrame      = CFrame.new(origin); proj.Parent = workspace

	local bf = Instance.new("BodyForce", proj)
	bf.Force = Vector3.new(0, proj.AssemblyMass * workspace.Gravity * G_COUNTER_PCT, 0)
	proj.AssemblyLinearVelocity = vel

	task.delay(0.10, function()
		if proj and proj.Parent then proj.CanCollide = true end
	end)

	local bb = Instance.new("BillboardGui", proj)
	bb.Size = UDim2.new(0, 48, 0, 48); bb.StudsOffset = Vector3.new(0, 0.8, 0)
	bb.AlwaysOnTop = false
	local emoji = Instance.new("TextLabel", bb)
	emoji.Size = UDim2.new(1,0,1,0); emoji.BackgroundTransparency = 1
	emoji.Text = itemData.emoji or "🍽"; emoji.TextScaled = true

	local maxLife = math.clamp(T * 2.5, 2, 10)
	game:GetService("Debris"):AddItem(proj, maxLife)
	return proj, radius
end

-- ============================================================
-- APPLY DAMAGE
-- ============================================================

local function applyDamage(attacker, target, itemData, itemName)
	local tState = PlayerState.Get(target)
	local aState = PlayerState.Get(attacker)
	if not tState or not aState then return end
	if tState.isEliminated or tState.inBathroom then return end

	local baseCL      = itemData.cl or 0
	local itemAllergy = getItemAllergy(itemName, itemData)

	-- 1. Allergy
	local allergyMult = 1.0
	if tState.allergy and tState.allergy ~= "None" then
		allergyMult = (itemAllergy == tState.allergy)
			and C.Allergy.MatchMultiplier or C.Allergy.NoMatchMultiplier
	end
	local clAfterAllergy = baseCL * allergyMult

	-- 2. Cook depth
	local clAfterDepth = clAfterAllergy * (1 + getCookDepthBonus(itemName))

	-- 3. Elemental
	local elementalMult = 1.0
	if isFireRecipe(itemName) and PlayerState.IsOilPrimed(target) then
		elementalMult = C.Elemental.OilFireMultiplier
		PlayerState.ClearOilPrimer(target)
	end
	local clAfterElemental = clAfterDepth * elementalMult

	-- 4. Mark bonus (read BEFORE applying new mark)
	local mark = PlayerState.GetActiveMark(target)
	local markBonus = 0
	if mark and tick() < mark.expiresAt then
		markBonus = clAfterElemental * mark.bonus
	end
	local clAfterMark = clAfterElemental + markBonus
	local markIngredients = { Tomato=true, ["Soy Sauce"]=true, ["Black Garlic"]=true }
	if markIngredients[itemName] then
		PlayerState.ApplyMarkToTarget(target, { name=itemName })
	end

	-- 5. Favourite bonus
	local favBonus = 0
	if aState.favourite and aState.favourite == itemName then
		favBonus = math.min(baseCL * C.Favourite.ThrowBonusMultiplier, C.Favourite.ThrowBonusCap)
	end
	local finalCL = math.max(0, clAfterMark + favBonus)

	-- 6. Apply CL
	if finalCL > 0 then
		PlayerState.ModifyCL(target, finalCL)
		PlayerState.RecordCLDealt(attacker, finalCL)
		PlayerState.AddPoints(attacker, finalCL * C.Points.DirectHitPerCL)
	end

	-- 7. Apply FL
	local isCooked = itemData.cooked == true
	local flDelta  = isCooked and C.FLPerHit.Cooked or C.FLPerHit.RawCold
	if tState.favourite and tState.favourite == itemName then
		flDelta = flDelta * C.Favourite.EnemyFLSpike
	end
	PlayerState.ModifyFL(target, flDelta)
	if flDelta > 0 then PlayerState.RecordFLDealt(attacker, flDelta) end

	-- 8. Oil primer
	if isOilIngredient(itemName) then PlayerState.ApplyOilPrimer(target) end

	-- 9. Hit-reveal
	if _G.InspectCheckHitReveal then
		_G.InspectCheckHitReveal(attacker, target, itemName, itemAllergy)
	end

	-- 10. Elimination
	local tState2 = PlayerState.Get(target)
	if tState2 and tState2.cl >= 100 then
		PlayerState.EliminatePlayer(target, attacker)
		PlayerState.AddPoints(attacker, C.Points.DownEnemy)
	end

	-- 11. Big-hit announcement
	local Announce = Remotes:FindFirstChild("Announce")
	if Announce and finalCL >= 60 then
		local atkName = attacker.DisplayName or attacker.Name
		local defName = target.DisplayName or target.Name
		Announce:FireAllClients("💣 "..atkName.." threw "..itemName.." at "..defName.."!",
			Color3.fromRGB(220,160,30), 5)
	end
end

-- ============================================================
-- PROCESS HIT (shared by .Touched and spherecast)
-- ============================================================

local function processHit(proj, hitPart, attacker, itemData, itemName, hitProcessed)
	if hitProcessed[1] then return false end
	local target = playerFromHit(hitPart)
	if not target or target == attacker then return false end
	local tState = PlayerState.Get(target)
	if not tState or tState.isEliminated or tState.inBathroom then return false end
	hitProcessed[1] = true
	proj:Destroy()
	applyDamage(attacker, target, itemData, itemName)
	return true
end

-- ============================================================
-- THROW FOOD — main remote handler
-- Client sends: ThrowFood(slotIndex, horizSpeed, targetPos)
-- horizSpeed validated server-side to [MinSpeed, MaxSpeed].
-- ============================================================

R("ThrowFood").OnServerEvent:Connect(function(player, slotIndex, horizSpeed, targetPos)
	local s = PlayerState.Get(player)
	if not s then return end
	if s.isEliminated or s.inBathroom then return end

	local now = tick()
	if lastThrowTime[player] and (now - lastThrowTime[player]) < C.Throw.Cooldown then return end

	slotIndex = math.floor(slotIndex or 1)
	if slotIndex < 1 or slotIndex > 10 then return end

	local itemData = s.inventory[slotIndex]
	if not itemData then return end
	if not itemData.paid then return end

	horizSpeed = math.clamp(tonumber(horizSpeed) or C.Throw.MinSpeed,
		C.Throw.MinSpeed, C.Throw.MaxSpeed)

	if typeof(targetPos) ~= "Vector3" then return end

	local char = player.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local origin = hrp.Position + Vector3.new(0, 1.5, 0)

	local toTarget = targetPos - origin
	if toTarget.Magnitude > C.Throw.MaxRange * 1.5 then
		targetPos = origin + toTarget.Unit * (C.Throw.MaxRange * 1.5)
	end

	lastThrowTime[player] = now
	local itemName = itemData.name
	local itemCopy = {}
	for k, v in pairs(itemData) do itemCopy[k] = v end
	PlayerState.RemoveItem(player, slotIndex)

	local proj, hitRadius = spawnProjectile(itemCopy, origin, targetPos, horizSpeed,
		itemCopy.rarity or "Common")

	local hitProcessed = {false}

	-- Primary: .Touched
	proj.Touched:Connect(function(part)
		processHit(proj, part, player, itemCopy, itemName, hitProcessed)
	end)

	-- Secondary: per-frame spherecast (catches fast/jumping targets .Touched misses)
	local prevPos = proj.Position
	local conn
	conn = RunService.Heartbeat:Connect(function()
		if hitProcessed[1] or not proj or not proj.Parent then
			conn:Disconnect(); return
		end
		local newPos = proj.Position
		local dir    = newPos - prevPos
		local dist   = dir.Magnitude
		if dist > 0.01 then
			local params = RaycastParams.new()
			if player.Character then
				params.FilterDescendantsInstances = {player.Character, proj}
				params.FilterType = Enum.RaycastFilterType.Exclude
			end
			local result = workspace:Spherecast(prevPos, hitRadius, dir.Unit * dist, params)
			if result and result.Instance then
				processHit(proj, result.Instance, player, itemCopy, itemName, hitProcessed)
				conn:Disconnect()
			end
		end
		prevPos = newPos
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	lastThrowTime[player] = nil
end)

print("[ThrowServer] Ready")
