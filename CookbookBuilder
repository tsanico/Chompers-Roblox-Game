-- ============================================================
local function hasAllergen(ingredients)
	local allergy = _G.Chompers and _G.Chompers.GetAllergy and
		_G.Chompers.GetAllergy() or nil
	if not allergy then return false end
	for _,ing in ipairs(ALLERGY_INGS[allergy] or {}) do
		if ingredients:find(ing) then return true end
	end
	return false
end

local function recipeHasAllergen(rdIngredients, allergyName)
	local ingList = ALLERGY_INGS[allergyName] or {}
	for _,ing in ipairs(ingList) do
		if rdIngredients:find(ing) then return true end
	end
	return false
end

local function getDisplayFullness(rd)
	if not SELF_CONSUME[rd.n] then return nil end
	local base = rd.fu or 0
	base = math.floor(base * 0.5)
	return base > 0 and base or nil
end

local function getRarestIngredientRarity(recipeIngredients)
	-- Returns the rarity of the rarest ingredient in a recipe
	-- Used for the stack badge in recipe detail
	local rarityRank = {
		Common=1, Uncommon=2, Rare=3, ["Ultra-Rare"]=4, Legendary=5
	}
	local highest = "Common"
	for _,ing in ipairs(INGREDIENT_DATA) do
		if recipeIngredients:find(ing.n) then
			if rarityRank[ing.r] > rarityRank[highest] then
				highest = ing.r
			end
		end
	end
	return highest
end

