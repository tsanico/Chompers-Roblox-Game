if FavScroll then
	local favRarityOrder = {"Common","Uncommon","Rare","Ultra-Rare","Legendary"}
	local favGrouped = {}
	for _,r in ipairs(favRarityOrder) do favGrouped[r]={} end
	for _,rd in ipairs(RECIPE_DATA) do
		table.insert(favGrouped[rd.r] or favGrouped.Common, rd.n)
