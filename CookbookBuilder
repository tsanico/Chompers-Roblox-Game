-- Wire tab button — PrelobbyGuiBuilder owns the tab buttons
-- We inject our panel into the existing tabPanels mechanism
-- by setting Visible directly when the tab is clicked.
-- PrelobbyGuiBuilder's switchTab handles this via tabPanels["COOKBOOK"]
-- We need to register CookPanel there. We do it through a shared table.
local tabPanelsShared = PrelobbyGui:WaitForChild(
	"StoreGuideOverlay",10):WaitForChild("Panel",10)
	:FindFirstChild("TabBar")

-- Direct approach: find the COOKBOOK tab button and wire it
local TabBar = Panel:WaitForChild("TabBar",5)
local allTabPanels = {} -- local registry

local function registerPanel(tabId, panel)
	allTabPanels[tabId] = panel
	-- Find existing tab button and connect
	local btn = TabBar:FindFirstChild(tabId.."Tab")
	if btn then
		btn.MouseButton1Click:Connect(function()
			-- Hide all panels we know about
			for _,p in pairs(allTabPanels) do
				p.Visible = false
			end
			-- Also hide panels from PrelobbyGuiBuilder
			-- by firing through _G.Chompers
			if _G.Chompers and _G.Chompers.HideAllPanels then
				_G.Chompers.HideAllPanels()
			end
			panel.Visible = true
			-- Update tab button colours
			for _,t in ipairs(TabBar:GetChildren()) do
				if t:IsA("TextButton") then
					if t.Name == tabId.."Tab" then
						-- Active colour set by PrelobbyGuiBuilder's
						-- switchTab — we call it if available
					end
				end
			end
			if _G.Chompers and _G.Chompers.SwitchTab then
				_G.Chompers.SwitchTab(tabId)
			end
		end)
	end
end

