-- ============================================================
-- EXPOSE API TO _G.CHOMPERS
-- ============================================================
if _G.Chompers then
	-- Called by server/other scripts to populate accolade winners
	_G.Chompers.SetAccoladeWinner = function(accoladeId, playerName)
		local card = AccAwardsPanel:FindFirstChild(accoladeId)
		if card then
			local winnerL = card:FindFirstChild(accoladeId.."_winner")
			if winnerL then
				winnerL.Text = playerName or "—"
				winnerL.TextColor3 = Color3.fromRGB(239,200,80)
			end
		end
	end

	-- Called by server to unlock achievements
	_G.Chompers.SetAchievementCount = function(achName, count)
		for _,card in ipairs(achScroll:GetChildren()) do
			if card:IsA("Frame") and card.Name==achName then
				local timesL = card:FindFirstChild("TimesEarned")
				local locked = card:FindFirstChild("LockedOverlay")
				if timesL then
					timesL.Text = tostring(count).."×"
				end
				if locked then
					locked.Visible = count==0
				end
				break
			end
		end
	end

	-- Expose recipe names for any script that needs them
	_G.Chompers.GetRecipeNames = function()
		local names = {}
		for _,rd in ipairs(RECIPE_DATA) do
			table.insert(names, rd.n)
		end
		return names
	end

	-- Expose ingredient data
	_G.Chompers.GetIngredientData = function()
		return INGREDIENT_DATA
	end

	-- Expose stack limit lookup
	_G.Chompers.GetStackLimit = function(rarity)
		return STACK_LIMIT[rarity] or 1
	end
end

