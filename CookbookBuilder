local TIER_COL = {
	Starter   = Color3.fromRGB(100, 175, 100),
	Common    = Color3.fromRGB(80, 120, 200),
	Uncommon  = Color3.fromRGB(130, 60, 200),
	Rare      = Color3.fromRGB(218, 65, 65),
	Elite     = Color3.fromRGB(239, 159, 39),
	Legendary = Color3.fromRGB(220, 180, 30),
}

local equippedTitle = nil
local titleBtns = {}

local function refreshTitleButtons()
	for _, btn in pairs(titleBtns) do
		local isEq = btn:GetAttribute("TitleName") == equippedTitle
		btn.Text = isEq and "✓ Equipped" or "Equip"
		btn.BackgroundColor3 = isEq
			and Color3.fromRGB(30,110,46)
			or Color3.fromRGB(70,20,20)
		btn.TextColor3 = isEq
			and Color3.fromRGB(200,255,210)
			or C.white
	end
end

for _, h in ipairs(HONORIFICS) do
	local tierCol = TIER_COL[h.tier] or C.dim
	local fullTitle = h.icon.." "..h.name

	local card = Instance.new("Frame", titlesScroll)
	card.Size = UDim2.new(1,0,0,76)
	card.BackgroundColor3 = Color3.fromRGB(22,20,34)
	card.BorderSizePixel = 0; card.LayoutOrder = h.n; card.ZIndex = 12
	corner(card, 10)
	mkStroke(card, 1.5, Color3.fromRGB(45,42,65))

	-- Tier badge (left accent)
	local accent = Instance.new("Frame", card)
	accent.Size = UDim2.new(0,4,1,-12); accent.Position = UDim2.new(0,4,0,6)
	accent.BackgroundColor3 = tierCol; accent.BorderSizePixel = 0
	corner(accent, 2)

	-- Title name (large)
	mkLabel(card, fullTitle, Enum.Font.GothamBlack, 15, C.title,
		Enum.TextXAlignment.Left,
		UDim2.new(0,16,0,6), UDim2.new(1,-170,0,22)).ZIndex = 13

	-- Tier label
	mkLabel(card, h.tier, Enum.Font.GothamBold, 10, tierCol,
		Enum.TextXAlignment.Left,
		UDim2.new(0,16,0,30), UDim2.new(0.4,0,0,14)).ZIndex = 13

	-- Unlock condition
	mkLabel(card, "🔒 "..h.unlock, Enum.Font.Gotham, 11, C.dim,
		Enum.TextXAlignment.Left,
		UDim2.new(0,16,0,46), UDim2.new(1,-170,0,20)).ZIndex = 13

	-- Cost badge
	local costFmt = h.cost >= 1000
		and tostring(h.cost/1000):gsub("%.0","").."k"
		or tostring(h.cost)
	local costBg = Instance.new("Frame", card)
	costBg.Size = UDim2.new(0,72,0,24)
	costBg.AnchorPoint = Vector2.new(1,0)
	costBg.Position = UDim2.new(1,-90,0,6)
	costBg.BackgroundColor3 = Color3.fromRGB(40,30,8)
	costBg.BorderSizePixel = 0; costBg.ZIndex = 13; corner(costBg,6)
	mkLabel(costBg, "🏅 "..costFmt, Enum.Font.GothamBlack, 13, C.gold).ZIndex = 14

	-- Equip button
	local equipBtn = Instance.new("TextButton", card)
	equipBtn.Size = UDim2.new(0,78,0,30)
	equipBtn.AnchorPoint = Vector2.new(1,1)
	equipBtn.Position = UDim2.new(1,-8,1,-8)
	equipBtn.BackgroundColor3 = Color3.fromRGB(70,20,20)
	equipBtn.BorderSizePixel = 0; equipBtn.AutoButtonColor = false
	equipBtn.Font = Enum.Font.GothamBold; equipBtn.TextSize = 12
	equipBtn.TextColor3 = C.white; equipBtn.Text = "Equip"
	equipBtn.ZIndex = 13; corner(equipBtn, 6)
	equipBtn:SetAttribute("TitleName", fullTitle)
	titleBtns[h.n] = equipBtn

	equipBtn.MouseButton1Click:Connect(function()
		equippedTitle = fullTitle
		equippedDisplay.Text = "Equipped: "..fullTitle
		refreshTitleButtons()
		if _G.Chompers and _G.Chompers.EquipTitle then
			_G.Chompers.EquipTitle(fullTitle)
		end
	end)
end

