local function showRecipeDetail(rd)
	local col = RARITY_COL[rd.r] or RARITY_COL.Common
	local bg2 = RARITY_BG[rd.r]  or RARITY_BG.Common
	local d   = recDetailD

	d.emojiL.Text = rd.emoji or "🍽"
	d.hdr.BackgroundColor3 = bg2
	d.nameL.Text = rd.n
	d.nameL.TextColor3 = col
	d.subNameL.Text = rd.zone or ""
	d.subNameL.TextColor3 = Color3.fromRGB(155,152,178)

	-- Badge 1: Cook method
	d.cookVal.Text  = (rd.cook or ""):gsub("%(raw%)", ""):match("^%s*(.-)%s*$")
	d.cookBadge.BackgroundColor3 = Color3.fromRGB(28,20,42)
	d.cookVal.TextColor3 = Color3.fromRGB(200,170,255)

	-- Badge 2: Allergen
	local foundAllergen = "None"
	for _,a in ipairs(ALLERGY_TYPES) do
		if recipeHasAllergen(rd.i, a.name) then
			foundAllergen = a.name
			break
		end
	end
	d.algIcon.Text = foundAllergen=="None" and "✓" or "⚠️"
	d.algVal.Text  = foundAllergen
	d.algBadge.BackgroundColor3 = foundAllergen=="None"
		and Color3.fromRGB(18,42,20) or Color3.fromRGB(48,20,20)
	d.algVal.TextColor3 = foundAllergen=="None"
		and Color3.fromRGB(100,200,110) or Color3.fromRGB(255,140,140)

	-- Badge 3: Stack limit (rarest ingredient)
	local rarestRarity = getRarestIngredientRarity(rd.i)
	local stackLimit   = STACK_LIMIT[rarestRarity] or 1
	local stackColor   = STACK_COL[rarestRarity]   or Color3.fromRGB(172,170,192)
	d.stkVal.Text  = stackLimit==1 and "×1 only" or "×"..stackLimit.." max"
	d.stkBadge.BackgroundColor3 = RARITY_BG[rarestRarity] or Color3.fromRGB(28,26,42)
	d.stkVal.TextColor3 = stackColor
	d.stkIcon.TextColor3 = stackColor

	-- Badge 4: Rarity
	d.rarIcon.Text = rd.r=="Legendary" and "✨" or "⭐"
	d.rarVal.Text  = rd.r
	d.rarBadge.BackgroundColor3 = RARITY_BG[rd.r] or Color3.fromRGB(30,20,45)
	d.rarVal.TextColor3 = RARITY_COL[rd.r] or Color3.fromRGB(175,140,255)

	-- Stat pills
	d.clVal.Text = rd.cl>0 and tostring(rd.cl) or "Buff"
	d.clVal.TextColor3 = Color3.fromRGB(80,185,255)

	local fuDisplay = getDisplayFullness(rd)
	d.fuVal.Text = fuDisplay and "+"..fuDisplay or "—"
	d.fuVal.TextColor3 = fuDisplay
		and Color3.fromRGB(255,175,55) or Color3.fromRGB(60,58,78)

	d.coVal.Text = rd.cost>0 and "$"..rd.cost or "FREE"
	d.coVal.TextColor3 = Color3.fromRGB(100,225,100)
	d.wtStatVal.Text = tostring(rd.wt)
	d.wtStatVal.TextColor3 = Color3.fromRGB(220,180,90)

	-- Cook depth bonus
	local ingCount = 1
	for _ in rd.i:gmatch("·") do ingCount=ingCount+1 end
	local depthBonus = ingCount>=4 and "+15% CL (4+ ing)"
		or ingCount==3 and "+10% CL (3 ing)"
		or ingCount==2 and "+5% CL (2 ing)"
		or "1 ingredient"

	d.sec1Hdr.Text = "Ingredients:  ("..depthBonus..")"
	d.sec1Body.Text = rd.i
	d.sec1Body.TextColor3 = Color3.fromRGB(215,212,235)

	d.sec2Hdr.Text = "Effect:"
	d.sec2Body.Text = EFFECTS[rd.n] or "Effect coming soon."
	d.sec2Body.TextColor3 = Color3.fromRGB(195,225,195)

	-- Banner
	local allergic = hasAllergen(rd.i)
	local isFav    = _G.Chompers and _G.Chompers.GetFavourite
		and rd.n==_G.Chompers.GetFavourite() or false
	if allergic then
		d.banner.Visible = true
		d.banner.BackgroundColor3 = Color3.fromRGB(80,20,20)
		d.bannerL.Text = "⚠ ALLERGIC — ×1.6 cleanliness when this hits you!"
		d.bannerL.TextColor3 = Color3.fromRGB(255,140,140)
		d.panel.BackgroundColor3 = Color3.fromRGB(30,16,16)
	elseif isFav then
		d.banner.Visible = true
		d.banner.BackgroundColor3 = Color3.fromRGB(55,42,10)
		d.bannerL.Text = "⭐ FAVOURITE — ×1.5 CL when thrown! They get +20 fullness."
		d.bannerL.TextColor3 = Color3.fromRGB(255,210,80)
		d.panel.BackgroundColor3 = Color3.fromRGB(28,24,12)
	else
		d.banner.Visible = false
		d.panel.BackgroundColor3 = Color3.fromRGB(22,20,34)
	end
end

