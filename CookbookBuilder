	Produce="🥦", Bakery="🥐", Dairy="🥛", Freezer="🧊",
	Meat="🥩", Aisles="🏪", Stockroom="📦",
}
local function emoji(name, zone)
	return EMOJI[name] or ZONE_EMOJI[zone] or "🍽"
end

-- normalise rarity
local function nr(r)
	if r == "UltraRare" then return "Ultra-Rare" end
	return r or "Common"
end

-- sort helper
local function rSort(a, b)
	local ra = RARITY_ORDER[nr(a.rarity)] or 5
	local rb = RARITY_ORDER[nr(b.rarity)] or 5
	if ra ~= rb then return ra < rb end
	return (a.name or "") < (b.name or "")
end

-- ============================================================
-- HELPER — ingredient card (used in Cookbook > Ingredients)
-- ============================================================

local function buildIngredientCard(parent, item, order)
	local r   = nr(item.rarity or "Common")
	local bg  = RARITY_BG[r] or C.bgCard
	local col = RARITY_COL[r] or C.stroke
	local ic  = emoji(item.name, item.zone)

	local card = Instance.new("Frame", parent)
	card.Size = UDim2.new(1,0,0,100)
	card.BackgroundColor3 = bg; card.BorderSizePixel = 0
	card.LayoutOrder = order; card.ZIndex = 12
	corner(card, 10); mkStroke(card, 2, col)

	-- Emoji
	mkLabel(card, ic, Enum.Font.GothamBold, 40, C.white,
		Enum.TextXAlignment.Center,
		UDim2.new(0,0,0,0), UDim2.new(0,88,1,0)).ZIndex = 13

	-- Name
	mkLabel(card, item.name, Enum.Font.GothamBlack, 16, C.white,
		Enum.TextXAlignment.Left,
		UDim2.new(0,92,0,8), UDim2.new(1,-100,0,22)).ZIndex = 13

	-- Rarity + Zone
	local zoneStr = (item.zone or "?") .. "  ·  " .. r
	mkLabel(card, zoneStr, Enum.Font.GothamBold, 11, col,
		Enum.TextXAlignment.Left,
		UDim2.new(0,92,0,32), UDim2.new(1,-100,0,14)).ZIndex = 13

	-- Stats row
	local stats = {}
	if item.wt  then table.insert(stats, "⚖ "  ..item.wt.."wt") end
	if item.cost then table.insert(stats, "💲"..item.cost) end
	if item.cl   then table.insert(stats, "🧼 +"..item.cl.." CL") end
	if item.allergy and item.allergy ~= "None" then
		table.insert(stats, "⚠ "..item.allergy)
	end
	mkLabel(card, table.concat(stats, "   "), Enum.Font.Gotham, 12,
		Color3.fromRGB(160,155,195), Enum.TextXAlignment.Left,
		UDim2.new(0,92,0,48), UDim2.new(1,-100,0,14)).ZIndex = 13

	-- Effect
	if item.effect and item.effect ~= "" then
		local eL = mkLabel(card, item.effect, Enum.Font.Gotham, 12,
			C.dim, Enum.TextXAlignment.Left,
			UDim2.new(0,92,0,64), UDim2.new(1,-100,0,28))
		eL.TextWrapped = true; eL.ZIndex = 13
	end
end

-- ============================================================
-- HELPER — recipe card (used in Cookbook > Recipes and FavScroll)
-- ============================================================

local function buildRecipeCard(parent, item, order, compact)
	local r   = nr(item.rarity or "Common")
	local bg  = RARITY_BG[r] or C.bgCard
	local col = RARITY_COL[r] or C.stroke
	local ic  = emoji(item.name)
	local h   = compact and 72 or 110

	local card = Instance.new("Frame", parent)
	card.Size = UDim2.new(1,0,0,h)
	card.BackgroundColor3 = bg; card.BorderSizePixel = 0
	card.LayoutOrder = order; card.ZIndex = 12
	corner(card, 10); mkStroke(card, 2, col)
	return card, ic, r, col
end

local function fillRecipeCard(card, item, ic, r, col, compact)
	-- Emoji
	mkLabel(card, ic, Enum.Font.GothamBold, compact and 28 or 38, C.white,
		Enum.TextXAlignment.Center,
		UDim2.new(0,0,0,0), UDim2.new(0, compact and 60 or 80, 1,0)).ZIndex = 13

	local x = compact and 64 or 84

	-- Name
	mkLabel(card, item.name, Enum.Font.GothamBlack, compact and 14 or 16, C.white,
		Enum.TextXAlignment.Left,
		UDim2.new(0,x,0,6), UDim2.new(1,-x-8,0,20)).ZIndex = 13

	-- Rarity
	mkLabel(card, r, Enum.Font.GothamBold, 11, col,
		Enum.TextXAlignment.Left,
		UDim2.new(0,x,0,28), UDim2.new(1,-x-8,0,14)).ZIndex = 13

	if not compact then
		-- Ingredients
		if item.ingredients then
			local ingStr = table.concat(item.ingredients, " · ")
			local iL = mkLabel(card, "📋 "..ingStr, Enum.Font.Gotham, 11,
				C.dim, Enum.TextXAlignment.Left,
				UDim2.new(0,x,0,44), UDim2.new(1,-x-8,0,24))
			iL.TextWrapped = true; iL.ZIndex = 13
		end
		-- Stats
		local stats = {}
		if item.cl and item.cl > 0 then table.insert(stats, "🧼 +"..item.cl.." CL") end
		if item.wt  then table.insert(stats, "⚖ "..item.wt.."wt") end
		if item.station and item.station ~= "" then
			table.insert(stats, "🍳 "..item.station)
		end
		mkLabel(card, table.concat(stats, "   "), Enum.Font.Gotham, 12,
			Color3.fromRGB(160,155,195), Enum.TextXAlignment.Left,
			UDim2.new(0,x,0,72), UDim2.new(1,-x-8,0,14)).ZIndex = 13
		-- Notes
		if item.notes and item.notes ~= "" then
			mkLabel(card, "📝 "..item.notes, Enum.Font.Gotham, 10,
				C.dim, Enum.TextXAlignment.Left,
				UDim2.new(0,x,0,88), UDim2.new(1,-x-8,0,14)).ZIndex = 13
		end
	else
		-- Compact stats
		local stats = {}
		if item.cl and item.cl > 0 then table.insert(stats, "🧼+"..item.cl) end
		if item.station then table.insert(stats, item.station) end
		mkLabel(card, table.concat(stats, " · "), Enum.Font.Gotham, 11,
			C.dim, Enum.TextXAlignment.Left,
			UDim2.new(0,x,0,44), UDim2.new(1,-x-8,0,14)).ZIndex = 13
	end
end

