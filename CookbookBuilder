local selectedFavBtn = nil

for i, item in ipairs(sortedRec) do
	local r   = nr(item.rarity or "Common")
	local col = RARITY_COL[r] or C.stroke
	local ic  = emoji(item.name)

	local row = Instance.new("TextButton", FavScroll)
	row.Name = "Fav_"..i
	row.Size = UDim2.new(1,0,0,60)
	row.BackgroundColor3 = Color3.fromRGB(24,22,38)
	row.BorderSizePixel = 0; row.AutoButtonColor = false
	row.LayoutOrder = i; row.ZIndex = 12
	corner(row, 10); mkStroke(row, 1.5, col)

	-- Emoji
	mkLabel(row, ic, Enum.Font.GothamBold, 26, C.white,
		Enum.TextXAlignment.Center,
		UDim2.new(0,0,0,0), UDim2.new(0,52,1,0)).ZIndex = 13

	-- Name
	local nameL = mkLabel(row, item.name, Enum.Font.GothamBlack, 14, C.white,
		Enum.TextXAlignment.Left,
		UDim2.new(0,56,0,6), UDim2.new(1,-64,0,20))
	nameL.ZIndex = 13

	-- CL + station
	local clStr = item.cl and item.cl > 0
		and ("🧼 +"..item.cl.."   🍳 "..item.station)
		or ("🟢 Buff/self-consume   🍳 "..item.station)
	mkLabel(row, clStr, Enum.Font.Gotham, 11, C.dim,
		Enum.TextXAlignment.Left,
		UDim2.new(0,56,0,28), UDim2.new(1,-64,0,14)).ZIndex = 13

	-- Click: select as favourite
	local capItem = item
	row.MouseButton1Click:Connect(function()
		-- Deselect previous
		if selectedFavBtn then
			selectedFavBtn.BackgroundColor3 = Color3.fromRGB(24,22,38)
			local s = selectedFavBtn:FindFirstChildWhichIsA("UIStroke")
			if s then s.Color = RARITY_COL[nr(s:GetAttribute("Rarity") or "Common")] or C.stroke end
		end
		-- Select new
		row.BackgroundColor3 = Color3.fromRGB(35,20,55)
		local s = row:FindFirstChildWhichIsA("UIStroke")
		if s then s.Color = C.purple end
		selectedFavBtn = row

		-- Update FavSelected label and fire server
		FavSelected.Text = "✓ "..capItem.name
		if Remotes then
			local r = Remotes:FindFirstChild("PlayerSelectFavourite")
			if r then r:FireServer(capItem.name) end
		end
	end)
end

