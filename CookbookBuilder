			local dot = Instance.new("Frame")
			dot.Size = UDim2.new(0,4,0.5,0)
			dot.Position = UDim2.new(0,4,0.25,0)
			dot.BackgroundColor3 = col
			dot.BorderSizePixel = 0
			dot.Parent = btn
			Instance.new("UICorner",dot).CornerRadius = UDim.new(0,2)

			local nameL = Instance.new("TextLabel")
			nameL.Size = UDim2.new(1,-14,1,0)
			nameL.Position = UDim2.new(0,12,0,0)
			nameL.BackgroundTransparency = 1
			nameL.Text = recipeName
			nameL.Font = Enum.Font.GothamMedium
