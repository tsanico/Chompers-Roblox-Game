-- ── Helpers ──────────────────────────────────────────────────
local function corner(p, r)
	Instance.new("UICorner", p).CornerRadius = UDim.new(0, r or 8)
end
local function mkStroke(p, t, c)
	local s = Instance.new("UIStroke", p)
	s.Thickness = t or 1.5; s.Color = c or C.stroke; return s
end
local function mkLabel(p, text, font, size, color, xAlign, pos, sz)
	local l = Instance.new("TextLabel")
	l.Text = text or ""; l.Font = font or Enum.Font.GothamBold
	l.TextSize = size or 14; l.TextColor3 = color or C.white
	l.TextXAlignment = xAlign or Enum.TextXAlignment.Center
	l.TextYAlignment = Enum.TextYAlignment.Center
	l.BackgroundTransparency = 1
	l.Position = pos or UDim2.new(0,0,0,0)
	l.Size = sz or UDim2.new(1,0,1,0)
	l.Parent = p; return l
end
local function mkScroll(parent, size, pos, barCol)
	local sf = Instance.new("ScrollingFrame", parent)
	sf.Size = size; sf.Position = pos
	sf.BackgroundTransparency = 1; sf.BorderSizePixel = 0
	sf.ScrollBarThickness = 6
	sf.ScrollBarImageColor3 = barCol or C.stroke
	sf.AutomaticCanvasSize = Enum.AutomaticSize.Y
	sf.CanvasSize = UDim2.new(0,0,0,0)
	local ll = Instance.new("UIListLayout", sf)
	ll.SortOrder = Enum.SortOrder.LayoutOrder
	ll.Padding = UDim.new(0,6)
	local pad = Instance.new("UIPadding", sf)
	pad.PaddingTop = UDim.new(0,6); pad.PaddingBottom = UDim.new(0,8)
	pad.PaddingLeft = UDim.new(0,8); pad.PaddingRight = UDim.new(0,8)
	return sf
end
local function mkSubTabBar(parent, h, tabs, onSwitch)
	local bar = Instance.new("Frame", parent)
	bar.Size = UDim2.new(1,0,0,h); bar.BackgroundColor3 = Color3.fromRGB(16,14,26)
	bar.BorderSizePixel = 0
	local ll = Instance.new("UIListLayout", bar)
	ll.FillDirection = Enum.FillDirection.Horizontal
	ll.HorizontalAlignment = Enum.HorizontalAlignment.Left
	ll.VerticalAlignment = Enum.VerticalAlignment.Center
	ll.Padding = UDim.new(0,2)
	local btns = {}
	for i, t in ipairs(tabs) do
		local b = Instance.new("TextButton", bar)
		b.Size = UDim2.new(1/#tabs,-2,0,h-4)
		b.BackgroundColor3 = i==1 and t.color or Color3.fromRGB(26,24,40)
		b.BorderSizePixel = 0; b.AutoButtonColor = false
		b.Font = Enum.Font.GothamBold; b.TextSize = 13
		b.TextColor3 = i==1 and C.white or C.dim
		b.Text = t.label; corner(b, 6)
		btns[t.id] = b
		local tId = t.id; local tCol = t.color
		b.MouseButton1Click:Connect(function()
			for id, btn in pairs(btns) do
				local isActive = id == tId
				btn.BackgroundColor3 = isActive and tCol or Color3.fromRGB(26,24,40)
				btn.TextColor3 = isActive and C.white or C.dim
			end
			onSwitch(tId)
		end)
	end
	return bar, btns
end

