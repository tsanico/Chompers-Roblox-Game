			btn.MouseButton1Click:Connect(function()
				-- Check if confirmed and game started
				local confirmed = _G.Chompers and
					_G.Chompers.IsConfirmed and
					_G.Chompers.IsConfirmed() or false
				if confirmed then return end

				if _G.Chompers and _G.Chompers.GetFavourite and
					_G.Chompers.GetFavourite()==recipeName then
					-- Deselect
					if _G.Chompers.SetFavourite then
						_G.Chompers.SetFavourite(nil)
					end
					btn.BackgroundColor3 = Color3.fromRGB(28,26,42)
					nameL.TextColor3 = Color3.fromRGB(190,188,210)
					selectedFavBtn = nil
					-- Update FavSelected label
					local prefPanel = ContentArea:FindFirstChild("PrefPanel")
					if prefPanel then
						local fs = prefPanel:FindFirstChild("FavSelected") -- label
						-- Find by searching children
						for _,child in ipairs(prefPanel:GetChildren()) do
							if child:IsA("TextLabel") and
								child.Text:find("⭐") then
								child.Text = "None selected"
								child.TextColor3 = Color3.fromRGB(210,148,42)
								break
							end
						end
					end
				else
					if selectedFavBtn then
						selectedFavBtn.BackgroundColor3 = Color3.fromRGB(28,26,42)
						local prev = selectedFavBtn:FindFirstChildWhichIsA("TextLabel")
						if prev then
							prev.TextColor3 = Color3.fromRGB(190,188,210)
						end
					end
					selectedFavBtn = btn
					btn.BackgroundColor3 = Color3.fromRGB(50,36,8)
					nameL.TextColor3 = col

					if _G.Chompers and _G.Chompers.SetFavourite then
						_G.Chompers.SetFavourite(recipeName)
					end

					-- Update FavSelected label in PrefPanel
					local prefPanel = ContentArea:FindFirstChild("PrefPanel")
					if prefPanel then
						for _,child in ipairs(prefPanel:GetChildren()) do
							if child:IsA("TextLabel") and
								child.TextColor3 ==
								Color3.fromRGB(210,148,42) then
								child.Text = "⭐  "..recipeName
								break
							end
						end
					end
				end

				-- Update billboard via PrelobbyGuiBuilder
				if _G.Chompers and _G.Chompers.UpdateBillboard then
					_G.Chompers.UpdateBillboard()
				end
				-- Fire remote
				local Remotes = game:GetService("ReplicatedStorage")
					:FindFirstChild("ChompersRemotes")
				if Remotes then
					Remotes.PlayerSelectFavourite:FireServer(
						_G.Chompers and _G.Chompers.GetFavourite
							and _G.Chompers.GetFavourite() or nil)
				end
			end)
		end
	end
end

