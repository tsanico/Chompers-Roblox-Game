-- ── STOVETOP ──────────────────────────────────────────────────
local function setupStovetop(part)
	local bb = Instance.new("BillboardGui", part)
	bb.Name = "StoveBillboard"
	bb.Size = UDim2.new(0, 160, 0, 52)
	bb.StudsOffset = Vector3.new(0, 4, 0)
	bb.AlwaysOnTop = false; bb.Active = false

	local stoveLbl = Instance.new("TextLabel", bb)
	stoveLbl.Name = "StoveLabel"
	stoveLbl.Size = UDim2.new(1,0,0,24)
	stoveLbl.BackgroundColor3 = Color3.fromRGB(14,12,24)
	stoveLbl.BackgroundTransparency = 0.3
	stoveLbl.BorderSizePixel = 0
	stoveLbl.Text = "🍳  STOVETOP"
	stoveLbl.Font = Enum.Font.GothamBlack; stoveLbl.TextSize = 13
	stoveLbl.TextColor3 = Color3.fromRGB(235,155,35)
	stoveLbl.TextXAlignment = Enum.TextXAlignment.Center
	Instance.new("UICorner", stoveLbl).CornerRadius = UDim.new(0, 5)

	local track = Instance.new("Frame", bb)
	track.Name = "ProgressTrack"
	track.Size = UDim2.new(1,-8,0,10)
	track.Position = UDim2.new(0,4,1,-14)
	track.BackgroundColor3 = Color3.fromRGB(28,26,40)
	track.BorderSizePixel = 0
	Instance.new("UICorner", track).CornerRadius = UDim.new(0,5)

	local fill = Instance.new("Frame", track)
	fill.Name = "ProgressFill"
	fill.Size = UDim2.new(0,0,1,0)
	fill.BackgroundColor3 = Color3.fromRGB(235,155,35)
	fill.BorderSizePixel = 0
	Instance.new("UICorner", fill).CornerRadius = UDim.new(0,5)

	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText = "Cook"
	prompt.ObjectText = "🍳  Stovetop"
	prompt.KeyboardKeyCode = Enum.KeyCode.E
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = 10
	prompt.RequiresLineOfSight = false
	prompt.Parent = part

	local function updateBillboard(text, progress)
		stoveLbl.Text = text or "🍳  STOVETOP"
		fill.Size = UDim2.new(math.clamp(progress or 0, 0, 1), 0, 1, 0)
	end

	prompt.Triggered:Connect(function(player)
		local s = PlayerState.Get(player)
		if not s or s.isEliminated then return end

		local session = cookSessions[part]

		-- [BFP-22] Sous-chef branch removed. If another player triggers
		-- a stovetop someone else is using, just ignore the input.
		if session and session.player ~= player then return end

		if heatBarSessions[player] and heatBarSessions[player] == part then
			return
		end

		if session and session.player == player then return end

		-- Find first Uncooked dish
		local uncookedSlot = nil
		for i, item in ipairs(s.inventory) do
			if item and item.cookStatus == "Uncooked" and not item.cooked then
				uncookedSlot = i; break
			end
		end
		if not uncookedSlot then
			local announce = Remotes:FindFirstChild("Announce")
			if announce then
				announce:FireClient(player,
					"🍳 No uncooked dish — assemble one at a Prep Table first.",
					Color3.fromRGB(105,100,138), 2.5)
			end
			return
		end

		local dish = s.inventory[uncookedSlot]
		-- [BFP-21] Cook time keyed by tier (was rarity, which dish never had).
		local cookTime = BarSystem.GetCookTime(dish.tier)

		local dishCopy = {}
		for k,v in pairs(dish) do dishCopy[k] = v end

		cookSessions[part] = {
			player    = player,
			dish      = dishCopy,
			slotIndex = uncookedSlot,
			startTime = tick(),
			cookTime  = cookTime,
			-- [BFP-22] sousChef field removed.
			coldRetry = false,
		}

		updateBillboard("🍳  Cooking: "..dishCopy.name, 0)
		ShowCookUI:FireClient(player, dishCopy.name, dishCopy.emoji, cookTime)

		print(string.format("[CookingServer] %s started cooking %s (%s, %.0fs)",
			player.Name, dishCopy.name, dishCopy.tier or "?", cookTime))

		-- ── Cook timer loop ────────────────────────────────────
		local session2 = cookSessions[part]
		local elapsed  = 0
		local interval = 0.25

		task.spawn(function()
			while cookSessions[part] == session2 do
				task.wait(interval)
				elapsed = tick() - session2.startTime
				local pct = math.clamp(elapsed / session2.cookTime, 0, 1)
				fill.Size = UDim2.new(pct, 0, 1, 0)
				if pct >= 1 then break end
			end

			if cookSessions[part] ~= session2 then return end

			-- [BFP-20] Single declaration of HEAT_* constants (was duplicated).
			local HEAT_SPEED  = 1.8
			local HEAT_WINDOW = 2.0
			local MISS_DELAY  = 1.2

			heatBarSessions[player] = part
			local heatStart = tick()
			heatBarStartTimes[player] = {
				startTick = heatStart, speed = HEAT_SPEED, part = part
			}

			updateBillboard("⚡ TIMING!", 1)
			BeginHeatBar:FireClient(player, dishCopy.name, HEAT_SPEED, HEAT_WINDOW,
				workspace:GetServerTimeNow())

			task.delay(HEAT_WINDOW + MISS_DELAY, function()
				if heatBarSessions[player] == part then
					heatBarSessions[player] = nil
					resolveCook(player, part, "Cold", false)
				end
			end)
		end)
	end)
end

-- ── RESOLVE COOK ─────────────────────────────────────────────
-- [BFP-19] Now properly local (was leaking to global table).
function resolveCook(player, part, zone, missedWindow)
	local session = cookSessions[part]
	if not session or session.player ~= player then return end

	-- Cold miss: extra time, then auto-resolve.
	if zone == "Cold" and not missedWindow and not session.coldRetry then
		session.coldRetry  = true
		local extraTime    = session.cookTime * 0.50
		session.startTime  = tick()
		session.cookTime   = extraTime
		heatBarSessions[player] = nil

		local announce = Remotes:FindFirstChild("Announce")
		if announce then
			announce:FireClient(player,
				"🥶 Too cold! Cooking longer…",
				Color3.fromRGB(80,160,255), 2)
		end

		task.spawn(function()
			task.wait(extraTime)
			if cookSessions[part] == session then
				resolveCook(player, part, "ColdComplete", true)
			end
		end)
		return
	end

	local finalZone = (zone == "ColdComplete") and "Cold" or zone

	-- [BFP-22] ApplyCookResult no longer takes sousChef arg.
	local finalDish = BarSystem.ApplyCookResult(session.dish, finalZone)
	finalDish.cookFinishedAt = tick()

	local s = PlayerState.Get(player)
	if s and s.inventory[session.slotIndex]
		and s.inventory[session.slotIndex].name == finalDish.name then
		s.inventory[session.slotIndex] = finalDish
		PlayerState.SyncInventory(player)
	end

	PlayerState.RecordRecipeCooked(player, finalDish.name)

	-- [BFP-22] Sous-chef points removed. Solo-cook points only.
	local rec = recByName[finalDish.name]
	-- Tier multiplier instead of rarity multiplier (recipes have tier, not rarity)
	local tierMult = (C.Points.TierMultiplier or {})[finalDish.tier] or 1
	PlayerState.AddPoints(player, (C.Points.FinishDishSolo_base or 10) * tierMult)

	cookSessions[part] = nil
	heatBarSessions[player] = nil

	local stoveBb = part:FindFirstChild("StoveBillboard")
	if stoveBb then
		local lbl = stoveBb:FindFirstChild("StoveLabel")
		if lbl then lbl.Text = "🍳  STOVETOP" end
		local tr = stoveBb:FindFirstChild("ProgressTrack")
		local fl = tr and tr:FindFirstChild("ProgressFill")
		if fl then fl.Size = UDim2.new(0,0,1,0) end
	end

	-- Legendary kill-feed announcement
	if finalDish.tier == "Legendary" then
		local KillFeedEvent = Remotes:FindFirstChild("KillFeedEvent")
		if KillFeedEvent then
			KillFeedEvent:FireAllClients("legendary_cooked", {
				chef  = player.Name,
				item  = finalDish.name,
				emoji = finalDish.emoji or "⭐",
			})
		end
	end

	CookingComplete:FireClient(player, finalDish, finalZone)
	HideCookUI:FireClient(player)

	print(string.format("[CookingServer] %s cooked %s → %s (CL=%d)",
		player.Name, finalDish.name, finalDish.cookZone or finalZone, finalDish.cl))
end

-- StopHeatBar: client pressed E. Server is authoritative for needle pos.
StopHeatBar.OnServerEvent:Connect(function(player, _ignored)
	local part = heatBarSessions[player]
	if not part then return end

	local info = heatBarStartTimes[player]
	local needlePos = 0.5

	if info then
		local elapsed = tick() - info.startTick
		local period  = 1 / info.speed
		local phase   = (elapsed % period) / period
		needlePos     = phase < 0.5 and (phase * 2) or ((1 - phase) * 2)
		heatBarStartTimes[player] = nil
	end

	local zone = BarSystem.EvaluateHeatZone(needlePos)
	heatBarSessions[player] = nil
	resolveCook(player, part, zone, false)
end)

-- ── DISTANCE LEASH ────────────────────────────────────────────
local LEASH_DISTANCE = 12
task.spawn(function()
	while true do
		task.wait(0.5)
		for part, session in pairs(cookSessions) do
			local player = session.player
			local char   = player and player.Character
			local hrp    = char and char:FindFirstChild("HumanoidRootPart")
			if hrp and part and part.Parent then
				if (hrp.Position - part.Position).Magnitude > LEASH_DISTANCE then
					cookSessions[part]        = nil
					heatBarSessions[player]   = nil
					heatBarStartTimes[player] = nil
					HideCookUI:FireClient(player)
					CookingCancelled:FireClient(player, "too_far")
					if AnnounceRemote then
						-- [BFP-18] Mojibake fixed: was "ð³"
						AnnounceRemote:FireClient(player,
							"🌳  You moved too far — cooking cancelled. Dish still in your bag.",
							Color3.fromRGB(220,80,60), 3)
					end
				end
			end
		end
	end
end)

-- ── HIT-CANCEL HOOK ──────────────────────────────────────────
_G.NotifyCookingHit = function(player)
	for part, session in pairs(cookSessions) do
		if session.player == player then
			session.startTime = tick()
			if heatBarSessions[player] then
				heatBarSessions[player]   = nil
				heatBarStartTimes[player] = nil
				CookingCancelled:FireClient(player, "hit_during_heat")
				ShowCookUI:FireClient(player,
					session.dish.name, session.dish.emoji, session.cookTime)
			end
			if AnnounceRemote then
				-- [BFP-18] Mojibake fixed: was "ð¥"
				AnnounceRemote:FireClient(player,
					"🔥  Hit during cooking — heat reset!",
					Color3.fromRGB(220,80,60), 2)
			end
			break
		end
	end
end

-- ── SCAN WORKSPACE FOR STATIONS ───────────────────────────────
local function setupAll()
	local nPrep, nStove = 0, 0
	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("BasePart") then
			if desc:GetAttribute("IsPrep") == true then
				setupPrepTable(desc); nPrep = nPrep + 1
			elseif desc:GetAttribute("IsStovetop") == true then
				setupStovetop(desc); nStove = nStove + 1
			end
		end
	end
	print(string.format("[CookingServer] Registered %d prep table(s), %d stovetop(s)",
		nPrep, nStove))
end

Players.PlayerRemoving:Connect(function(player)
	prepSessions[player]   = nil
	heatBarSessions[player] = nil
	for part, session in pairs(cookSessions) do
		if session.player == player then
			cookSessions[part] = nil
		end
	end
end)

setupAll()
print("[CookingServer] Ready")
