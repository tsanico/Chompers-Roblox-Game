-- ============================================================
-- DoorSystem — Script (final)
-- Location: ServerScriptService > DoorSystem
--
-- New attributes supported:
--   SlideOnGathering bool  — slides open at gathering start (main entry doors)
--                            all other OpenOnGathering doors disappear
--   HingeOffset      num   — studs from centre to hinge edge in local X
--   SwingAngle       num   — degrees; sign controls direction
--   SlideDirection   num   — ±1 for split-panel halves
--   ApproachRange    num   — per-door override of global approach range
-- ============================================================

local Players             = game:GetService("Players")
local TweenService        = game:GetService("TweenService")
local ServerScriptService = game:GetService("ServerScriptService")

local PhaseChangedEvent = ServerScriptService:FindFirstChild("PhaseChangedEvent")
if not PhaseChangedEvent then
	PhaseChangedEvent = Instance.new("BindableEvent")
	PhaseChangedEvent.Name   = "PhaseChangedEvent"
	PhaseChangedEvent.Parent = ServerScriptService
end

local APPROACH_RANGE  = 14     -- global default; override with ApproachRange attr
local POLL_INTERVAL   = 0.25
local SLIDE_DURATION  = 0.5    -- slightly slower for smooth grocery-store feel
local SWING_DURATION  = 0.30
local DEFAULT_SWING   = 100

local currentPhase = "Prelobby"
local doorStates   = {}

-- ── Find Doors folder ─────────────────────────────────────────
local function findDoorsFolder()
	local map = workspace:FindFirstChild("Map")
	if map then local d=map:FindFirstChild("Doors"); if d then return d end end
	return workspace:FindFirstChild("Doors")
end
local DoorsFolder = nil
local function waitForDoors()
	for i=1,20 do
		DoorsFolder = findDoorsFolder()
		if DoorsFolder then break end
		task.wait(0.5)
	end
	if not DoorsFolder then warn("[DoorSystem] Doors folder not found") end
	return DoorsFolder
end

local tweenInfo_slide = TweenInfo.new(SLIDE_DURATION, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local tweenInfo_swing = TweenInfo.new(SWING_DURATION, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

-- ── Slide vector (fixed) ──────────────────────────────────────
-- Thin-in-X doors (face ⊥ X): slide along Z using -LookVector
-- Thin-in-Z doors (face ⊥ Z): slide along X using RightVector
-- SlideDirection (±1) controls which half goes which way
local function getSlideVector(door)
	local size = door.Size
	local cf   = door.CFrame
	local dir  = door:GetAttribute("SlideDirection") or 1
	if size.X <= 3 then
		return -cf.LookVector * size.Z * 0.9 * dir
	else
		return cf.RightVector * size.X * 0.9 * dir
	end
end

-- ── Hinge-pivot CFrame ────────────────────────────────────────
local function getHingeCF(door, state, angleDeg)
	local hingeOffset = door:GetAttribute("HingeOffset") or 0
	local origCF      = state.origCFrame
	local pivotCF     = origCF * CFrame.new(hingeOffset, 0, 0)
	local localCF     = pivotCF:Inverse() * origCF
	return (pivotCF * CFrame.Angles(0, math.rad(angleDeg), 0)) * localCF
end

-- ── Disappear / reappear ──────────────────────────────────────
local function disappearDoor(door, state)
	if state.isOpen then return end
	door.Transparency=1; door.CanCollide=false
	state.isOpen=true; door:SetAttribute("IsOpen",true)
end
local function reappearDoor(door, state)
	if not state.isOpen or state.lockedOpen then return end
	door.Transparency=0; door.CanCollide=true
	state.isOpen=false; door:SetAttribute("IsOpen",false)
end

-- ── Open / close ──────────────────────────────────────────────
local function tweenDoorOpen(door, state)
	if state.isOpen then return end
	local doorType = door:GetAttribute("DoorType") or "AutoSliding"
	if doorType == "AutoSliding" then
		TweenService:Create(door, tweenInfo_slide,
			{CFrame = state.origCFrame + getSlideVector(door)}):Play()
	elseif doorType == "Hinged" or doorType == "ButcherSwing" then
		local angle = door:GetAttribute("SwingAngle") or DEFAULT_SWING
		TweenService:Create(door, tweenInfo_swing,
			{CFrame = getHingeCF(door, state, angle)}):Play()
	end
	state.isOpen=true; door:SetAttribute("IsOpen",true)
end

local function tweenDoorClose(door, state)
	if not state.isOpen or state.lockedOpen then return end
	if door.Transparency == 1 then reappearDoor(door, state); return end
	local doorType = door:GetAttribute("DoorType") or "AutoSliding"
	if doorType == "Hinged" or doorType == "ButcherSwing" then
		TweenService:Create(door, tweenInfo_swing, {CFrame=state.origCFrame}):Play()
	else
		TweenService:Create(door, tweenInfo_slide, {CFrame=state.origCFrame}):Play()
	end
	state.isOpen=false; door:SetAttribute("IsOpen",false)
end

-- ── Register ──────────────────────────────────────────────────
local function registerDoor(door)
	if not door:IsA("BasePart") then return end
	if not door:GetAttribute("DoorType") then return end
	doorStates[door] = {
		isOpen     = false,
		lockedOpen = door:GetAttribute("StaysOpen") == true,
		origCFrame = door.CFrame,
	}
	door.Anchored = true
end

-- ── Phase control ─────────────────────────────────────────────
local function openGatheringDoors()
	for door, state in pairs(doorStates) do
		if door:GetAttribute("SlideOnGathering") then
			-- Main entry doors: slide open and lock open through FoodFight
			tweenDoorOpen(door, state)
			state.lockedOpen = true
		else
			-- Everything else: disappear (butcher, fire exits, WC, knobs, handles)
			disappearDoor(door, state)
		end
	end
end

local function closeAllDoors()
	for door, state in pairs(doorStates) do
		state.lockedOpen = false
		if door.Transparency == 1 then
			reappearDoor(door, state)
		else
			tweenDoorClose(door, state)
		end
		-- Restore StaysOpen for next match if applicable
		-- (StaysOpen here means "stays open during gathering phase", not forever)
		-- We reset it so doors close correctly at EndGame
	end
end

-- ── Proximity helpers ─────────────────────────────────────────
local function getNearestPlayer(position)
	local nearest, nearestDist = nil, math.huge
	for _, player in ipairs(Players:GetPlayers()) do
		local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			local dist = (hrp.Position - position).Magnitude
			if dist < nearestDist then nearest=player; nearestDist=dist end
		end
	end
	return nearest, nearestDist
end

local function isOnInteriorSide(door, playerPos)
	local exitDir = door:GetAttribute("ExitDirection")
	if not exitDir then return true end
	return door.CFrame.LookVector:Dot((playerPos - door.Position).Unit) < 0
end

local function swingTowardPlayer(door, state, playerPos)
	if state.isOpen then return end
	local dot = door.CFrame.LookVector:Dot((playerPos - door.Position).Unit)
	local base = door:GetAttribute("SwingAngle") or DEFAULT_SWING
	TweenService:Create(door, tweenInfo_swing,
		{CFrame=getHingeCF(door,state, dot>=0 and base or -base)}):Play()
	state.isOpen=true; door:SetAttribute("IsOpen",true)
end

-- ── Proximity loop ────────────────────────────────────────────
local function runProximityLoop()
	while true do
		task.wait(POLL_INTERVAL)
		if not DoorsFolder then continue end
		for door, state in pairs(doorStates) do
			if not door:GetAttribute("OpenOnApproach") then continue end
			if state.lockedOpen then continue end

			local range = door:GetAttribute("ApproachRange") or APPROACH_RANGE
			local nearest, dist = getNearestPlayer(door.Position)

			if dist <= range then
				if door:GetAttribute("OneWayExit") then
					local hrp = nearest.Character and nearest.Character:FindFirstChild("HumanoidRootPart")
					if not hrp or not isOnInteriorSide(door, hrp.Position) then
						if state.isOpen then tweenDoorClose(door, state) end
						continue
					end
				end
				if door:GetAttribute("DoorType")=="ButcherSwing"
					and door:GetAttribute("TwoWaySwing") then
					local hrp = nearest.Character and nearest.Character:FindFirstChild("HumanoidRootPart")
					if hrp then swingTowardPlayer(door, state, hrp.Position) end
				else
					tweenDoorOpen(door, state)
				end
			else
				if state.isOpen then tweenDoorClose(door, state) end
			end
		end
	end
end

-- ── Phase listener ────────────────────────────────────────────
PhaseChangedEvent.Event:Connect(function(newPhase)
	currentPhase = newPhase
	if newPhase=="Gathering" or newPhase=="Cooking"
		or newPhase=="FoodFight" or newPhase=="CookingGrace" then
		openGatheringDoors()
	elseif newPhase=="Prelobby" or newPhase=="EndGame" then
		task.wait(1); closeAllDoors()
	end
end)

-- ── Boot ──────────────────────────────────────────────────────
task.spawn(function()
	waitForDoors()
	if not DoorsFolder then return end
	for _, part in ipairs(DoorsFolder:GetChildren()) do registerDoor(part) end
	DoorsFolder.ChildAdded:Connect(registerDoor)
	local n=0; for _ in pairs(doorStates) do n=n+1 end
	print(string.format("[DoorSystem] final — %d doors registered", n))
	task.spawn(runProximityLoop)
	print("[DoorSystem] Boot complete")
end)
