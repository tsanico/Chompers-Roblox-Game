-- ============================================================
-- ThrowClient — LocalScript · StarterPlayerScripts
--
-- Tap-to-throw (overhead lift feel, matching video reference):
--   • LMB tap → overhead lift animation plays
--   • At animation peak (~0.4s) → ThrowFood fires to server
--   • Servings pip indicator: Common=3 pips, Uncommon=2, Rare/UR/Leg=1
--   • 0.8s cooldown (Bible Part 33, locked)
--   • No hold/charge/arc preview — tap fires immediately
--
-- Animation setup:
--   1. Make overhead lift animation in Studio Animation Editor.
--      Arms peak overhead at frame 18 (30fps default) = 0.6s.
--   2. Publish → copy asset ID → paste into THROW_ANIM_ID below.
--   3. Server spawns physics clone at ANIM_PEAK_TIME seconds.
-- ============================================================

local Players          = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")

local player  = Players.LocalPlayer
local camera  = workspace.CurrentCamera
local Remotes = ReplicatedStorage:WaitForChild("ChompersRemotes", 15)

local waited = 0
while not (_G.Chompers and _G.Chompers.GetSelectedSlot) and waited < 8 do
	task.wait(0.05); waited = waited + 0.05
end

local ThrowFood = Remotes:WaitForChild("ThrowFood", 15)

-- ── Config ─────────────────────────────────────────────────────
-- Paste your Studio Animation Editor asset ID here after publishing
local THROW_ANIM_ID  = "rbxassetid://0"
local ANIM_PEAK_TIME = 0.6   -- frame 18 at 30fps (Studio Animation Editor)
local COOLDOWN       = 0.8   -- Bible Part 33, locked
local THROW_SPEED    = 160   -- studs/s lateral (2× Bible base for distance)

-- ── Servings by rarity (Bible §Servings by Rarity) ────────────
local SERVINGS = { Common=3, Uncommon=2, Rare=1, UltraRare=1, Legendary=1 }

-- ── ScreenGui ──────────────────────────────────────────────────
local playerGui = player:WaitForChild("PlayerGui")
local ThrowGui  = Instance.new("ScreenGui")
ThrowGui.Name           = "ThrowUI"
ThrowGui.ResetOnSpawn   = false
ThrowGui.IgnoreGuiInset = true
ThrowGui.DisplayOrder   = 5
ThrowGui.Parent         = playerGui

-- Warning label (reused pattern from old client)
local WarnLabel = Instance.new("TextLabel", ThrowGui)
WarnLabel.Size                  = UDim2.new(0, 380, 0, 28)
WarnLabel.AnchorPoint           = Vector2.new(0.5, 1)
WarnLabel.Position              = UDim2.new(0.5, 0, 1, -120)
WarnLabel.BackgroundTransparency = 1
WarnLabel.Font                  = Enum.Font.GothamBlack
WarnLabel.TextSize              = 14
WarnLabel.TextColor3            = Color3.fromRGB(255, 90, 90)
WarnLabel.TextXAlignment        = Enum.TextXAlignment.Center
WarnLabel.Visible               = false
WarnLabel.ZIndex                = 10

-- Servings pip row (up to 3 pips, one per serving)
local ServingsRow = Instance.new("Frame", ThrowGui)
ServingsRow.Name                  = "ServingsRow"
ServingsRow.Size                  = UDim2.new(0, 76, 0, 12)
ServingsRow.AnchorPoint           = Vector2.new(0.5, 1)
ServingsRow.Position              = UDim2.new(0.5, 0, 1, -150)
ServingsRow.BackgroundTransparency = 1
ServingsRow.Visible               = false

local pips = {}
for i = 1, 3 do
	local pip = Instance.new("Frame", ServingsRow)
	pip.Size             = UDim2.new(0, 18, 0, 10)
	pip.Position         = UDim2.new(0, (i-1)*25, 0.5, -5)
	pip.BorderSizePixel  = 0
	Instance.new("UICorner", pip).CornerRadius = UDim.new(0, 4)
	pips[i] = pip
end

local COL_FULL  = Color3.fromRGB(65, 200, 100)
local COL_EMPTY = Color3.fromRGB(50, 50, 60)

local function refreshServingsUI()
	local slot = _G.Chompers.GetSelectedSlot and _G.Chompers.GetSelectedSlot() or 1
	local inv  = _G.Chompers.GetInventory and _G.Chompers.GetInventory()
	local item = inv and inv[slot]
	if not item then ServingsRow.Visible = false; return end

	local rarity  = item.rarity or "Common"
	local maxS    = SERVINGS[rarity] or 1
	local leftS   = item.servingsLeft or maxS

	-- Only show pips for multi-serving items
	if maxS <= 1 then ServingsRow.Visible = false; return end
	ServingsRow.Visible = true

	for i = 1, 3 do
		pips[i].Visible          = (i <= maxS)
		pips[i].BackgroundColor3 = (i <= leftS) and COL_FULL or COL_EMPTY
	end
end

local warnTw = nil
local function showWarn(msg)
	if warnTw then warnTw:Cancel() end
	WarnLabel.Text = msg; WarnLabel.TextTransparency = 0; WarnLabel.Visible = true
	warnTw = TweenService:Create(WarnLabel,
		TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In, 0, false, 1.2),
		{TextTransparency = 1})
	warnTw:Play()
	warnTw.Completed:Connect(function() WarnLabel.Visible = false end)
end

-- ── Helpers ────────────────────────────────────────────────────
local function isBlocked()
	if UserInputService:GetFocusedTextBox() then return true end
	if _G.Chompers.IsStoreGuideOpen and _G.Chompers.IsStoreGuideOpen() then return true end
	if _G.Chompers.GetInventoryOpen  and _G.Chompers.GetInventoryOpen()  then return true end
	local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	return not hum or hum.Health <= 0
end

local function getAimPoint()
	local sz  = camera.ViewportSize
	local ray = camera:ScreenPointToRay(sz.X/2, sz.Y/2)
	local p   = RaycastParams.new()
	if player.Character then
		p.FilterDescendantsInstances = {player.Character}
		p.FilterType = Enum.RaycastFilterType.Exclude
	end
	local r = workspace:Raycast(ray.Origin, ray.Direction * 200, p)
	return r and r.Position or (ray.Origin + ray.Direction * 80)
end

-- ── Animation ──────────────────────────────────────────────────
local loadedAnim = nil
local function ensureAnim()
	local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	if not hum or THROW_ANIM_ID == "rbxassetid://0" then return nil end
	if loadedAnim then return loadedAnim end
	local ao = Instance.new("Animation"); ao.AnimationId = THROW_ANIM_ID
	local t  = hum:LoadAnimation(ao)
	t.Priority = Enum.AnimationPriority.Action
	loadedAnim = t
	return t
end

-- ── State ──────────────────────────────────────────────────────
local throwing     = false
local blockedUntil = 0

-- ── Core throw sequence ────────────────────────────────────────
local function doThrow()
	if throwing or isBlocked() then return end
	if tick() < blockedUntil then return end

	local slot = _G.Chompers.GetSelectedSlot and _G.Chompers.GetSelectedSlot() or 1
	local inv  = _G.Chompers.GetInventory and _G.Chompers.GetInventory()
	local item = inv and inv[slot]

	if not item then showWarn("❌  No item in slot "..slot); return end
	if not item.paid then showWarn("🏷️  Pay at Checkout first"); return end
	if item.name == "Alliance Bracelet" then showWarn("🤝  Can't throw the bracelet"); return end

	throwing      = true
	blockedUntil  = tick() + COOLDOWN

	-- Lock aim direction at throw intent (before animation delay)
	local aimPoint = getAimPoint()

	-- Play overhead lift animation
	local track = ensureAnim()
	if track then track:Play() end

	-- Fire to server at animation peak
	task.delay(ANIM_PEAK_TIME, function()
		local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
		if hrp and not isBlocked() then
			ThrowFood:FireServer(slot, THROW_SPEED, aimPoint)
		end
		-- Stop animation shortly after throw
		if track then
			task.delay(0.15, function()
				if track.IsPlaying then track:Stop(0.15) end
			end)
		end
		throwing = false
	end)

	-- Optimistic servings decrement on client (server is authoritative)
	if item then
		local rarity = item.rarity or "Common"
		local maxS   = SERVINGS[rarity] or 1
		if not item.servingsLeft then item.servingsLeft = maxS end
		if item.servingsLeft > 1 then
			item.servingsLeft = item.servingsLeft - 1
		elseif item.servingsLeft == 1 then
			-- Last serving just thrown — hide pips immediately
			ServingsRow.Visible = false
			return  -- skip refreshServingsUI, row is gone
		end
		refreshServingsUI()
	end
end

-- ── Input ──────────────────────────────────────────────────────
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.KeyCode       == Enum.KeyCode.ButtonR2 then
		doThrow()
	end
end)

-- ── Slot-change servings refresh ──────────────────────────────
task.spawn(function()
	local last = nil
	while true do
		task.wait(0.1)
		if _G.Chompers and _G.Chompers.GetSelectedSlot then
			local s = _G.Chompers.GetSelectedSlot()
			if s ~= last then refreshServingsUI(); last = s end
		end
	end
end)

-- ── Reset on respawn ───────────────────────────────────────────
player.CharacterAdded:Connect(function()
	loadedAnim = nil; throwing = false; blockedUntil = 0
end)

print("[ThrowClient] Ready")
