-- ============================================================
-- ThrowClient — LocalScript · StarterPlayerScripts
--
-- LMB HOLD  → starts charging immediately
--              arc preview dots appear and track camera aim
--              charge bar fills blue → red
--              NO camera or FOV changes — camera stays free
-- LMB RELEASE → fires at current charge
-- AUTO-FIRE   → holds at full charge for 0.25s grace, then fires
-- RMB         → cancel current charge without firing
--
-- Charge curve (eased, not linear):
--   alpha     = clamp((held - MinCharge) / (MaxCharge - MinCharge), 0, 1)
--   eased     = alpha ^ 0.8       (front-loaded: mid-charge is strong)
--   horizSpeed = MinSpeed + (MaxSpeed - MinSpeed) * eased  → 66..85 st/s
--   range      = MinRange + (MaxRange - MinRange) * eased   → 20..50 st
--
-- Sends ThrowFood(slot, horizSpeed, targetPos) to ThrowServer.
-- ============================================================

local Players          = game:GetService("Players")
local ReplicatedStorage= game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local RunService       = game:GetService("RunService")
local TweenService     = game:GetService("TweenService")

local player  = Players.LocalPlayer
local camera  = workspace.CurrentCamera
local Remotes = ReplicatedStorage:WaitForChild("ChompersRemotes", 15)
local C_Data  = require(ReplicatedStorage:WaitForChild("ChompersData")).Constants

local waited = 0
while not (_G.Chompers and _G.Chompers.GetSelectedSlot) and waited < 8 do
	task.wait(0.05); waited = waited + 0.05
end

local ThrowFood = Remotes:WaitForChild("ThrowFood", 15)

-- ── Constants ─────────────────────────────────────────────────
local C      = C_Data.Throw
local G_EFF  = C.EffectiveGravity or 175   -- studs/s²

local ARC_DOTS = 14
local ARC_DT   = 0.055

-- ── Own ScreenGui ─────────────────────────────────────────────
local playerGui = player:WaitForChild("PlayerGui")
local ThrowGui  = Instance.new("ScreenGui")
ThrowGui.Name = "ThrowUI"; ThrowGui.ResetOnSpawn = false
ThrowGui.IgnoreGuiInset = true; ThrowGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ThrowGui.DisplayOrder = 5; ThrowGui.Parent = playerGui

-- ── Charge bar ────────────────────────────────────────────────
local ChargeBar = Instance.new("Frame", ThrowGui)
ChargeBar.Name = "ChargeBar"
ChargeBar.Size = UDim2.new(0, 340, 0, 18)
ChargeBar.AnchorPoint = Vector2.new(0.5, 1)
ChargeBar.Position = UDim2.new(0.5, 0, 1, -120)
ChargeBar.BackgroundColor3 = Color3.fromRGB(18, 16, 28)
ChargeBar.BorderSizePixel = 0; ChargeBar.Visible = false; ChargeBar.ZIndex = 10
local _cc = Instance.new("UICorner", ChargeBar); _cc.CornerRadius = UDim.new(0, 9)
local _cs = Instance.new("UIStroke", ChargeBar); _cs.Color = Color3.fromRGB(80,76,110); _cs.Thickness = 1.5

local ChargeFill = Instance.new("Frame", ChargeBar)
ChargeFill.Size = UDim2.new(0, 0, 1, 0)
ChargeFill.BackgroundColor3 = Color3.fromRGB(65, 140, 255)
ChargeFill.BorderSizePixel = 0; ChargeFill.ZIndex = 11
local _cf = Instance.new("UICorner", ChargeFill); _cf.CornerRadius = UDim.new(0, 9)

-- ── Arc preview dots ──────────────────────────────────────────
local arcDots = {}
for i = 1, ARC_DOTS do
	local dot = Instance.new("Part")
	dot.Shape = Enum.PartType.Ball; dot.Size = Vector3.new(0.28, 0.28, 0.28)
	dot.Color = Color3.fromRGB(255, 210, 50); dot.Material = Enum.Material.Neon
	dot.CanCollide = false; dot.Anchored = true; dot.CastShadow = false
	dot.Transparency = 0.12 + (i / ARC_DOTS) * 0.70
	dot.CFrame = CFrame.new(0, -2000, 0); dot.Parent = workspace
	arcDots[i] = dot
end

local function hideArcDots()
	for _, d in ipairs(arcDots) do d.CFrame = CFrame.new(0, -2000, 0) end
end

-- ── State ─────────────────────────────────────────────────────
local charging    = false
local holdStart   = 0
local graceStart  = nil     -- set when full charge first reached
local lastThrow   = 0

-- ── Helpers ───────────────────────────────────────────────────
local function isBlocked()
	if UserInputService:GetFocusedTextBox() then return true end
	if _G.Chompers.IsStoreGuideOpen and _G.Chompers.IsStoreGuideOpen() then return true end
	if _G.Chompers.GetInventoryOpen and _G.Chompers.GetInventoryOpen() then return true end
	local char = player.Character
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	if not hum or hum.Health <= 0 then return true end
	return false
end

local function getHRP()
	local c = player.Character; return c and c:FindFirstChild("HumanoidRootPart")
end

local function getOrigin()
	local hrp = getHRP(); if not hrp then return nil end
	return hrp.Position + Vector3.new(0, 1.5, 0)
end

-- Screen-centre raycast so aim follows camera crosshair exactly
local function getAimPoint()
	local sz     = camera.ViewportSize
	local unitRay= camera:ScreenPointToRay(sz.X/2, sz.Y/2)
	local params = RaycastParams.new()
	local char   = player.Character
	if char then
		params.FilterDescendantsInstances = {char}
		params.FilterType = Enum.RaycastFilterType.Exclude
	end
	local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 400, params)
	return result and result.Position or (unitRay.Origin + unitRay.Direction * 80)
end

-- Eased charge curve — front-loaded so mid-charge feels strong
local function getChargeParams(elapsed)
	local held  = math.max(0, elapsed - C.MinCharge)
	local alpha = math.clamp(held / (C.MaxCharge - C.MinCharge), 0, 1)
	local eased = alpha ^ 0.8
	local horizSpeed = C.MinSpeed + (C.MaxSpeed - C.MinSpeed) * eased
	local range      = C.MinRange + (C.MaxRange - C.MinRange) * eased
	return horizSpeed, range, eased
end

local function chargeColour(eased)
	return Color3.new(0.15 + eased*0.70, 0.08*(1-eased), (1-eased)*0.75 + 0.05)
end

-- Ballistic solver: given horizontal speed, find launch velocity to hit target
local function computeVelocity(origin, target, horizSpeed)
	local disp  = target - origin
	local hDist = Vector3.new(disp.X, 0, disp.Z).Magnitude
	if hDist < 0.5 then hDist = 0.5 end
	local T = hDist / math.max(horizSpeed, 4)
	return disp / T + Vector3.new(0, 0.5 * G_EFF * T, 0)
end

local function simulateArc(origin, vel)
	local pts = {}
	local pos, v = origin, vel
	local grav = Vector3.new(0, -G_EFF, 0)
	for i = 1, ARC_DOTS do
		pos = pos + v * ARC_DT; v = v + grav * ARC_DT
		pts[i] = pos; if pos.Y < -50 then break end
	end
	return pts
end

local function updateArcDots(origin, vel)
	local pts = simulateArc(origin, vel)
	for i, dot in ipairs(arcDots) do
		dot.CFrame = pts[i] and CFrame.new(pts[i]) or CFrame.new(0,-2000,0)
	end
end

-- ── Throw ─────────────────────────────────────────────────────
local function doThrow(horizSpeed)
	if tick() - lastThrow < (C.Cooldown or 0.8) then return end
	local origin = getOrigin(); if not origin then return end
	local aimPt  = getAimPoint()
	-- Clamp target to current range
	local flat = Vector3.new(aimPt.X-origin.X, 0, aimPt.Z-origin.Z)
	local range = C.MinRange + (C.MaxRange - C.MinRange) *
		math.clamp((horizSpeed - C.MinSpeed) / math.max(C.MaxSpeed - C.MinSpeed, 1), 0, 1)
	if flat.Magnitude > range then
		aimPt = origin + (flat.Unit * range) + Vector3.new(0, aimPt.Y - origin.Y, 0)
	end
	local slot = _G.Chompers.GetSelectedSlot and _G.Chompers.GetSelectedSlot() or 1
	lastThrow  = tick()
	ThrowFood:FireServer(slot, horizSpeed, aimPt)
end

local function cancelCharge()
	charging = false; graceStart = nil
	ChargeBar.Visible = false
	hideArcDots()
end

-- ── Heartbeat — charge bar + arc + grace window ───────────────
RunService.Heartbeat:Connect(function()
	if not charging then return end

	local elapsed = tick() - holdStart
	local horizSpeed, range, eased = getChargeParams(elapsed)
	local atCap = elapsed >= C.MaxCharge

	-- Grace window: hold at cap for GracePeriod before auto-fire
	if atCap then
		if not graceStart then graceStart = tick() end
		if tick() - graceStart >= (C.GracePeriod or 0.25) then
			cancelCharge()
			if not isBlocked() then doThrow(C.MaxSpeed) end
			return
		end
		-- Flash bar at full charge during grace
		local flash = math.floor(tick() * 8) % 2 == 0
		ChargeFill.BackgroundColor3 = flash
			and Color3.fromRGB(255, 255, 100)
			or  Color3.fromRGB(220, 60, 30)
		ChargeFill.Size = UDim2.new(1, 0, 1, 0)
	else
		graceStart = nil
		ChargeFill.BackgroundColor3 = chargeColour(eased)
		TweenService:Create(ChargeFill, TweenInfo.new(0.04),
			{Size = UDim2.new(elapsed / C.MaxCharge, 0, 1, 0),
			 BackgroundColor3 = chargeColour(eased)}):Play()
	end
	ChargeBar.Visible = true

	-- Arc preview
	local origin = getOrigin()
	if origin then
		local vel = computeVelocity(origin, getAimPoint(), horizSpeed)
		updateArcDots(origin, vel)
	end
end)

-- ── Input ─────────────────────────────────────────────────────
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end

	-- RMB → cancel charge without firing
	if input.UserInputType == Enum.UserInputType.MouseButton2
		or input.KeyCode == Enum.KeyCode.ButtonL2 then
		cancelCharge(); return
	end

	-- LMB → start charging
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.KeyCode == Enum.KeyCode.ButtonR2 then
		if isBlocked() then return end
		if charging then return end   -- already charging
		charging  = true
		holdStart = tick()
		graceStart = nil
	end
end)

UserInputService.InputEnded:Connect(function(input)
	-- LMB release → fire at current charge
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.KeyCode == Enum.KeyCode.ButtonR2 then
		if not charging then return end
		local elapsed = tick() - holdStart
		local horizSpeed = getChargeParams(elapsed)
		cancelCharge()
		if not isBlocked() then doThrow(horizSpeed) end
	end
end)

print("[ThrowClient] Ready")
