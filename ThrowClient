-- ── Arc preview dots ───────────────────────────────────────────
local arcDots = {}
for i = 1, ARC_DOTS do
	local dot = Instance.new("Part")
	dot.Shape         = Enum.PartType.Ball
	dot.Size          = Vector3.new(0.28, 0.28, 0.28)
	dot.Color         = Color3.fromRGB(255, 210, 50)
	dot.Material      = Enum.Material.Neon
	dot.CanCollide    = false
	dot.Anchored      = true
	dot.CastShadow    = false
	dot.Transparency  = 0.12 + (i / ARC_DOTS) * 0.70
	dot.CFrame        = CFrame.new(0, -2000, 0)
	dot.Parent        = workspace
	arcDots[i]        = dot
end

local function hideArcDots()
	for _, d in ipairs(arcDots) do d.CFrame = CFrame.new(0, -2000, 0) end
end

-- ── State ──────────────────────────────────────────────────────
local charging           = false
local holdStart          = 0
local chargeBlockedUntil = 0
local preChargeSpeed     = nil
local smoothedAimPoint   = nil   -- lerped aim for preview stability

-- ── Helpers ────────────────────────────────────────────────────
local function isBlocked()
	if UserInputService:GetFocusedTextBox() then return true end
	if _G.Chompers.IsStoreGuideOpen and _G.Chompers.IsStoreGuideOpen() then return true end
	if _G.Chompers.GetInventoryOpen and _G.Chompers.GetInventoryOpen() then return true end
	local char = player.Character
	local hum  = char and char:FindFirstChildOfClass("Humanoid")
	if not hum or hum.Health <= 0 then return true end
	return false
end

-- Clamp raw aim point to charge-based max range (flat horizontal)
local function clampAimPoint(origin, rawTarget, horizSpeed)
	local minRange = C.MinRange or 20
	local maxRange = C.MaxRange or 50
	local alpha    = math.clamp(
		(horizSpeed - (C.MinSpeed or 66)) / math.max((C.MaxSpeed or 85) - (C.MinSpeed or 66), 1),
		0, 1)
	local allowed  = minRange + (maxRange - minRange) * alpha

	local flat = Vector3.new(rawTarget.X - origin.X, 0, rawTarget.Z - origin.Z)
	local dist = flat.Magnitude
	if dist < 0.001 then
		local look = camera.CFrame.LookVector
		flat = Vector3.new(look.X, 0, look.Z)
		dist = math.max(flat.Magnitude, 0.001)
	end
	local clamped = flat.Unit * math.min(dist, allowed)
	local y = math.clamp(rawTarget.Y, origin.Y - 8, origin.Y + 12)
	return Vector3.new(origin.X, 0, origin.Z) + clamped + Vector3.new(0, y, 0)
end

local function getHumanoid()
	local c = player.Character
	return c and c:FindFirstChildOfClass("Humanoid")
end

local function getOrigin()
	local c   = player.Character
	local hrp = c and c:FindFirstChild("HumanoidRootPart")
	return hrp and (hrp.Position + Vector3.new(0, 1.5, 0)) or nil
end

local function getAimPoint()
	local sz     = camera.ViewportSize
	local ray    = camera:ScreenPointToRay(sz.X / 2, sz.Y / 2)
	local params = RaycastParams.new()
	local char   = player.Character
	if char then
		params.FilterDescendantsInstances = {char}
		params.FilterType = Enum.RaycastFilterType.Exclude
	end
	local result = workspace:Raycast(ray.Origin, ray.Direction * 400, params)
	return result and result.Position or (ray.Origin + ray.Direction * 80)
end

-- Eased charge curve — front-loaded so mid-charge is already strong
local function getChargeParams(elapsed)
	local held  = math.max(0, elapsed - MIN_CHARGE)
	local alpha = math.clamp(held / (MAX_CHARGE - MIN_CHARGE), 0, 1)
	local eased = alpha ^ 0.8
	return
		C.MinSpeed + (C.MaxSpeed - C.MinSpeed) * eased,
		C.MinRange + (C.MaxRange - C.MinRange) * eased,
		eased
end

local function chargeColour(eased)
	return Color3.new(0.15 + eased * 0.70, 0.08 * (1 - eased), (1 - eased) * 0.75 + 0.05)
end

-- Ballistic solver
local function computeVelocity(origin, target, horizSpeed)
	local disp  = target - origin
	local hDist = Vector3.new(disp.X, 0, disp.Z).Magnitude
	if hDist < 0.5 then hDist = 0.5 end
	local T = hDist / math.max(horizSpeed, 4)
	return disp / T + Vector3.new(0, 0.5 * G_EFF * T, 0)
end

local function updateArcDots(origin, vel)
	local pos, v = origin, vel
	local grav   = Vector3.new(0, -G_EFF, 0)
	for _, dot in ipairs(arcDots) do
		pos = pos + v * ARC_DT
		v   = v   + grav * ARC_DT
		dot.CFrame = (pos.Y > -50) and CFrame.new(pos) or CFrame.new(0, -2000, 0)
	end
end

-- ── Speed debuff ───────────────────────────────────────────────
local function applySpeedDebuff()
	local hum = getHumanoid(); if not hum then return end
	preChargeSpeed = hum.WalkSpeed
	TweenService:Create(hum,
		TweenInfo.new(SPEED_RAMP, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{WalkSpeed = preChargeSpeed * SPEED_MULT}):Play()
end

local function restoreSpeed()
	local hum = getHumanoid()
	if hum and preChargeSpeed then
		TweenService:Create(hum,
			TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{WalkSpeed = preChargeSpeed}):Play()
	end
	preChargeSpeed = nil
end

-- ── Throw warning hint (non-intrusive, near crosshair) ────────
-- Appears briefly when player tries to throw an empty slot or
-- an unpaid item. Does NOT use the main Announce system.
local ThrowWarnLabel = Instance.new("TextLabel", ThrowGui)
ThrowWarnLabel.Size               = UDim2.new(0, 320, 0, 28)
ThrowWarnLabel.AnchorPoint        = Vector2.new(0.5, 0.5)
ThrowWarnLabel.Position           = UDim2.new(0.5, 0, 0.5, 40)
ThrowWarnLabel.BackgroundColor3   = Color3.fromRGB(14, 12, 24)
ThrowWarnLabel.BackgroundTransparency = 0.25
ThrowWarnLabel.BorderSizePixel    = 0
ThrowWarnLabel.Font               = Enum.Font.GothamBold
ThrowWarnLabel.TextSize           = 14
ThrowWarnLabel.TextColor3         = Color3.fromRGB(220, 180, 80)
ThrowWarnLabel.Text               = ""
ThrowWarnLabel.TextXAlignment     = Enum.TextXAlignment.Center
ThrowWarnLabel.Visible            = false
ThrowWarnLabel.ZIndex             = 15
do
	local c = Instance.new("UICorner", ThrowWarnLabel); c.CornerRadius = UDim.new(0,8)
end

local warnThread = nil
local function showThrowWarn(msg)
	ThrowWarnLabel.Text    = msg
	ThrowWarnLabel.Visible = true
	ThrowWarnLabel.TextTransparency = 0
	ThrowWarnLabel.BackgroundTransparency = 0.25
	if warnThread then task.cancel(warnThread) end
	warnThread = task.delay(1.4, function()
		-- Fade out
		for i = 1, 8 do
			task.wait(0.04)
			local t = i / 8
			ThrowWarnLabel.TextTransparency          = t
			ThrowWarnLabel.BackgroundTransparency    = 0.25 + 0.75 * t
		end
		ThrowWarnLabel.Visible = false
		warnThread = nil
	end)
end

-- ── Throw — fires after delivery delay ─────────────────────────
local function doThrow(horizSpeed)
	local origin = getOrigin(); if not origin then return end

	-- Client-side validation: check slot before firing to server
	local slot = _G.Chompers.GetSelectedSlot and _G.Chompers.GetSelectedSlot() or 1
	local inv   = _G.Chompers.GetInventory and _G.Chompers.GetInventory()
	local item  = inv and inv[slot]

	if not item then
		showThrowWarn("❌  No item in slot " .. slot)
		smoothedAimPoint = nil; return
	end
	if not item.paid then
		showThrowWarn("🏷️  Can't throw — pay at Checkout first")
		smoothedAimPoint = nil; return
	end

	local rawAim = smoothedAimPoint or getAimPoint()
	local aimPt  = clampAimPoint(origin, rawAim, horizSpeed)
	ThrowFood:FireServer(slot, horizSpeed, aimPt)
	smoothedAimPoint = nil
end

-- ── End charge (release or auto-fire) ─────────────────────────
local function endCharge()
	charging = false
	restoreSpeed()
	ChargeBar.Visible     = false
	ChargeLabel.Visible   = false
	CrosshairRing.Visible = false
	hideArcDots()
end

-- ── Cancel charge (RMB) — spring-back before hiding ────────────
local function cancelCharge()
	if not charging then return end
	charging = false
	restoreSpeed()
	hideArcDots()
	CrosshairRing.Visible = false
	-- Spring-back: tween fill to 0 then hide — feels like releasing bow tension
	TweenService:Create(ChargeFill,
		TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{Size = UDim2.new(0, 0, 1, 0)}):Play()
	ChargeLabel.Text    = "cancelled"
	ChargeLabel.Visible = true
	task.delay(0.20, function()
		ChargeBar.Visible   = false
		ChargeLabel.Visible = false
	end)
end

-- ── Heartbeat — charge bar + crosshair ring + arc ──────────────
RunService.Heartbeat:Connect(function()
	if not charging then return end

	local elapsed = tick() - holdStart

	-- Auto-fire at MaxHoldTime
	if elapsed >= MAX_HOLD then
		endCharge()
		if not isBlocked() then doThrow(C.MaxSpeed) end
		return
	end

	local inGrace = elapsed >= MAX_CHARGE

	-- Arc preview (show once MIN_CHARGE reached)
	if elapsed >= MIN_CHARGE then
		local origin = getOrigin()
		if origin then
			local horizSpeed = getChargeParams(elapsed)
			local rawAim     = getAimPoint()

			-- Smooth aim point to kill shift-lock jitter (0.12s lerp)
			if not smoothedAimPoint then smoothedAimPoint = rawAim end
			smoothedAimPoint = smoothedAimPoint:Lerp(rawAim, 0.18)

			-- Clamp to charge-based range BEFORE preview so arc matches throw
			local aimPt = clampAimPoint(origin, smoothedAimPoint, horizSpeed)

			-- During grace overdraw: add Perlin drift to PREVIEW only
			if inGrace then
				local driftT   = math.clamp((elapsed - MAX_CHARGE) / (MAX_HOLD - MAX_CHARGE), 0, 1)
				local driftMag = driftT * DRIFT_MAX
				local driftX   = math.noise(tick() * 1.8, 0, 99) * driftMag
				local driftZ   = math.noise(99, tick() * 1.8, 0) * driftMag
				aimPt          = aimPt + Vector3.new(driftX, 0, driftZ)
			end

			local vel = computeVelocity(origin, aimPt, horizSpeed)
			updateArcDots(origin, vel)
		end
	else
		hideArcDots()
		smoothedAimPoint = nil   -- reset so next charge starts fresh
	end

	-- Before minimum — bar hidden, hint label visible
	if elapsed < MIN_CHARGE then
		ChargeBar.Visible     = false
		ChargeLabel.Visible   = true
		CrosshairRing.Visible = false
		ChargeLabel.Text      = "hold to charge…"
		ChargeLabel.TextColor3 = Color3.fromRGB(105, 100, 138)
		return
	end

	ChargeBar.Visible     = true
	ChargeLabel.Visible   = true
	CrosshairRing.Visible = true

	if inGrace then
		-- Full charge — bar flashes gold, ring holds tight, arc drifts
		local flash = math.floor(tick() * 8) % 2 == 0
		local goldCol = Color3.fromRGB(255, 225, 50)
		local whiteCol = Color3.fromRGB(255, 255, 200)
		ChargeFill.Size             = UDim2.new(1, 0, 1, 0)
		ChargeFill.BackgroundColor3 = flash and goldCol or whiteCol
		RingStroke.Color            = flash and goldCol or whiteCol
		CrosshairRing.Size          = UDim2.new(0, RING_MIN_PX, 0, RING_MIN_PX)
		ChargeLabel.Text            = "⚡ RELEASE  or  AUTO-FIRES in "
			.. string.format("%.1f", MAX_HOLD - elapsed) .. "s"
		ChargeLabel.TextColor3      = goldCol
	else
		-- Filling phase — ring contracts, bar fills, colour shifts blue→orange
		local _, _, eased = getChargeParams(elapsed)
		local fillPct = (elapsed - MIN_CHARGE) / (MAX_CHARGE - MIN_CHARGE)
		local col     = chargeColour(eased)

		-- Charge bar
		ChargeFill.Size             = UDim2.new(math.clamp(fillPct, 0, 1), 0, 1, 0)
		ChargeFill.BackgroundColor3 = col

		-- Crosshair ring: large → tight as fillPct goes 0→1
		local ringPx = RING_MAX_PX - (fillPct * (RING_MAX_PX - RING_MIN_PX))
		CrosshairRing.Size  = UDim2.new(0, ringPx, 0, ringPx)
		RingStroke.Color    = col

		-- Range hint under bar
		local horizSpeed = getChargeParams(elapsed)
		local range = C.MinRange + (C.MaxRange - C.MinRange) *
			math.clamp((horizSpeed - C.MinSpeed) / math.max(C.MaxSpeed - C.MinSpeed, 1), 0, 1)
		ChargeLabel.Text       = math.floor(range) .. " studs"
		ChargeLabel.TextColor3 = col
	end
end)

-- ── Input ──────────────────────────────────────────────────────
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end

	-- RMB → cancel with spring-back
	if input.UserInputType == Enum.UserInputType.MouseButton2
		or input.KeyCode == Enum.KeyCode.ButtonL2 then
		cancelCharge(); return
	end

	-- LMB → start charging
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.KeyCode == Enum.KeyCode.ButtonR2 then
		if isBlocked() then return end
		if charging then return end
		if tick() < chargeBlockedUntil then return end

		charging           = true
		holdStart          = tick()
		chargeBlockedUntil = tick() + COOLDOWN
		applySpeedDebuff()
	end
end)

UserInputService.InputEnded:Connect(function(input)
	-- LMB release → delivery delay then throw
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.KeyCode == Enum.KeyCode.ButtonR2 then
		if not charging then return end

		local elapsed    = tick() - holdStart
		local horizSpeed = getChargeParams(elapsed)   -- capture aim BEFORE endCharge

		endCharge()

		if not isBlocked() and elapsed >= MIN_CHARGE then
			-- Delivery delay: 0.12s arm-swing-through before projectile spawns
			-- The aim direction is captured above at release moment
			task.delay(DELIVERY_DELAY, function()
				if not isBlocked() then
					doThrow(horizSpeed)
				end
			end)
		end
		-- elapsed < MIN_CHARGE: silent cancel, cooldown still ticking
	end
end)

print("[ThrowClient] Ready")
