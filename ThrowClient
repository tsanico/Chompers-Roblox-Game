-- ============================================================
-- ThrowClient — LocalScript · StarterPlayerScripts
--
-- Bow-draw / baseball windup feel (Part 46 rework):
--   • Delivery delay: 0.12s between LMB release and projectile spawn
--   • Tightening crosshair ring: 80px → 12px as charge builds
--   • Arc drift: Perlin noise on PREVIEW during grace overdraw (visual only)
--   • Cancel spring-back: bar tweens to 0 on RMB, not instant snap
--
-- CHARGE WINDOW:
--   LMB hold     → charge begins. Cooldown clock starts NOW.
--   < 0.3s       → silent cancel (no throw, cooldown still ticks)
--   ≥ 0.3s       → throws at current charge power
--   1.5s         → full charge, bar flashes gold + ring tightens to dot
--   2.0s         → auto-fires at MaxSpeed
--   RMB          → cancel — spring-back, speed restored, cooldown ticks
-- ============================================================

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService  = game:GetService("UserInputService")
local RunService        = game:GetService("RunService")
local TweenService      = game:GetService("TweenService")

local player  = Players.LocalPlayer
local camera  = workspace.CurrentCamera
local Remotes = ReplicatedStorage:WaitForChild("ChompersRemotes", 15)
local C_Data  = require(ReplicatedStorage:WaitForChild("ChompersData")).Constants

local waited = 0
while not (_G.Chompers and _G.Chompers.GetSelectedSlot) and waited < 8 do
	task.wait(0.05); waited = waited + 0.05
end

local ThrowFood = Remotes:WaitForChild("ThrowFood", 15)

-- ── Constants ──────────────────────────────────────────────────
local C          = C_Data.Throw
local G_EFF      = C.EffectiveGravity or 175
local MIN_CHARGE = C.MinCharge    or 0.3
local MAX_CHARGE = C.MaxCharge    or 1.5
local MAX_HOLD   = C.MaxHoldTime  or 2.0
local COOLDOWN   = C.Cooldown     or 0.8
local SPEED_MULT = C.AimSpeedMult or 0.80
local SPEED_RAMP = C.AimSpeedRamp or 0.30

local DELIVERY_DELAY = 0.12   -- seconds between LMB release and projectile spawn
local ARC_DOTS       = 14
local ARC_DT         = 0.055
local RING_MAX_PX    = 80     -- crosshair ring diameter at tap-charge
local RING_MIN_PX    = 12     -- crosshair ring diameter at full charge
local DRIFT_MAX      = 3.5    -- max stud drift during grace window

