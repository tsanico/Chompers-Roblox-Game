local function buildMeter(isLeft, baseCol, warnCol, icon, labelText)
	local xScale  = isLeft and 0 or 1
	local xOffset = isLeft and 14 or -14
	local anchor  = Vector2.new(isLeft and 0 or 1, 0.5)

	local container = Instance.new("Frame")
	container.Name                = labelText .. "Meter"
	container.Size                = UDim2.new(0, METER_W + 20, 0, METER_H + 80)
	container.AnchorPoint         = anchor
	container.Position            = UDim2.new(xScale, xOffset, 0.5, -10)
	container.BackgroundTransparency = 1
	container.Visible             = true
	container.Parent              = Gui

	mkLabel(container, icon, Enum.Font.GothamBold, 24, C.white,
		Enum.TextXAlignment.Center,
		UDim2.new(0, 0, 0, 0), UDim2.new(1, 0, 0, 30))

	local track = mkFrame(container,
		UDim2.new(0, METER_W, 0, METER_H),
		UDim2.new(0.5, -METER_W / 2, 0, 34),
		Color3.fromRGB(24, 22, 38), 8)

	local fill = Instance.new("Frame", track)
	fill.Name             = "Fill"
	fill.Size             = UDim2.new(1, 0, 0, 0)
	fill.Position         = UDim2.new(0, 0, 1, 0)
	fill.AnchorPoint      = Vector2.new(0, 1)
	fill.BackgroundColor3 = baseCol
	fill.BorderSizePixel  = 0
	corner(fill, 8)

	local warnOverlay = Instance.new("Frame", track)
	warnOverlay.Size             = UDim2.new(1, 0, 1, 0)
	warnOverlay.BackgroundColor3 = warnCol
	warnOverlay.BackgroundTransparency = 1
	warnOverlay.BorderSizePixel  = 0
	warnOverlay.ZIndex           = 3
	corner(warnOverlay, 8)

	local pctBg = mkFrame(container,
		UDim2.new(1, 4, 0, 22),
		UDim2.new(0, -2, 0, METER_H + 38),
		Color3.fromRGB(35, 12, 12), 6, true)
	local pctLabel = mkLabel(pctBg, "0%",
		Enum.Font.GothamBlack, 13, Color3.fromRGB(255, 80, 80))
	pctLabel.Name = "PctLabel"

	mkLabel(container, labelText,
		Enum.Font.GothamBlack, 12, C.white,
		Enum.TextXAlignment.Center,
		UDim2.new(0, 0, 0, METER_H + 62), UDim2.new(1, 0, 0, 16))

	local bathIcon = mkLabel(container,
		isLeft and "🚽" or "🚿",
		Enum.Font.GothamBold, 20, C.warn,
		Enum.TextXAlignment.Center,
		UDim2.new(0, 0, 0, METER_H + 42), UDim2.new(1, 0, 0, 22))
	bathIcon.Visible = false

	return fill, pctLabel, warnOverlay, bathIcon
end

local FFill, FPct, FWarn, FArrow =
	buildMeter(true,  C.fullness, C.warn, "🍔", "FULL")
local CFill, CPct, CWarn, CArrow =
	buildMeter(false, C.dirty, Color3.fromRGB(155, 115, 35), "🧼", "DIRTY")

local warnTweens = {}

local function updateMeter(fill, pctL, warnF, arrowL, baseCol, warnCol, pct)
	if not pct then return end
	pct = math.clamp(pct, 0, 1)
	TweenService:Create(fill, TweenInfo.new(0.3, Enum.EasingStyle.Quad),
		{Size = UDim2.new(1, 0, pct, 0)}):Play()
	pctL.Text = math.floor(pct * 100) .. "%"
	-- Interpolate colour toward warn
	local r = math.clamp(baseCol.R + (warnCol.R - baseCol.R) * pct, 0, 1)
	local g = math.clamp(baseCol.G + (warnCol.G - baseCol.G) * pct, 0, 1)
	local b = math.clamp(baseCol.B + (warnCol.B - baseCol.B) * pct, 0, 1)
	TweenService:Create(fill, TweenInfo.new(0.3),
		{BackgroundColor3 = Color3.new(r, g, b)}):Play()
	if pct >= 0.8 then
		arrowL.Visible = true
		if not warnTweens[warnF] then
			warnTweens[warnF] = TweenService:Create(warnF,
				TweenInfo.new(0.5, Enum.EasingStyle.Sine,
					Enum.EasingDirection.InOut, -1, true),
				{BackgroundTransparency = 0.7})
			warnTweens[warnF]:Play()
		end
	else
		arrowL.Visible = false
		if warnTweens[warnF] then
			warnTweens[warnF]:Cancel()
			warnTweens[warnF] = nil
			warnF.BackgroundTransparency = 1
		end
	end
end

-- Wire _G.Chompers meter functions
_G.Chompers.UpdateCleanliness = function(value)
