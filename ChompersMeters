-- Helpers
local function corner(parent, r)
	local c = Instance.new("UICorner", parent)
	c.CornerRadius = UDim.new(0, r or 12)
end
local function mkStroke(parent, t, col)
	local s = Instance.new("UIStroke", parent)
	s.Thickness = t or 1.5; s.Color = col or C.stroke
	return s
end
local function mkLabel(parent, text, font, size, color, xAlign, pos, sz)
	local l = Instance.new("TextLabel")
	l.Text = text or ""
	l.Font = font or Enum.Font.GothamBold
	l.TextSize = size or 14
	l.TextColor3 = color or C.white
	l.TextXAlignment = xAlign or Enum.TextXAlignment.Center
	l.TextYAlignment = Enum.TextYAlignment.Center
	l.BackgroundTransparency = 1
	l.Position = pos or UDim2.new(0, 0, 0, 0)
	l.Size = sz or UDim2.new(1, 0, 1, 0)
	l.Parent = parent
	return l
end
local function mkFrame(parent, size, pos, bg, r, nostroke)
	local f = Instance.new("Frame")
	f.Size = size; f.Position = pos or UDim2.new(0, 0, 0, 0)
	f.BackgroundColor3 = bg or C.bg
	f.BorderSizePixel = 0; f.Parent = parent
	corner(f, r or 12)
	if not nostroke then mkStroke(f) end
	return f
end

