-- PUBLIC API (extends _G.Chompers)
-- ============================================================

_G.Chompers.SetPhase = setPhase

_G.Chompers.SetPlayerCount = function(current, total)
	current = current or 0; total = total or 0
	PlayerLabel.Text      = "👥 " .. current .. " / " .. total
	PlayerLabel.TextColor3 = current >= total and total > 0 and C.green or C.dim
end

_G.Chompers.UpdateScoreboard = function(data)
	scoreData = data or {}
end

-- ============================================================
-- REMOTE LISTENERS
-- ============================================================

local function R(name)
	return Remotes:WaitForChild(name, 5)
end

local UpdateCL = R("UpdateCleanliness")
local UpdateFL = R("UpdateFullness")
local UpdateWt = R("UpdateWeight")
local PhaseRem = R("PhaseChanged")
local LobbyRem = R("UpdateLobbyState")

if UpdateCL then
	UpdateCL.OnClientEvent:Connect(function(value)
		_G.Chompers.UpdateCleanliness(value or 0)
	end)
end

if UpdateFL then
	UpdateFL.OnClientEvent:Connect(function(value)
		_G.Chompers.UpdateFullness(value or 0)
	end)
end

if UpdateWt then
	UpdateWt.OnClientEvent:Connect(function(current, maxW)
		_G.Chompers.SetWeight(current, maxW)
	end)
end

if PhaseRem then
	PhaseRem.OnClientEvent:Connect(function(phase)
		setPhase(phase)
	end)
end

if LobbyRem then
	LobbyRem.OnClientEvent:Connect(function(state)
		if not state then return end
		_G.Chompers.SetPlayerCount(
			state.totalCount or state.PlayerCount or 0,
			state.minToStart or state.MinPlayers  or 0)
	end)
end

