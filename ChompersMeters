			Enum.Font.GothamBold, 14, rankCol,
			Enum.TextXAlignment.Left,
			UDim2.new(0, 8, 0, 0), UDim2.new(0.45, 0, 1, 0)).ZIndex = 64
		mkLabel(row, "🧼 " .. tostring(data.clDealt or 0),
			Enum.Font.Gotham, 13, C.white,
			Enum.TextXAlignment.Center,
			UDim2.new(0.45, 0, 0, 0), UDim2.new(0.2, 0, 1, 0)).ZIndex = 64
		mkLabel(row, "🍔 " .. tostring(data.flDealt or 0),
			Enum.Font.Gotham, 13, C.white,
			Enum.TextXAlignment.Center,
			UDim2.new(0.65, 0, 0, 0), UDim2.new(0.2, 0, 1, 0)).ZIndex = 64
		mkLabel(row, "🍳 " .. tostring(data.recipes or 0),
