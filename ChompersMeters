local function buildMeter(isLeft,baseCol,warnCol,icon,labelText)
	local xScale  = isLeft and 0 or 1
	local xOffset = isLeft and 14 or -14
	local anchor  = Vector2.new(isLeft and 0 or 1,0.5)

	local container = Instance.new("Frame")
	container.Name  = labelText.."Meter"
	container.Size  = UDim2.new(0,METER_W+20,0,METER_H+80)
	container.AnchorPoint = anchor
	container.Position = UDim2.new(xScale,xOffset,0.5,-10)
	container.BackgroundTransparency = 1
	container.Visible = true
	container.Parent = Gui

	mkLabel(container,icon,
		Enum.Font.GothamBold,24,C.white,
		Enum.TextXAlignment.Center,
		UDim2.new(0,0,0,0),UDim2.new(1,0,0,30))

	local track = mkFrame(container,"Track",
		UDim2.new(0,METER_W,0,METER_H),
		UDim2.new(0.5,-METER_W/2,0,34),
		nil,Color3.fromRGB(24,22,38),8)

	local fill = mkFrame(track,"Fill",
		UDim2.new(1,0,0,0),
		UDim2.new(0,0,1,0),
		Vector2.new(0,1),baseCol,8,true)

	local warnOverlay = mkFrame(track,"Warn",
		UDim2.new(1,0,1,0),UDim2.new(0,0,0,0),
		nil,warnCol,8,true)
	warnOverlay.BackgroundTransparency = 1
	warnOverlay.ZIndex = 3

	local pctBg = mkFrame(container,"PctBg",
		UDim2.new(1,4,0,22),
		UDim2.new(0,-2,0,METER_H+38),
		nil,Color3.fromRGB(35,12,12),6,true)

	local pctL = mkLabel(pctBg,"0%",
		Enum.Font.GothamBlack,13,
		Color3.fromRGB(255,80,80))
	pctL.Name = "PctLabel"

	mkLabel(container,labelText,
		Enum.Font.GothamBlack,12,C.white,
		Enum.TextXAlignment.Center,
		UDim2.new(0,0,0,METER_H+62),
		UDim2.new(1,0,0,16))

	local arrowL = mkLabel(container,
		isLeft and "🚽" or "🚿",
		Enum.Font.GothamBold,20,C.warn,
		Enum.TextXAlignment.Center,
		UDim2.new(0,0,0,METER_H+42),
		UDim2.new(1,0,0,22))
	arrowL.Visible = false

	return fill,pctL,warnOverlay,arrowL
end

local FFill,FPct,FWarn,FArrow =
	buildMeter(true,  C.fullness,C.warn,"🍔","FULL")
local CFill,CPct,CWarn,CArrow =
	buildMeter(false, C.dirty,
		Color3.fromRGB(155,115,35),"🧼","DIRTY")

local warnTweens = {}

local function updateMeter(fill,pctL,warnF,arrowL,baseCol,warnCol,pct)
	pct = math.clamp(pct,0,1)
	TweenService:Create(fill,
		TweenInfo.new(0.3,Enum.EasingStyle.Quad),
		{Size=UDim2.new(1,0,0,METER_H*pct)}):Play()
	pctL.Text = math.floor(pct*100).."%"
	local r = baseCol.R+(warnCol.R-baseCol.R)*pct
	local g = baseCol.G+(warnCol.G-baseCol.G)*pct
	local b = baseCol.B+(warnCol.B-baseCol.B)*pct
	TweenService:Create(fill,TweenInfo.new(0.3),
		{BackgroundColor3=Color3.new(
			math.clamp(r,0,1),
			math.clamp(g,0,1),
			math.clamp(b,0,1))}):Play()
	if pct>=0.8 then
		arrowL.Visible = true
		if not warnTweens[warnF] then
			warnTweens[warnF] = TweenService:Create(warnF,
				TweenInfo.new(0.5,Enum.EasingStyle.Sine,
					Enum.EasingDirection.InOut,-1,true),
				{BackgroundTransparency=0.7})
			warnTweens[warnF]:Play()
		end
	else
		arrowL.Visible = false
		if warnTweens[warnF] then
			warnTweens[warnF]:Cancel()
			warnTweens[warnF] = nil
			warnF.BackgroundTransparency = 1
		end
	end
end

