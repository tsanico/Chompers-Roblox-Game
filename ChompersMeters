local scoreData = {}

local function refreshScoreboard()
	for _,c in ipairs(sbScroll:GetChildren()) do
		if c:IsA("Frame") then c:Destroy() end
	end
	table.sort(scoreData,function(a,b)
		return (a.cleanDealt or 0)>(b.cleanDealt or 0)
	end)
	if #scoreData==0 then
		mkLabel(sbScroll,
			"Scores appear when the match begins",
			Enum.Font.Gotham,14,C.dim,
			Enum.TextXAlignment.Center,
			UDim2.new(0,0,0,16),UDim2.new(1,0,0,40)).ZIndex = 63
		return
	end
	for rank,data in ipairs(scoreData) do
		local row = Instance.new("Frame")
		row.Size = UDim2.new(1,0,0,38)
		row.BackgroundColor3 = rank==1
			and Color3.fromRGB(50,40,15)
			or Color3.fromRGB(24,22,36)
		row.BorderSizePixel = 0
		row.ZIndex = 63
		row.Parent = sbScroll
		local rc = Instance.new("UICorner")
		rc.CornerRadius = UDim.new(0,6)
		rc.Parent = row
		local rankCol = rank==1 and C.gold
			or rank==2 and Color3.fromRGB(185,185,195)
			or rank==3 and Color3.fromRGB(165,105,65)
			or C.dim
		local vals = {
			rank.."  "..(data.name or "Player"),
			tostring(data.cleanDealt or 0),
			tostring(data.fullDealt  or 0),
			tostring(data.cleanTaken or 0),
			tostring(data.fullTaken  or 0),
			tostring(data.cleans     or 0),
		}
		local colX = 0
		for i,val in ipairs(vals) do
			local vl = mkLabel(row,val,
				i==1 and Enum.Font.GothamBold or Enum.Font.Gotham,
				i==1 and 14 or 13,
				i==1 and rankCol or Color3.fromRGB(182,180,200),
				i==1 and Enum.TextXAlignment.Left or Enum.TextXAlignment.Center,
				UDim2.new(colX,i==1 and 6 or 0,0,0),
				UDim2.new(COLS[i].w,0,1,0))
			vl.ZIndex = 64
			colX = colX+COLS[i].w
		end
	end
end

refreshScoreboard()

local sbVisible = false
UserInputService.InputBegan:Connect(function(input,processed)
	if processed then return end
	if input.KeyCode==Enum.KeyCode.Tab then
		sbVisible = true
		refreshScoreboard()
		ScoreboardOverlay.Visible = true
	end
end)
UserInputService.InputEnded:Connect(function(input)
	if input.KeyCode==Enum.KeyCode.Tab then
		sbVisible = false
		ScoreboardOverlay.Visible = false
	end
end)

-- ============================================================
-- PHASE
-- ============================================================
local function setPhase(key)
	local data = PHASES[key] or PHASES.WAITING
	PhaseLabel.Text = data.label
	PhaseLabel.TextColor3 = data.color
	TweenService:Create(PhasePill,TweenInfo.new(0.2),
		{BackgroundColor3=Color3.fromRGB(35,32,52)}):Play()
	task.wait(0.4)
	TweenService:Create(PhasePill,TweenInfo.new(0.5),
		{BackgroundColor3=C.bg}):Play()
	if key=="FOODFIGHT" then
		startTimer(300)
		ScorePill.Visible = true
	end
end

-- ============================================================
-- PUBLIC API
-- ============================================================
task.wait(0.1)
_G.Chompers = _G.Chompers or {}

_G.Chompers.SetPhase = setPhase

_G.Chompers.SetPlayerCount = function(current,total)
	local minPlayers = total
	if current>=minPlayers then
		PlayerLabel.Text = "👥  "..current.." / 40"
		PlayerLabel.TextColor3 = C.green
	else
		PlayerLabel.Text = "👥  "..current.." / "..minPlayers
		PlayerLabel.TextColor3 = C.dim
	end
end

_G.Chompers.UpdateFullness = function(pct)
	updateMeter(FFill,FPct,FWarn,FArrow,
		C.fullness,C.warn,pct)
end

_G.Chompers.UpdateCleanliness = function(pct)
	updateMeter(CFill,CPct,CWarn,CArrow,
		C.dirty,Color3.fromRGB(155,115,35),pct)
end

_G.Chompers.SetWeight = function(current,maxW)
	updateWeight(current,maxW)
end

_G.Chompers.AddScore = function(hits)
	for _,d in ipairs(scoreData) do
		if d.userId==player.UserId then
			d.cleanDealt = (d.cleanDealt or 0)+(hits or 1)
			local t = d.cleanDealt
			ScoreLabel.Text = t.." hit"..(t==1 and "" or "s")
			return
		end
	end
	table.insert(scoreData,{
		userId=player.UserId,
		name=player.Name,
		cleanDealt=hits or 1,
	})
	ScoreLabel.Text = (hits or 1).." hit"
end

_G.Chompers.UpdateScoreboard = function(data)
	scoreData = data
end

_G.Chompers.ToggleScoreboard = function()
	sbVisible = not sbVisible
	if sbVisible then refreshScoreboard() end
	ScoreboardOverlay.Visible = sbVisible
end

