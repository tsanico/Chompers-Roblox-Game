local otherDots = {}
local function getOrMakeDot(userId)
	if not otherDots[userId] then
		local d = Instance.new("Frame")
		d.Size = UDim2.new(0,6,0,6)
		d.AnchorPoint = Vector2.new(0.5,0.5)
		d.BackgroundColor3 = C.white
		d.BorderSizePixel = 0
		d.ZIndex = 9
		d.Visible = false
		d.Parent = MapInner
		local dc = Instance.new("UICorner")
		dc.CornerRadius = UDim.new(1,0)
		dc.Parent = d
		otherDots[userId] = d
	end
	return otherDots[userId]
end

RunService.RenderStepped:Connect(function()
	local char = player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local sx,sz = worldToFrac(hrp.Position.X,hrp.Position.Z)
	SelfDot.Position   = UDim2.new(sx,0,sz,0)
	pulseRing.Position = UDim2.new(sx,0,sz,0)
	for _,op in ipairs(Players:GetPlayers()) do
		if op~=player then
			local dot = getOrMakeDot(op.UserId)
			local oc = op.Character
			if oc then
				local oh = oc:FindFirstChild("HumanoidRootPart")
				if oh then
					local ox,oz = worldToFrac(oh.Position.X,oh.Position.Z)
					dot.Position = UDim2.new(ox,0,oz,0)
					dot.Visible = true
				else dot.Visible=false end
			else dot.Visible=false end
		end
	end
	for uid,dot in pairs(otherDots) do
		local found = false
		for _,p in ipairs(Players:GetPlayers()) do
			if p.UserId==uid then found=true break end
		end
		if not found then dot:Destroy() otherDots[uid]=nil end
	end
end)

