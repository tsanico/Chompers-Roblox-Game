local function updateWeight(current,maxW)
	local pct = math.clamp(current/(maxW>0 and maxW or 1),0,1)
	TweenService:Create(weightFill,
		TweenInfo.new(0.3,Enum.EasingStyle.Quad),
		{Size=UDim2.new(1,0,pct,0)}):Play()

	weightDisplay.Text = current.."/"..maxW

	local overweight = pct >= 1
	local fillCol = overweight and C.warn
		or pct >= 0.8 and C.gold
		or Color3.fromRGB(200,160,80)

	TweenService:Create(weightFill,TweenInfo.new(0.3),
		{BackgroundColor3=fillCol}):Play()
	weightDisplay.TextColor3 = overweight
		and C.warn or Color3.fromRGB(239,200,100)

	if overweight then
		TweenService:Create(WeightBarOuter,TweenInfo.new(0.15),
			{BackgroundColor3=Color3.fromRGB(40,18,18)}):Play()
	else
		TweenService:Create(WeightBarOuter,TweenInfo.new(0.3),
			{BackgroundColor3=Color3.fromRGB(22,20,34)}):Play()
	end
end

