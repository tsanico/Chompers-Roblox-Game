Remotes.UpdateLobbyState.OnClientEvent:Connect(function(state)
	if state.Phase=="WAITING" then setPhase("WAITING")
	elseif state.Phase=="COUNTDOWN" then setPhase("COUNTDOWN") end
	_G.Chompers.SetPlayerCount(state.PlayerCount,state.MinPlayers)
end)

Remotes.PhaseChanged.OnClientEvent:Connect(function(phase)
	local map = {
		GATHERING="SHOPPING",COOKING="COOKING",
		FOODFIGHT="FOODFIGHT",ACCOLADES="CLEANUP",
	}
	if map[phase] then setPhase(map[phase]) end
end)

