-- Timer
local matchTime   = 0
local timerActive = false
local timerConn   = nil

local function startTimer(secs)
	matchTime   = secs or 0
	timerActive = true
	if timerConn then timerConn:Disconnect() end
	timerConn = RunService.Heartbeat:Connect(function(dt)
		if not timerActive then return end
		matchTime = math.max(0, matchTime - dt)
		local m = math.floor(matchTime / 60)
		local s = math.floor(matchTime % 60)
		TimerLabel.Text = string.format("%d:%02d", m, s)
		TimerLabel.TextColor3 = matchTime <= 30 and C.red
			or matchTime <= 60 and C.gold or C.white
		if matchTime <= 0 then
			timerActive = false
			timerConn:Disconnect()
		end
	end)
end

local PHASES = {
	Prelobby    = {label = "Lobby",       color = C.dim},
	Gathering   = {label = "Shopping 🛒",  color = C.green},
	Cooking     = {label = "Cooking 🍳",   color = C.gold},
	CookingGrace = {label = "Almost...",  color = C.gold},
	FoodFight   = {label = "Food Fight! 🍅", color = C.red},
	EndGame     = {label = "Match Over",  color = C.dim},
	Accolades   = {label = "Accolades 🏅", color = C.gold},
}

local function setPhase(key)
	local data = PHASES[key] or {label = key, color = C.dim}
	PhaseLabel.Text       = data.label
	PhaseLabel.TextColor3 = data.color
	TweenService:Create(PhasePill, TweenInfo.new(0.2),
		{BackgroundColor3 = Color3.fromRGB(35, 32, 52)}):Play()
	task.delay(0.4, function()
		TweenService:Create(PhasePill, TweenInfo.new(0.5),
			{BackgroundColor3 = C.bg}):Play()
	end)
	-- Start timer for active phases
	if key == "Gathering" then
		startTimer(180)
	elseif key == "Cooking" then
		startTimer(180)
	elseif key == "FoodFight" then
		startTimer(360)
	elseif key == "Prelobby" then
		timerActive = false
		TimerLabel.Text = "—"
		TimerLabel.TextColor3 = C.white
	end
end

