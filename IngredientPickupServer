-- ── 100% state drop (all items, with owner lock) ────────────
-- PlayerState._Trigger100State calls DropAllItems and fires HitPlayer
-- to the client. We listen here server-side to spawn the world parts.
--
-- We hook this by exposing a function on _G that PlayerState calls.
-- This avoids circular requires.

_G.SpawnDroppedItems = function(player, droppedItems)
	local char = player.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local pos  = hrp and hrp.Position or Vector3.new(0, 5, 0)

	for _, item in ipairs(droppedItems) do
		local part = spawnDroppedPart(player, item, pos, true)
		if part then
			-- Balance Patch v1: owner lock for 1 second
			part:SetAttribute("OwnerLock",   true)
			part:SetAttribute("OwnerPlayer", player.UserId)
			task.delay(C.State100.OwnerLockDuration, function()
				if part and part.Parent then
					part:SetAttribute("OwnerLock", false)
					part:SetAttribute("OwnerPlayer", nil)
				end
			end)
		end
	end
end

-- ============================================================
-- TRASH CAN & DUMPSTER HANDLING
--
-- Two types, differentiated by attribute:
--   IsTrashCan = true  → 2 random Common items, quick rummage (0.5s hold)
--   IsDumpster = true  → 4 random Common items, longer dig (1.0s hold)
--
-- Both give +5 CL penalty on pickup (dirty food off the floor).
-- This is an intentional "free ingredients at a CL cost" mechanic.
-- Items deplete per pickup. Dumpster HUD shows contents to nearby players.
-- ============================================================

-- ── Universal "best anchor" helper ──────────────────────────
-- Roblox measures ProximityPrompt distance from the Part's CFrame centre,
-- NOT from its surface. If the tagged Part is buried inside a Model,
-- players can't get close enough to trigger it.
-- This helper walks up to the Model's PrimaryPart (or first accessible
-- BasePart) so the prompt activates from any surface approach.
local function getBestAnchor(part)
    local parent = part.Parent
    if parent then
        if parent:IsA("Model") then
            return parent.PrimaryPart or part
        end
    end
    return part
end

local function makeInteractPrompt(part, objectText, actionText, holdDuration)
    local anchor = getBestAnchor(part)
    -- Remove any existing prompt on anchor to avoid duplicates
    local existing = anchor:FindFirstChildWhichIsA("ProximityPrompt")
    if existing then existing:Destroy() end

    local prompt = Instance.new("ProximityPrompt")
    prompt.ObjectText            = objectText
    prompt.ActionText            = actionText
    prompt.KeyboardKeyCode       = Enum.KeyCode.E
    prompt.HoldDuration          = holdDuration or 0
    prompt.MaxActivationDistance = 15   -- generous — works from any surface approach
    prompt.RequiresLineOfSight   = false
    prompt.Exclusivity           = Enum.ProximityPromptExclusivity.OnePerButton
    prompt.Parent                = anchor
    return prompt, anchor
end

local dumpsterContents = {}   -- [originalPart] = {item, ...}

local commonIngredients = {}
for _, ing in ipairs(ChompersData.Ingredients) do
    if ing.rarity == "Common" then table.insert(commonIngredients, ing) end
end

local GetDumpsterContents = Remotes:FindFirstChild("GetDumpsterContents")
if not GetDumpsterContents then
    GetDumpsterContents = Instance.new("RemoteFunction")
    GetDumpsterContents.Name = "GetDumpsterContents"; GetDumpsterContents.Parent = Remotes
end
local DumpsterUpdated = Remotes:FindFirstChild("DumpsterUpdated")
if not DumpsterUpdated then
    DumpsterUpdated = Instance.new("RemoteEvent")
    DumpsterUpdated.Name = "DumpsterUpdated"; DumpsterUpdated.Parent = Remotes
end

GetDumpsterContents.OnServerInvoke = function(_, dumpsterPart)
    if typeof(dumpsterPart) ~= "Instance" then return {} end
    return dumpsterContents[dumpsterPart] or {}
end

local function populateContainers()
    dumpsterContents = {}
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("BasePart") then
            local isTrash   = desc:GetAttribute("IsTrashCan") == true
            local isDumpster= desc:GetAttribute("IsDumpster")  == true
            if isTrash or isDumpster then
                local count = isDumpster and 4 or 2
                local items = {}
                for _ = 1, count do
                    if #commonIngredients > 0 then
                        local ing = commonIngredients[math.random(1, #commonIngredients)]
                        table.insert(items, {
                            name=ing.name, emoji=ing.emoji or "🍽", rarity=ing.rarity,
                            wt=ing.wt, allergy=ing.allergy, zone=ing.zone, cl=ing.cl,
                        })
                    end
                end
                dumpsterContents[desc] = items
            end
        end
    end
end

local function handlePickup(player, desc, isDumpster)
    local s = PlayerState.Get(player)
    if not s or s.isEliminated then return end

    local list = dumpsterContents[desc] or {}
    if #list == 0 then
        if AnnounceRemote then
            AnnounceRemote:FireClient(player,
                "🗑️  " .. (isDumpster and "Dumpster" or "Trash can") .. " is empty.",
                Color3.fromRGB(130,120,165), 2)
        end
        return
    end

    local ing = table.remove(list, 1)
    PlayerState.ModifyCL(player, ChompersData.Constants.TrashCanCL or 5)
    PlayerState.AddItem(player, {
        name=ing.name, rarity=ing.rarity, wt=ing.wt,
        cost=0, emoji=ing.emoji, allergy=ing.allergy,
        zone=ing.zone, cl=ing.cl, paid=true,
    })
    if AnnounceRemote then
        AnnounceRemote:FireClient(player,
            "🗑️  Found " .. (ing.emoji or "") .. " " .. ing.name
            .. "! (+" .. (ChompersData.Constants.TrashCanCL or 5) .. " CL — dirty food)",
            Color3.fromRGB(160,120,60), 3.5)
    end
    DumpsterUpdated:FireAllClients(desc, list)
end

local function setupContainers()
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("BasePart") then
            local isTrash    = desc:GetAttribute("IsTrashCan")  == true
            local isDumpster = desc:GetAttribute("IsDumpster")   == true
            if isTrash or isDumpster then
                local objText  = isDumpster and "🗑️ Dumpster" or "🗑️ Trash Can"
                local actText  = isDumpster and "Dig through" or "Rummage"
                local holdTime = isDumpster and 1.0 or 0.5

                local prompt = makeInteractPrompt(desc, objText, actText, holdTime)
                local capIsDumpster = isDumpster
                prompt.Triggered:Connect(function(player)
                    handlePickup(player, desc, capIsDumpster)
                end)
            end
        end
    end
end

-- Populate on Gathering start
