-- ============================================================
-- IngredientPickupServer — Script
-- Location: ServerScriptService > IngredientPickupServer
--
-- Handles ProximityPrompt pickup for all parts in Ingredients_Live.
-- All state (inventory, money, weight, napkins) is owned by
-- PlayerState — this script never tracks state itself.
--
-- Handles:
--   • Ingredient pickup → PlayerState.AddItem()
--   • Cash pickup       → PlayerState.AddMoney()
--   • Napkin pickup     → PlayerState.AddNapkin()
--   • Single item drop  → DropItem remote
--   • 100% state drop   → PlayerState.DropAllItems() (called by
--                         HitPlayer remote, spawns parts in world)
--   • Owner lock        → 1s lock on 100% drops (Balance Patch v1)
--   • Pickup speed      → scales with overweight (Part 6)
--
-- REQUIRES: ServerScriptService > PlayerState
-- REQUIRES: ReplicatedStorage > ChompersData
-- ============================================================

local Players             = game:GetService("Players")
local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local ServerScriptService = game:GetService("ServerScriptService")

local ChompersData = require(ReplicatedStorage:WaitForChild("ChompersData"))
local PlayerState  = require(ServerScriptService:WaitForChild("PlayerState"))
local C            = ChompersData.Constants

local Remotes = ReplicatedStorage:WaitForChild("ChompersRemotes")
local function R(name) return Remotes:WaitForChild(name) end

local DropItemRemote      = R("DropItem")
local UpdateInventory     = R("UpdateInventory")
local AnnounceRemote      = Remotes:FindFirstChild("Announce")

local LIVE_FOLDER_NAME    = "Ingredients_Live"

-- ============================================================
-- PICKUP HOLD TIME (scales with overweight — Part 6)
-- ============================================================

-- Base hold: 0.25s for ingredients, 0.2s for loot
-- Overweight penalty added on top
local function getPickupHoldTime(player, baseTime)
	local s = PlayerState.Get(player)
	if not s then return baseTime end
	local wt    = PlayerState.GetTotalWeight(player)
	local limit = PlayerState.GetWeightLimit(player)
	local over  = math.max(0, wt - limit)

	-- Lookup table from Part 6 (pickup speed penalties)
	local penalty
	if over <= 10     then penalty = 0
	elseif over <= 20 then penalty = 0.20
	elseif over <= 35 then penalty = 0.40
	elseif over <= 50 then penalty = 0.60
	else                   penalty = 0.75
	end

	-- Penalty multiplies the hold time (slower = longer hold)
	return baseTime * (1 + penalty)
end

-- ============================================================
-- INGREDIENT PICKUP HANDLER
-- ============================================================

local function onIngredientPickup(part, player)
	local s = PlayerState.Get(player)
	if not s then return end
	if s.isEliminated then return end

	-- Check owner lock (Balance Patch v1 — dropped items locked 1s)
	if part:GetAttribute("OwnerLock") then
		local ownerUserId = part:GetAttribute("OwnerPlayer")
		if ownerUserId and ownerUserId ~= player.UserId then
			-- Silently reject — prompt will still show but pickup denied
			return
		end
	end

	-- Build item data from part attributes
	local itemData = {
		name    = part:GetAttribute("IngredientName") or part.Name,
		rarity  = part:GetAttribute("Rarity")         or "Common",
		wt      = part:GetAttribute("Weight")         or 1,
		cost    = part:GetAttribute("Cost")            or 0,
		emoji   = part:GetAttribute("Emoji")           or "🍽",
		allergy = part:GetAttribute("Allergy")         or "None",
		zone    = part:GetAttribute("Zone")            or "Unknown",
		cl      = part:GetAttribute("CLValue")         or 0,
		paid    = part:GetAttribute("IsPaid")          == true,
	}

	-- Attempt to add to PlayerState inventory
	local ok, reason = PlayerState.AddItem(player, itemData)
	if not ok then
		if reason == "slots_full" then
			-- 10-slot cap is a UI limit, not a gameplay failure — don't alert.
			-- Only announce if the player is so overweight they're at 0% speed.
			local speedMult = PlayerState.GetSpeedMult and PlayerState.GetSpeedMult(player) or 1
			if speedMult <= 0 then
				local Announce = ReplicatedStorage:WaitForChild("ChompersRemotes",5)
					and ReplicatedStorage.ChompersRemotes:FindFirstChild("Announce")
				if Announce then
					Announce:FireClient(player,
						"🎒 Completely overloaded! Drop something — can't move.",
						Color3.fromRGB(220,60,60), 2.5)
				end
			end
		end
		return
	end

	-- Destroy the world part — respawn is handled by IngredientSpawner
	part:Destroy()

	print(string.format("[Pickup] %s picked up %s (wt=%d, $%d)",
		player.Name, itemData.name, itemData.wt, itemData.cost))
end

-- ============================================================
-- LOOT PICKUP HANDLER (cash / napkin)
-- ============================================================

local function onLootPickup(part, player)
	local s = PlayerState.Get(player)
	if not s then return end
	if s.isEliminated then return end

	local lootType  = part:GetAttribute("LootType")
	local lootValue = part:GetAttribute("LootValue") or 0
	local lootName  = part:GetAttribute("LootName")  or "Loot"
	local lootEmoji = part:GetAttribute("LootEmoji") or "💵"

	if lootType == "cash" then
		PlayerState.AddMoney(player, lootValue)
		-- Points: +1 per $1 found
		PlayerState.AddPoints(player, lootValue * 1)
		print(string.format("[Pickup] %s picked up %s ($%d)",
			player.Name, lootName, lootValue))

	elseif lootType == "napkin" then
		PlayerState.AddNapkin(player, 1)
		print(string.format("[Pickup] %s picked up a Napkin", player.Name))
	end

	part:Destroy()
end

-- ============================================================
-- SETUP PROMPT ON A SINGLE PART
-- ============================================================

local function setupPickupPrompt(part)
	if not part:IsA("BasePart") then return end

	local prompt = part:FindFirstChildWhichIsA("ProximityPrompt")
	if not prompt then return end

	-- Determine base hold time
	local isIngredient = part:GetAttribute("IsIngredient")
	local isLoot       = part:GetAttribute("IsLoot")
	if not isIngredient and not isLoot then return end

	local baseHold = isLoot and 0.2 or 0.25

	prompt.Triggered:Connect(function(player)
		-- Update hold time dynamically based on current overweight
		prompt.HoldDuration = getPickupHoldTime(player, baseHold)

		if isIngredient then
			onIngredientPickup(part, player)
		elseif isLoot then
			onLootPickup(part, player)
		end
	end)

	-- Update hold duration when player approaches (best-effort)
	prompt.PromptButtonHoldBegan:Connect(function(player)
		prompt.HoldDuration = getPickupHoldTime(player, baseHold)
	end)
end

-- ============================================================
-- WATCH THE LIVE FOLDER
-- ============================================================

local function watchLiveFolder()
	local LiveFolder = workspace:WaitForChild(LIVE_FOLDER_NAME, 30)
	if not LiveFolder then
		warn("[IngredientPickupServer] Ingredients_Live folder not found")
		return
	end

	-- Setup prompts on all existing parts
	for _, part in ipairs(LiveFolder:GetChildren()) do
		setupPickupPrompt(part)
	end

	-- Setup prompts on parts added later (respawns + drops)
	LiveFolder.ChildAdded:Connect(function(part)
		task.wait()   -- one frame so attributes are set before connecting
		setupPickupPrompt(part)
	end)
end

task.spawn(watchLiveFolder)

-- ============================================================
-- DROP SYSTEM
-- ============================================================

-- Build and parent a dropped part to Ingredients_Live
local function spawnDroppedPart(player, itemData, position, isTrash)
	local LiveFolder = workspace:FindFirstChild(LIVE_FOLDER_NAME)
	if not LiveFolder then return end

	local part = Instance.new("Part")
	part.Name     = itemData.name
	part.Size     = Vector3.new(2, 2, 2)
	part.Position = position + Vector3.new(
		math.random(-4, 4), 2, math.random(-4, 4))
	part.Anchored   = false
	part.CanCollide = true
	part.CastShadow = false
	part.Color      = isTrash
		and Color3.fromRGB(80, 60, 40)
		or Color3.fromRGB(120, 100, 80)
	part.Material = Enum.Material.SmoothPlastic

	part:SetAttribute("IsIngredient",   true)
	part:SetAttribute("IngredientName", itemData.name)
	part:SetAttribute("Rarity",         itemData.rarity)
	part:SetAttribute("Weight",         itemData.wt)
	part:SetAttribute("Cost",           isTrash and 0 or itemData.cost)
	part:SetAttribute("Emoji",          itemData.emoji)
	part:SetAttribute("Allergy",        itemData.allergy)
	part:SetAttribute("Zone",           itemData.zone or "Unknown")
	part:SetAttribute("CLValue",        itemData.cl or 0)
	part:SetAttribute("IsPaid",         itemData.paid or false)
	part:SetAttribute("IsTrash",        isTrash or false)

	-- Prompt
	local prompt = Instance.new("ProximityPrompt")
	prompt.ActionText            = "Pick up"
	prompt.ObjectText            = (itemData.emoji or "🍽") .. " " .. itemData.name
		.. (isTrash and " (trash)" or "")
	prompt.KeyboardKeyCode       = Enum.KeyCode.E
	prompt.HoldDuration          = 0.25
	prompt.MaxActivationDistance = 8
	prompt.RequiresLineOfSight   = false
	prompt.Parent                = part

	part.Parent = LiveFolder
	return part
end

-- ── Single item drop (client presses Q / drop button) ───────
DropItemRemote.OnServerEvent:Connect(function(player, slotIndex)
	local s = PlayerState.Get(player)
	if not s then return end

	local item = PlayerState.RemoveItem(player, slotIndex)
	if not item then return end

	local char = player.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local pos  = hrp and hrp.Position or Vector3.new(0, 5, 0)

	spawnDroppedPart(player, item, pos, false)
end)

-- ── 100% state drop (all items, with owner lock) ────────────
-- PlayerState._Trigger100State calls DropAllItems and fires HitPlayer
-- to the client. We listen here server-side to spawn the world parts.
--
-- We hook this by exposing a function on _G that PlayerState calls.
-- This avoids circular requires.

_G.SpawnDroppedItems = function(player, droppedItems)
	local char = player.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	local pos  = hrp and hrp.Position or Vector3.new(0, 5, 0)

	for _, item in ipairs(droppedItems) do
		local part = spawnDroppedPart(player, item, pos, true)
		if part then
			-- Balance Patch v1: owner lock for 1 second
			part:SetAttribute("OwnerLock",   true)
			part:SetAttribute("OwnerPlayer", player.UserId)
			task.delay(C.State100.OwnerLockDuration, function()
				if part and part.Parent then
					part:SetAttribute("OwnerLock", false)
					part:SetAttribute("OwnerPlayer", nil)
				end
			end)
		end
	end
end

