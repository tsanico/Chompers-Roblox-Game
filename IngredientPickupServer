task.spawn(setupContainers)

-- ============================================================
-- CONTAINER DISPENSARY PROMPTS
-- Parts tagged IsBasketDispensary=true / IsCartDispensary=true
-- get a ProximityPrompt so players can see the interaction.
-- On trigger: fires ContainerSwitch remote to client, which
-- calls selectCart(choice, true) in StoreGuide.
-- ============================================================

local ContainerSwitchR = Remotes:FindFirstChild("ContainerSwitch")
if not ContainerSwitchR then
    ContainerSwitchR = Instance.new("RemoteEvent")
    ContainerSwitchR.Name   = "ContainerSwitch"
    ContainerSwitchR.Parent = Remotes
end

local function setupDispensaryPrompts()
    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("BasePart") then
            local isBasket = desc:GetAttribute("IsBasketDispensary") == true
            local isCart   = desc:GetAttribute("IsCartDispensary")   == true
            if isBasket or isCart then
                local choice = isBasket and "basket" or "cart"
                local prompt = makeInteractPrompt(desc,
                    isBasket and "🧺 Basket Rack" or "🛒 Cart Rack",
                    isBasket and "Switch to Basket (faster)" or "Switch to Cart (carries more)",
                    0)
                prompt.Triggered:Connect(function(player)
                    ContainerSwitchR:FireClient(player, choice)
                end)
            end
        end
    end
end
task.spawn(setupDispensaryPrompts)

