	currentAnnounce = task.delay(duration or 4, function()
		TweenService:Create(AnnounceBanner,TweenInfo.new(0.4),
			{BackgroundColor3=Color3.fromRGB(14,10,26)}):Play()
		task.wait(0.5); AnnounceBanner.Visible=false
	end)
end

