local function hideCharacterLocally(hide)
    -- Only used for toilet — hides character from their own camera
    local char = player.Character
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.LocalTransparencyModifier = hide and 1 or 0
        end
    end
end

onR("BathroomAnimStart", function(animType, duration)
    bathroomAnimType = animType
    local isSink = animType == "sink"

    -- Style for sink vs toilet
    local animStroke = BathroomAnimCard:FindFirstChildWhichIsA("UIStroke")
    if animStroke then
        animStroke.Color = isSink
            and Color3.fromRGB(80,160,255)
            or  Color3.fromRGB(150,80,220)
    end
    BathroomAnimEmoji.Text    = isSink and "🚿" or "🚽"
    BathroomAnimLabel.Text    = isSink and "Washing hands…" or "Using the bathroom…"
    BathroomAnimLabel.TextColor3 = isSink
        and Color3.fromRGB(100,200,255)
        or  Color3.fromRGB(180,120,255)
    BathroomAnimOverlay.Visible = true

    if not isSink then hideCharacterLocally(true) end

    -- Countdown ticker
    if bathroomAnimThread then task.cancel(bathroomAnimThread) end
    bathroomAnimThread = task.spawn(function()
        local remaining = math.ceil(duration)
        while remaining > 0 and BathroomAnimOverlay.Visible do
            BathroomAnimCountdown.Text = remaining .. "s"
            BathroomAnimCountdown.TextColor3 = remaining <= 1
                and Color3.fromRGB(220,80,60)
                or  Color3.fromRGB(160,150,200)
            task.wait(1)
            remaining -= 1
        end
        BathroomAnimCountdown.Text = ""
    end)
end)

onR("BathroomAnimComplete", function()
    if bathroomAnimThread then
        task.cancel(bathroomAnimThread)
        bathroomAnimThread = nil
    end
    BathroomAnimOverlay.Visible = false
    if bathroomAnimType == "toilet" then hideCharacterLocally(false) end
    bathroomAnimType = nil
end)
