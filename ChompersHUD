	AnnounceLabel.Text = msg
	AnnounceLabel.TextColor3 = color or C.gold
	local stroke = AnnounceBanner:FindFirstChildWhichIsA("UIStroke")
	if stroke then stroke.Color = color or C.gold end
	AnnounceBanner.Visible = true
