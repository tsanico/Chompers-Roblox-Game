-- ── Helpers ──────────────────────────────────────────────────
local function corner(p, r)
	Instance.new("UICorner", p).CornerRadius = UDim.new(0, r or 12)
end
local function mkStroke(p, t, col)
	local s = Instance.new("UIStroke", p)
	s.Thickness = t or 1.5; s.Color = col or C.stroke; return s
end
local function mkLabel(p, text, font, size, color, xAlign, pos, sz)
	local l = Instance.new("TextLabel")
	l.Text=text or ""; l.Font=font or Enum.Font.GothamBold; l.TextSize=size or 14
	l.TextColor3=color or C.white
	l.TextXAlignment=xAlign or Enum.TextXAlignment.Center
	l.TextYAlignment=Enum.TextYAlignment.Center
	l.BackgroundTransparency=1
	l.Position=pos or UDim2.new(0,0,0,0); l.Size=sz or UDim2.new(1,0,1,0)
	l.Parent=p; return l
end
local function mkFrame(p, size, pos, bg, r, noStroke)
	local f = Instance.new("Frame", p)
	f.Size=size; f.Position=pos or UDim2.new(0,0,0,0)
	f.BackgroundColor3=bg or C.bg; f.BorderSizePixel=0
	corner(f, r or 12)
	if not noStroke then mkStroke(f) end
	return f
end
local function onR(name, fn)
	if not Remotes then return end
	local r = Remotes:FindFirstChild(name)
	if r then r.OnClientEvent:Connect(fn) end
end

