-- Proximity detection loop — finds nearest player within INSPECT_RANGE
RunService.Heartbeat:Connect(function()
	if inspectOpen then return end
	local char = player.Character
	if not char then nearestTarget = nil; InspectHint.Visible = false; return end
	local hrp  = char:FindFirstChild("HumanoidRootPart")
	if not hrp then nearestTarget = nil; InspectHint.Visible = false; return end

	local bestDist = INSPECT_RANGE + 1
	local best = nil
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player then
			local c = p.Character
			local h = c and c:FindFirstChild("HumanoidRootPart")
			if h then
				local d = (hrp.Position - h.Position).Magnitude
				if d < bestDist then bestDist = d; best = p end
			end
		end
	end
	nearestTarget = best
	if best then
		InspectHint.Text = "Press E to Inspect "..best.DisplayName
		InspectHint.Visible = true
	else
		InspectHint.Visible = false
	end
end)



UserInputService.InputBegan:Connect(function(input,gpe)
	if gpe then return end
	local kc=input.KeyCode
	-- Tab: open Store Guide directly to Match → Scoreboard
	if kc==Enum.KeyCode.Tab then
		if _G.Chompers.OpenToScoreboard then
			_G.Chompers.OpenToScoreboard()
		end
	end
	-- E key: open inspect for nearest player, or close if already open
	if kc==Enum.KeyCode.E then
		if inspectOpen then closeInspect()
		elseif nearestTarget then openInspect(nearestTarget) end
	end
	-- Escape: close inspect panel
	if kc==Enum.KeyCode.Escape and inspectOpen then closeInspect() end
	if kc==Enum.KeyCode.G then
		if inventoryOpen then setInventoryOpen(false) end
		if _G.Chompers.IsStoreGuideOpen() then _G.Chompers.CloseStoreGuide()
		else _G.Chompers.OpenStoreGuide() end
	end
	if kc==Enum.KeyCode.I then
		if _G.Chompers.IsStoreGuideOpen() then _G.Chompers.CloseStoreGuide() end
		setInventoryOpen(not inventoryOpen)
	end
	-- Number slot keys
	local n = kc.Value - Enum.KeyCode.One.Value + 1
	if kc==Enum.KeyCode.Zero then n=10 end
	if n>=1 and n<=10 then
		highlightSlot(n)
		local r=Remotes and Remotes:FindFirstChild("SelectSlot")
		if r then r:FireServer(n) end
	end
end)
