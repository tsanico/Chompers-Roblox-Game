local function buildMeter(isLeft, baseCol, warnCol, labelText)
	local container=Instance.new("Frame",Gui)
	container.Name=labelText.."Meter"
	container.Size=UDim2.new(0,METER_W+18,0,METER_H+90)
	container.BackgroundTransparency=1
	-- AnchorPoint centre-Y: left meter left-anchored, right meter right-anchored
	container.AnchorPoint = Vector2.new(isLeft and 0 or 1, 0.5)
	container.Position = UDim2.new(
		isLeft and 0 or 1, isLeft and 8 or -8,
		0.5, 0)   -- true vertical screen centre

	local track=mkFrame(container,
		UDim2.new(0,METER_W,0,METER_H),
		UDim2.new(0,8,0,0),
		Color3.fromRGB(20,18,32),8,true)
	mkStroke(track,1.5,Color3.fromRGB(40,38,55))

	local fill=Instance.new("Frame",track)
	fill.Size=UDim2.new(1,0,0,0); fill.AnchorPoint=Vector2.new(0,1)
	fill.Position=UDim2.new(0,0,1,0)
	fill.BackgroundColor3=baseCol; fill.BorderSizePixel=0; corner(fill,8)

	local warnOverlay=Instance.new("Frame",track)
	warnOverlay.Size=UDim2.new(1,0,1,0)
	warnOverlay.BackgroundColor3=warnCol; warnOverlay.BackgroundTransparency=1
	warnOverlay.BorderSizePixel=0; corner(warnOverlay,8)

	-- container width = METER_W+18 = 48px. Track width = METER_W = 30px at x=8.
	-- Track centre = 8+15 = 23px. Container centre = 24px. Centre pctBg accordingly.
	-- pctBg width = METER_W+4 = 34px → x = (48-34)/2 = 7px to centre under track.
	local pctBg=mkFrame(container,
		UDim2.new(0,METER_W+4,0,26),
		UDim2.new(0,7,0,METER_H+6),
		Color3.fromRGB(30,10,10),6,true)
	local pctL=mkLabel(pctBg,"0%",Enum.Font.GothamBlack,15,Color3.fromRGB(255,80,80))
	pctL.Name="PctLabel"

	-- FULL / DIRTY label centred under pctBg
	mkLabel(container,labelText,Enum.Font.GothamBlack,14,C.dim,
		Enum.TextXAlignment.Center,
		UDim2.new(0,0,0,METER_H+38),UDim2.new(1,0,0,20))

	-- Bath icon (both sides show toilet emoji — 🚽)
	local bathIcon=mkLabel(container,"🚽",
		Enum.Font.GothamBold,24,C.warn,Enum.TextXAlignment.Center,
		UDim2.new(0,0,0,METER_H+60),UDim2.new(1,0,0,26))
	bathIcon.Visible=false

	return fill, pctL, warnOverlay, bathIcon
end

local FFill,FPct,FWarn,FBath=buildMeter(true,  C.fullness, C.warn,   "FULL")
local CFill,CPct,CWarn,CBath=buildMeter(false, C.dirty,    Color3.fromRGB(155,115,35), "DIRTY")

local warnTweens={}
local function updateMeter(fill,pctL,warnF,bathI,baseCol,warnCol,pct)
	pct=math.clamp(pct or 0,0,1)
	TweenService:Create(fill,TweenInfo.new(0.3,Enum.EasingStyle.Quad),
		{Size=UDim2.new(1,0,pct,0)}):Play()
	pctL.Text=math.floor(pct*100).."%"
	local r=math.clamp(baseCol.R+(warnCol.R-baseCol.R)*pct,0,1)
	local g=math.clamp(baseCol.G+(warnCol.G-baseCol.G)*pct,0,1)
	local b=math.clamp(baseCol.B+(warnCol.B-baseCol.B)*pct,0,1)
	TweenService:Create(fill,TweenInfo.new(0.3),{BackgroundColor3=Color3.new(r,g,b)}):Play()
	bathI.Visible=pct>=0.8
	if pct>=0.8 then
		if not warnTweens[warnF] then
			warnTweens[warnF]=TweenService:Create(warnF,
				TweenInfo.new(0.5,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut,-1,true),
				{BackgroundTransparency=0.7})
			warnTweens[warnF]:Play()
		end
	else
		if warnTweens[warnF] then
			warnTweens[warnF]:Cancel(); warnTweens[warnF]=nil; warnF.BackgroundTransparency=1
		end
	end
end

_G.Chompers.UpdateCleanliness=function(v)
	updateMeter(CFill,CPct,CWarn,CBath,C.dirty,Color3.fromRGB(155,115,35),(v or 0)/100)
end
_G.Chompers.UpdateFullness=function(v)
	updateMeter(FFill,FPct,FWarn,FBath,C.fullness,C.warn,(v or 0)/100)
end

