local function addTipLine(text, font, size, color, order)
	local l = Instance.new("TextLabel", TooltipFrame)
	l.Size=UDim2.new(1,0,0,0); l.AutomaticSize=Enum.AutomaticSize.Y
	l.BackgroundTransparency=1; l.Text=text
	l.Font=font or Enum.Font.GothamBold; l.TextSize=size or 14
	l.TextColor3=color or C.white; l.TextXAlignment=Enum.TextXAlignment.Left
	l.TextWrapped=true; l.ZIndex=21; l.LayoutOrder=order or 0
	return l
end

local function addTipDivider(order)
	local d=Instance.new("Frame",TooltipFrame); d.LayoutOrder=order
	d.Size=UDim2.new(1,0,0,1); d.BackgroundColor3=Color3.fromRGB(50,46,70)
	d.BorderSizePixel=0; d.ZIndex=21
end

local function buildTooltip(data, slotIndex)
	clearTooltip()
	if not data or not data.name then TooltipFrame.Visible=false; return end

	-- X-position: centre tooltip above the hovered slot, clamped to screen
	local slotCentreX = (slotIndex-1)*(SLOT_SIZE+SLOT_GAP) + SLOT_SIZE/2
	local pct = math.clamp(slotCentreX/totalHotbarW, 0.05, 0.95)
	TooltipFrame.AnchorPoint = Vector2.new(pct, 1)
	TooltipFrame.Position    = UDim2.new(0.5,0,1,-(BAR_BOTTOM+SLOT_SIZE+10))

	addTipLine((data.emoji or "🍽").."  "..data.name, Enum.Font.GothamBlack, 16, C.white, 1)

	local isRecipe = data.cookStatus ~= nil or data.ingredients ~= nil
	if isRecipe then
		local st = data.cookStatus=="Cooked" and "✅ Cooked"
			or data.cookStatus=="Burned" and "🔥 Burned"
			or data.cookStatus=="Uncooked" and "⚠ Uncooked — needs Stovetop"
			or "🥗 Recipe"
		local sc = data.cookStatus=="Cooked" and C.green or data.cookStatus=="Burned" and C.red or C.gold
		addTipLine(st, Enum.Font.GothamBold, 13, sc, 2)
	else
		addTipLine(data.paid and "✅ Paid — ready to throw" or "❌ Unpaid — pay at checkout",
			Enum.Font.GothamBold, 13, data.paid and C.green or C.red, 2)
	end

	addTipDivider(3)
	if data.cl and data.cl>0 then
		addTipLine("🧼 +"..data.cl.." CL", Enum.Font.Gotham, 13, Color3.fromRGB(65,185,235), 4)
	end
	if data.allergy and data.allergy~="None" then
		addTipLine("⚠️ "..data.allergy, Enum.Font.Gotham, 13, Color3.fromRGB(230,90,90), 5)
	end
	if data.cost and data.cost>0 then
		addTipLine("💲 $"..data.cost, Enum.Font.Gotham, 13, C.money, 6)
	end
	if data.effect and data.effect~="" then
		addTipLine("💥 "..data.effect, Enum.Font.Gotham, 12, Color3.fromRGB(200,195,230), 7)
	end
	if data.buildsInto and #data.buildsInto>0 then
		addTipDivider(8)
		addTipLine("Builds: "..table.concat(data.buildsInto,", "), Enum.Font.Gotham, 12, C.dim, 9)
	end
	TooltipFrame.Visible = true
end

