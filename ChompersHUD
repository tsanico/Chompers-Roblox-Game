local function worldToFrac(wx, wz)
	return math.clamp((300-wx)/600,0,1), math.clamp((wz+200)/400,0,1)
end

-- Draw zone blocks from map
local map = workspace:FindFirstChild("Map")
if map then
	local zones = map:FindFirstChild("Zones")
	if zones then
		for _, z in ipairs(zones:GetChildren()) do
			if z:IsA("BasePart") then
				local x1,z1=worldToFrac(z.Position.X+z.Size.X/2, z.Position.Z-z.Size.Z/2)
				local x2,z2=worldToFrac(z.Position.X-z.Size.X/2, z.Position.Z+z.Size.Z/2)
				local zf = Instance.new("Frame", MapInner)
				zf.Size = UDim2.new(x2-x1,0,z2-z1,0); zf.Position = UDim2.new(x1,0,z1,0)
				zf.BackgroundColor3 = ZONE_COLS[z.Name] or Color3.fromRGB(40,38,55)
				zf.BorderSizePixel = 0; zf.ZIndex = 2; corner(zf, 2)
				mkLabel(zf, z.Name:gsub("Zone_",""):sub(1,4),
					Enum.Font.GothamBold, 6, Color3.fromRGB(220,215,240)).ZIndex = 3
			end
		end
	end
end

