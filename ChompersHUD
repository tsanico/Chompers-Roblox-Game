local function highlightSlot(i)
	for j,sl in ipairs(slots) do
		local str=sl:FindFirstChild("SlotStroke")
		if str then str.Color=j==i and C.red or C.stroke; str.Thickness=j==i and 2.5 or 1.5 end
	end
	activeSlot=i
