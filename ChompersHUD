		{BackgroundColor3=Color3.fromRGB(28,36,52)}):Play()
end)
NapkinPill.MouseLeave:Connect(function()
	TweenService:Create(NapkinPill,TweenInfo.new(0.1),{BackgroundColor3=C.bg}):Play()
end)

-- Click to use napkin
local NapBtn=Instance.new("TextButton",NapkinPill)
NapBtn.Size=UDim2.new(1,0,1,0); NapBtn.BackgroundTransparency=1; NapBtn.Text=""
NapBtn.ZIndex=5
NapBtn.MouseButton1Click:Connect(function()
	if napkinStock<=0 then return end
	napkinStock=napkinStock-1
	-- Queue cooldown: starts after previous cooldowns finish
	local now=os.clock()
	local startAt = #napkinQueue>0 and napkinQueue[#napkinQueue].finishTime or now
	table.insert(napkinQueue,{startTime=startAt, finishTime=startAt+NAP_COOLDOWN})
	napkinRefreshUI()
	local r=Remotes and Remotes:FindFirstChild("UseNapkin")
	if r then r:FireServer() end
end)

