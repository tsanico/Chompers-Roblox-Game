		{BackgroundColor3 = over and C.warn or pct >= 0.8 and C.gold or C.weight}):Play()
	wDisplay.TextColor3 = over and C.warn or C.gold
	TweenService:Create(WeightOuter, TweenInfo.new(0.3),
		{BackgroundColor3 = over and Color3.fromRGB(40,18,18) or Color3.fromRGB(22,20,34)}):Play()
