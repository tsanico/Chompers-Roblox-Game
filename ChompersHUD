_G.Chompers.SetSlotItem = function(i, data)
	if i<1 or i>NUM_SLOTS then return end
	local sl = slots[i]; slotData[i] = data or {}
	local r  = data and data.rarity or nil

	-- Background: cook status for recipes, paid status for ingredients
	local bg
	if data then
		if data.cookStatus == "Cooked" then
			bg = SLOT_COOKED_BG
		elseif data.cookStatus == "Burned" then
			bg = SLOT_BURNED_BG
		elseif data.cookStatus == "Uncooked" then
			bg = SLOT_UNCOOKED_BG
		elseif data.ingredients then
			-- Recipe with no cookStatus = ready
			bg = SLOT_COOKED_BG
		elseif data.paid == false then
			bg = SLOT_UNPAID_BG
		elseif data.paid == true then
			bg = SLOT_PAID_BG
		else
			bg = r and (RARITY_BG[r] or C.bg) or C.bg
		end
	else
		bg = C.bg
	end
	sl.BackgroundColor3 = bg

	local str = sl:FindFirstChild("SlotStroke")
	if str then
		str.Color     = i==activeSlot and C.red or (r and RARITY_STROKE[r] or C.stroke)
		str.Thickness = i==activeSlot and 2.5 or 1.5
	end
	sl.EmojiLabel.Text = data and (data.emoji or "") or ""
	-- Price label: show paid status indicator instead of price
	if data then
		if data.cookStatus == "Cooked" then
			sl.PriceLabel.Text = "✓ COOKED"; sl.PriceLabel.TextColor3 = C.green
		elseif data.cookStatus == "Burned" then
			sl.PriceLabel.Text = "BURNED"; sl.PriceLabel.TextColor3 = C.red
		elseif data.cookStatus == "Uncooked" then
			sl.PriceLabel.Text = "RAW"; sl.PriceLabel.TextColor3 = C.gold
		elseif data.paid == false then
			sl.PriceLabel.Text = "UNPAID"; sl.PriceLabel.TextColor3 = C.red
		else
			sl.PriceLabel.Text = data.cost and ("$"..data.cost) or ""
			sl.PriceLabel.TextColor3 = C.green
		end
	else
		sl.PriceLabel.Text = ""
	end
end
_G.Chompers.SetSelectedSlot = function(i) highlightSlot(i) end
_G.Chompers.GetSelectedSlot = function() return activeSlot end
_G.Chompers.GetSlotCount    = function() return NUM_SLOTS end

