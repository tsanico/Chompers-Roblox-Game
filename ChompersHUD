	-- Always grey alliance button immediately — server will re-enable if conditions met
	setAllianceBtnState(false)
	-- If phase blocks alliance, show reason instead of "no bracelet"
	if ALLIANCE_BLOCKED[currentPhase] then
		AllianceBtn.Text = "🤝  Alliances open during match only"
