local NAP_COOLDOWN    = 20  -- seconds per napkin
local napkinStock     = 1   -- immediately usable
local napkinQueue     = {}  -- {finishTime=absolute} per queued cooldown
local napkinUsedTotal = 0   -- total used (for queue end calculation)

