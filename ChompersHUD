local function highlightSlot(i)
	for j, sl in ipairs(slots) do
		local str = sl:FindFirstChild("SlotStroke")
		if str then
			str.Color = j == i and C.red or C.stroke
			str.Thickness = j == i and 2.5 or 1.5
		end
	end
	activeSlot = i
end
highlightSlot(1)

_G.Chompers.SetSlotItem = function(i, data)
	if i < 1 or i > NUM_SLOTS then return end
	local sl = slots[i]; slotData[i] = data or {}
	local r = data and data.rarity or nil
	sl.BackgroundColor3 = r and (RARITY_BG[r] or C.bg) or C.bg
	local str = sl:FindFirstChild("SlotStroke")
	if str then str.Color = i==activeSlot and C.red or (r and RARITY_STROKE[r] or C.stroke) end
	sl.EmojiLabel.Text   = data and (data.emoji or "") or ""
	sl.PriceLabel.Text   = data and data.price and ("$"..data.price) or ""
	sl.PriceLabel.TextColor3 = data and data.paid and C.green or C.gold
end
_G.Chompers.SetSelectedSlot = function(i) highlightSlot(i) end
_G.Chompers.GetSelectedSlot = function() return activeSlot end
_G.Chompers.GetSlotCount    = function() return NUM_SLOTS end

-- Number key slot switching
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	local n = input.KeyCode.Value - Enum.KeyCode.One.Value + 1
	if input.KeyCode == Enum.KeyCode.Zero then n = 10 end
	if n >= 1 and n <= 10 then
		highlightSlot(n)
		if Remotes then
			local r = Remotes:FindFirstChild("SelectSlot")
			if r then r:FireServer(n) end
		end
	end
end)

