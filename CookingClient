		if _G.Chompers and _G.Chompers.Announce then
			_G.Chompers.Announce(
				"✅  "..data.name.." assembled! Take it to the Stovetop.",
				Color3.fromRGB(70,195,85), 3)
		end
	else
		if _G.Chompers and _G.Chompers.Announce then
			_G.Chompers.Announce("❌  "..tostring(data),
				Color3.fromRGB(218,65,65), 2.5)
		end
	end
end)

