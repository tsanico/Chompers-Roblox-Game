end

-- Stop heat bar — send empty signal (server computes needle from its own clock)
local function stopHeatBar()
	if not heatActive then return end
	heatActive = false
	if heatConn then heatConn:Disconnect(); heatConn = nil end
	showHeatPanel(false)
	StopHeatBar:FireServer()   -- server ignores args; uses heatBarStartTimes[player]
end

BeginHeatBar.OnClientEvent:Connect(function(dishName, speed, window, serverTime)
	showCookPanel(false)
	if cookConn then cookConn:Disconnect(); cookConn = nil end

	heatActive      = true
	heatSpeed       = speed  or 1.8
	heatWindow      = window or 2.0
	-- Use server clock so client needle matches server's computation exactly
	heatServerStart = serverTime or workspace:GetServerTimeNow()

	HeatTitle.Text = "⚡  HEAT CONTROL — press E  ·  "..dishName
	showHeatPanel(true)

	if heatConn then heatConn:Disconnect() end
	heatConn = RunService.Heartbeat:Connect(function()
		if not heatActive then return end

		-- Match server triangle-wave formula exactly:
		-- elapsed → phase (0-1) → triangle (0→1→0)
		local elapsed = workspace:GetServerTimeNow() - heatServerStart
		local period  = 1 / heatSpeed
		local phase   = (elapsed % period) / period
		local needle  = phase < 0.5 and (phase * 2) or ((1 - phase) * 2)

		Needle.Position = UDim2.new(needle, -2.5, 0, -5)

		-- Zone-based needle colour and perfect-zone glow
		local inPerfect = needle >= 0.32 and needle <= 0.68
		if needle < 0.32 then
			Needle.BackgroundColor3 = Color3.fromRGB(100,150,255)
			perfectZone.BackgroundColor3 = Color3.fromRGB(35,160,55)
		elseif inPerfect then
			-- Pulse the perfect zone brighter when needle is inside it
			local pulse = math.floor(tick()*8) % 2 == 0
			Needle.BackgroundColor3 = Color3.fromRGB(255,255,255)
			perfectZone.BackgroundColor3 = pulse
				and Color3.fromRGB(60,200,80)
				or  Color3.fromRGB(35,160,55)
		else
			Needle.BackgroundColor3 = Color3.fromRGB(255,90,70)
			perfectZone.BackgroundColor3 = Color3.fromRGB(35,160,55)
		end

		-- Auto-expire
		if elapsed >= heatWindow then
			stopHeatBar()
		end
	end)
end)

-- E stops the heat bar
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.E and heatActive then
		stopHeatBar()
	end
end)

