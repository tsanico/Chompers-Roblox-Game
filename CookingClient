		local row = Instance.new("TextButton", PrepScroll)
		row.LayoutOrder = i
		row.Size = UDim2.new(1,0,0,72)
		row.BackgroundColor3 = Color3.fromRGB(24,22,38)
		row.BorderSizePixel = 0; row.AutoButtonColor = false
		row.Text = ""; row.ZIndex = 21; corner(row, 10)
		local rowStroke = mkStroke(row, 1.5, Color3.fromRGB(48,44,70))

		-- Large emoji
		mkLabel(row, r.emoji or "🍳", Enum.Font.GothamBold, 40,
			Color3.fromRGB(245,242,255), Enum.TextXAlignment.Center,
			UDim2.new(0,0,0,0), UDim2.new(0,70,1,0)).ZIndex = 22

		-- Name + rarity
		mkLabel(row, r.name, Enum.Font.GothamBlack, 20,
			Color3.fromRGB(245,242,255), Enum.TextXAlignment.Left,
			UDim2.new(0,74,0,8), UDim2.new(0.55,0,0,26)).ZIndex = 22
		mkLabel(row, (r.rarity or "Common").."  ·  "..#(r.ingredients or {}).." ingredients",
			Enum.Font.GothamBold, 14, Color3.fromRGB(105,100,138),
			Enum.TextXAlignment.Left, UDim2.new(0,74,0,38), UDim2.new(0.55,0,0,18)).ZIndex = 22

		-- CL badge
		if r.cl and r.cl > 0 then
			local badge = Instance.new("Frame", row); badge.ZIndex = 22
			badge.Size=UDim2.new(0,80,0,30); badge.AnchorPoint=Vector2.new(1,0.5)
			badge.Position=UDim2.new(1,-10,0.5,0)
			badge.BackgroundColor3=Color3.fromRGB(14,28,50); badge.BorderSizePixel=0; corner(badge,8)
			mkStroke(badge, 1.5, Color3.fromRGB(65,185,235))
			mkLabel(badge,"🧼 +"..r.cl,Enum.Font.GothamBlack,16,Color3.fromRGB(65,185,235)).ZIndex=23
		end

		-- Hover + click
		row.MouseEnter:Connect(function()
			TweenService:Create(row,TweenInfo.new(0.08),
				{BackgroundColor3=Color3.fromRGB(32,30,50)}):Play()
			rowStroke.Color = Color3.fromRGB(70,195,85)
		end)
		row.MouseLeave:Connect(function()
			TweenService:Create(row,TweenInfo.new(0.08),
				{BackgroundColor3=Color3.fromRGB(24,22,38)}):Play()
			rowStroke.Color = Color3.fromRGB(48,44,70)
		end)

		local capName = r.name
		row.MouseButton1Click:Connect(function()
			-- Stamp flash — row goes bright green then resets
			row.BackgroundColor3 = Color3.fromRGB(14,36,18)
			rowStroke.Color = Color3.fromRGB(70,195,85)
			task.delay(0.15, function()
				TweenService:Create(row,TweenInfo.new(0.2),
					{BackgroundColor3=Color3.fromRGB(24,22,38)}):Play()
			end)
			RequestAssemble:FireServer(capName)
		end)
	end
	showPrepUI(true)
end)

HidePrepUI.OnClientEvent:Connect(function()
	showPrepUI(false); task.wait(0.25); clearPrepScroll()
end)

AssembleResult.OnClientEvent:Connect(function(success, data)
	if success then
		-- Brief green stamp flash on the prep panel before it hides
		TweenService:Create(PrepFrame, TweenInfo.new(0.1),
			{BackgroundColor3=Color3.fromRGB(14,36,18)}):Play()
		task.delay(0.12, function()
			TweenService:Create(PrepFrame, TweenInfo.new(0.2),
				{BackgroundColor3=Color3.fromRGB(16,14,28)}):Play()
		end)
		task.wait(0.18)
		showPrepUI(false); task.wait(0.25); clearPrepScroll()
		if _G.Chompers and _G.Chompers.Announce then
			_G.Chompers.Announce(
				"✅  "..data.name.." assembled — take it to a Stovetop.",
				Color3.fromRGB(70,195,85), 2.5)
		end
	else
		if _G.Chompers and _G.Chompers.Announce then
			_G.Chompers.Announce("❌  "..tostring(data), Color3.fromRGB(218,65,65), 2.5)
		end
	end
end)

UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.Escape and PrepFrame.Visible then
		showPrepUI(false); task.wait(0.25); clearPrepScroll()
	end
end)

