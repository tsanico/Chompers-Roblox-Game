-- ── HOT HANDS BADGE (0.8s after perfect/cold cook) ───────────
-- Small pill at bottom-right of hotbar area pulses gold.
local HotHandsBadge = Instance.new("Frame", CookGui)
HotHandsBadge.Size             = UDim2.new(0, 180, 0, 36)
HotHandsBadge.AnchorPoint      = Vector2.new(1, 1)
HotHandsBadge.Position         = UDim2.new(1, -14, 1, -110)
HotHandsBadge.BackgroundColor3 = Color3.fromRGB(40, 28, 6)
HotHandsBadge.BorderSizePixel  = 0
HotHandsBadge.Visible          = false
HotHandsBadge.ZIndex           = 55
corner(HotHandsBadge, 10)
mkStroke(HotHandsBadge, 2, Color3.fromRGB(239,159,39))
local HotHandsLabel = mkLabel(HotHandsBadge,
	"🔥 HOT HANDS ACTIVE",
	Enum.Font.GothamBlack, 14,
	Color3.fromRGB(255,200,50))
HotHandsLabel.ZIndex = 56

local hotHandsThread = nil
local function showHotHands(duration)
	if hotHandsThread then task.cancel(hotHandsThread) end
	HotHandsBadge.Visible = true
	hotHandsThread = task.spawn(function()
		local endT = tick() + duration
		while tick() < endT do
			-- Pulse gold ↔ orange
			local pulse = math.floor(tick() * 6) % 2 == 0
			HotHandsBadge.BackgroundColor3 = pulse
				and Color3.fromRGB(50,34,6)
				or  Color3.fromRGB(30,20,4)
			local strokeC = HotHandsBadge:FindFirstChildWhichIsA("UIStroke")
			if strokeC then
				strokeC.Color = pulse
					and Color3.fromRGB(255,200,50)
					or  Color3.fromRGB(180,120,30)
			end
			task.wait(0.08)
		end
		HotHandsBadge.Visible = false
		hotHandsThread = nil
	end)
end

