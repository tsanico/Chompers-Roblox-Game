		row.BackgroundColor3 = Color3.fromRGB(24,22,38)
		row.BorderSizePixel = 0; row.AutoButtonColor = false
		row.Text = ""; row.ZIndex = 21; corner(row, 10)
		mkStroke(row, 1.5, Color3.fromRGB(48,44,70))

		-- Emoji
		mkLabel(row, r.emoji or "🍳", Enum.Font.GothamBold, 40,
			Color3.fromRGB(245,242,255), Enum.TextXAlignment.Center,
			UDim2.new(0,0,0,0), UDim2.new(0,70,1,0)).ZIndex = 22

		-- Name
		mkLabel(row, r.name, Enum.Font.GothamBlack, 20,
			Color3.fromRGB(245,242,255), Enum.TextXAlignment.Left,
			UDim2.new(0,74,0,8), UDim2.new(0.55,0,0,26)).ZIndex = 22

		-- Rarity + ingredient count
		mkLabel(row, (r.rarity or "Common").."  ·  "..#(r.ingredients or {}).." ingredients",
			Enum.Font.GothamBold, 14, Color3.fromRGB(105,100,138),
			Enum.TextXAlignment.Left,
			UDim2.new(0,74,0,38), UDim2.new(0.55,0,0,18)).ZIndex = 22

		-- CL badge
		if r.cl and r.cl > 0 then
			local badge = Instance.new("Frame", row); badge.ZIndex = 22
			badge.Size = UDim2.new(0,80,0,30)
			badge.AnchorPoint = Vector2.new(1,0.5)
			badge.Position = UDim2.new(1,-10,0.5,0)
			badge.BackgroundColor3 = Color3.fromRGB(14,28,50)
			badge.BorderSizePixel = 0; corner(badge, 8)
			mkStroke(badge, 1.5, Color3.fromRGB(65,185,235))
			mkLabel(badge, "🧼 +"..r.cl, Enum.Font.GothamBlack, 16,
				Color3.fromRGB(65,185,235)).ZIndex = 23
		end

