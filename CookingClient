CookTrack.BackgroundColor3=Color3.fromRGB(28,26,40); CookTrack.BorderSizePixel=0; corner(CookTrack,6)
local CookFill = Instance.new("Frame", CookTrack)
CookFill.Size=UDim2.new(0,0,1,0); CookFill.BackgroundColor3=Color3.fromRGB(235,155,35)
CookFill.BorderSizePixel=0; corner(CookFill,6)

local cookStartTime = 0
local cookDuration  = 0
local cookConn      = nil
local cookPulseConn = nil

local function showCookPanel(visible)
	CookFrame.Visible = visible or false
	slide(CookFrame, visible or false)
	-- Start/stop danger pulse
	if cookPulseConn then cookPulseConn:Disconnect(); cookPulseConn = nil end
	if visible then
		cookPulseConn = RunService.Heartbeat:Connect(function()
			local pulseFast = math.floor(tick()*5) % 2 == 0
			cookStroke.Color = pulseFast
				and Color3.fromRGB(235,155,35)
				or  Color3.fromRGB(100,70,20)
		end)
	else
		cookStroke.Color = Color3.fromRGB(235,155,35)
	end
end

ShowCookUI.OnClientEvent:Connect(function(dishName, dishEmoji, duration)
	cookStartTime = tick()
	cookDuration  = duration
	CookTitle.Text = (dishEmoji or "🍳").."  Cooking "..dishName.."…"
	CookFill.Size  = UDim2.new(0,0,1,0)
	showCookPanel(true)

	if cookConn then cookConn:Disconnect() end
	cookConn = RunService.Heartbeat:Connect(function()
		local pct = math.clamp((tick()-cookStartTime)/math.max(cookDuration,0.1), 0, 1)
		CookFill.Size = UDim2.new(pct,0,1,0)
		-- Fill colour warms as it nears completion
		CookFill.BackgroundColor3 = pct < 0.7
			and Color3.fromRGB(235,155,35)
			or  Color3.fromRGB(255, 100 + math.floor((1-pct)*155), 20)
		if pct >= 1 then
			if cookConn then cookConn:Disconnect(); cookConn = nil end
		end
	end)
end)

HideCookUI.OnClientEvent:Connect(function()
	if cookConn then cookConn:Disconnect(); cookConn = nil end
	showCookPanel(false)
end)

