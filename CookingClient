CookingComplete.OnClientEvent:Connect(function(finalDish, zone)
	-- Clean up any active UI
	if heatActive then
		heatActive = false
		if heatConn then heatConn:Disconnect(); heatConn = nil end
		showHeatPanel(false)
	end
	showCookPanel(false)

	local dishName = finalDish and finalDish.name or "Dish"
	local cl       = finalDish and finalDish.cl or 0

	if zone == "Perfect" then
		-- Green flash + steam + stamp + HOT HANDS
		flashScreen(Color3.fromRGB(40,200,60), 0.4)
		spawnSteam()
		showResultStamp("✓", "PERFECT HEAT", "+"..cl.." CL  ·  "..dishName,
			Color3.fromRGB(80,220,80), 2.0)
		showHotHands(0.8)

	elseif zone == "Burned" then
		-- Red flash + smoke + stamp (burned identity, not failure)
		flashScreen(Color3.fromRGB(200,50,30), 0.5)
		spawnSmoke()
		showResultStamp("🔥", "BURNED", dishName.."  ·  −20% CL  +30% status",
			Color3.fromRGB(235,90,60), 2.0)
		-- No HOT HANDS for burned — no throw bonus

	else  -- Cold
		flashScreen(Color3.fromRGB(60,100,200), 0.3)
		showResultStamp("🥶", "COLD COOK", dishName.."  ·  no heat bonus",
			Color3.fromRGB(100,150,255), 1.6)
	end
end)

