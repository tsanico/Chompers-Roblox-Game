-- ── SMOKE PARTICLES (burned dish — simple UI effect) ──────────
-- Three "smoke" dots that float up and fade on burned result
local function spawnSmoke()
	for i = 1, 3 do
		local dot = Instance.new("TextLabel", CookGui)
		dot.Text = "💨"
		dot.Font = Enum.Font.GothamBold
		dot.TextSize = 28 + i * 6
		dot.BackgroundTransparency = 1
		dot.Size = UDim2.new(0,50,0,50)
		dot.ZIndex = 57
		dot.Position = UDim2.new(0.5, (i-2)*40, 0.42, 10)
		task.delay(i * 0.1, function()
			TweenService:Create(dot,
				TweenInfo.new(1.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
				{Position = UDim2.new(0.5, (i-2)*50, 0.28, 0)}):Play()
			TweenService:Create(dot,
				TweenInfo.new(1.4, Enum.EasingStyle.Linear),
				{TextTransparency = 1}):Play()
			task.delay(1.5, function() dot:Destroy() end)
		end)
	end
end

