-- Heat bar state
local heatActive   = false
local heatSpeed    = 1.8
local heatWindow   = 2.0
local heatStart    = 0
local heatConn     = nil
local heatSentZone = false

local function showHeatPanel(visible)
	HeatFrame.Visible = visible
	TweenService:Create(HeatFrame, TweenInfo.new(0.15, Enum.EasingStyle.Back,
		Enum.EasingDirection.Out),
		{Position = UDim2.new(0.5,0,1, visible and -24 or 80)}):Play()
end

local function stopHeatBar(needlePos)
	if not heatActive then return end
	heatActive   = false
	heatSentZone = true
	if heatConn then heatConn:Disconnect(); heatConn = nil end
	showHeatPanel(false)
	StopHeatBar:FireServer(needlePos)
end

BeginHeatBar.OnClientEvent:Connect(function(dishName, speed, window)
	-- Hide cook progress panel
	showCookPanel(false)
	if cookConn then cookConn:Disconnect(); cookConn = nil end

	heatActive    = true
	heatSentZone  = false
	heatSpeed     = speed or 1.8
	heatWindow    = window or 2.0
	heatStart     = tick()

	HeatTitle.Text = "⚡  HEAT CONTROL — press E!  (" .. dishName .. ")"
	showHeatPanel(true)

	if heatConn then heatConn:Disconnect() end
	heatConn = RunService.Heartbeat:Connect(function()
		if not heatActive then return end
		local elapsed = tick() - heatStart
		-- Needle oscillates: abs(sin(t)) goes 0→1→0 repeatedly
		local needle  = math.abs(math.sin(elapsed * heatSpeed * math.pi))
		Needle.Position = UDim2.new(needle, -2, 0, -4)

		-- Colour needle by zone
		if needle < 0.32 then
			Needle.BackgroundColor3 = Color3.fromRGB(100,140,255)
		elseif needle <= 0.68 then
			Needle.BackgroundColor3 = Color3.fromRGB(80,220,80)
		else
			Needle.BackgroundColor3 = Color3.fromRGB(255,80,60)
		end

		-- Auto-expire
		if elapsed >= heatWindow then
			stopHeatBar(needle)  -- send final position as Cold
		end
	end)
end)

-- E key stops the heat bar
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.E and heatActive then
		local elapsed = tick() - heatStart
		local needle  = math.abs(math.sin(elapsed * heatSpeed * math.pi))
		stopHeatBar(needle)
	end
end)

-- ── COOKING COMPLETE ─────────────────────────────────────────
-- Flash the hotbar slot for 0.8s (Finish Window — Part 41A)
CookingComplete.OnClientEvent:Connect(function(finalDish, zone)
	if heatActive then
		heatActive = false
		if heatConn then heatConn:Disconnect(); heatConn = nil end
		showHeatPanel(false)
	end
	showCookPanel(false)

	-- Announce result locally
	local msg, col
	if zone == "Perfect" then
		msg = "✓ PERFECT HEAT  +"..math.floor((finalDish.cl or 0)).." CL  — "..(finalDish.name)
		col = Color3.fromRGB(80,220,80)
	elseif zone == "Burned" then
		msg = "🔥 BURNED  "..(finalDish.name).." — −20% CL, +30% status"
		col = Color3.fromRGB(218,65,65)
	else
		msg = "🥶 Cold cook  "..(finalDish.name).." — no heat bonus"
		col = Color3.fromRGB(100,140,255)
	end

	if _G.Chompers and _G.Chompers.Announce then
		_G.Chompers.Announce(msg, col, 3)
	end

	-- 0.8s finish window: flash hotbar gold
	-- ThrowServer checks dish.cookFinishedAt — hotbar flash is purely cosmetic here
	local FINISH_WINDOW = 0.8
	local flashEnd = tick() + FINISH_WINDOW
	task.spawn(function()
		local ch = _G.Chompers
		while tick() < flashEnd do
			local flashOn = math.floor(tick()*10) % 2 == 0
			-- Brief gold pulse on selected slot — visual only
			if ch and ch.GetSelectedSlot then
				local slot = ch.GetSelectedSlot()
				-- If the hotbar slot matches the cooked dish, flash it
				-- (best-effort; exact slot tracking would require a sync)
			end
			task.wait(0.05)
		end
	end)
end)

