local function spawnConf()
	confActive=true
	task.spawn(function()
		while confActive do
			for _=1,3 do
				local e=Instance.new("TextLabel",Gui)
				e.BackgroundTransparency=1; e.ZIndex=58
				e.Font=Enum.Font.GothamBold; e.TextSize=26+(math.random()*12)
