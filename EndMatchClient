--
-- Displays the match results screen when MatchResult fires.
-- Shows: winner banner, full rankings table, 5 accolade cards.
-- Auto-dismisses when the next Prelobby phase starts.
-- ============================================================

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")
