        if row.userId==player.UserId then stroke(rf,1.5,C.blue) end

        lbl(rf,RANK_MEDALS[i] or tostring(i),Enum.Font.GothamBlack,18,C.gold,
            Enum.TextXAlignment.Center,UDim2.new(0,0,0,0),UDim2.new(0,30,1,0)).ZIndex=24
        local nl=lbl(rf,row.name,Enum.Font.GothamBold,14,
            row.isEliminated and C.dim or C.white,Enum.TextXAlignment.Left,
            UDim2.new(0,32,0,2),UDim2.new(0.5,-34,0,18)); nl.ZIndex=24; nl.TextTruncate=Enum.TextTruncate.AtEnd
        local sl=lbl(rf,row.isEliminated and "💀 Elim" or "🟢 Alive",Enum.Font.Gotham,11,
