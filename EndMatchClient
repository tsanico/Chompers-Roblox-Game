-- ── Show / hide logic ─────────────────────────────────────────
local countdownConn = nil

local function hideScreen()
    ResultGui.Enabled = false
    if countdownConn then countdownConn:Disconnect(); countdownConn = nil end
end

local function showScreen(result)
    ResultGui.Enabled = true

    -- Winner banner
    local w = result.winner
    if w.type == "LastChef" then
        WinEmoji.Text    = "👑"
        WinNameLabel.Text = w.name
        WinTypeLabel.Text  = "Last Chef Standing  ·  Golden Apron"
        WinScoreLabel.Text = tostring(w.score).." pts"
        mkStroke(WinBanner, 2, Color3.fromRGB(255,215,0))
    elseif w.type == "GrandGrocer" then
        WinEmoji.Text    = "🏆"
        WinNameLabel.Text = w.name
        WinTypeLabel.Text  = "Grand Grocer  ·  Top Points"
        WinScoreLabel.Text = tostring(w.score).." pts"
        mkStroke(WinBanner, 2, C.gold)
    else
        WinEmoji.Text    = "🤷"
        WinNameLabel.Text = "No winner this round"
        WinTypeLabel.Text  = result.timedOut and "Time expired — everyone survived" or ""
        WinScoreLabel.Text = ""
    end

    buildRankings(result.rankings)
    buildAccolades(result.accolades)

    -- Countdown label (driven by server phase timer — approximate)
    local accoladesDuration = 20   -- matches C.Phase.Accolades
    local endAt = tick() + accoladesDuration
    if countdownConn then countdownConn:Disconnect() end
    countdownConn = RunService.Heartbeat:Connect(function()
        local remaining = math.max(0, math.ceil(endAt - tick()))
        CountdownLabel.Text = "Next match in " .. remaining .. "s"
        if remaining <= 0 then
            countdownConn:Disconnect(); countdownConn = nil
        end
    end)

    -- Entrance animation: panel drops in from above
    Panel.Position = UDim2.new(0.5, 0, -0.2, 0)
    TweenService:Create(Panel,
        TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
end

-- ── Remote listeners ──────────────────────────────────────────
if MatchResult then
    MatchResult.OnClientEvent:Connect(function(result)
        showScreen(result)
    end)
end

if PhaseChangedR then
    PhaseChangedR.OnClientEvent:Connect(function(phase)
        if phase == "Prelobby" then
            hideScreen()
        end
    end)
end

print("[EndMatchClient] Ready")
