local function buildLB(rankings)
	for _,c in ipairs(LBScroll:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
	for i,row in ipairs(rankings) do
		local isMe=row.userId==player.UserId
		local rf=Instance.new("Frame",LBScroll)
		rf.Size=UDim2.new(1,0,0,44); rf.LayoutOrder=i
		rf.BackgroundColor3=isMe and Color3.fromRGB(22,28,48) or Color3.fromRGB(18,16,30)
		rf.BorderSizePixel=0; rf.ZIndex=22; corner(rf,8)
		if isMe then mkStroke(rf,1.5,C.blue) end

		lbl(rf,MEDALS_LBL[i] or tostring(i),Enum.Font.GothamBlack,18,C.gold,
			Enum.TextXAlignment.Center,UDim2.new(0,0,0,0),UDim2.new(0,32,1,0)).ZIndex=23

		local nameC=row.isEliminated and C.dim or C.white
		local nl=lbl(rf,row.name,Enum.Font.GothamBold,14,nameC,
			Enum.TextXAlignment.Left,UDim2.new(0,34,0,4),UDim2.new(0.44,-36,0,18))
		nl.ZIndex=23; nl.TextTruncate=Enum.TextTruncate.AtEnd

		local statusTxt=row.isSurvivor and "🟢" or "💀"
		lbl(rf,statusTxt,Enum.Font.Gotham,13,row.isSurvivor and C.green or C.red,
			Enum.TextXAlignment.Left,UDim2.new(0,34,0,24),UDim2.new(0.44,-36,0,16)).ZIndex=23

		lbl(rf,tostring(row.score),Enum.Font.GothamBlack,15,C.gold,
			Enum.TextXAlignment.Left,UDim2.new(0.46,0,0,0),UDim2.new(0.18,0,1,0)).ZIndex=23
		lbl(rf,tostring((row.clDealt or 0)+(row.flDealt or 0)),Enum.Font.GothamBold,14,C.white,
			Enum.TextXAlignment.Left,UDim2.new(0.64,0,0,0),UDim2.new(0.18,0,1,0)).ZIndex=23
		lbl(rf,tostring(row.cook or 0),Enum.Font.GothamBold,14,C.white,
			Enum.TextXAlignment.Left,UDim2.new(0.82,0,0,0),UDim2.new(0.18,0,1,0)).ZIndex=23
	end
end

