-- ── Rankings table ────────────────────────────────────────────
local RankScroll = Instance.new("ScrollingFrame", Panel)
RankScroll.Size = UDim2.new(0.52,-18,1,-220)
RankScroll.Position = UDim2.new(0,12,0,162)
RankScroll.BackgroundTransparency = 1; RankScroll.BorderSizePixel=0
RankScroll.ScrollBarThickness = 5
RankScroll.ScrollBarImageColor3 = C.gold
RankScroll.CanvasSize = UDim2.new(1,0,0,0)
RankScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
RankScroll.ZIndex = 22
local RankLayout = Instance.new("UIListLayout", RankScroll)
RankLayout.SortOrder = Enum.SortOrder.LayoutOrder; RankLayout.Padding = UDim.new(0,4)
local RankPad = Instance.new("UIPadding", RankScroll)
RankPad.PaddingTop = UDim.new(0,2); RankPad.PaddingBottom = UDim.new(0,8)

local RANK_MEDALS = {"🥇","🥈","🥉","4️⃣","5️⃣","6️⃣","7️⃣","8️⃣","9️⃣","🔟"}

local function buildRankings(rankings)
    for _, c in ipairs(RankScroll:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end
    end

    -- Column header
    local hdr = Instance.new("Frame", RankScroll)
    hdr.Size=UDim2.new(1,0,0,22); hdr.BackgroundTransparency=1
    hdr.LayoutOrder=0; hdr.ZIndex=23
    local function hcol(txt, pos, sz)
        local l = mkLabel(hdr, txt, Enum.Font.GothamBlack, 11, C.dim,
            Enum.TextXAlignment.Left, pos, sz); l.ZIndex=23
    end
    hcol("PLAYER",  UDim2.new(0,32,0,0), UDim2.new(0.48,0,1,0))
    hcol("PTS",     UDim2.new(0.48,0,0,0), UDim2.new(0.2,0,1,0))
    hcol("CL",      UDim2.new(0.68,0,0,0), UDim2.new(0.16,0,1,0))
    hcol("ELIM",    UDim2.new(0.84,0,0,0), UDim2.new(0.16,0,1,0))

    for i, row in ipairs(rankings) do
        local isMe = row.userId == player.UserId
        local row_f = Instance.new("Frame", RankScroll)
        row_f.Size = UDim2.new(1,0,0,44)
        row_f.BackgroundColor3 = isMe
            and Color3.fromRGB(24,30,50)
            or  Color3.fromRGB(18,16,30)
        row_f.BorderSizePixel=0; row_f.LayoutOrder=i; row_f.ZIndex=22
        corner(row_f, 8)
        if isMe then mkStroke(row_f, 1.5, C.blue) end

        local medalStr = RANK_MEDALS[i] or tostring(i)
        mkLabel(row_f, medalStr, Enum.Font.GothamBlack, 20, C.gold,
            Enum.TextXAlignment.Center, UDim2.new(0,0,0,0), UDim2.new(0,30,1,0)).ZIndex=23

        local nameCol = row.isEliminated and C.dim or C.white
        local nameL = mkLabel(row_f, row.name, Enum.Font.GothamBold, 14, nameCol,
            Enum.TextXAlignment.Left, UDim2.new(0,32,0,4), UDim2.new(0.48,-34,0,20))
        nameL.ZIndex=23; nameL.TextTruncate = Enum.TextTruncate.AtEnd

        local statusSub = row.isEliminated and "Eliminated" or "Survivor ✓"
        local statusCol = row.isEliminated and C.red or C.green
        mkLabel(row_f, statusSub, Enum.Font.Gotham, 11, statusCol,
            Enum.TextXAlignment.Left, UDim2.new(0,32,0,26), UDim2.new(0.48,-34,0,14)).ZIndex=23

        mkLabel(row_f, tostring(row.score), Enum.Font.GothamBlack, 16, C.gold,
            Enum.TextXAlignment.Left, UDim2.new(0.48,0,0,0), UDim2.new(0.2,0,1,0)).ZIndex=23
        mkLabel(row_f, tostring(row.clDealt), Enum.Font.GothamBold, 14, C.white,
            Enum.TextXAlignment.Left, UDim2.new(0.68,0,0,0), UDim2.new(0.16,0,1,0)).ZIndex=23
        mkLabel(row_f, tostring(row.eliminations or 0), Enum.Font.GothamBold, 14, C.white,
            Enum.TextXAlignment.Left, UDim2.new(0.84,0,0,0), UDim2.new(0.16,0,1,0)).ZIndex=23
    end
end

