				e.Position=UDim2.new(sx,0,-0.06,0)
				tw(e,TweenInfo.new(2.0+math.random(),Enum.EasingStyle.Quad,Enum.EasingDirection.In),
					{Position=UDim2.new(sx+(math.random()-0.5)*0.2,0,1.08,0)})
				tw(e,TweenInfo.new(2.8),{TextTransparency=0.7})
				game:GetService("Debris"):AddItem(e,3.2)
			end
			task.wait(0.16)
		end
	end)
end

