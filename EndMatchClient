local function buildAccolades(accolades)
    for _, c in ipairs(AccScroll:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    for i, acc in ipairs(accolades) do
        local card = Instance.new("Frame", AccScroll)
        card.Size = UDim2.new(1,0,0,62)
        card.BackgroundColor3 = Color3.fromRGB(20,16,38)
        card.BorderSizePixel=0; card.LayoutOrder=i; card.ZIndex=22
        corner(card, 10); mkStroke(card, 1.5, C.purple)

        mkLabel(card, acc.emoji, Enum.Font.GothamBold, 34, C.white,
            Enum.TextXAlignment.Center, UDim2.new(0,0,0,0), UDim2.new(0,52,1,0)).ZIndex=23

        mkLabel(card, acc.title, Enum.Font.GothamBlack, 16, C.purple,
            Enum.TextXAlignment.Left, UDim2.new(0,56,0,6), UDim2.new(1,-60,0,22)).ZIndex=23

        mkLabel(card, acc.winnerName.."  ·  "..acc.valueStr,
            Enum.Font.GothamBold, 13, C.white,
            Enum.TextXAlignment.Left, UDim2.new(0,56,0,28), UDim2.new(1,-60,0,18)).ZIndex=23

        mkLabel(card, acc.sub, Enum.Font.Gotham, 11, C.dim,
            Enum.TextXAlignment.Left, UDim2.new(0,56,0,46), UDim2.new(1,-60,0,14)).ZIndex=23
    end
end

