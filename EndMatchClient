-- CEREMONY SEQUENCER
-- ============================================================
local ceremonyThread=nil

local function hideAll()
	Gui.Enabled=false; confActive=false
	P1.Visible=false; P2.Visible=false; P3.Visible=false; P4.Visible=false
	SendoffFrame.Visible=false
	P1.Position=UDim2.new(0.5,0,-0.5,0)
	P2.Position=UDim2.new(1.6,0,0.48,0)
	P3.Position=UDim2.new(0.5,0,1.4,0)
	P4.Position=UDim2.new(0.5,0,1.6,0)
	Dim.BackgroundTransparency=1
	if ceremonyThread then task.cancel(ceremonyThread); ceremonyThread=nil end
end

local function fadeOut(obj,dur)
	tw(obj,TweenInfo.new(dur or 0.3,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
		{Position=UDim2.new(obj.Position.X.Scale,0,-0.5,0)})
	task.wait(dur or 0.3)
	obj.Visible=false
end

local function runCeremony(result)
	Gui.Enabled=true

	-- Dim
	tw(Dim,SLOW,{BackgroundTransparency=0.50})

	-- ── Phase 1: Golden Apron ─────────────────────────────────
	task.wait(0.45)
	local w=result.winner
	if w.type=="LastChef" then
		P1_badge.Text="🥇  GOLDEN APRON"
		P1_type.Text="Last Chef Standing"
		P1_name.Text=w.name
		P1_detail.Text="Survived the entire Food Fight"
		P1_score.Text=tostring(w.score).." pts"
		P1_medals.Text="👑  +50 medals awarded"
	elseif w.type=="GrandGrocer" then
		P1_badge.Text="⏱  NO GOLDEN APRON"
		P1_type.Text="Multiple survivors — market closed"
		P1_name.Text=""; P1_detail.Text=""; P1_score.Text=""; P1_medals.Text=""
	else
		P1_badge.Text="⏱  NO GOLDEN APRON"
		P1_type.Text="Time expired — everyone out"
		P1_name.Text=""; P1_detail.Text=""; P1_score.Text=""; P1_medals.Text=""
	end

	P1.Visible=true
	tw(P1,BACK,{Position=UDim2.new(0.5,0,0.42,0)})
	if w.type=="LastChef" then spawnConf() end

	task.wait(6.5); confActive=false
	tw(P1,FAST,{Position=UDim2.new(0.5,0,-0.55,0)})
	task.wait(0.4); P1.Visible=false

	-- ── Phase 2: Grand Grocer ─────────────────────────────────
	P2_name.Text=w.name
	P2_pts.Text=tostring(w.score).." pts"
	local ggRow=nil
	for _,r in ipairs(result.rankings) do if r.userId==w.userId then ggRow=r; break end end
	if ggRow then
		P2_stats.Text="Dishes: "..ggRow.cook.."  ·  Purchased: "..(ggRow.purchased or 0).."  ·  Gathered: "..(ggRow.gather or 0)
	end
	P2_medals.Text = w.type=="LastChef" and "🏆  +35 Grand Grocer medals also awarded"
		or "🏆  +35 medals awarded"

	P2.Visible=true
	tw(P2,BACK,{Position=UDim2.new(0.5,0,0.48,0)})

	task.wait(5.5)
	tw(P2,FAST,{Position=UDim2.new(1.6,0,0.48,0)})
	task.wait(0.4); P2.Visible=false

	-- ── Phase 3: Accolades ────────────────────────────────────
	-- Reset cards
	for _,ac in ipairs(AccCards) do
		ac.frame.BackgroundTransparency=1; ac.stroke.Transparency=1
		ac.emoji.TextTransparency=1; ac.title.TextTransparency=1
		ac.name.TextTransparency=1; ac.value.TextTransparency=1
		ac.divider.BackgroundTransparency=1
		ac.medalBadge.BackgroundTransparency=1; ac.medalLabel.TextTransparency=1
	end

	P3.Visible=true
	tw(P3,BACK,{Position=UDim2.new(0.5,0,1,-14)})
	task.wait(0.6)

	for i,acc in ipairs(result.accolades) do
		local ac=AccCards[i]; if not ac then continue end
		local col=ACC_COLOR[acc.key] or C.purple
		local bg=ACC_BG[acc.key] or C.panel
		ac.frame.BackgroundColor3=bg; ac.stroke.Color=col
		ac.emoji.Text=acc.emoji; ac.title.Text=acc.title
		ac.name.Text=acc.winnerName; ac.value.Text=acc.valueStr

		local popIn=TweenInfo.new(0.28,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
		tw(ac.frame,popIn,{BackgroundTransparency=0})
		tw(ac.stroke,popIn,{Transparency=0})
		tw(ac.emoji,popIn,{TextTransparency=0})
		tw(ac.title,popIn,{TextTransparency=0}); ac.title.TextColor3=col
		tw(ac.divider,popIn,{BackgroundTransparency=0.4}); ac.divider.BackgroundColor3=col
		tw(ac.name,popIn,{TextTransparency=0})
		tw(ac.value,popIn,{TextTransparency=0})
		tw(ac.medalBadge,popIn,{BackgroundTransparency=0.2})
		tw(ac.medalLabel,popIn,{TextTransparency=0})
		task.wait(1.8)
	end

	task.wait(1.4)
	tw(P3,FAST,{Position=UDim2.new(0.5,0,1.4,0)})
	task.wait(0.4); P3.Visible=false

	-- ── Phase 4: Leaderboard + Medals ─────────────────────────
	buildLB(result.rankings)
	local myMedals=result.playerMedals and result.playerMedals[player.UserId]
	buildMedalPanel(myMedals)

	P4.Visible=true
	tw(P4,BACK,{Position=UDim2.new(0.5,0,0.52,0)})

	task.wait(5.5)

	-- ── Chompy sendoff ────────────────────────────────────────
	SendoffFrame.BackgroundTransparency=0.15; SendoffFrame.Visible=true
	tw(SendoffFrame,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
		{BackgroundTransparency=0.1})

	task.wait(2.5)
	tw(SendoffFrame,TweenInfo.new(0.4),{BackgroundTransparency=1})
	task.wait(0.4); SendoffFrame.Visible=false
end

-- ── Countdown bar ─────────────────────────────────────────────
local TOTAL=30
local cdConn=nil
local function startCountdown()
	if cdConn then cdConn:Disconnect() end
	local endAt=tick()+TOTAL
	cdConn=RunService.Heartbeat:Connect(function()
		local rem=math.max(0,endAt-tick())
		ProgBar.Size=UDim2.new(rem/TOTAL,0,0,3)
		NextLbl.Text="Next match in "..math.ceil(rem).."s"
		if rem<=0 then cdConn:Disconnect(); cdConn=nil end
	end)
end

-- ── Remote listeners ──────────────────────────────────────────
MatchResultR.OnClientEvent:Connect(function(result)
	if ceremonyThread then task.cancel(ceremonyThread) end
	startCountdown()
	ceremonyThread=task.spawn(function() runCeremony(result) end)
end)

PhaseChangedR.OnClientEvent:Connect(function(phase)
	if phase=="Prelobby" then hideAll() end
end)

print("[EndMatchClient] Ready")
