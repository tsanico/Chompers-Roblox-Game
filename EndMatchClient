-- ── Confetti spawner (ingredient emojis rain down) ────────────
local CONFETTI = {"🍅","🥚","🍜","🥕","🧀","🧅","🍋","🌶️","🥦","🍞"}
local confettiActive = false
local function startConfetti()
    confettiActive = true
    task.spawn(function()
        while confettiActive do
            for _=1,3 do
                local e = Instance.new("TextLabel",Gui)
                e.BackgroundTransparency=1; e.ZIndex=55
                e.Font=Enum.Font.GothamBold; e.TextSize=28
                e.Text=CONFETTI[math.random(#CONFETTI)]
                e.Size=UDim2.new(0,40,0,40)
                e.Position=UDim2.new(math.random()*0.9+0.05,0,-0.05,0)
                local landX = e.Position.X.Scale + (math.random()-0.5)*0.3
                tween(e, TweenInfo.new(2.2+math.random()*1.2,Enum.EasingStyle.Quad,Enum.EasingDirection.In),
                    {Position=UDim2.new(landX,0,1.1,0)})
                tween(e, TweenInfo.new(2.8,Enum.EasingStyle.Linear), {TextTransparency=0.6})
                game:GetService("Debris"):AddItem(e,3.2)
            end
            task.wait(0.18)
        end
    end)
end
local function stopConfetti() confettiActive=false end

