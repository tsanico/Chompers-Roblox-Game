            UDim2.new(0,32,0,22),UDim2.new(0.5,-34,0,14)); sl.ZIndex=24
        lbl(rf,tostring(row.score).." pts",Enum.Font.GothamBlack,15,C.gold,
            Enum.TextXAlignment.Right,UDim2.new(0.5,0,0,0),UDim2.new(0.28,0,1,0)).ZIndex=24
        lbl(rf,row.clDealt.." CL",Enum.Font.Gotham,13,C.white,
            Enum.TextXAlignment.Right,UDim2.new(0.78,0,0,0),UDim2.new(0.22,-6,1,0)).ZIndex=24
    end
end

-- ============================================================
-- CEREMONY SEQUENCER
-- ============================================================

local ceremonyThread = nil

local function hideAll()
    Gui.Enabled = false
    stopConfetti()
    P1.Visible=false; P2.Visible=false; P3.Visible=false; P4.Visible=false
    P1.Position=UDim2.new(0.5,0,-0.4,0)
    P2.Position=UDim2.new(1.5,0,0.5,0)
    P3.Position=UDim2.new(0.5,0,1.3,0)
    P4.Position=UDim2.new(0.5,0,1.5,0)
    Dim.BackgroundTransparency=1
    if ceremonyThread then task.cancel(ceremonyThread) end
end

local function runCeremony(result)
    Gui.Enabled=true

    -- Dim fades in
    tween(Dim,SLOW,{BackgroundTransparency=0.45})

    -- ── PHASE 1 — Golden Apron ────────────────────────────────
    task.wait(0.4)
    local w = result.winner
    if w.type == "LastChef" then
        P1_Name.Text   = w.name
        P1_Sub.Text    = "Last Chef Standing"
        P1_Detail.Text = tostring(w.score).." points · Survived the Food Fight"
        P1_NoWin.Visible = false
    elseif w.type == "GrandGrocer" then
        -- No Last Chef Standing — explain briefly
        P1_Title.Text  = "⏱  NO GOLDEN APRON"
        P1_Sub.Text    = "Multiple survivors — no Last Chef"
        P1_Name.Text   = ""; P1_Detail.Text=""
        P1_NoWin.Visible = true
    else
        P1_Title.Text  = "⏱  NO GOLDEN APRON"
        P1_Sub.Text    = "Time expired — the market closed"
        P1_Name.Text   = ""; P1_Detail.Text=""
        P1_NoWin.Visible = true
    end

    P1.Visible=true
    tween(P1, BACK, {Position=UDim2.new(0.5,0,0.38,0)})
    if w.type == "LastChef" then startConfetti() end

    task.wait(6.5)
    stopConfetti()
    tween(P1, FAST, {Position=UDim2.new(0.5,0,-0.4,0)})
    task.wait(0.5)
    P1.Visible=false

    -- ── PHASE 2 — Grand Grocer ────────────────────────────────
    -- Find Grand Grocer data (highest scorer among survivors)
    local gg = result.winner
    local ggRow = nil
    for _,r in ipairs(result.rankings) do
        if r.userId==gg.userId then ggRow=r; break end
    end

    P2_Name.Text  = gg.name
    P2_Score.Text = tostring(gg.score).." points"
    if ggRow then
        P2_Stats.Text = "Dishes cooked: "..ggRow.cook.."  ·  Items gathered: "..ggRow.gather
    end
    if w.type == "LastChef" then
        P2_Title.Text = "🏆  GRAND GROCER"
        P2_Sub.Text   = "Highest Points Earned"
    end

    P2.Visible=true
    tween(P2, BACK, {Position=UDim2.new(0.5,0,0.46,0)})

    task.wait(5.5)
    tween(P2, FAST, {Position=UDim2.new(1.5,0,0.5,0)})
    task.wait(0.5)
    P2.Visible=false

    -- ── PHASE 3 — Accolades ───────────────────────────────────
    -- Reset all cards
    for _,ac in ipairs(AccCards) do
        ac.frame.BackgroundTransparency=1
        ac.cardStroke.Transparency=1
        ac.emoji.Text=""
        ac.title.Text=""; ac.name.Text=""; ac.value.Text=""
    end

    P3.Visible=true
    tween(P3, BACK, {Position=UDim2.new(0.5,0,1,-16)})
    task.wait(0.6)

    for i,acc in ipairs(result.accolades) do
        local ac=AccCards[i]
        if ac then
            ac.emoji.Text=acc.emoji; ac.title.Text=acc.title
            ac.name.Text=acc.winnerName; ac.value.Text=acc.valueStr
            -- Pop card in
            tween(ac.frame, TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
                {BackgroundTransparency=0})
            tween(ac.cardStroke, TweenInfo.new(0.25), {Transparency=0})
        end
        task.wait(1.8)
    end

    task.wait(1.2)
    tween(P3, FAST, {Position=UDim2.new(0.5,0,1.3,0)})
    task.wait(0.5)
    P3.Visible=false

    -- ── PHASE 4 — Leaderboard + Receipt ──────────────────────
    buildLeaderboard(result.rankings)

    -- Populate receipt
    local topAcc = result.accolades
    RLines[3].Text = w.type=="LastChef" and "GOLDEN APRON" or "GRAND GROCER"
    RLines[4].Text = w.name
    RLines[6].Text = topAcc[1] and (topAcc[1].emoji.." "..topAcc[1].title) or ""
    RLines[7].Text = topAcc[2] and (topAcc[2].emoji.." "..topAcc[2].title) or ""
    RLines[8].Text = topAcc[3] and (topAcc[3].emoji.." "..topAcc[3].title) or ""
    local totalMedals = 5 + #result.accolades * 3   -- placeholder until DataService
    RLines[10].Text = "TOTAL MEDALS: +"..totalMedals

    P4.Visible=true
    tween(P4, BACK, {Position=UDim2.new(0.5,0,0.56,0)})

    task.wait(6.0)
    -- Animate receipt tear (slides down and off)
    tween(Receipt, TweenInfo.new(0.6,Enum.EasingStyle.Back,Enum.EasingDirection.In),
        {Position=UDim2.new(0.55,4,1.2,0)})
end

-- ── Countdown bar ─────────────────────────────────────────────
local TOTAL_DURATION = 30   -- matches ChompersData.Constants.Phase.Accolades
local countdownConn = nil

local function startCountdown()
    local endAt = tick() + TOTAL_DURATION
    if countdownConn then countdownConn:Disconnect() end
    countdownConn = RunService.Heartbeat:Connect(function()
        local rem = math.max(0, endAt - tick())
        local pct = rem / TOTAL_DURATION
        CdBar.Size = UDim2.new(pct, 0, 0, 4)
        CdLabel.Text = "Next match in "..math.ceil(rem).."s"
        if rem <= 0 then
            countdownConn:Disconnect(); countdownConn = nil
        end
    end)
end

-- ── Remote listeners ──────────────────────────────────────────
if MatchResultR then
    MatchResultR.OnClientEvent:Connect(function(result)
        if ceremonyThread then task.cancel(ceremonyThread) end
        startCountdown()
        ceremonyThread = task.spawn(function() runCeremony(result) end)
    end)
end

if PhaseChangedR then
    PhaseChangedR.OnClientEvent:Connect(function(phase)
        if phase == "Prelobby" then hideAll() end
    end)
end

print("[EndMatchClient] Ready")
