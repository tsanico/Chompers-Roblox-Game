-- ============================================================
-- INVENTORY TOGGLE
-- Fires a BindableEvent that InventoryClient listens to.
-- We use a BindableEvent so BottomBar and InventoryClient
-- stay decoupled — BottomBar doesn't know about the panel.
-- ============================================================

local InventoryToggleEvent = Instance.new("BindableEvent")
InventoryToggleEvent.Name   = "InventoryToggle"
InventoryToggleEvent.Parent = player.PlayerGui

local inventoryOpen = false
local function toggleInventory()
	inventoryOpen = not inventoryOpen
	-- Visual feedback on icon
	TweenService:Create(ContainerIcon, TweenInfo.new(0.1),
		{BackgroundColor3 = inventoryOpen
			and Color3.fromRGB(35, 32, 52)
			or C.bg}):Play()
	ciStroke.Color = inventoryOpen and C.red or C.stroke
	InventoryToggleEvent:Fire(inventoryOpen)
end

ContainerIcon.MouseButton1Click:Connect(toggleInventory)

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.I then
		toggleInventory()
	end
end)

-- ============================================================
-- NAPKIN SYSTEM
-- ============================================================

local napkinCount    = 1
local napkinCooldown = 0
local napkinUsing    = false
local NAPKIN_CD      = 20
local NAPKIN_USE     = 2

local function updateNapkinUI()
	NapkinCount.Text = "🧻 ×" .. napkinCount
	if napkinCooldown > 0 then
		local pct = 1 - (napkinCooldown / NAPKIN_CD)
		TweenService:Create(cdFill, TweenInfo.new(0.1),
			{Size = UDim2.new(pct, 0, 1, 0)}):Play()
		NapkinPill.BackgroundColor3 = Color3.fromRGB(22, 20, 36)
	else
		cdFill.Size = UDim2.new(1, 0, 1, 0)
		NapkinPill.BackgroundColor3 = napkinCount > 0
			and Color3.fromRGB(18, 28, 40)
			or Color3.fromRGB(20, 18, 32)
	end
end

NapkinBtn.MouseButton1Click:Connect(function()
	if napkinUsing or napkinCooldown > 0 or napkinCount <= 0 then return end
	napkinUsing = true
	cdLabel.Text = "Using..."
	cdLabel.TextColor3 = C.napkin
	task.wait(NAPKIN_USE)
	if napkinUsing then
		napkinCount  = napkinCount - 1
		napkinCooldown = NAPKIN_CD
		napkinUsing  = false
		updateNapkinUI()
	end
end)

game:GetService("RunService").Heartbeat:Connect(function(dt)
	if napkinCooldown > 0 then
		napkinCooldown = math.max(0, napkinCooldown - dt)
		updateNapkinUI()
	end
end)

updateNapkinUI()

