local totalHotbarW = NUM_SLOTS * (SLOT_SIZE + SLOT_GAP) - SLOT_GAP

local HotbarFrame = Instance.new("Frame")
HotbarFrame.Name = "HotbarFrame"
HotbarFrame.BackgroundTransparency = 1
HotbarFrame.AnchorPoint = Vector2.new(0.5, 1)
HotbarFrame.Position = UDim2.new(0.5, 0, 1, -BAR_BOTTOM)
HotbarFrame.Size = UDim2.new(0, totalHotbarW, 0, SLOT_SIZE)
HotbarFrame.Parent = Gui

local inventorySlots = {}
local selectedSlot   = 1

local function buildHotbar()
	for _, c in ipairs(HotbarFrame:GetChildren()) do c:Destroy() end
	inventorySlots = {}
	for i = 1, NUM_SLOTS do
		local xPos = (i - 1) * (SLOT_SIZE + SLOT_GAP)
		local slot = Instance.new("Frame")
		slot.Name = "Slot_" .. i
		slot.Size = UDim2.new(0, SLOT_SIZE, 0, SLOT_SIZE)
		slot.Position = UDim2.new(0, xPos, 0, 0)
		slot.BackgroundColor3 = C.bgLight
		slot.BorderSizePixel = 0
		slot.Parent = HotbarFrame
		Instance.new("UICorner", slot).CornerRadius = UDim.new(0, 8)
		local stroke = Instance.new("UIStroke", slot)
		stroke.Thickness = i == 1 and 2.5 or 1.5
		stroke.Color = i == 1 and C.red or C.stroke

		local numL = Instance.new("TextLabel")
		numL.Name = "SlotNum"
		numL.Size = UDim2.new(0, 18, 0, 14)
		numL.Position = UDim2.new(0, 3, 1, -16)
		numL.BackgroundTransparency = 1
		numL.Text = tostring(i == 10 and 0 or i)
		numL.Font = Enum.Font.GothamBold
		numL.TextSize = 10
		numL.TextColor3 = C.dim
		numL.TextXAlignment = Enum.TextXAlignment.Left
		numL.ZIndex = 2
		numL.Parent = slot

		local ico = Instance.new("TextLabel")
		ico.Name = "ItemIcon"
		ico.Size = UDim2.new(1, -4, 1, -18)
		ico.Position = UDim2.new(0, 2, 0, 2)
		ico.BackgroundTransparency = 1
		ico.Text = ""
		ico.Font = Enum.Font.GothamBold
		ico.TextSize = 22
		ico.TextXAlignment = Enum.TextXAlignment.Center
		ico.TextYAlignment = Enum.TextYAlignment.Center
		ico.ZIndex = 2
		ico.Parent = slot

		local wgt = Instance.new("TextLabel")
		wgt.Name = "ItemWeight"
		wgt.Size = UDim2.new(0, 22, 0, 14)
		wgt.Position = UDim2.new(1, -24, 1, -16)
		wgt.BackgroundTransparency = 1
		wgt.Text = ""
		wgt.Font = Enum.Font.GothamBold
		wgt.TextSize = 9
		wgt.TextColor3 = C.weight
		wgt.TextXAlignment = Enum.TextXAlignment.Right
		wgt.ZIndex = 2
		wgt.Parent = slot

		table.insert(inventorySlots, slot)
	end
end
