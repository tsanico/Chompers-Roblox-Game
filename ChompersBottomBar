_G.Chompers.AddBuff = function(icon, color, duration)
	local bf = Instance.new("Frame", BuffRow)
	bf.Size             = UDim2.new(0, 36, 0, 36)
	bf.BackgroundColor3 = C.bgLight
	bf.BorderSizePixel  = 0
	corner(bf, 8)
	local bfS = Instance.new("UIStroke", bf)
	bfS.Thickness = 1.5; bfS.Color = color
	local icoL = label(bf, icon, Enum.Font.GothamBold, 18, C.white)
	icoL.Size = UDim2.new(1, 0, 0.65, 0)
	local tBg = Instance.new("Frame", bf)
	tBg.Size = UDim2.new(1, -4, 0, 3)
	tBg.Position = UDim2.new(0, 2, 1, -5)
	tBg.BackgroundColor3 = C.bg; tBg.BorderSizePixel = 0
	corner(tBg, 2)
	local tFill = Instance.new("Frame", tBg)
	tFill.Size = UDim2.new(1, 0, 1, 0)
	tFill.BackgroundColor3 = color; tFill.BorderSizePixel = 0
	corner(tFill, 2)
	TweenService:Create(tFill, TweenInfo.new(duration, Enum.EasingStyle.Linear),
		{Size = UDim2.new(0, 0, 1, 0)}):Play()
	task.delay(duration, function()
		TweenService:Create(bf, TweenInfo.new(0.2),
			{BackgroundTransparency = 1}):Play()
		task.wait(0.2); bf:Destroy()
	end)
end

