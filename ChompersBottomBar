-- NAPKIN SYSTEM
-- ============================================================

local napkinCount    = 1
local napkinCooldown = 0
local napkinUsing    = false

local function updateNapkinUI()
	NapkinCount.Text = "🧻 ×" .. napkinCount
	if napkinCooldown > 0 then
		local pct = 1 - (napkinCooldown / 20)
		TweenService:Create(cdFill, TweenInfo.new(0.1),
			{Size = UDim2.new(pct, 0, 1, 0)}):Play()
		NapkinPill.BackgroundColor3 = Color3.fromRGB(22, 20, 36)
	else
		cdFill.Size = UDim2.new(1, 0, 1, 0)
		NapkinPill.BackgroundColor3 = napkinCount > 0
			and Color3.fromRGB(18, 28, 40) or C.bg
	end
end

NapkinBtn.MouseButton1Click:Connect(function()
	if napkinUsing or napkinCooldown > 0 or napkinCount <= 0 then return end
	napkinUsing = true
	cdLabel.Text = "Using..."
	task.wait(2)
	if napkinUsing then
		napkinCount    = napkinCount - 1
		napkinCooldown = 20
		napkinUsing    = false
		updateNapkinUI()
	end
end)

RunService.Heartbeat:Connect(function(dt)
	if napkinCooldown > 0 then
		napkinCooldown = math.max(0, napkinCooldown - dt)
		updateNapkinUI()
	end
end)
updateNapkinUI()

