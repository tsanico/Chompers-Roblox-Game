-- ============================================================
-- NAPKIN COOLDOWN SYSTEM
-- ============================================================
local napkinCount    = 1
local napkinCooldown = 0
local napkinUsing    = false
local NAPKIN_CD      = 20
local NAPKIN_USE     = 2

local function updateNapkinUI()
	NapkinCount.Text = "🧻 ×"..napkinCount
	if napkinCooldown > 0 then
		local pct = 1 - (napkinCooldown/NAPKIN_CD)
		TweenService:Create(cdFill,TweenInfo.new(0.1),
			{Size=UDim2.new(pct,0,1,0)}):Play()
		NapkinPill.BackgroundColor3 = Color3.fromRGB(22,20,36)
	else
		cdFill.Size = UDim2.new(1,0,1,0)
		NapkinPill.BackgroundColor3 = napkinCount>0
			and Color3.fromRGB(18,28,40)
			or  Color3.fromRGB(20,18,32)
	end
end

NapkinBtn.MouseButton1Click:Connect(function()
	if napkinUsing or napkinCooldown>0 or napkinCount<=0 then return end
	napkinUsing = true
	cdLabel.Text = "Using..."
	cdLabel.TextColor3 = C.napkin
	task.wait(NAPKIN_USE)
	if napkinUsing then
		napkinCount = napkinCount - 1
		napkinCooldown = NAPKIN_CD
		napkinUsing = false
		if _G.Chompers and _G.Chompers.UpdateCleanliness then
			-- Heal 25% cleanliness (25/100)
			-- Actual server call would go here in Phase 6
		end
		updateNapkinUI()
	end
end)

-- Cooldown tick
game:GetService("RunService").Heartbeat:Connect(function(dt)
	if napkinCooldown > 0 then
		napkinCooldown = math.max(0,napkinCooldown-dt)
		updateNapkinUI()
	end
end)

