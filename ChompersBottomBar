_G.Chompers.AddBuff = function(icon, color, duration)
	local bf = Instance.new("Frame")
	bf.Size             = UDim2.new(0, 36, 0, 36)
	bf.BackgroundColor3 = Color3.fromRGB(28, 26, 42)
	bf.BorderSizePixel  = 0
	bf.Parent           = BuffRow
	Instance.new("UICorner", bf).CornerRadius = UDim.new(0, 8)
	local bfS = Instance.new("UIStroke", bf)
	bfS.Thickness = 1.5
	bfS.Color = color

	local icoL = Instance.new("TextLabel")
	icoL.Size                = UDim2.new(1, 0, 0.65, 0)
	icoL.BackgroundTransparency = 1
	icoL.Text                = icon
	icoL.Font                = Enum.Font.GothamBold
	icoL.TextSize            = 18
	icoL.TextXAlignment      = Enum.TextXAlignment.Center
	icoL.TextYAlignment      = Enum.TextYAlignment.Center
	icoL.Parent              = bf

	local tBg = Instance.new("Frame")
	tBg.Size             = UDim2.new(1, -4, 0, 3)
	tBg.Position         = UDim2.new(0, 2, 1, -5)
	tBg.BackgroundColor3 = Color3.fromRGB(20, 18, 32)
	tBg.BorderSizePixel  = 0
	tBg.Parent           = bf
	Instance.new("UICorner", tBg).CornerRadius = UDim.new(0, 2)

	local tFill = Instance.new("Frame")
	tFill.Size             = UDim2.new(1, 0, 1, 0)
	tFill.BackgroundColor3 = color
	tFill.BorderSizePixel  = 0
	tFill.Parent           = tBg
	Instance.new("UICorner", tFill).CornerRadius = UDim.new(0, 2)

	TweenService:Create(tFill,
		TweenInfo.new(duration, Enum.EasingStyle.Linear),
		{Size = UDim2.new(0, 0, 1, 0)}):Play()
	task.delay(duration, function()
		TweenService:Create(bf, TweenInfo.new(0.2),
			{BackgroundTransparency = 1}):Play()
		task.wait(0.2)
		bf:Destroy()
	end)
end

