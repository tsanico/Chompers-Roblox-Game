	inventorySlots = {}
	for i = 1, NUM_SLOTS do
		local xPos = (i - 1) * (SLOT_SIZE + SLOT_GAP)
		local slot = Instance.new("Frame")
		slot.Name             = "Slot_" .. i
		slot.Size             = UDim2.new(0, SLOT_SIZE, 0, SLOT_SIZE)
		slot.Position         = UDim2.new(0, xPos, 0, 0)
		slot.BackgroundColor3 = C.bgLight
		slot.BorderSizePixel  = 0
		slot.Parent           = HotbarFrame
		corner(slot, 8)
		local s = stroke(slot, i == 1 and 2.5 or 1.5, i == 1 and C.red or C.stroke)
		s.Name = "SlotStroke"

		-- Key label (bottom-left)
		local keyL = label(slot, i == 10 and "0" or tostring(i),
			Enum.Font.GothamBold, 10, C.dim,
			Enum.TextXAlignment.Left,
			UDim2.new(0, 3, 1, -15), UDim2.new(0, 16, 0, 12))
		keyL.ZIndex = 2

		-- Item emoji
		local ico = label(slot, "",
			Enum.Font.GothamBold, 22, C.white,
			Enum.TextXAlignment.Center,
			UDim2.new(0, 2, 0, 2), UDim2.new(1, -4, 1, -18))
