local breaksRemaining = 3

local function updateBreaks(count)
	breaksRemaining = math.max(0, count)
	for i = 1, 3 do
		if i <= breaksRemaining then
			-- Break available — full opacity, normal colour
			breakIcons[i].TextTransparency = 0
			breakIcons[i].TextColor3 = Color3.fromRGB(255,255,255)
		else
			-- Break used — dimmed out with X
			breakIcons[i].Text = "❌"
			breakIcons[i].TextTransparency = 0.4
		end
	end
	-- Flash red warning at 1 break left
	if breaksRemaining == 1 then
		TweenService:Create(BathroomPill,TweenInfo.new(0.3),
			{BackgroundColor3=Color3.fromRGB(50,15,15)}):Play()
	elseif breaksRemaining == 0 then
		-- All out — show spectate warning
		TweenService:Create(BathroomPill,TweenInfo.new(0.3),
			{BackgroundColor3=Color3.fromRGB(80,10,10)}):Play()
		mkLabel(BathroomPill,"SPECTATING",
			Enum.Font.GothamBold,10,C.warn,
			Enum.TextXAlignment.Center,
			UDim2.new(0,0,1,-14),UDim2.new(1,0,0,12))
	else
		TweenService:Create(BathroomPill,TweenInfo.new(0.3),
			{BackgroundColor3=Color3.fromRGB(20,18,32)}):Play()
	end
end

updateBreaks(3)

