_G.Chompers = _G.Chompers or {}

-- Store Guide — PrelobbyGuiBuilder assigns _G.Chompers.OpenStoreGuide
-- Always callable. Mutual minimize handled here.
StoreGuideBtn.MouseButton1Click:Connect(function()
	-- If inventory is open, close it first
	local invEvt = player.PlayerGui:FindFirstChild("InventoryToggle")
	if invEvt and _G.Chompers and _G.Chompers.GetInventoryOpen
	and _G.Chompers.GetInventoryOpen() then
		inventoryOpen = false
		TweenService:Create(ContainerIcon, TweenInfo.new(0.1),
			{BackgroundColor3 = C.bg}):Play()
		ciStroke.Color = C.stroke
		invEvt:Fire(false)
	end
	-- Open Store Guide
	if _G.Chompers and _G.Chompers.OpenStoreGuide then
		_G.Chompers.OpenStoreGuide()
	elseif _G.Chompers and _G.Chompers.OnStoreGuideClick then
		_G.Chompers.OnStoreGuideClick()
	end
end)

-- G hotkey opens Store Guide (closes inventory if open)
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode == Enum.KeyCode.G then
		StoreGuideBtn:GetPropertyChangedSignal("Text") -- no-op to avoid duplicate G handling
		local invEvt = player.PlayerGui:FindFirstChild("InventoryToggle")
		if invEvt and _G.Chompers and _G.Chompers.GetInventoryOpen
		and _G.Chompers.GetInventoryOpen() then
			inventoryOpen = false
			TweenService:Create(ContainerIcon, TweenInfo.new(0.1),
				{BackgroundColor3 = C.bg}):Play()
			ciStroke.Color = C.stroke
			invEvt:Fire(false)
		end
		if _G.Chompers and _G.Chompers.OpenStoreGuide then
			_G.Chompers.OpenStoreGuide()
		end
	end
end)

