_G.Chompers.SetSlotItem = function(slotIndex, itemData)
	local slot = inventorySlots[slotIndex]
	if not slot then return end
	local ico    = slot:FindFirstChild("ItemIcon")
	local wgt    = slot:FindFirstChild("ItemWeight")
	local stroke = slot:FindFirstChildWhichIsA("UIStroke")

	if not itemData then
		if ico then ico.Text = "" end
		if wgt then wgt.Text = "" end
		slot.BackgroundColor3 = C.bgLight
		if stroke then
			stroke.Color     = slotIndex == selectedSlot and C.red or C.stroke
			stroke.Thickness = slotIndex == selectedSlot and 2.5 or 1.5
		end
		local unpaidL = slot:FindFirstChild("UnpaidLabel")
		if unpaidL then unpaidL:Destroy() end
		return
	end

	local rarity = itemData.rarity
	if ico then ico.Text = itemData.emoji or "🍽" end
	if wgt then wgt.Text = "⚖" .. tostring(itemData.weight or itemData.wt or 0) end
	slot.BackgroundColor3 = RARITY_BG[rarity] or C.bgLight

	if stroke then
		stroke.Color = slotIndex == selectedSlot and C.red
			or (not itemData.paid and Color3.fromRGB(200, 120, 30))
			or RARITY_STROKE[rarity] or C.stroke
		stroke.Thickness = slotIndex == selectedSlot and 2.5 or 1.5
	end

	local unpaidL = slot:FindFirstChild("UnpaidLabel")
	if not itemData.paid then
		if not unpaidL then
			unpaidL = Instance.new("TextLabel")
			unpaidL.Name = "UnpaidLabel"
			unpaidL.Size = UDim2.new(0, 28, 0, 14)
			unpaidL.Position = UDim2.new(1, -30, 0, 2)
			unpaidL.BackgroundTransparency = 1
			unpaidL.Font = Enum.Font.GothamBold
			unpaidL.TextSize = 9
			unpaidL.TextColor3 = Color3.fromRGB(200, 120, 30)
			unpaidL.TextXAlignment = Enum.TextXAlignment.Right
			unpaidL.ZIndex = 4
			unpaidL.Parent = slot
		end
		unpaidL.Text = "$" .. tostring(itemData.cost or 0)
		unpaidL.Visible = true
	elseif unpaidL then
		unpaidL:Destroy()
	end
end

_G.Chompers.SetSelectedSlot = function(index)
	local prev = selectedSlot
	selectedSlot = index
	for _, i in ipairs({prev, index}) do
		local slot = inventorySlots[i]
		if slot then
			local stroke = slot:FindFirstChildWhichIsA("UIStroke")
			if stroke then
				local unpaidL = slot:FindFirstChild("UnpaidLabel")
				local isUnpaid = unpaidL ~= nil
				stroke.Color = i == selectedSlot and C.red
					or isUnpaid and Color3.fromRGB(200, 120, 30)
					or C.stroke
				stroke.Thickness = i == selectedSlot and 2.5 or 1.5
			end
		end
	end
end

_G.Chompers.GetSelectedSlot = function() return selectedSlot end

