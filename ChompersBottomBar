_G.Chompers.SetSlotItem = function(slotIndex, itemData)
	local slot = inventorySlots[slotIndex]
	if not slot then return end
	local ico = slot:FindFirstChild("ItemIcon")
	local wgt = slot:FindFirstChild("ItemWeight")
	local stroke = slot:FindFirstChildWhichIsA("UIStroke")
	if not itemData then
		if ico then ico.Text = "" end
		if wgt then wgt.Text = "" end
		slot.BackgroundColor3 = Color3.fromRGB(28,26,42)
		if stroke then
			stroke.Color = C.stroke
			stroke.Thickness = 1.5
		end
		local unpaidL = slot:FindFirstChild("UnpaidLabel")
		if unpaidL then unpaidL.Visible = false end
		return
	end
	if ico then ico.Text = itemData.emoji or "" end
	if wgt then wgt.Text = "⚖"..tostring(itemData.weight or 0) end
	local rarityBg = {
		Common        = Color3.fromRGB(40,38,55),
		Uncommon      = Color3.fromRGB(22,42,25),
		Rare          = Color3.fromRGB(18,28,52),
		["Ultra-Rare"]= Color3.fromRGB(35,20,50),
		Legendary     = Color3.fromRGB(50,38,10),
	}
	local rarityStroke = {
		Common        = Color3.fromRGB(80,78,100),
		Uncommon      = Color3.fromRGB(50,140,60),
		Rare          = Color3.fromRGB(50,100,200),
		["Ultra-Rare"]= Color3.fromRGB(130,60,200),
		Legendary     = Color3.fromRGB(200,140,30),
	}
	slot.BackgroundColor3 = rarityBg[itemData.rarity] or Color3.fromRGB(28,26,42)
	if stroke then
		stroke.Color = itemData.paid
			and (rarityStroke[itemData.rarity] or C.stroke)
			or  Color3.fromRGB(200,120,30)
		stroke.Thickness = itemData.paid and 1.5 or 2.5
	end
	local unpaidL = slot:FindFirstChild("UnpaidLabel")
	if not itemData.paid then
		if not unpaidL then
			unpaidL = Instance.new("TextLabel")
			unpaidL.Name = "UnpaidLabel"
			unpaidL.Size = UDim2.new(0,24,0,14)
			unpaidL.Position = UDim2.new(1,-26,0,2)
			unpaidL.BackgroundTransparency = 1
			unpaidL.Text = "$"..tostring(itemData.cost or 0)
			unpaidL.Font = Enum.Font.GothamBold
			unpaidL.TextSize = 9
			unpaidL.TextColor3 = Color3.fromRGB(200,120,30)
			unpaidL.TextXAlignment = Enum.TextXAlignment.Right
			unpaidL.ZIndex = 4
			unpaidL.Parent = slot
		else
			unpaidL.Text = "$"..tostring(itemData.cost or 0)
			unpaidL.Visible = true
		end
	else
		if unpaidL then unpaidL.Visible = false end
	end
end

_G.Chompers.SetSelectedSlot = function(index)
	for i, slot in ipairs(inventorySlots) do
		local stroke = slot:FindFirstChildWhichIsA("UIStroke")
		if stroke then
			if i == index then
				stroke.Color = C.red
				stroke.Thickness = 2.5
			else
				local unpaidL = slot:FindFirstChild("UnpaidLabel")
				local isUnpaid = unpaidL and unpaidL.Visible
				stroke.Color = isUnpaid
					and Color3.fromRGB(200,120,30)
					or  C.stroke
				stroke.Thickness = isUnpaid and 2.5 or 1.5
			end
		end
	end
end

