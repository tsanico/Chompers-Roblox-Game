-- ============================================================
-- NAPKIN SYSTEM
-- ============================================================

local napkinCount    = 1
local napkinCooldown = 0
local napkinUsing    = false
local NAPKIN_MAX_CD  = 20

local function updateNapkinUI()
	NapkinCountLabel.Text = "🧻 ×" .. napkinCount
	if napkinCooldown > 0 then
		local pct = 1 - (napkinCooldown / NAPKIN_MAX_CD)
		TweenService:Create(NapCdFill, TweenInfo.new(0.08),
			{Size = UDim2.new(pct, 0, 1, 0)}):Play()
		NapkinPill.BackgroundColor3 = Color3.fromRGB(22, 20, 36)
	else
		NapCdFill.Size              = UDim2.new(1, 0, 1, 0)
		NapkinPill.BackgroundColor3 = napkinCount > 0
			and Color3.fromRGB(18, 28, 40)
			or C.bg
	end
end

NapkinBtn.MouseButton1Click:Connect(function()
	if napkinUsing or napkinCooldown > 0 or napkinCount <= 0 then return end
	napkinUsing = true
	napkinCount = napkinCount - 1
	updateNapkinUI()
	task.wait(2)   -- 2s use time
	napkinUsing    = false
	napkinCooldown = NAPKIN_MAX_CD
	updateNapkinUI()
end)

RunService.Heartbeat:Connect(function(dt)
	if napkinCooldown > 0 then
		napkinCooldown = math.max(0, napkinCooldown - dt)
		-- Recharge to ×1 when cooldown completes
		if napkinCooldown == 0 and napkinCount == 0 then
			napkinCount = 1
		end
		updateNapkinUI()
	end
end)
updateNapkinUI()

-- ============================================================
-- BATHROOM BREAKS
-- ============================================================

local breaksRemaining = 3

local function updateBreaksUI()
	for i = 1, 3 do
		if i <= breaksRemaining then
			breakIcons[i].Text             = "🚽"
			breakIcons[i].TextTransparency = 0
		else
			breakIcons[i].Text             = "❌"
			breakIcons[i].TextTransparency = 0.4
		end
	end
	local bg = breaksRemaining == 0 and Color3.fromRGB(80, 10, 10)
		or breaksRemaining == 1 and Color3.fromRGB(50, 15, 15)
		or C.bg
	TweenService:Create(BathPill, TweenInfo.new(0.3),
		{BackgroundColor3 = bg}):Play()
end
updateBreaksUI()

-- ============================================================
-- INVENTORY TOGGLE STATE
-- ============================================================

local inventoryOpen = false

local function setInventoryOpen(open)
	inventoryOpen = open
	TweenService:Create(ContainerIcon, TweenInfo.new(0.1),
		{BackgroundColor3 = open
			and Color3.fromRGB(35, 32, 52) or C.bg}):Play()
	ciStroke.Color = open and C.red or C.stroke
	InvToggleEvent:Fire(open)
end

-- Expose so InventoryClient can report back
_G.Chompers.GetInventoryOpen = function() return inventoryOpen end

ContainerIcon.MouseButton1Click:Connect(function()
	-- Close Store Guide if open
	if _G.Chompers.IsStoreGuideOpen() then
		_G.Chompers.CloseStoreGuide()
	end
	setInventoryOpen(not inventoryOpen)
end)

-- ============================================================
-- INPUT (G = Store Guide, I = Inventory)
-- ============================================================

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end

	if input.KeyCode == Enum.KeyCode.G then
		-- Close inventory if open, then open/toggle Store Guide
		if inventoryOpen then setInventoryOpen(false) end
		if _G.Chompers.IsStoreGuideOpen() then
			_G.Chompers.CloseStoreGuide()
		else
			_G.Chompers.OpenStoreGuide()
		end

	elseif input.KeyCode == Enum.KeyCode.I then
		-- Close Store Guide if open, then toggle inventory
		if _G.Chompers.IsStoreGuideOpen() then
			_G.Chompers.CloseStoreGuide()
		end
		setInventoryOpen(not inventoryOpen)
	end
end)

