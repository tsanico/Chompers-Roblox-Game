	end
end

_G.Chompers.GetSlotCount   = function() return NUM_SLOTS end
_G.Chompers.GetSelectedSlot = function() return currentSelectedSlot end

_G.Chompers.SetSelectedSlot = function(index)
	local prev = currentSelectedSlot
	currentSelectedSlot = index
	for _, i in ipairs({prev, index}) do
		local slot = inventorySlots[i]
		if not slot then continue end
		local s = slot:FindFirstChild("SlotStroke")
		if s then
			s.Color     = i == currentSelectedSlot and C.red or C.stroke
			s.Thickness = i == currentSelectedSlot and 2.5 or 1.5
		end
	end
end

_G.Chompers.SetSlotItem = function(slotIndex, itemData)
	local slot = inventorySlots[slotIndex]
	if not slot then return end
	local ico    = slot:FindFirstChild("ItemIcon")
	local wgt    = slot:FindFirstChild("ItemWeight")
	local s      = slot:FindFirstChild("SlotStroke")
	local unpaid = slot:FindFirstChild("UnpaidLabel")

	if not itemData then
		if ico then ico.Text = "" end
		if wgt then wgt.Text = "" end
		slot.BackgroundColor3 = C.bgLight
		if s then
			s.Color     = slotIndex == currentSelectedSlot and C.red or C.stroke
			s.Thickness = slotIndex == currentSelectedSlot and 2.5 or 1.5
		end
		if unpaid then unpaid:Destroy() end
		return
	end

	local rarity = itemData.rarity or "Common"
	if ico then ico.Text = itemData.emoji or "🍽" end
	if wgt then wgt.Text = "⚖" .. tostring(itemData.weight or 0) end
	slot.BackgroundColor3 = RARITY_BG[rarity] or C.bgLight
	if s then
		s.Color = slotIndex == currentSelectedSlot and C.red
			or (not itemData.paid and Color3.fromRGB(200, 120, 30))
			or RARITY_STROKE[rarity] or C.stroke
		s.Thickness = slotIndex == currentSelectedSlot and 2.5 or 1.5
	end
	-- Unpaid price tag
	if not itemData.paid then
		if not unpaid then
			unpaid = Instance.new("TextLabel")
			unpaid.Name               = "UnpaidLabel"
			unpaid.Size               = UDim2.new(0, 28, 0, 14)
			unpaid.Position           = UDim2.new(1, -30, 0, 2)
			unpaid.BackgroundTransparency = 1
			unpaid.Font               = Enum.Font.GothamBold
			unpaid.TextSize           = 9
			unpaid.TextColor3         = Color3.fromRGB(200, 120, 30)
			unpaid.TextXAlignment     = Enum.TextXAlignment.Right
			unpaid.ZIndex             = 4
			unpaid.Parent             = slot
		end
		unpaid.Text    = "$" .. tostring(itemData.cost or 0)
		unpaid.Visible = true
	elseif unpaid then
		unpaid:Destroy()
	end
end

