R("PlayerSelectAllergy").OnServerEvent:Connect(function(player, allergyType)
	PlayerState.SetAllergy(player, allergyType)
	UpdateLobbyState:FireClient(player, { allergy = allergyType })
end)

R("PlayerSelectCart").OnServerEvent:Connect(function(player, choice)
	PlayerState.SetContainer(player, choice)
	UpdateLobbyState:FireClient(player, { container = choice })
end)

R("PlayerSelectFavourite").OnServerEvent:Connect(function(player, recipeName)
	PlayerState.SetFavourite(player, recipeName)
	UpdateLobbyState:FireClient(player, { favourite = recipeName })
end)

R("RequestLobbyData").OnServerEvent:Connect(function(player)
	local s = _state[player]
	if not s then return end
	UpdateLobbyState:FireClient(player, {
		allergy   = s.allergy,
		container = s.container,
		favourite = s.favourite,
		money     = s.money,
		napkins   = s.napkins,
	})
end)

R("RequestScoreboard").OnServerEvent:Connect(function(player)
	local ScoreboardData = R("ScoreboardData")
	if ScoreboardData then
		ScoreboardData:FireClient(player, PlayerState.GetScoreboardData())
	end
end)

R("EquipTitle").OnServerEvent:Connect(function(player, titleStr)
	if type(titleStr) ~= "string" or #titleStr > 80 then return end
	PlayerState.SetEquippedTitle(player, titleStr)
	local r = R("BillboardRefresh")
	if r then r:FireClient(player, titleStr) end
end)

-- ReorderInventory: client requests a slot-to-slot move (no holes ever created)
-- Auto-create the remote here so it always exists even if not in ChompersRemotes folder
local reorderRemote = Remotes:FindFirstChild("ReorderInventory")
if not reorderRemote then
	reorderRemote = Instance.new("RemoteEvent")
	reorderRemote.Name = "ReorderInventory"
	reorderRemote.Parent = Remotes
end
reorderRemote.OnServerEvent:Connect(function(player, fromSlot, toSlot)
	if type(fromSlot) ~= "number" or type(toSlot) ~= "number" then return end
	fromSlot = math.floor(fromSlot); toSlot = math.floor(toSlot)
	PlayerState.MoveItem(player, fromSlot, toSlot)
end)

-- ============================================================
-- PLAYER LIFECYCLE
-- ============================================================

Players.PlayerAdded:Connect(function(player)
	PlayerState.Init(player)

	-- Fire initial bar values immediately so client scripts
	-- (ChompersMeters etc.) never see nil on their first check
	UpdateCleanliness:FireClient(player, 0)
	UpdateFullness:FireClient(player, 0)
	UpdateMoney:FireClient(player, C.Economy.StartingCash)

	player.CharacterAdded:Connect(function()
		-- Full sync once character is loaded — short wait for GUI to settle
		task.wait(0.2)
		PlayerState.SyncAll(player)
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	PlayerState.Cleanup(player)
end)

-- ============================================================
-- START FL DECAY LOOP
-- ============================================================

PlayerState.StartFLDecay()

return PlayerState
