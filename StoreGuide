local function showIngredientDetail(item)
    clearRight(ingRight)
    local r   = nRarity(item.rarity)
    local col = RARITY_COL[r] or C.stroke
    local ic  = emj(item.name, item.zone)

    -- Hero row
    local hero=Instance.new("Frame",ingRight); hero.LayoutOrder=1
    hero.Size=UDim2.new(1,0,0,80); hero.BackgroundColor3=RARITY_BG[r] or C.bgCard
    hero.BorderSizePixel=0; hero.ZIndex=12; corner(hero,12); mkStroke(hero,2,col)
    mkLabel(hero,ic,Enum.Font.GothamBold,44,C.white,Enum.TextXAlignment.Center,
        UDim2.new(0,0,0,0),UDim2.new(0,80,1,0)).ZIndex=13
    mkLabel(hero,item.name,Enum.Font.GothamBlack,18,C.white,Enum.TextXAlignment.Left,
        UDim2.new(0,84,0,8),UDim2.new(1,-90,0,24)).ZIndex=13
    mkLabel(hero,(item.zone or "?").."  ·  "..r,Enum.Font.GothamBold,12,col,
        Enum.TextXAlignment.Left,UDim2.new(0,84,0,34),UDim2.new(1,-90,0,16)).ZIndex=13
    mkLabel(hero,"⚖ "..(item.wt or"?").."wt   💲"..(item.cost or"?").."   🧼 +"..
        (item.cl or"0").." CL",Enum.Font.Gotham,12,Color3.fromRGB(155,150,188),
        Enum.TextXAlignment.Left,UDim2.new(0,84,0,52),UDim2.new(1,-90,0,16)).ZIndex=13

    if item.allergy and item.allergy~="None" then
        rightChip(ingRight,"⚠ Allergy: "..item.allergy,Color3.fromRGB(50,14,14),
            Color3.fromRGB(230,120,120),2)
    end
    if item.effect then
        rightBigLabel(ingRight,"💥 "..item.effect,Enum.Font.Gotham,14,
            Color3.fromRGB(200,198,218),3)
    end

    rightDivider(ingRight,4)

    -- Recipes that use this ingredient
    local used = ingToRecipes[item.name] or {}
    if #used > 0 then
        rightBigLabel(ingRight,"Used in "..#used.." recipe"..(#used==1 and "" or "s")
            ..":",Enum.Font.GothamBold,14,C.dim,5,20)
        for j, rec in ipairs(used) do
            local rc  = nRarity(rec.rarity)
            local rcol= RARITY_COL[rc] or C.stroke
            local chip=rightChip(ingRight,
                emj(rec.name).."  "..rec.name.."   ("..rc..")",
                RARITY_BG[rc] or C.bgCard,C.white,5+j)
            mkStroke(chip,1.5,rcol)
            chip.Size=UDim2.new(1,0,0,34)
        end
    else
        rightBigLabel(ingRight,"Used in recipes: none listed",Enum.Font.Gotham,13,C.dim,5,20)
    end
end

