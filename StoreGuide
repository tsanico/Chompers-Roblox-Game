mkStroke(searchInput,1.5,C.stroke)

-- ── Helper: build the two-panel container for a sub-tab ──────
local function makeCookSub(subId, accentCol)
    local container = Instance.new("Frame", CookPanel)
    container.Name = subId.."Container"
    container.Size = UDim2.new(1,0,1,-CONTENT_TOP)
    container.Position = UDim2.new(0,0,0,CONTENT_TOP)
    container.BackgroundTransparency = 1
    container.Visible = (subId=="INGREDIENTS")
    cookSubPanels[subId] = container

    -- Vertical divider
    local divider = Instance.new("Frame", container)
    divider.Size = UDim2.new(0,1,1,0); divider.Position = UDim2.new(DIVIDER_X,0,0,0)
    divider.BackgroundColor3 = C.stroke; divider.BorderSizePixel=0

    -- Left: scrollable compact list
    local leftScroll = Instance.new("ScrollingFrame", container)
    leftScroll.Name = "LeftScroll"
    leftScroll.Size = UDim2.new(DIVIDER_X,-1,1,0)
    leftScroll.BackgroundTransparency=1; leftScroll.BorderSizePixel=0
    leftScroll.ScrollBarThickness=5; leftScroll.ScrollBarImageColor3=accentCol
    leftScroll.AutomaticCanvasSize=Enum.AutomaticSize.Y
    leftScroll.CanvasSize=UDim2.new(0,0,0,0)
    local ll=Instance.new("UIListLayout",leftScroll)
    ll.SortOrder=Enum.SortOrder.LayoutOrder; ll.Padding=UDim.new(0,3)
    local lpad=Instance.new("UIPadding",leftScroll)
    lpad.PaddingTop=UDim.new(0,4); lpad.PaddingBottom=UDim.new(0,4)
    lpad.PaddingLeft=UDim.new(0,6); lpad.PaddingRight=UDim.new(0,4)

    -- Right: detail panel (dynamically built on selection)
    local rightPanel = Instance.new("ScrollingFrame", container)
    rightPanel.Name = "RightPanel"
    rightPanel.Size = UDim2.new(1-DIVIDER_X,-1,1,0)
    rightPanel.Position = UDim2.new(DIVIDER_X,1,0,0)
    rightPanel.BackgroundTransparency=1; rightPanel.BorderSizePixel=0
    rightPanel.ScrollBarThickness=5; rightPanel.ScrollBarImageColor3=accentCol
    rightPanel.AutomaticCanvasSize=Enum.AutomaticSize.Y
    rightPanel.CanvasSize=UDim2.new(0,0,0,0)
    local rl=Instance.new("UIListLayout",rightPanel)
    rl.SortOrder=Enum.SortOrder.LayoutOrder; rl.Padding=UDim.new(0,6)
    local rpad=Instance.new("UIPadding",rightPanel)
    rpad.PaddingTop=UDim.new(0,10); rpad.PaddingBottom=UDim.new(0,10)
    rpad.PaddingLeft=UDim.new(0,10); rpad.PaddingRight=UDim.new(0,10)

    -- Placeholder
    local placeholder = mkLabel(rightPanel,
        "← Select an item to see full details.",
        Enum.Font.Gotham,14,C.dim,Enum.TextXAlignment.Center,
        UDim2.new(0,0,0,0),UDim2.new(1,0,0,80))
    placeholder.Name="Placeholder"

    return container, leftScroll, rightPanel
end

-- ── Right panel builder helpers ──────────────────────────────
local function clearRight(rightPanel)
    for _, c in ipairs(rightPanel:GetChildren()) do
        if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
    end
    rightPanel.CanvasPosition = Vector2.zero
end

local function rightBigLabel(parent, text, font, size, color, order, h)
    local l=Instance.new("TextLabel",parent); l.LayoutOrder=order
    l.Size=UDim2.new(1,0,0,h or 0); l.AutomaticSize=h and Enum.AutomaticSize.None or Enum.AutomaticSize.Y
    l.BackgroundTransparency=1; l.Text=text
    l.Font=font or Enum.Font.GothamBold; l.TextSize=size or 14
    l.TextColor3=color or C.white; l.TextXAlignment=Enum.TextXAlignment.Left
    l.TextYAlignment=Enum.TextYAlignment.Top; l.TextWrapped=true; l.ZIndex=12
    return l
end

local function rightDivider(parent, order)
    local d=Instance.new("Frame",parent); d.LayoutOrder=order
    d.Size=UDim2.new(1,0,0,1); d.BackgroundColor3=C.stroke; d.BorderSizePixel=0
end

local function rightChip(parent, text, bg, col, order)
    local f=Instance.new("Frame",parent); f.LayoutOrder=order
    f.Size=UDim2.new(1,0,0,28); f.BackgroundColor3=bg or C.bgLight
