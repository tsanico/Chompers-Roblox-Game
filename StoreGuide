searchInput.BackgroundColor3 = Color3.fromRGB(28,26,42); searchInput.BorderSizePixel=0
searchInput.Font = Enum.Font.Gotham; searchInput.TextSize = 21
searchInput.TextColor3 = C.white; searchInput.PlaceholderColor3 = C.dim
