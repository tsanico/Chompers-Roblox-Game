local function updateBillboard()
    local char = player.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end
    local ex = head:FindFirstChild("ChompersBillboard")
    if ex then ex:Destroy() end
    if not Selections.equippedTitle
    and not Selections.favourite
    and not Selections.allergy then return end

    local bb = Instance.new("BillboardGui")
    bb.Name = "ChompersBillboard"; bb.ResetOnSpawn = false
    bb.Size = UDim2.new(0,300,0,80); bb.StudsOffset = Vector3.new(0,3.2,0)
    bb.AlwaysOnTop = false; bb.Parent = head
    local ll = Instance.new("UIListLayout", bb)
    ll.SortOrder = Enum.SortOrder.LayoutOrder; ll.Padding = UDim.new(0,1)
    ll.HorizontalAlignment = Enum.HorizontalAlignment.Center

    if Selections.equippedTitle then
        local l = Instance.new("TextLabel", bb); l.LayoutOrder = 1
