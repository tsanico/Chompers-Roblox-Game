end

-- helper: make a tab panel frame
local function makePanel(name, tabId)
    local f = Instance.new("Frame", ContentArea)
    f.Name = name; f.Size = UDim2.new(1,0,1,0)
    f.BackgroundTransparency = 1; f.Visible = false; f.ZIndex = 9
    tabPanels[tabId] = f; return f
end

-- helper: sub-tab bar inside a panel
local function mkSubBar(parent, h, tabs, onSwitch)
    local bar = Instance.new("Frame", parent)
    bar.Size = UDim2.new(1,0,0,h); bar.BackgroundColor3 = Color3.fromRGB(16,14,26)
    bar.BorderSizePixel = 0; bar.ZIndex = 10
    local ll = Instance.new("UIListLayout", bar)
    ll.FillDirection = Enum.FillDirection.Horizontal
    ll.HorizontalAlignment = Enum.HorizontalAlignment.Left
    ll.VerticalAlignment = Enum.VerticalAlignment.Center; ll.Padding = UDim.new(0,2)
    local btns = {}
    for i, st in ipairs(tabs) do
        local b = Instance.new("TextButton", bar)
        b.Size = UDim2.new(1/#tabs,-2,0,h-4)
        b.BackgroundColor3 = i==1 and st.color or Color3.fromRGB(24,22,38)
        b.BorderSizePixel = 0; b.AutoButtonColor = false
        b.Font = Enum.Font.GothamBold; b.TextSize = 12
        b.TextColor3 = i==1 and Color3.fromRGB(253,248,240) or C.dim
        b.Text = st.label; b.ZIndex = 11; corner(b,6)
        btns[st.id] = b; local sid=st.id; local sc=st.color
        b.MouseButton1Click:Connect(function()
            for id2, b2 in pairs(btns) do
                local a = id2==sid
                b2.BackgroundColor3 = a and sc or Color3.fromRGB(24,22,38)
                b2.TextColor3 = a and Color3.fromRGB(253,248,240) or C.dim
            end
            onSwitch(sid)
        end)
    end
    return bar, btns
end

