local TIER_RANGES = {
    {min=0,    max=100,  label="Starter",   bg=Color3.fromRGB(18,32,18)},
    {min=101,  max=200,  label="Common",    bg=Color3.fromRGB(14,20,42)},
    {min=201,  max=400,  label="Uncommon",  bg=Color3.fromRGB(22,10,40)},
    {min=401,  max=700,  label="Rare",      bg=Color3.fromRGB(38,10,10)},
    {min=701,  max=1100, label="Elite",     bg=Color3.fromRGB(40,30,4)},
    {min=1101, max=9999, label="Legendary", bg=Color3.fromRGB(34,28,4)},
}
local function tierFor(cost)
    for _, t in ipairs(TIER_RANGES) do
        if cost >= t.min and cost <= t.max then return t end
    end
    return {label="?", bg=C.bgCard}
end

