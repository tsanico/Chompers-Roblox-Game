closeGuide = function()
    isOpen = false
    TweenService:Create(Overlay,TweenInfo.new(0.18),{BackgroundTransparency=1}):Play()
    TweenService:Create(Panel,
        TweenInfo.new(0.22,Enum.EasingStyle.Back,Enum.EasingDirection.In),
        {Position=UDim2.new(0.5,0,0,PANEL_TOP+12)}):Play()
    task.wait(0.24)
    if not isOpen then Overlay.Visible=false end
end

-- defaultTab: which main tab to show for the current phase
local function defaultTab(phase)
    if phase=="Prelobby"                         then return "PREFERENCES" end
    if phase=="Gathering"                        then return "COOKBOOK"    end
    if phase=="Cooking" or phase=="CookingGrace" then return "COOKBOOK"    end
    if phase=="FoodFight"                        then return "MATCH"       end
    if phase=="EndGame" or phase=="Accolades"    then return "ACCOLADES"   end
    return activeTab
end

-- defaultCookSub: which Cookbook sub-tab for the current phase
local function defaultCookSub(phase)
    if phase=="Cooking" or phase=="CookingGrace" then return "RECIPES"     end
    return "INGREDIENTS"
end

openGuide = function(tabId)
    isOpen = true; Overlay.Visible = true
    Panel.Position = UDim2.new(0.5,0,0,PANEL_TOP+12)
    Overlay.BackgroundTransparency = 0.6
    TweenService:Create(Overlay,TweenInfo.new(0.18),{BackgroundTransparency=0.25}):Play()
    TweenService:Create(Panel,
        TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
        {Position=UDim2.new(0.5,0,0,PANEL_TOP)}):Play()
    -- Route: explicit tabId wins; otherwise phase default; otherwise keep current
    local target = tabId or defaultTab(currentPhase) or activeTab or "PREFERENCES"
    switchTab(target)
    -- Auto-route within Cookbook sub-tabs by phase (no tabId means player opened manually)
    if target == "COOKBOOK" and not tabId then
        local sub = defaultCookSub(currentPhase)
        task.defer(function()
            for sid, pnl in pairs(cookSubPanels) do
                if typeof(pnl) == "Instance" then pnl.Visible = (sid == sub) end
            end
        end)
    end
end

CloseBtn.MouseButton1Click:Connect(closeGuide)
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode==Enum.KeyCode.Escape and isOpen then closeGuide() end
    if input.KeyCode==Enum.KeyCode.G then
        if isOpen then closeGuide() else openGuide() end
    end
end)

-- ============================================================
-- PHASE LISTENER — lock prefs, re-route if open; NEVER force-open
-- The guide only auto-opens ONCE on first join (see INITIAL STATE below).
-- After that, opening is always player-initiated. Phase changes only affect:
--   • Preferences lock/unlock
--   • Tab routing IF the guide is already open
-- ============================================================

local prefBufferTimer = nil

local function lockPrefs()
    prefsLocked = true
    FavScrollLock.Visible     = true
    AllergyScrollLock.Visible = true
    -- If player has guide open on Preferences, redirect to phase-appropriate tab
    if isOpen and activeTab == "PREFERENCES" then
        switchTab(defaultTab(currentPhase))
    end
end
local function unlockPrefs()
    prefsLocked = false
    FavScrollLock.Visible     = false
    AllergyScrollLock.Visible = false
end

local PhaseRemote = Remotes and Remotes:FindFirstChild("PhaseChanged")
if PhaseRemote then
    PhaseRemote.OnClientEvent:Connect(function(phase)
        currentPhase = phase

        if phase == "Gathering" then
            if not Selections.confirmed then
                -- Give 10s to finish preferences before locking
                if prefBufferTimer then pcall(task.cancel, prefBufferTimer) end
                prefBufferTimer = task.delay(10, lockPrefs)
            else
                lockPrefs()
            end
            -- If guide is already open, re-route to Ingredients
            if isOpen then switchTab("COOKBOOK") end

        elseif phase == "Cooking" or phase == "CookingGrace" then
            lockPrefs()
            if isOpen then
                switchTab("COOKBOOK")
                task.defer(function()
                    for sid, pnl in pairs(cookSubPanels) do
                        if typeof(pnl) == "Instance" then pnl.Visible = (sid == "RECIPES") end
                    end
                end)
            end

        elseif phase == "FoodFight" then
            lockPrefs()
            if isOpen then _G.Chompers.OpenToScoreboard() end

        elseif phase == "Prelobby" then
            unlockPrefs()
            Selections.confirmed = false
            ConfirmBtn.Text = "✓  Ready to Shop!"
            ConfirmBtn.BackgroundColor3 = Color3.fromRGB(46,165,66)
            -- No forced open — player may be in the middle of something

        elseif phase == "EndGame" or phase == "Accolades" then
            unlockPrefs()
            if isOpen then switchTab("ACCOLADES") end
        end
    end)
end

