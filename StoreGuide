local CookPanel = makePanel("CookPanel","COOKBOOK")
local cookSubPanels = {}

-- Build cross-reference: ingredient name → list of recipe objects
local ingToRecipes = {}
for _, recipe in ipairs(Data.Recipes) do
    for _, ingName in ipairs(recipe.ingredients or {}) do
        if not ingToRecipes[ingName] then ingToRecipes[ingName] = {} end
        table.insert(ingToRecipes[ingName], recipe)
    end
end

local COOK_HEADER_H = 40
local SEARCH_H      = 36
local DIVIDER_X     = 0.36   -- left panel width fraction
local CONTENT_TOP   = COOK_HEADER_H + SEARCH_H

mkSubBar(CookPanel, COOK_HEADER_H, {
    {id="INGREDIENTS", label="🥦 Ingredients", color=Color3.fromRGB(46,140,60)},
    {id="RECIPES",     label="📖 Recipes",     color=Color3.fromRGB(65,48,128)},
}, function(id)
    for sid, pnl in pairs(cookSubPanels) do pnl.Visible=(sid==id) end
end)

