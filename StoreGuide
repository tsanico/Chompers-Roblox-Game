end

-- ── Shared detail-panel helper ───────────────────────────────
-- Builds a stat chip: big icon top, label bottom, centred in a pill.
local function detailChip(parent, icon, label, bg, tc, order)
    local f = Instance.new("Frame", parent); f.LayoutOrder = order
    f.Size = UDim2.new(0, 0, 0, 72); f.AutomaticSize = Enum.AutomaticSize.X
    f.BackgroundColor3 = bg; f.BorderSizePixel = 0
    corner(f, 12); mkStroke(f, 2, tc)
    local ll = Instance.new("UIListLayout", f)
    ll.SortOrder = Enum.SortOrder.LayoutOrder
    ll.HorizontalAlignment = Enum.HorizontalAlignment.Center
    ll.VerticalAlignment   = Enum.VerticalAlignment.Center
    local pad = Instance.new("UIPadding", f)
    pad.PaddingLeft = UDim.new(0,12); pad.PaddingRight  = UDim.new(0,12)
    pad.PaddingTop  = UDim.new(0,8);  pad.PaddingBottom = UDim.new(0,8)
    local iL = Instance.new("TextLabel", f); iL.LayoutOrder = 1
    iL.Size = UDim2.new(0, 0, 0, 32); iL.AutomaticSize = Enum.AutomaticSize.X
    iL.BackgroundTransparency = 1; iL.Text = icon
    iL.Font = Enum.Font.GothamBold; iL.TextSize = 30
    iL.TextColor3 = tc; iL.ZIndex = 13
    local lL = Instance.new("TextLabel", f); lL.LayoutOrder = 2
    lL.Size = UDim2.new(0, 0, 0, 20); lL.AutomaticSize = Enum.AutomaticSize.X
    lL.BackgroundTransparency = 1; lL.Text = label
    lL.Font = Enum.Font.GothamBlack; lL.TextSize = 17
    lL.TextColor3 = tc; lL.ZIndex = 13
    return f
end

-- Chip row wrapper (horizontal list)
local function detailChipRow(parent, order)
    local row = Instance.new("Frame", parent); row.LayoutOrder = order
    row.Size = UDim2.new(1, 0, 0, 0); row.AutomaticSize = Enum.AutomaticSize.Y
    row.BackgroundTransparency = 1; row.ZIndex = 12
    local ll = Instance.new("UIListLayout", row)
    ll.FillDirection = Enum.FillDirection.Horizontal
    ll.HorizontalAlignment = Enum.HorizontalAlignment.Left
    ll.VerticalAlignment   = Enum.VerticalAlignment.Center
    ll.Padding = UDim.new(0, 8)
    return row
end

-- Section header label
local function detailSection(parent, text, order)
    local l = Instance.new("TextLabel", parent); l.LayoutOrder = order
    l.Size = UDim2.new(1, 0, 0, 24); l.BackgroundTransparency = 1
    l.Text = text; l.Font = Enum.Font.GothamBlack; l.TextSize = 15
    l.TextColor3 = C.dim; l.TextXAlignment = Enum.TextXAlignment.Left
    l.ZIndex = 12; return l
end

-- Ingredient/recipe chip for the "builds into / requires" section
local function detailItemChip(parent, emoji, name, subText, rCol, rBg, order)
    local chip = Instance.new("Frame", parent); chip.LayoutOrder = order
    chip.Size = UDim2.new(1, 0, 0, 48); chip.BackgroundColor3 = rBg or C.bgCard
    chip.BorderSizePixel = 0; chip.ZIndex = 12; corner(chip, 8)
    mkStroke(chip, 1.5, rCol or C.stroke)
    mkLabel(chip, emoji, Enum.Font.GothamBold, 28, C.white,
        Enum.TextXAlignment.Center, UDim2.new(0,0,0,0), UDim2.new(0,52,1,0)).ZIndex = 13
    mkLabel(chip, name, Enum.Font.GothamBold, 17, C.white,
        Enum.TextXAlignment.Left, UDim2.new(0,56,0,4), UDim2.new(1,-60,0,22)).ZIndex = 13
    if subText and subText ~= "" then
        mkLabel(chip, subText, Enum.Font.Gotham, 13, C.dim,
            Enum.TextXAlignment.Left, UDim2.new(0,56,0,26), UDim2.new(1,-60,0,16)).ZIndex = 13
    end
    return chip
end

-- Divider
local function detailDivider(parent, order)
    local d = Instance.new("Frame", parent); d.LayoutOrder = order
    d.Size = UDim2.new(1,0,0,1); d.BackgroundColor3 = C.stroke
    d.BorderSizePixel = 0; return d
