local FL_COOKED = Data.Constants and Data.Constants.FLPerHit and Data.Constants.FLPerHit.Cooked or 2
local FL_RAW    = Data.Constants and Data.Constants.FLPerHit and Data.Constants.FLPerHit.RawCold or 1

-- ── Build INGREDIENTS sub-tab ────────────────────────────────
local _, ingLeft, ingRight = makeCookSub("INGREDIENTS", Color3.fromRGB(46,140,60))
local sortedIng = rSort(Data.Ingredients)
local ingRows   = {}

local function showIngredientDetail(item)
    clearRight(ingRight)
    local r   = nRarity(item.rarity)
    local col = RARITY_COL[r] or C.stroke

    -- ── HERO: large centred emoji fills left column, name fills right ──────
    -- Emoji takes up a tall square on the left; name+rarity subtitle stacked right
    local hero = Instance.new("Frame", ingRight); hero.LayoutOrder = 1
    hero.Size = UDim2.new(1, 0, 0, 110)
    hero.BackgroundColor3 = RARITY_BG[r] or C.bgCard
    hero.BorderSizePixel = 0; hero.ZIndex = 12; corner(hero, 12); mkStroke(hero, 2, col)

    -- Large emoji — fills the left 100px column completely
    mkLabel(hero, emj(item.name, item.zone), Enum.Font.GothamBold, 64, C.white,
        Enum.TextXAlignment.Center,
        UDim2.new(0,0,0,0), UDim2.new(0,100,1,0)).ZIndex = 13

    -- Name — big and bold, top of right column
    mkLabel(hero, item.name, Enum.Font.GothamBlack, 24, C.white,
        Enum.TextXAlignment.Left,
        UDim2.new(0,104,0,16), UDim2.new(1,-108,0,32)).ZIndex = 13

    -- Rarity coloured subtitle — small, below name
    mkLabel(hero, r.."  ·  "..(item.zone or "?"), Enum.Font.GothamBold, 15, col,
        Enum.TextXAlignment.Left,
        UDim2.new(0,104,0,52), UDim2.new(1,-108,0,20)).ZIndex = 13

    -- ── SUBICONS: Rarity | Zone | Allergy | Cost | CL | FL ────
    local chipRow = detailChipRow(ingRight, 2)
    detailChip(chipRow, "⭐", r,
        RARITY_BG[r] or C.bgCard, col, 1)
    detailChip(chipRow, "📍", item.zone or "?",
        Color3.fromRGB(22,18,36), Color3.fromRGB(160,145,210), 2)
    if item.allergy and item.allergy ~= "None" then
        detailChip(chipRow, "⚠️", item.allergy,
            Color3.fromRGB(50,10,10), Color3.fromRGB(230,90,90), 3)
    else
        detailChip(chipRow, "✅", "No Allergen",
            Color3.fromRGB(10,28,14), Color3.fromRGB(70,195,85), 3)
    end
    detailChip(chipRow, "💲", "$"..(item.cost or "?"),
        Color3.fromRGB(10,28,14), Color3.fromRGB(70,195,85), 4)
    local clVal = (item.cl and item.cl > 0) and "+"..item.cl.." CL" or "N/A"
    local clCol = (item.cl and item.cl > 0) and Color3.fromRGB(65,185,235) or C.dim
    detailChip(chipRow, "🧼", clVal,
        Color3.fromRGB(14,28,50), clCol, 5)
    detailChip(chipRow, "🍔", "+"..FL_RAW.." FL (raw)",
        Color3.fromRGB(34,22,8), Color3.fromRGB(235,155,35), 6)

    -- ── EFFECT / DESCRIPTION ──────────────────────────────────
    if item.effect then
        detailDivider(ingRight, 3)
        local eff = Instance.new("TextLabel", ingRight); eff.LayoutOrder = 4
        eff.Size = UDim2.new(1,0,0,0); eff.AutomaticSize = Enum.AutomaticSize.Y
        eff.BackgroundTransparency = 1; eff.Text = "💥  "..item.effect
        eff.Font = Enum.Font.GothamBold; eff.TextSize = 18
        eff.TextColor3 = Color3.fromRGB(220,215,240)
        eff.TextXAlignment = Enum.TextXAlignment.Left
        eff.TextYAlignment = Enum.TextYAlignment.Top
        eff.TextWrapped = true; eff.ZIndex = 12
    end

    -- ── BUILDS INTO ───────────────────────────────────────────
    detailDivider(ingRight, 5)
    local used = ingToRecipes[item.name] or {}
    detailSection(ingRight, "Builds into "..#used.." recipe"
        ..(#used==1 and "" or "s")..":", 6)
    if #used > 0 then
        for j, rec in ipairs(used) do
            local rc   = nRarity(rec.rarity)
            local rcol = RARITY_COL[rc] or C.stroke
            local rbg  = RARITY_BG[rc] or C.bgCard
            local sub  = rc.."  ·  🧼 +"..(rec.cl or 0).." CL"
            detailItemChip(ingRight, emj(rec.name), rec.name, sub, rcol, rbg, 7+j)
        end
    else
        local none = Instance.new("TextLabel", ingRight); none.LayoutOrder = 7
        none.Size = UDim2.new(1,0,0,24); none.BackgroundTransparency = 1
        none.Text = "Not used in any listed recipe"; none.Font = Enum.Font.Gotham
        none.TextSize = 14; none.TextColor3 = C.dim
        none.TextXAlignment = Enum.TextXAlignment.Left; none.ZIndex = 12
    end
end

