-- activeSubId tracks which cook sub is showing (INGREDIENTS or RECIPES)
local activeSubId = "INGREDIENTS"
-- Note: cookSubPanels must only contain Frame instances as values.
-- Never insert non-Instance values — the mkSubBar switch loops over all values.

searchInput:GetPropertyChangedSignal("Text"):Connect(function()
    local q = searchInput.Text:lower()
    local function matches(row)
        if q == "" then return true end
        -- Search by the named "RowName" label (the item name text)
        local lbl = row:FindFirstChild("RowName")
        if lbl and lbl.Text:lower():find(q, 1, true) then return true end
        -- Fallback: any TextLabel
        for _, c in ipairs(row:GetChildren()) do
            if c:IsA("TextLabel") and c.Text:lower():find(q, 1, true) then return true end
        end
        return false
    end
    for _, row in ipairs(ingRows) do row.Visible = matches(row) end
    for _, row in ipairs(recRows) do row.Visible = matches(row) end
end)

