    {id="COOKBOOK",    label="📖 Cookbook",    color=Color3.fromRGB(65,48,128),   order=2},
    {id="MATCH",       label="📋 Match",       color=Color3.fromRGB(50,70,100),   order=3},
    {id="PREFERENCES", label="😋 Preferences", color=Color3.fromRGB(46,140,60),   order=4},
