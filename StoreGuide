local function switchTab(id)
    activeTab = id
    for _, c in ipairs(ContentArea:GetChildren()) do
        if c:IsA("Frame") then c.Visible = false end
    end
    if tabPanels[id] then tabPanels[id].Visible = true end
    for _, tb in ipairs(TABS) do
        local btn = tabButtons[tb.id]; if not btn then continue end
        local active = tb.id == id
        btn.BackgroundColor3 = active and tb.color or Color3.fromRGB(28,26,42)
        btn.TextColor3       = active and Color3.fromRGB(253,248,240) or C.dim
    end
end

for _, tb in ipairs(TABS) do
    local btn = Instance.new("TextButton", TabBar)
    btn.Name = tb.id.."Tab"; btn.LayoutOrder = tb.order
    btn.Size = UDim2.new(0.2,-2,0,TAB_H-4)
    btn.BackgroundColor3 = Color3.fromRGB(28,26,42); btn.BorderSizePixel = 0
    btn.Font = Enum.Font.GothamBold; btn.TextSize = 12
    btn.TextColor3 = C.dim; btn.Text = tb.label
