-- ============================================================
-- WelcomeScreen — LocalScript · StarterPlayerScripts
--
-- Shows once per session on first character spawn.
-- Controls the onboarding gate for shift-lock:
--   _G.Chompers.WelcomeScreenActive = true  → StoreGuide auto-open blocked
--   WelcomeScreen CONFIRM pressed           → StoreGuide opens to PREFERENCES
--   StoreGuide closed by player             → _G.Chompers.ShiftLockReady = true
--
-- "Don't show again" is session-local (no DataStore yet).
-- Persists within the session across respawns. Will be wired
-- into DataService when persistence is built.
-- ============================================================

local Players          = game:GetService("Players")
local TweenService     = game:GetService("TweenService")
local ReplicatedStorage= game:GetService("ReplicatedStorage")

local player    = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Block StoreGuide auto-open immediately — before its 1.5s timer fires
-- CharacterController also reads this to defer shift-lock
_G.Chompers = _G.Chompers or {}
_G.Chompers.WelcomeScreenActive = true
_G.Chompers.ShiftLockReady      = false

-- ── Session state (persists across respawns this session) ──
local dontShowAgain   = false
local onboardingDone  = false   -- true once player has gone through the flow once

-- ── Palette (matches HUD) ──────────────────────────────────
local C = {
	bg       = Color3.fromRGB(12, 10, 20),
	panel    = Color3.fromRGB(22, 18, 38),
	stroke   = Color3.fromRGB(70, 60, 110),
	gold     = Color3.fromRGB(255, 200, 50),
	white    = Color3.fromRGB(230, 225, 255),
	muted    = Color3.fromRGB(130, 120, 165),
	confirm  = Color3.fromRGB(65, 180, 90),
	confirmH = Color3.fromRGB(85, 210, 110),
	warn     = Color3.fromRGB(226, 75, 74),
}

-- ── UI helpers ─────────────────────────────────────────────
local function corner(inst, r)
	local c = Instance.new("UICorner", inst)
	c.CornerRadius = UDim.new(0, r or 8)
end
local function stroke(inst, col, t)
	local s = Instance.new("UIStroke", inst)
	s.Color = col or C.stroke; s.Thickness = t or 1.5
end
local function label(parent, text, size, color, font, xa, pos, sz)
	local l = Instance.new("TextLabel", parent)
	l.BackgroundTransparency = 1
	l.Text = text; l.TextSize = size
	l.TextColor3 = color or C.white
	l.Font = font or Enum.Font.Gotham
	l.TextXAlignment = xa or Enum.TextXAlignment.Left
	l.TextWrapped = true
	l.Size = sz or UDim2.new(1, 0, 0, size + 6)
	if pos then l.Position = pos end
	return l
end

-- ── Build the UI ───────────────────────────────────────────
