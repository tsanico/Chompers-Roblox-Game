	btFill.BorderSizePixel  = 0
	btFill.ZIndex           = 4

	-- "Don't show again" checkbox
	local dontBtn = Instance.new("TextButton", bottom)
	dontBtn.Size               = UDim2.new(0, 200, 0, 28)
	dontBtn.Position           = UDim2.new(0, 14, 0, 16)
	dontBtn.BackgroundColor3   = Color3.fromRGB(28, 22, 45)
	dontBtn.BorderSizePixel    = 0
	dontBtn.Text               = "☐  Don't show again"
	dontBtn.Font               = Enum.Font.GothamMedium
	dontBtn.TextSize           = 13
	dontBtn.TextColor3         = C.muted
	dontBtn.AutoButtonColor    = false
	dontBtn.ZIndex             = 5
	corner(dontBtn, 6)

	-- Confirm button
	local confirmBtn = Instance.new("TextButton", bottom)
	confirmBtn.Name            = "ConfirmBtn"
	confirmBtn.Size            = UDim2.new(0, 180, 0, 36)
	confirmBtn.AnchorPoint     = Vector2.new(1, 0.5)
	confirmBtn.Position        = UDim2.new(1, -14, 0.5, 0)
	confirmBtn.BackgroundColor3= C.confirm
	confirmBtn.BorderSizePixel = 0
	confirmBtn.Text            = "CHOOSE YOUR CONTAINER  →"
	confirmBtn.Font            = Enum.Font.GothamBlack
	confirmBtn.TextSize        = 14
	confirmBtn.TextColor3      = Color3.fromRGB(255, 255, 255)
	confirmBtn.AutoButtonColor = false
	confirmBtn.ZIndex          = 5
	corner(confirmBtn, 8)

	-- Don't-show toggle behaviour
	local dontChecked = false
	dontBtn.MouseButton1Click:Connect(function()
		dontChecked = not dontChecked
		dontBtn.Text = dontChecked and "☑  Don't show again" or "☐  Don't show again"
		dontBtn.TextColor3 = dontChecked and C.gold or C.muted
	end)

	-- Hover effect on confirm
	confirmBtn.MouseEnter:Connect(function()
		confirmBtn.BackgroundColor3 = C.confirmH
	end)
	confirmBtn.MouseLeave:Connect(function()
		confirmBtn.BackgroundColor3 = C.confirm
	end)

	return sg, confirmBtn, dontChecked, function() return dontChecked end
end

-- ── Poll until StoreGuide closes, then activate shift-lock ─
local function waitForGuideClose()
	task.spawn(function()
		task.wait(0.8)   -- give StoreGuide time to open
		while true do
			task.wait(0.25)
			if _G.Chompers.IsStoreGuideOpen and not _G.Chompers.IsStoreGuideOpen() then
				_G.Chompers.ShiftLockReady = true
				break
			end
		end
	end)
end

-- ── Main flow ──────────────────────────────────────────────
local function runOnboarding()
	if onboardingDone then
		-- Player already went through onboarding this session
		-- Shift-lock stays active — no need to re-show anything
		return
	end

	if dontShowAgain then
		-- Skip welcome, go straight to StoreGuide
		_G.Chompers.WelcomeScreenActive = false
		task.wait(0.5)
		if _G.Chompers.OpenStoreGuide then
			_G.Chompers.OpenStoreGuide("PREFERENCES")
		end
		waitForGuideClose()
		return
	end

	-- Build and show the welcome screen
	local sg, confirmBtn, _, getDontShow = buildWelcomeGui()

	-- Tween in
	local panel = sg:FindFirstChild("Panel")
	if panel then
		panel.Position = UDim2.new(0.5, 0, 0.6, 0)
		TweenService:Create(panel,
			TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{Position = UDim2.new(0.5, 0, 0.5, 0)}):Play()
	end

	-- CONFIRM pressed
	confirmBtn.MouseButton1Click:Connect(function()
		dontShowAgain = getDontShow()
		onboardingDone = true
		_G.Chompers.WelcomeScreenActive = false

		-- Tween out
		if panel then
			TweenService:Create(panel,
				TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
				{Position = UDim2.new(0.5, 0, 0.4, 0)}):Play()
		end
		TweenService:Create(sg:FindFirstChild("Overlay"),
			TweenInfo.new(0.2),
			{BackgroundTransparency = 1}):Play()

		task.delay(0.22, function()
			sg:Destroy()
			-- Open StoreGuide to Preferences
			if _G.Chompers.OpenStoreGuide then
				_G.Chompers.OpenStoreGuide("PREFERENCES")
			end
			-- When guide closes → shift-lock activates
			waitForGuideClose()
		end)
	end)
end

-- ── Connect to character spawn ─────────────────────────────
-- WelcomeScreen runs once per session. On respawn, shift-lock
-- is already active so we don't re-gate it.
player.CharacterAdded:Connect(function()
	if not onboardingDone then
		_G.Chompers.WelcomeScreenActive = true
		_G.Chompers.ShiftLockReady      = false
		task.wait(0.2)   -- let StoreGuide start loading
		runOnboarding()
	end
end)

-- Also run if character already exists when script loads
if player.Character and not onboardingDone then
	_G.Chompers.WelcomeScreenActive = true
	_G.Chompers.ShiftLockReady      = false
	task.wait(0.5)
	runOnboarding()
end
