	local subLabel = Instance.new("TextLabel", titleBar)
	subLabel.Size               = UDim2.new(1, -24, 0, 18)
	subLabel.Position           = UDim2.new(0, 12, 0, 44)
	subLabel.BackgroundTransparency = 1
