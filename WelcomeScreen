	subLabel.TextSize           = 13
	subLabel.TextColor3         = C.muted
	subLabel.TextXAlignment     = Enum.TextXAlignment.Left
	subLabel.ZIndex             = 5

	-- Scrollable content
	local scroll = Instance.new("ScrollingFrame", panel)
	scroll.Name                  = "Content"
	scroll.Size                  = UDim2.new(1, -24, 0, 444)
	scroll.Position              = UDim2.new(0, 12, 0, 76)
	scroll.BackgroundTransparency= 1
	scroll.BorderSizePixel       = 0
	scroll.ScrollBarThickness    = 4
	scroll.ScrollBarImageColor3  = C.stroke
	scroll.CanvasSize            = UDim2.new(0, 0, 0, 0)  -- auto-sized below
	scroll.AutomaticCanvasSize   = Enum.AutomaticSize.Y
	scroll.ZIndex                = 4

	local layout = Instance.new("UIListLayout", scroll)
	layout.SortOrder  = Enum.SortOrder.LayoutOrder
	layout.Padding    = UDim.new(0, 10)

	local pad = Instance.new("UIPadding", scroll)
	pad.PaddingLeft   = UDim.new(0, 6)
	pad.PaddingRight  = UDim.new(0, 6)
	pad.PaddingTop    = UDim.new(0, 6)

	-- Content builder
	local lo = 0
	local function section(title, body, accent)
		lo = lo + 1
		local card = Instance.new("Frame", scroll)
		card.Size             = UDim2.new(1, 0, 0, 0)
		card.AutomaticSize    = Enum.AutomaticSize.Y
