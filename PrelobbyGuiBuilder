-- ── Helpers ──────────────────────────────────────────────────
local function corner(p, r)
	Instance.new("UICorner", p).CornerRadius = UDim.new(0, r or 12)
end
local function mkStroke(p, t, c)
	local s = Instance.new("UIStroke", p)
	s.Thickness = t or 1.5; s.Color = c or C.stroke; return s
end
local function mkLabel(p, text, font, size, color, xAlign, pos, sz)
	local l = Instance.new("TextLabel")
	l.Text=text or ""; l.Font=font or Enum.Font.Gotham
	l.TextSize=size or 16; l.TextColor3=color or C.white
	l.TextXAlignment=xAlign or Enum.TextXAlignment.Left
	l.TextYAlignment=Enum.TextYAlignment.Center
	l.BackgroundTransparency=1
	l.Position=pos or UDim2.new(0,0,0,0)
	l.Size=sz or UDim2.new(1,0,1,0)
	l.Parent=p; return l
end
local function mkScroll(p, name, size, pos, barColor)
	local sf = Instance.new("ScrollingFrame")
	sf.Name=name; sf.Size=size; sf.Position=pos
	sf.BackgroundTransparency=1; sf.BorderSizePixel=0
	sf.ScrollBarThickness=7
	sf.ScrollBarImageColor3=barColor or C.red
	sf.AutomaticCanvasSize=Enum.AutomaticSize.Y
	sf.CanvasSize=UDim2.new(0,0,0,0); sf.Parent=p
	local pad=Instance.new("UIPadding",sf)
	pad.PaddingTop=UDim.new(0,6);pad.PaddingBottom=UDim.new(0,6)
	pad.PaddingLeft=UDim.new(0,6);pad.PaddingRight=UDim.new(0,6)
	local ll=Instance.new("UIListLayout",sf)
	ll.SortOrder=Enum.SortOrder.LayoutOrder; ll.Padding=UDim.new(0,6)
	return sf
end

-- ============================================================
-- BILLBOARD — shows allergy + favourite above head AT ALL TIMES
-- ============================================================

local function updateBillboard()
	local char = player.Character
	if not char then return end
	local head = char:FindFirstChild("Head")
	if not head then return end
	local ex = head:FindFirstChild("ChompersBillboard")
	if ex then ex:Destroy() end
	if not Selections.allergy and not Selections.favourite then return end

	local bb = Instance.new("BillboardGui")
	bb.Name="ChompersBillboard"; bb.ResetOnSpawn=false
	bb.Size=UDim2.new(0,280,0,60); bb.StudsOffset=Vector3.new(0,3.2,0)
	bb.AlwaysOnTop=false; bb.Parent=head
	local ll=Instance.new("UIListLayout",bb)
	ll.SortOrder=Enum.SortOrder.LayoutOrder; ll.Padding=UDim.new(0,2)
	ll.HorizontalAlignment=Enum.HorizontalAlignment.Center

	if Selections.allergy then
		local col=Color3.fromRGB(226,75,74)
		for _,a in ipairs(ALLERGY_TYPES) do
			if a.name==Selections.allergy then col=a.color; break end
		end
		local l=Instance.new("TextLabel",bb)
		l.Size=UDim2.new(1,0,0,28); l.BackgroundTransparency=1
		l.Text="⚠ Allergic to "..Selections.allergy
		l.Font=Enum.Font.GothamBold; l.TextSize=15
		l.TextColor3=col; l.TextStrokeTransparency=0.3
		l.TextStrokeColor3=Color3.new(0,0,0)
		l.TextXAlignment=Enum.TextXAlignment.Center; l.LayoutOrder=1
	end
	if Selections.favourite then
		local l=Instance.new("TextLabel",bb)
		l.Size=UDim2.new(1,0,0,28); l.BackgroundTransparency=1
		l.Text="⭐ Loves "..Selections.favourite
		l.Font=Enum.Font.GothamBold; l.TextSize=15
		l.TextColor3=C.gold; l.TextStrokeTransparency=0.3
		l.TextStrokeColor3=Color3.new(0,0,0)
		l.TextXAlignment=Enum.TextXAlignment.Center; l.LayoutOrder=2
	end
end

player.CharacterAdded:Connect(function()
	task.wait(1); updateBillboard()
end)
