local function mkLabel(parent,text,font,size,color,xAlign,pos,sz)
	local l = Instance.new("TextLabel")
	l.Text = text
	l.Font = font or Enum.Font.Gotham
	l.TextSize = size or 16
	l.TextColor3 = color or Color3.fromRGB(220,218,232)
	l.TextXAlignment = xAlign or Enum.TextXAlignment.Left
	l.TextYAlignment = Enum.TextYAlignment.Center
	l.BackgroundTransparency = 1
	l.Position = pos or UDim2.new(0,0,0,0)
	l.Size = sz or UDim2.new(1,0,1,0)
	l.Parent = parent
	return l
end

local function mkFrame(parent,name,size,pos,anchor,bg,corner,nostroke)
	local f = Instance.new("Frame")
	f.Name = name or "Frame"
	f.Size = size
	f.Position = pos
	if anchor then f.AnchorPoint = anchor end
	f.BackgroundColor3 = bg or Color3.fromRGB(20,18,32)
	f.BorderSizePixel = 0
	f.Parent = parent
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0,corner or 12)
	c.Parent = f
	if not nostroke then
		local s = Instance.new("UIStroke")
		s.Thickness = 1.5
		s.Color = Color3.fromRGB(50,46,72)
		s.Parent = f
	end
	return f
end

local function mkScroll(parent,name,size,pos,barColor)
	local sf = Instance.new("ScrollingFrame")
	sf.Name = name
	sf.Size = size
	sf.Position = pos
	sf.BackgroundTransparency = 1
	sf.BorderSizePixel = 0
	sf.ScrollBarThickness = 7
	sf.ScrollBarImageColor3 = barColor or Color3.fromRGB(195,52,52)
	sf.AutomaticCanvasSize = Enum.AutomaticSize.Y
	sf.CanvasSize = UDim2.new(0,0,0,0)
	sf.Parent = parent
	local p = Instance.new("UIPadding")
	p.PaddingTop=UDim.new(0,8) p.PaddingBottom=UDim.new(0,8)
	p.PaddingLeft=UDim.new(0,8) p.PaddingRight=UDim.new(0,8)
	p.Parent = sf
	local ll = Instance.new("UIListLayout")
	ll.SortOrder = Enum.SortOrder.LayoutOrder
	ll.Padding = UDim.new(0,6)
	ll.Parent = sf
	return sf
end

