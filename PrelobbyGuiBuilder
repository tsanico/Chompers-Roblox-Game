-- WIRE + AUTO-OPEN
-- ============================================================
task.spawn(function()
	local waited = 0
	while (not _G.Chompers or not _G.Chompers.SetSlots) and waited < 8 do
		task.wait(0.1)
		waited = waited + 0.1
	end

	if _G.Chompers then
		-- Open/close wiring
		_G.Chompers.OnStoreGuideClick = function()
			if isOpen then closeGuide(false) else openGuide("PREFERENCES") end
		end
		_G.Chompers.OpenGuideTab  = openGuide
		_G.Chompers.CloseGuide    = closeGuide
		_G.Chompers.SwitchTab     = switchTab

		-- Expose allergy and favourite getters for CookbookBuilder
		_G.Chompers.GetAllergy   = function() return Selections.Allergy end
		_G.Chompers.GetFavourite = function() return Selections.Favourite end
		_G.Chompers.IsConfirmed  = function()
			return Selections.Confirmed and gameStarted
		end
		_G.Chompers.SetFavourite = function(name)
			Selections.Favourite = name
			-- Update FavSelected label
			FavSelected.Text = name and ("⭐  "..name) or "None selected"
			updateBillboard()
			if Remotes then
				Remotes.PlayerSelectFavourite:FireServer(name)
			end
		end
		_G.Chompers.UpdateBillboard = updateBillboard

		-- Panel management for CookbookBuilder
		_G.Chompers.HideAllPanels = function()
			for _,child in ipairs(ContentArea:GetChildren()) do
				if child:IsA("Frame") then child.Visible = false end
			end
		end
		_G.Chompers.RegisterTabPanel = function(tabId, panel)
			tabPanels[tabId] = panel
		end
	end

	-- Set default slot count
	local char = player.Character or player.CharacterAdded:Wait()
	task.wait(0.5)

	-- Auto-open on load to Preferences
	openGuide("PREFERENCES")
end)

