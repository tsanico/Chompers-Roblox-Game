	PhaseRemote.OnClientEvent:Connect(function(phase)
		if phase == "Gathering" or phase == "Cooking"
		or phase == "FoodFight" then
			gatheringStarted = true
			PrefLockOverlay.Visible = true
			-- Switch away from Preferences if currently open
			if isOpen and activeTab == "PREFERENCES" then
				switchTab("RULES")
			end
		elseif phase == "Prelobby" then
			gatheringStarted = false
			PrefLockOverlay.Visible = false
			Selections.confirmed = false
			ConfirmBtn.Text = "✓ Ready to Shop!"
			ConfirmBtn.BackgroundColor3 = Color3.fromRGB(46,165,66)
		end
	end)
end

