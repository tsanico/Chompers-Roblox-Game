		local rf=Instance.new("Frame",rScroll)
		rf.Size=UDim2.new(1,0,0,0); rf.AutomaticSize=Enum.AutomaticSize.Y
		rf.BackgroundColor3=Color3.fromRGB(26,24,40); rf.BorderSizePixel=0; rf.ZIndex=11
		corner(rf,10)
		local rfp=Instance.new("UIPadding",rf)
		rfp.PaddingTop=UDim.new(0,12);rfp.PaddingBottom=UDim.new(0,12)
		rfp.PaddingLeft=UDim.new(0,16);rfp.PaddingRight=UDim.new(0,16)
		local dot=Instance.new("Frame",rf)
		dot.Size=UDim2.new(0,6,0,6);dot.Position=UDim2.new(0,-10,0,12)
		dot.BackgroundColor3=color;dot.BorderSizePixel=0;dot.ZIndex=12;corner(dot,99)
		local rl=Instance.new("TextLabel",rf)
		rl.Size=UDim2.new(1,0,0,0);rl.AutomaticSize=Enum.AutomaticSize.Y
		rl.BackgroundTransparency=1;rl.Text=rule
		rl.Font=Enum.Font.Gotham;rl.TextSize=18
		rl.TextColor3=Color3.fromRGB(215,212,230)
		rl.TextXAlignment=Enum.TextXAlignment.Left
		rl.TextYAlignment=Enum.TextYAlignment.Top
		rl.TextWrapped=true;rl.LineHeight=1.4;rl.ZIndex=12
	end
end

