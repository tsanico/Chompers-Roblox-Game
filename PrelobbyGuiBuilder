-- BILLBOARD
-- ============================================================
local function updateBillboard()
	local char = player.Character
	if not char then return end
	local head = char:FindFirstChild("Head")
	if not head then return end
	local ex = head:FindFirstChild("ChompersBillboard")
	if ex then ex:Destroy() end
	if not Selections.Allergy and not Selections.Favourite then return end
	local bb = Instance.new("BillboardGui")
	bb.Name = "ChompersBillboard"
	bb.Size = UDim2.new(0,280,0,60)
	bb.StudsOffset = Vector3.new(0,3.2,0)
	bb.AlwaysOnTop = false
	bb.ResetOnSpawn = false
	bb.Parent = head
	local ll = Instance.new("UIListLayout")
	ll.SortOrder = Enum.SortOrder.LayoutOrder
	ll.Padding = UDim.new(0,2)
	ll.HorizontalAlignment = Enum.HorizontalAlignment.Center
	ll.Parent = bb
	if Selections.Allergy then
		local col = Color3.fromRGB(226,75,74)
		for _,a in ipairs(ALLERGY_TYPES) do
			if a.name==Selections.Allergy then col=a.color break end
		end
		local l = Instance.new("TextLabel")
		l.Size = UDim2.new(1,0,0,28)
		l.BackgroundTransparency = 1
		l.Text = "⚠ Allergic to "..Selections.Allergy
		l.Font = Enum.Font.GothamBold
		l.TextSize = 15
		l.TextColor3 = col
		l.TextStrokeTransparency = 0.3
		l.TextStrokeColor3 = Color3.fromRGB(0,0,0)
		l.TextXAlignment = Enum.TextXAlignment.Center
		l.LayoutOrder = 1
		l.Parent = bb
	end
	if Selections.Favourite then
		local l = Instance.new("TextLabel")
		l.Size = UDim2.new(1,0,0,28)
		l.BackgroundTransparency = 1
		l.Text = "⭐ Loves "..Selections.Favourite
		l.Font = Enum.Font.GothamBold
		l.TextSize = 15
		l.TextColor3 = Color3.fromRGB(239,159,39)
		l.TextStrokeTransparency = 0.3
		l.TextStrokeColor3 = Color3.fromRGB(0,0,0)
		l.TextXAlignment = Enum.TextXAlignment.Center
		l.LayoutOrder = 2
		l.Parent = bb
	end
end

