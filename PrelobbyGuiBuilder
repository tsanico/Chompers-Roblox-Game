local PhaseRemote = Remotes and Remotes:FindFirstChild("PhaseChanged")
if PhaseRemote then
	PhaseRemote.OnClientEvent:Connect(function(phase)
		local lockPhases = {Gathering=true, Cooking=true, CookingGrace=true, FoodFight=true}
		if lockPhases[phase] then
			prefsLocked = true
			PrefLock.Visible = true
			-- Auto-switch away from Preferences if currently open
			if isOpen and activeTab=="PREFERENCES" then
				switchTab("RULES")
			end
		else
			-- Prelobby, EndGame, Accolades — unlock
			prefsLocked = false
			PrefLock.Visible = false
			if phase=="Prelobby" then
				-- Full reset for new match
				Selections.confirmed = false
				ConfirmBtn.Text = "✓ Ready to Shop!"
				ConfirmBtn.BackgroundColor3 = Color3.fromRGB(46,165,66)
			end
		end
	end)
end

