local function selectCart(choice)
	if gatheringStarted and Selections.confirmed then return end
	Selections.cart=choice
	if choice=="basket" then
		BasketBtn.BackgroundColor3=C.red
		BasketBtn.TextColor3=Color3.fromRGB(253,248,240)
		CartBtn.BackgroundColor3=Color3.fromRGB(32,30,46)
		CartBtn.TextColor3=Color3.fromRGB(82,80,105)
	else
		CartBtn.BackgroundColor3=C.red
		CartBtn.TextColor3=Color3.fromRGB(253,248,240)
		BasketBtn.BackgroundColor3=Color3.fromRGB(32,30,46)
		BasketBtn.TextColor3=Color3.fromRGB(82,80,105)
	end
	_G.Chompers.SetContainerType(choice=="basket" and "Basket" or "Cart")
	if Remotes then
		local r=Remotes:FindFirstChild("PlayerSelectCart")
		if r then r:FireServer(choice) end
	end
end

