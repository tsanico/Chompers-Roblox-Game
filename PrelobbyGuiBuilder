local function switchTab(tabId)
	activeTab = tabId
	for _, child in ipairs(ContentArea:GetChildren()) do
		if child:IsA("Frame") then child.Visible=false end
	end
	local pnl = tabPanels[tabId]
	if pnl then pnl.Visible=true end
	for _, t in ipairs(TABS) do
		local btn=tabButtons[t.id]; if not btn then continue end
		if t.id==tabId then
			btn.BackgroundColor3=t.color
			btn.TextColor3=Color3.fromRGB(253,248,240)
		else
			btn.BackgroundColor3=Color3.fromRGB(30,28,44)
			btn.TextColor3=Color3.fromRGB(105,100,135)
		end
	end
end

for _, t in ipairs(TABS) do
	local btn=Instance.new("TextButton",TabBar)
	btn.Name=t.id.."Tab"; btn.LayoutOrder=t.order
	btn.Size=UDim2.new(0.2,-2,0,TAB_H-4)
	btn.BackgroundColor3=Color3.fromRGB(30,28,44)
	btn.BorderSizePixel=0; btn.Font=Enum.Font.GothamBold
	btn.TextSize=13; btn.TextColor3=Color3.fromRGB(105,100,135)
	btn.Text=t.label; btn.AutoButtonColor=false; btn.ZIndex=11
	corner(btn,8); tabButtons[t.id]=btn
	local tId=t.id
	btn.MouseButton1Click:Connect(function() switchTab(tId) end)
end

