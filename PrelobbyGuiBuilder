local function closeGuide()
	isOpen=false
	TweenService:Create(Overlay,TweenInfo.new(0.18),
		{BackgroundTransparency=1}):Play()
	TweenService:Create(Panel,
		TweenInfo.new(0.22,Enum.EasingStyle.Back,Enum.EasingDirection.In),
		{Position=UDim2.new(0.5,0,0,PANEL_TOP+10)}):Play()
	task.wait(0.24)
	if not isOpen then Overlay.Visible=false end
end

local function openGuide(tabId)
	isOpen=true; Overlay.Visible=true
	Overlay.BackgroundTransparency=0.6
	Panel.Position=UDim2.new(0.5,0,0,PANEL_TOP+10)
	TweenService:Create(Overlay,TweenInfo.new(0.18),
		{BackgroundTransparency=0.25}):Play()
	TweenService:Create(Panel,
		TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
		{Position=UDim2.new(0.5,0,0,PANEL_TOP)}):Play()
	switchTab(tabId or activeTab or "RULES")
end

CloseBtn.MouseButton1Click:Connect(closeGuide)
UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.KeyCode==Enum.KeyCode.Escape and isOpen then closeGuide() end
end)

