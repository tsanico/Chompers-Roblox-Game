			Selections.Cart=="basket" and BASKET_SLOTS or CART_SLOTS)
		_G.Chompers.SetWeight(0,
			Selections.Cart=="basket" and 35 or 70)
	end
	task.wait(0.8)
	closeGuide()
end)

local function selectCart(choice)
	if Selections.Confirmed and gameStarted then return end
	Selections.Cart = choice
	if _G.Chompers then
		_G.Chompers.SetSlots(
			choice=="basket" and BASKET_SLOTS or CART_SLOTS)
		_G.Chompers.SetWeight(0,
			choice=="basket" and 35 or 70)
	end
	if Remotes then Remotes.PlayerSelectCart:FireServer(choice) end
	if choice=="basket" then
		BasketButton.BackgroundColor3 = Color3.fromRGB(218,65,65)
		BasketButton.TextColor3 = Color3.fromRGB(253,248,240)
		CartButton.BackgroundColor3 = Color3.fromRGB(32,30,46)
		CartButton.TextColor3 = Color3.fromRGB(82,80,105)
	else
		CartButton.BackgroundColor3 = Color3.fromRGB(218,65,65)
		CartButton.TextColor3 = Color3.fromRGB(253,248,240)
		BasketButton.BackgroundColor3 = Color3.fromRGB(32,30,46)
		BasketButton.TextColor3 = Color3.fromRGB(82,80,105)
	end
end

BasketButton.MouseButton1Click:Connect(function() selectCart("basket") end)
