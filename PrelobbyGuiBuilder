-- ============================================================
-- OPEN / CLOSE
-- ============================================================
local function closeGuide(force)
	local needsWarning = not force
		and not gameStarted
		and (not Selections.Allergy or not Selections.Favourite)
		and activeTab ~= "PREFERENCES"
	if needsWarning then
		WarnDialog.Visible = true
		return
	end
	WarnDialog.Visible = false
	isOpen = false
	TweenService:Create(Overlay,TweenInfo.new(0.18),
		{BackgroundTransparency=1}):Play()
	TweenService:Create(Panel,
		TweenInfo.new(0.22,Enum.EasingStyle.Back,Enum.EasingDirection.In),
		{Position=UDim2.new(0.5,0,0,PANEL_TOP+10)}):Play()
	task.wait(0.24)
	Overlay.Visible = false
end

local function openGuide(tabId)
	isOpen = true
	Overlay.Visible = true
	Overlay.BackgroundTransparency = 0.6
	Panel.Position = UDim2.new(0.5,0,0,PANEL_TOP+10)
	TweenService:Create(Overlay,TweenInfo.new(0.18),
		{BackgroundTransparency=0.25}):Play()
	TweenService:Create(Panel,
		TweenInfo.new(0.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out),
		{Position=UDim2.new(0.5,0,0,PANEL_TOP)}):Play()
	switchTab(tabId or "PREFERENCES")
end

CloseBtn.MouseButton1Click:Connect(function() closeGuide(false) end)
warnYes.MouseButton1Click:Connect(function() closeGuide(true) end)
warnNo.MouseButton1Click:Connect(function()
	WarnDialog.Visible = false
	switchTab("PREFERENCES")
end)

