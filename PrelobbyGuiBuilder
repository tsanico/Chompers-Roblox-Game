local function addSection(title, color, rules)
	local hdr=Instance.new("TextLabel",rScroll)
	hdr.Size=UDim2.new(1,0,0,36); hdr.BackgroundTransparency=1
	hdr.Text=title; hdr.Font=Enum.Font.GothamBold; hdr.TextSize=22
